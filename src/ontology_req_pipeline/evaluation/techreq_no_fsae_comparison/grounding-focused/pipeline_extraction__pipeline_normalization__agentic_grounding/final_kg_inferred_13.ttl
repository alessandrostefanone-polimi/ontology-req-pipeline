@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/13#> a owl:Ontology .

<http://example.org/req/13#DesignSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/13#Cart_0> ;
    ns1:satisfiesRequirement <http://example.org/req/13#Req_0> .

<http://example.org/req/13#ObjSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/13#CollectDataProcess_0> ;
    ns1:prescribes <http://example.org/req/13#Cart_0> .

<http://example.org/req/13#PlanSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/13#CollectDataProcess_0> ;
    ns1:satisfiesRequirement <http://example.org/req/13#Req_0> .

<http://example.org/req/13#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 1e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/13#Wheelbase_0> .

<http://example.org/req/13#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 1e+00 ;
    ns2:minInclusive 1e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/13#CircleDiameter_0> .

<http://example.org/req/13#CircleDiameter_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/13#VE_req0_c1> ;
    ns1:processCharacteristicOf <http://example.org/req/13#CollectDataProcess_0> .

<http://example.org/req/13#Wheelbase_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/13#VE_req0_c0> ;
    ns1:qualityOf <http://example.org/req/13#Cart_0> .

<http://qudt.org/vocab/unit/M> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter>,
        <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/13#Cart_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    ns1:hasQuality <http://example.org/req/13#Wheelbase_0> ;
    ns1:satisfiesRequirement <http://example.org/req/13#Req_0> .

<http://example.org/req/13#CollectDataProcess_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:hasProcessCharacteristic <http://example.org/req/13#CircleDiameter_0> ;
    ns1:prescribedBy <http://example.org/req/13#PlanSpec_0> .

<http://example.org/req/13#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The cart shall have a wheelbase of at least 1 meter to be able to collect data of the plants in a circle with a diameter of 1 meter." ;
    ns1:isAbout <http://example.org/req/13#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/13#DesignSpec_0> .

