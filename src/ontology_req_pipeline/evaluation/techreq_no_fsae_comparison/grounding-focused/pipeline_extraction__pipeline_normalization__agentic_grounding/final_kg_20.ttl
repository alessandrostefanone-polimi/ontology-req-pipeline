@prefix : <http://example.org/req/20#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:ResolutionConstraint_1_0 a iof:InformationContentEntity ;
    iof:describes :PictureSet_0 ;
    iof:isAbout :Cart_0 .

:ActionSpec_0 a iof:ActionSpecification ;
    iof:prescribes :PictureTakingProcess_0 .

:Cart_0 a bfo:BFO_0000040 .

:CoverageShapeSpec_0 a iof:InformationContentEntity ;
    iof:describes :CoverageRegion_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The prototype shall be able to take pictures of the crops in a circle with a diameter of 1 meter and below the cart with enough resolution to distinguish separate plants." ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1e+00 ;
    qudt:minInclusive 1e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :CoverageRegion_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:CoverageRegion_0 a bfo:BFO_0000029 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:isSubjectOf :CoverageShapeSpec_0 .

:PictureSet_0 a iof:InformationContentEntity ;
    iof:isSpecifiedOutputOf :PictureTakingProcess_0 ;
    iof:prescribedBy :ObjSpec_0 .

:PictureTakingCapability_0 a iof:Capability ;
    iof:capabilityOf :Prototype_0 ;
    iof:prescribedBy :ObjSpec_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ActionSpec_0,
        :ObjSpec_0 ;
    iof:prescribes :PictureTakingProcess_0 ;
    iof:satisfiesRequirement :Req_0 .

:Prototype_0 a iof:EngineeredSystem ;
    iof:hasCapability :PictureTakingCapability_0 .

:PictureTakingProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :Prototype_0 ;
    iof:achievesAtSomeTime :ObjSpec_0 ;
    iof:prescribedBy :PlanSpec_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :PictureSet_0,
        :PictureTakingCapability_0 .

