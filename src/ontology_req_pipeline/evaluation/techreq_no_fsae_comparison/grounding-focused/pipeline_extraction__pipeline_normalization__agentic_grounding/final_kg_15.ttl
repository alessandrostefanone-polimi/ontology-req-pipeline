@prefix : <http://example.org/req/15#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The robot shall be able to place its tool within a circle with a diameter of 1 meter at a height of 0.2 meters over the ground." ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1e+00 ;
    qudt:minInclusive 1e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :PlacementRegionDiameter_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e-01 ;
    qudt:minInclusive 2e-01 ;
    qudt:unit qudtu:DeciM ;
    iof:isValueExpressionOfAtSomeTime :HeightOverGround_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Height a qudt:QuantityKind .

qudtu:DeciM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:HeightOverGround_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:processCharacteristicOf :PlaceProcess_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :PlaceProcess_0 ;
    iof:prescribes :PlacementCapability_0 .

:PlacementCapability_0 a iof:Capability ;
    iof:capabilityOf :Robot_0 .

:PlacementRegionDiameter_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:processCharacteristicOf :PlaceProcess_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :PlaceProcess_0 ;
    iof:satisfiesRequirement :Req_0 .

:Robot_0 a iof:EngineeredSystem ;
    iof:hasCapability :PlacementCapability_0 ;
    iof:hasComponentPartAtSomeTime :Tool_0 .

:Tool_0 a iof:MaterialArtifact .

:PlaceProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :Robot_0,
        :Tool_0 ;
    iof:achievesAtSomeTime :ObjSpec_0 ;
    iof:hasProcessCharacteristic :HeightOverGround_0,
        :PlacementRegionDiameter_0 ;
    iof:prescribedBy :PlanSpec_0 .

