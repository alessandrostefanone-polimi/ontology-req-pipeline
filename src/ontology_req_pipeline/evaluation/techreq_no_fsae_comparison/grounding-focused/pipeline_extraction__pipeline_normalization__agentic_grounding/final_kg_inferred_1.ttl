@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/1#> a owl:Ontology .

<http://example.org/req/1#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "In design solutions the temperature range is from 0 °C up to 85 °C without any extra cooling of components, but with water cooling 125 °C." ;
    ns1:requirementSatisfiedBy <http://example.org/req/1#Spec_0> .

<http://example.org/req/1#Spec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:InformationContentEntity ;
    ns1:satisfiesRequirement <http://example.org/req/1#Req_0> .

