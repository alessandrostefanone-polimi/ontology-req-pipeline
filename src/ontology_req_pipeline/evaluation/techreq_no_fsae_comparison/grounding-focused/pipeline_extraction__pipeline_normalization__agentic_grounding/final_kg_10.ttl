@prefix : <http://example.org/req/10#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:ActionSpec_0 a iof:ActionSpecification ;
    iof:prescribes :MoveProcess_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The system shall move along crop rows with widths in the range of 1-1.4 meters, heights between 0.2 and 0.6 meters and lengths between 10 and 100 meters." ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :Spec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.4e+00 ;
    qudt:minInclusive 1e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :CropRowWidth_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 6e-01 ;
    qudt:minInclusive 2e-01 ;
    qudt:unit qudtu:DeciM ;
    iof:isValueExpressionOfAtSomeTime :CropRowHeight_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1e+02 ;
    qudt:minInclusive 1e+01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :CropRowLength_0 .

qudtqk:Height a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

qudtqk:Width a qudt:QuantityKind .

qudtu:DeciM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:CropRowHeight_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :CropRows_0 .

:CropRowLength_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 ;
    iof:qualityOf :CropRows_0 .

:CropRowWidth_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :CropRows_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :MoveProcess_0 ;
    iof:prescribes :CropRowHeight_0,
        :CropRowLength_0,
        :CropRowWidth_0 .

:Spec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ActionSpec_0,
        :ObjSpec_0 ;
    iof:prescribes :MoveProcess_0 ;
    iof:satisfiesRequirement :Req_0 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length,
        qudtqk:Width .

:CropRows_0 a bfo:BFO_0000040 .

:MoveProcess_0 a iof:PlannedProcess ;
    iof:prescribedBy :Spec_0 .

