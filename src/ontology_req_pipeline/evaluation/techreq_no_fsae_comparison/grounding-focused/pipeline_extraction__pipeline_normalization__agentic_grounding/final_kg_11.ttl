@prefix : <http://example.org/req/11#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Cart_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The cart shall have an axle track in the range of 1.2 to 1.5 meters to move along the rows without damaging the crops." ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :Spec_0 .

:Spec_0 a iof:DesignSpecification ;
    iof:prescribes :AxleTrack_0,
        :Cart_0 ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.5e+00 ;
    qudt:minInclusive 1.2e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :AxleTrack_0 .

qudtqk:Width a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Width .

:Cart_0 a iof:MaterialArtifact ;
    iof:hasQuality :AxleTrack_0 .

:AxleTrack_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

