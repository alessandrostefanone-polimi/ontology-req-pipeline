@prefix : <http://example.org/req/2#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The crusher must be able to crush solid rock 0,2 m3/h and with maximum power of 7,5 kW (reserved)." ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 5.555556e-05 ;
    qudt:minInclusive 5.555556e-05 ;
    qudt:unit qudtu:M3-PER-SEC ;
    iof:isValueExpressionOfAtSomeTime :Throughput_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 7.5e+00 ;
    qudt:unit qudtu:KiloW ;
    iof:isValueExpressionOfAtSomeTime :Power_0 .

qudtqk:Power a qudt:QuantityKind .

qudtqk:VolumeFlowRate a qudt:QuantityKind .

qudtu:KiloW a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Power .

qudtu:M3-PER-SEC a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:VolumeFlowRate .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :CrushingProcess_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :CrushingProcess_0 ;
    iof:satisfiesRequirement :Req_0 .

:Power_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:processCharacteristicOf :CrushingProcess_0 .

:Throughput_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:processCharacteristicOf :CrushingProcess_0 .

:CrushingProcess_0 a iof:PlannedProcess ;
    iof:hasProcessCharacteristic :Power_0,
        :Throughput_0 ;
    iof:prescribedBy :PlanSpec_0 .

