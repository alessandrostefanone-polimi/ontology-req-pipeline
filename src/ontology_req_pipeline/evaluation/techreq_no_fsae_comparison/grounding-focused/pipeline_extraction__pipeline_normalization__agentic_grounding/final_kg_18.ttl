@prefix : <http://example.org/req/18#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:ElectromechanicalComponents_0 a bfo:BFO_0000040 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Weight_0 .

:PowerAndControlEquipment_0 a iof:PieceOfEquipment .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The robot shall have a maximum weight of 50 kilograms, including not only the electromechanical components, but also the power and control equipment" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :Spec_0 .

:Robot_0 a iof:EngineeredSystem ;
    iof:hasComponentPartAtAllTimes :ElectromechanicalComponents_0,
        :PowerAndControlEquipment_0 ;
    iof:hasQuality :Weight_0 .

:Spec_0 a iof:DesignSpecification ;
    iof:prescribes :Robot_0 ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 5e+01 ;
    qudt:unit qudtu:KiloGM ;
    iof:isValueExpressionOfAtSomeTime :Weight_0 .

qudtqk:Mass a qudt:QuantityKind .

qudtu:KiloGM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Mass .

:Weight_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

