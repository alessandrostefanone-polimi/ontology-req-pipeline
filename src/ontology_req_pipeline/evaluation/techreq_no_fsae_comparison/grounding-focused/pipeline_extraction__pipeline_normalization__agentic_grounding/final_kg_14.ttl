@prefix : <http://example.org/req/14#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Cart_0 a iof:MaterialArtifact ;
    iof:hasDisposition :Payload_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The cart shall carry a payload of at least 120 kilograms" ;
    iof:isAbout :Obj_0 ;
    iof:requirementSatisfiedBy :Spec_0 .

:Spec_0 a iof:DesignSpecification ;
    iof:prescribes :Cart_0 ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.2e+02 ;
    qudt:unit qudtu:KiloGM ;
    iof:isValueExpressionOfAtSomeTime :Payload_0 .

qudtqk:PayloadMass a qudt:QuantityKind .

qudtu:KiloGM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:PayloadMass .

:Obj_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Payload_0 .

:Payload_0 a bfo:BFO_0000016 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:prescribedBy :Obj_0 .

