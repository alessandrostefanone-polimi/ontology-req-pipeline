@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/2#> a owl:Ontology .

<http://example.org/req/2#ObjSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:prescribes <http://example.org/req/2#CrushingCapability_0> .

<http://example.org/req/2#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "The crusher must be able to crush solid rock 0,2 m3/h and with maximum power of 7,5 kW (reserved)." ;
    ns2:isAbout <http://example.org/req/2#ObjSpec_0> ;
    ns2:requirementSatisfiedBy <http://example.org/req/2#Spec_0> .

<http://example.org/req/2#Spec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/2#Crusher_0>,
        <http://example.org/req/2#CrushingCapability_0> ;
    ns2:satisfiesRequirement <http://example.org/req/2#Req_0> .

<http://example.org/req/2#Unit_M3-PER-HR> a ns1:Unit,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/VolumeFlowRate> .

<http://example.org/req/2#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:numericValue 0.2,
        2e-01 ;
    ns1:unit <http://example.org/req/2#Unit_M3-PER-HR> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/2#CrushingCapability_0> .

<http://example.org/req/2#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 7.5e+00,
        7.5 ;
    ns1:unit <http://qudt.org/vocab/unit/KiloW> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/2#CrushingCapability_0> .

<http://qudt.org/vocab/unit/KiloW> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Power> .

<http://example.org/req/2#Crusher_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact ;
    ns2:hasCapability <http://example.org/req/2#CrushingCapability_0> .

<http://example.org/req/2#CrushingCapability_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000016>,
        <http://purl.obolibrary.org/obo/BFO_0000017>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:Capability ;
    ns2:capabilityOf <http://example.org/req/2#Crusher_0> ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/2#VE_req0_c0>,
        <http://example.org/req/2#VE_req0_c1> .

