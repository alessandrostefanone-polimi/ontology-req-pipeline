@prefix : <http://example.org/req/20#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Action_0 a iof:ActionSpecification ;
    iof:prescribes :PictureTakingProcess_0 .

:Prototype_0 a iof:EngineeredSystem ;
    iof:hasCapability :ImagingCapability_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The prototype shall be able to take pictures of the crops in a circle with a diameter of 1 meter and below the cart with enough resolution to distinguish separate plants."^^xsd:string ;
    iof:requirementSatisfiedBy :Spec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 1.0 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :CoverageDiameter_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:CoverageDiameter_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:prescribedBy :Objective_0 .

:ImagingCapability_0 a iof:Capability ;
    iof:capabilityOf :Prototype_0 ;
    iof:prescribedBy :Objective_0 .

:Spec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :Action_0,
        :Objective_0 ;
    iof:prescribes :PictureTakingProcess_0 ;
    iof:satisfiesRequirement :Req_0 .

:PictureTakingProcess_0 a iof:PlannedProcess ;
    iof:achievesAtSomeTime :Objective_0 ;
    iof:prescribedBy :Spec_0 .

:Objective_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :PictureTakingProcess_0 ;
    iof:prescribes :CoverageDiameter_0,
        :ImagingCapability_0 .

