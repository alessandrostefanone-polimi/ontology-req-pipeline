@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix ns3: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/17#> a owl:Ontology .

<http://example.org/req/17#DesignSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/17#Robot_0> ;
    ns1:satisfiesRequirement <http://example.org/req/17#Req_0> .

<http://example.org/req/17#PlanSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/17#Objective_0> ;
    ns1:prescribes <http://example.org/req/17#PositioningProcess_0> .

<http://example.org/req/17#PositioningPrecision_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/17#VE_req0_c0> ;
    ns1:qualityOf <http://example.org/req/17#Tool_0> .

<http://example.org/req/17#PositioningProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:prescribedBy <http://example.org/req/17#PlanSpec_0> .

<http://example.org/req/17#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The robot shall have a precision of at least 10 millimeters in the positioning of its tool." ;
    ns1:isAbout <http://example.org/req/17#Objective_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/17#DesignSpec_0> .

<http://example.org/req/17#Robot_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000027,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:EngineeredSystem,
        ns1:System .

<http://example.org/req/17#Tool_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000030,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact .

<http://example.org/req/17#VE_req0_c0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns3:minInclusive 1e+01,
        10.0 ;
    ns3:unit <http://qudt.org/vocab/unit/MilliM> .

<http://qudt.org/vocab/unit/MilliM> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/17#Objective_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:prescribes <http://example.org/req/17#PositioningPrecision_0> .

