@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix ns3: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/0#> a owl:Ontology .

<http://example.org/req/0#ProcessingPlant_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000029,
        ns2:BFO_0000141,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/0#ActionSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/0#MiningProcess_0>,
        <http://example.org/req/0#TransportProcess_0> .

<http://example.org/req/0#MiningCapability_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000016,
        ns2:BFO_0000017,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing,
        ns1:Capability ;
    ns2:BFO_0000054 <http://example.org/req/0#MiningProcess_0> ;
    ns1:capabilityOf <http://example.org/req/0#RobotMiner_0> .

<http://example.org/req/0#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The robot miner should be able to mine up to 0,2 m3/h 100 MPa (uniaxial compressive strength) hard rock and transport the same amount to the processing plant." ;
    ns1:isAbout <http://example.org/req/0#Objective_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/0#PlanSpec_0> .

<http://example.org/req/0#TransportCapability_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000016,
        ns2:BFO_0000017,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing,
        ns1:Capability ;
    ns2:BFO_0000054 <http://example.org/req/0#TransportProcess_0> ;
    ns1:capabilityOf <http://example.org/req/0#RobotMiner_0> .

<http://example.org/req/0#VE_req0_c0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns3:maxInclusive 0.2,
        2e-01 ;
    ns3:unit <http://qudt.org/vocab/unit/M3-PER-HR> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/0#MiningRate_0> .

<http://example.org/req/0#VE_req0_c1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns3:numericValue 1e+02,
        100.0 ;
    ns3:unit <http://qudt.org/vocab/unit/MPa> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/0#UniaxialCompressiveStrength_0> .

<http://example.org/req/0#VE_req0_c2> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns3:maxInclusive 0.2,
        2e-01 ;
    ns3:unit <http://qudt.org/vocab/unit/M3-PER-HR> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/0#TransportRate_0> .

<http://qudt.org/vocab/unit/MPa> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/Pressure> .

<http://example.org/req/0#RobotMiner_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000027,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:EngineeredSystem,
        ns1:System ;
    ns1:hasCapability <http://example.org/req/0#MiningCapability_0>,
        <http://example.org/req/0#TransportCapability_0> .

<http://example.org/req/0#UniaxialCompressiveStrength_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/0#VE_req0_c1> .

<http://qudt.org/vocab/unit/M3-PER-HR> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/VolumeFlowRate> .

<http://example.org/req/0#HardRock_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasQuality <http://example.org/req/0#UniaxialCompressiveStrength_0> .

<http://example.org/req/0#MiningRate_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/0#VE_req0_c0> ;
    ns1:processCharacteristicOf <http://example.org/req/0#MiningProcess_0> .

<http://example.org/req/0#PlanSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/0#ActionSpec_0>,
        <http://example.org/req/0#Objective_0> ;
    ns1:prescribes <http://example.org/req/0#MiningProcess_0>,
        <http://example.org/req/0#TransportProcess_0> ;
    ns1:satisfiesRequirement <http://example.org/req/0#Req_0> .

<http://example.org/req/0#TransportRate_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/0#VE_req0_c2> ;
    ns1:processCharacteristicOf <http://example.org/req/0#TransportProcess_0> .

<http://example.org/req/0#Objective_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/0#MiningProcess_0>,
        <http://example.org/req/0#TransportProcess_0> ;
    ns1:prescribes <http://example.org/req/0#MiningRate_0>,
        <http://example.org/req/0#TransportRate_0> .

<http://example.org/req/0#MiningProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:achievesAtSomeTime <http://example.org/req/0#Objective_0> ;
    ns1:hasInput <http://example.org/req/0#HardRock_0> ;
    ns1:hasProcessCharacteristic <http://example.org/req/0#MiningRate_0> ;
    ns1:prescribedBy <http://example.org/req/0#PlanSpec_0> .

<http://example.org/req/0#TransportProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialLocationChangeProcess,
        ns1:PlannedProcess ;
    ns2:BFO_0000057 <http://example.org/req/0#HardRock_0> ;
    ns1:achievesAtSomeTime <http://example.org/req/0#Objective_0> ;
    ns1:hasInput <http://example.org/req/0#HardRock_0> ;
    ns1:hasProcessCharacteristic <http://example.org/req/0#TransportRate_0> ;
    ns1:prescribedBy <http://example.org/req/0#PlanSpec_0> .

