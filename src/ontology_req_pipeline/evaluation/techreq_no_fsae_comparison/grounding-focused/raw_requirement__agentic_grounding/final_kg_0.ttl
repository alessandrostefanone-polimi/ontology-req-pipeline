@prefix : <http://example.org/req/0#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:ProcessingPlant_0 a bfo:BFO_0000029 .

:ActionSpec_0 a iof:ActionSpecification ;
    iof:prescribes :MiningProcess_0,
        :TransportProcess_0 .

:MiningCapability_0 a iof:Capability ;
    bfo:BFO_0000054 :MiningProcess_0 ;
    iof:capabilityOf :RobotMiner_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The robot miner should be able to mine up to 0,2 m3/h 100 MPa (uniaxial compressive strength) hard rock and transport the same amount to the processing plant." ;
    iof:isAbout :Objective_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:TransportCapability_0 a iof:Capability ;
    bfo:BFO_0000054 :TransportProcess_0 ;
    iof:capabilityOf :RobotMiner_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 0.2 ;
    qudt:unit qudtu:M3-PER-HR ;
    iof:isValueExpressionOfAtSomeTime :MiningRate_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 100.0 ;
    qudt:unit qudtu:MPa ;
    iof:isValueExpressionOfAtSomeTime :UniaxialCompressiveStrength_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 0.2 ;
    qudt:unit qudtu:M3-PER-HR ;
    iof:isValueExpressionOfAtSomeTime :TransportRate_0 .

qudtqk:Pressure a qudt:QuantityKind .

qudtqk:VolumeFlowRate a qudt:QuantityKind .

qudtu:MPa a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Pressure .

:RobotMiner_0 a iof:EngineeredSystem ;
    iof:hasCapability :MiningCapability_0,
        :TransportCapability_0 .

:UniaxialCompressiveStrength_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

qudtu:M3-PER-HR a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:VolumeFlowRate .

:HardRock_0 a bfo:BFO_0000040 ;
    iof:hasQuality :UniaxialCompressiveStrength_0 .

:MiningRate_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:processCharacteristicOf :MiningProcess_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ActionSpec_0,
        :Objective_0 ;
    iof:prescribes :MiningProcess_0,
        :TransportProcess_0 ;
    iof:satisfiesRequirement :Req_0 .

:TransportRate_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 ;
    iof:processCharacteristicOf :TransportProcess_0 .

:Objective_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :MiningProcess_0,
        :TransportProcess_0 ;
    iof:prescribes :MiningRate_0,
        :TransportRate_0 .

:MiningProcess_0 a iof:PlannedProcess ;
    iof:achievesAtSomeTime :Objective_0 ;
    iof:hasInput :HardRock_0 ;
    iof:hasProcessCharacteristic :MiningRate_0 ;
    iof:prescribedBy :PlanSpec_0 .

:TransportProcess_0 a iof:MaterialLocationChangeProcess ;
    bfo:BFO_0000057 :HardRock_0 ;
    iof:achievesAtSomeTime :Objective_0 ;
    iof:hasInput :HardRock_0 ;
    iof:hasProcessCharacteristic :TransportRate_0 ;
    iof:prescribedBy :PlanSpec_0 .

