@prefix : <http://example.org/req/9#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Objective_0 a iof:ObjectiveSpecification ;
    iof:prescribes :TractionFunction_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The anchoring system shall give 10 000 – 15 000 N total traction force." ;
    iof:isAbout :Objective_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 15000.0 ;
    qudt:minInclusive 10000.0 ;
    qudt:unit qudtu:N ;
    iof:isValueExpressionOfAtSomeTime :TractionFunction_0 .

qudtqk:Force a qudt:QuantityKind .

qudtu:N a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Force .

:AnchoringSystem_0 a iof:EngineeredSystem ;
    iof:hasFunction :TractionFunction_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :AnchoringSystem_0 ;
    iof:satisfiesRequirement :Req_0 .

:TractionFunction_0 a bfo:BFO_0000034,
        iof:DesignedFunction ;
    iof:functionOf :AnchoringSystem_0 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:prescribedBy :DesignSpec_0 .

