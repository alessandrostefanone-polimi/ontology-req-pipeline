@prefix : <http://example.org/req/1#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:CoolingCondition_None a iof:DesignSpecification ;
    iof:prescribes :NoExtraCooling_0 .

:CoolingCondition_Water a iof:DesignSpecification ;
    iof:prescribes :WaterCooling_0 .

:DesignSolution_0 a bfo:BFO_0000002 ;
    iof:hasQuality :TemperatureQuality_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    bfo:BFO_0000110 :Objective_0 ;
    iof:prescribes :DesignSolution_0 ;
    iof:satisfiesRequirement :Req_0 .

:NoExtraCooling_0 a bfo:BFO_0000002 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "In design solutions the temperature range is from 0 °C up to 85 °C without any extra cooling of components, but with water cooling 125 °C." ;
    iof:isAbout :Objective_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 85.0 ;
    qudt:minInclusive 0.0 ;
    qudt:unit qudtu:DEG_C ;
    iof:isValueExpressionOfAtSomeTime :TemperatureQuality_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 125.0 ;
    qudt:unit qudtu:DEG_C ;
    iof:isValueExpressionOfAtSomeTime :TemperatureQuality_0 .

:WaterCooling_0 a bfo:BFO_0000002 .

qudtqk:Temperature a qudt:QuantityKind .

:Objective_0 a iof:ObjectiveSpecification ;
    iof:prescribes :TemperatureQuality_0 .

qudtu:DEG_C a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Temperature .

:TemperatureQuality_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0,
        :VE_req0_c1 .

