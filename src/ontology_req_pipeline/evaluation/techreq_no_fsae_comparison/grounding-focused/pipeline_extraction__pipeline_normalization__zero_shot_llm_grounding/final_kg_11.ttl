@prefix : <http://example.org/req/11#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AxleTrack_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Cart_0 ;
    iof:satisfiesRequirement :Req_0 .

:Objective_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Cart_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The cart shall have an axle track in the range of 1.2 to 1.5 meters to move along the rows without damaging the crops." ;
    iof:isAbout :Objective_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.5 ;
    qudt:minInclusive 1.2 ;
    qudt:unit qudtu:Meter .

qudtqk:Width a qudt:QuantityKind .

qudtu:Meter a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Width .

:Cart_0 a iof:MaterialArtifact ;
    iof:hasQuality :AxleTrack_0 .

