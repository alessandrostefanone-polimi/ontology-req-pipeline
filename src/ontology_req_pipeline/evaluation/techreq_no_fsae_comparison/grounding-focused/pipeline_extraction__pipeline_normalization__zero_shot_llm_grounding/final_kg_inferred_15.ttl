@prefix : <http://example.org/req/15#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 1.0 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :PlacementRegion_0 .

:Ground_0 a bfo:BFO_0000029 .

:HeightOverGround_0 a bfo:BFO_0000019 ;
    iof:isValueExpressionOfAtSomeTime :VE_req0_c2 ;
    iof:qualityOf :PlacementRegion_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :PlacementCapability_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The robot shall be able to place its tool within a circle with a diameter of 1 meter at a height of 0.2 meters over the ground." ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :Spec_0 .

:Spec_0 a iof:DesignSpecification ;
    iof:prescribes :Ground_0,
        :HeightOverGround_0,
        :PlacementCapability_0,
        :PlacementRegion_0,
        :Robot_0,
        :Tool_0 ;
    iof:satisfiesRequirement :Req_0 .

:Tool_0 a bfo:BFO_0000040 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 0.2 ;
    qudt:unit qudtu:DeciM .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Height a qudt:QuantityKind .

qudtu:DeciM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:Robot_0 a iof:EngineeredSystem ;
    iof:hasFunction :PlacementCapability_0 .

:PlacementCapability_0 a iof:Capability ;
    iof:capabilityOf :Robot_0 .

:PlacementRegion_0 a bfo:BFO_0000029 .

