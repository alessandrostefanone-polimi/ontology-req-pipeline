@prefix : <http://example.org/req/7#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :CrossSectionArea_0,
        :Diameter_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Diameter shall be 0,8 m (cross-section area of the tunnel 0,5 m2)" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :Spec_0 .

:Spec_0 a iof:DesignSpecification ;
    iof:prescribes :CrossSectionArea_0,
        :Diameter_0,
        :Tunnel_0 ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 0.8 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Diameter_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 0.5 ;
    qudt:unit qudtu:M2 ;
    iof:isValueExpressionOfAtSomeTime :CrossSectionArea_0 .

qudtqk:CrossSectionalArea a qudt:QuantityKind .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

qudtu:M2 a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:CrossSectionalArea .

:Tunnel_0 a bfo:BFO_0000040 ;
    iof:hasQuality :CrossSectionArea_0,
        :Diameter_0 .

:CrossSectionArea_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :Tunnel_0 .

:Diameter_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :Tunnel_0 .

