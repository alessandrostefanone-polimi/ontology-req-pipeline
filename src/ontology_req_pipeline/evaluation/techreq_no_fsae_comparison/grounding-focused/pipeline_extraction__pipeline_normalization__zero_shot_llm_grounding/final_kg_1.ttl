@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix : <http://example.org/req/1#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Objective_0 a iof:ObjectiveSpecification ;
    iof:prescribes :DesignSolution_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "In design solutions the temperature range is from 0 °C up to 85 °C without any extra cooling of components, but with water cooling 125 °C."^^xsd:string ;
    iof:isAbout :Objective_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:DesignSolution_0 a bfo:BFO_0000002 ;
    iof:hasQuality :TemperatureQuality_0,
        :TemperatureQuality_1 ;
    iof:prescribedBy :DesignSpec_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :DesignSolution_0,
        :TemperatureQuality_0,
        :TemperatureQuality_1 ;
    iof:satisfiesRequirement :Req_0 .

