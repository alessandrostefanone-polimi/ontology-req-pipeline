@prefix : <http://example.org/req/12#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Ground_0 a bfo:BFO_0000040 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Cart_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The cart shall have clear height of 1 to 1.4 meters over the ground to hold the robot, sensors and actuators that must work over the plants." ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :Spec_0 .

:Spec_0 a iof:DesignSpecification ;
    iof:prescribes :Cart_0,
        :ClearHeight_0 ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.4 ;
    qudt:minInclusive 1.0 ;
    qudt:unit qudtu:M .

qudtqk:Height a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:ClearHeight_0 a bfo:BFO_0000019 ;
    iof:isSubjectOf :Ground_0 ;
    iof:isValueExpressionOfAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :Cart_0 .

:Cart_0 a iof:MaterialArtifact ;
    iof:hasQuality :ClearHeight_0 .

