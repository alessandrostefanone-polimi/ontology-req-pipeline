@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/2#> a owl:Ontology .

<http://example.org/req/2#ActionSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/2#CrusherCrushingProcess_0> .

<http://example.org/req/2#Crusher_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact,
        ns2:PieceOfEquipment ;
    ns3:BFO_0000056 <http://example.org/req/2#CrusherCrushingProcess_0> .

<http://example.org/req/2#Power_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/2#VE_req0_c1> ;
    ns2:processCharacteristicOf <http://example.org/req/2#CrusherCrushingProcess_0> .

<http://example.org/req/2#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "The crusher must be able to crush solid rock 0,2 m3/h and with maximum power of 7,5 kW (reserved)." ;
    ns2:isAbout <http://example.org/req/2#ObjSpec_0> ;
    ns2:requirementSatisfiedBy <http://example.org/req/2#Spec_0> .

<http://example.org/req/2#SolidRock_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:RawMaterial .

<http://example.org/req/2#Throughput_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/2#VE_req0_c0> ;
    ns2:processCharacteristicOf <http://example.org/req/2#CrusherCrushingProcess_0> .

<http://example.org/req/2#VE_req0_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:numericValue 5.555556e-05 ;
    ns1:unit <http://qudt.org/vocab/unit/M3-PER-SEC> .

<http://example.org/req/2#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 7.5e+00 ;
    ns1:unit <http://qudt.org/vocab/unit/KiloW> .

<http://qudt.org/vocab/unit/KiloW> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Power> .

<http://qudt.org/vocab/unit/M3-PER-SEC> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/VolumeFlowRate> .

<http://example.org/req/2#ObjSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:isAchievedByAtSomeTime <http://example.org/req/2#CrusherCrushingProcess_0> ;
    ns2:prescribes <http://example.org/req/2#CrusherCrushingProcess_0> .

<http://example.org/req/2#Spec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns3:BFO_0000110 <http://example.org/req/2#ActionSpec_0>,
        <http://example.org/req/2#ObjSpec_0> ;
    ns2:prescribes <http://example.org/req/2#CrusherCrushingProcess_0> ;
    ns2:satisfiesRequirement <http://example.org/req/2#Req_0> .

<http://example.org/req/2#CrusherCrushingProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns3:BFO_0000057 <http://example.org/req/2#Crusher_0> ;
    ns2:hasInput <http://example.org/req/2#SolidRock_0> ;
    ns2:hasProcessCharacteristic <http://example.org/req/2#Power_0>,
        <http://example.org/req/2#Throughput_0> ;
    ns2:prescribedBy <http://example.org/req/2#Spec_0> .

