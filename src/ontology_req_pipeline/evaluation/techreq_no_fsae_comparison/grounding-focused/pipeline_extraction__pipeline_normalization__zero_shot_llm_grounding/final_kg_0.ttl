@prefix : <http://example.org/req/0#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:ActionSpec_0 a iof:ActionSpecification ;
    iof:prescribes :MiningProcess_0,
        :TransportProcess_0 .

:MaterialTypeConstraint_0 a iof:InformationContentEntity ;
    iof:describes :MinedRock_0 ;
    iof:hasSimpleExpressionValue "hard rock" .

:ObjSpec_0 a iof:ObjectiveSpecification .

:ProcessingPlant_0 a bfo:BFO_0000040 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The robot miner should be able to mine up to 0,2 m3/h 100 MPa (uniaxial compressive strength) hard rock and transport the same amount to the processing plant." ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :Spec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 5.555556e-05 ;
    qudt:unit qudtu:M3-PER-SEC ;
    iof:isValueExpressionOfAtSomeTime :MiningRate_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 1e+02 ;
    qudt:unit qudtu:MegaPA ;
    iof:isValueExpressionOfAtSomeTime :UniaxialCompressiveStrength_0 .

qudtqk:TotalPressure a qudt:QuantityKind .

qudtqk:VolumeFlowRate a qudt:QuantityKind .

qudtu:M3-PER-SEC a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:VolumeFlowRate .

qudtu:MegaPA a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:TotalPressure .

:MiningRate_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:processCharacteristicOf :MiningProcess_0 .

:RobotMiner_0 a iof:EngineeredSystem ;
    iof:prescribedBy :Spec_0 .

:TransportedAmount_0 a bfo:BFO_0000040 ;
    iof:prescribedBy :ObjectiveSpec_0 .

:UniaxialCompressiveStrength_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :MinedRock_0 .

:ObjectiveSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :MiningProcess_0,
        :TransportProcess_0 ;
    iof:prescribes :MinedRock_0,
        :TransportedAmount_0 .

:TransportProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :MinedRock_0,
        :ProcessingPlant_0,
        :RobotMiner_0 ;
    iof:hasInput :MinedRock_0 ;
    iof:hasSpecifiedOutput :TransportedAmount_0 ;
    iof:prescribedBy :Spec_0 .

:MiningProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :RobotMiner_0 ;
    iof:hasProcessCharacteristic :MiningRate_0 ;
    iof:hasSpecifiedOutput :MinedRock_0 ;
    iof:prescribedBy :Spec_0 .

:Spec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ActionSpec_0,
        :ObjectiveSpec_0 ;
    iof:prescribes :MiningProcess_0,
        :TransportProcess_0 ;
    iof:satisfiesRequirement :Req_0 .

:MinedRock_0 a bfo:BFO_0000040 ;
    iof:describedBy :MaterialTypeConstraint_0 ;
    iof:hasQuality :UniaxialCompressiveStrength_0 ;
    iof:prescribedBy :ObjectiveSpec_0 .

