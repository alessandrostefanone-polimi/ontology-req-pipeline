@prefix : <http://example.org/req/23#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AscentVenting_0 a bfo:BFO_0000015 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:prescribedBy :ObjSpec_0 .

:CubeSat_0 a iof:EngineeredSystem ;
    iof:prescribedBy :DS_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The CubeSat shall be designed to accommodate ascent venting per ventable volume/area of less than 50.8 meters (2000 inches)" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxExclusive 50.8 ;
    qudt:unit qudtu:M .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :CubeSat_0 ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :AscentVenting_0 .

