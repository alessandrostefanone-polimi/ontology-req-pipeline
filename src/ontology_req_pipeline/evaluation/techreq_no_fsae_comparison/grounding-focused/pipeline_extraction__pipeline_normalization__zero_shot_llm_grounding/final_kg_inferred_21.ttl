@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/21#> a owl:Ontology .

<http://example.org/req/21#CubeSatMaterials> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasQuality <http://example.org/req/21#TML_0> .

<http://example.org/req/21#Spec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns3:BFO_0000110 <http://example.org/req/21#ObjSpec_0> ;
    ns1:prescribes <http://example.org/req/21#CubeSatMaterials> ;
    ns1:satisfiesRequirement <http://example.org/req/21#Req_0> .

<http://example.org/req/21#VE_req0_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 0.01,
        1e-02 ;
    ns2:unit <http://qudt.org/vocab/unit/NUM> .

<http://qudt.org/vocab/unit/NUM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/DimensionlessRatio> .

<http://example.org/req/21#ObjSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isSubjectOf <http://example.org/req/21#Req_0> ;
    ns1:prescribes <http://example.org/req/21#TML_0> .

<http://example.org/req/21#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "CubeSats materials shall have a Total Mass Loss (TML) of less than or equal to 1.0 %" ;
    ns1:isAbout <http://example.org/req/21#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/21#Spec_0> .

<http://example.org/req/21#TML_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/21#VE_req0_c0> .

