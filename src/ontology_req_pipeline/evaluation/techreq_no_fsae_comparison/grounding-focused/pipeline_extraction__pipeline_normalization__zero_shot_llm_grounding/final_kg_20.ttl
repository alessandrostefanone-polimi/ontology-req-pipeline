@prefix : <http://example.org/req/20#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:BelowCartDescription_1 a iof:InformationContentEntity ;
    iof:describes :BelowCartRegion_1 ;
    iof:hasSimpleExpressionValue "below the cart"^^xsd:string .

:CircleDesignation_0 a iof:InformationContentEntity ;
    iof:denotes :CaptureArea_0 ;
    iof:hasSimpleExpressionValue "circle"^^xsd:string .

:Prototype_0 a iof:EngineeredSystem ;
    iof:satisfiesRequirement :Req_0 .

:ResolutionRequirement_1 a iof:InformationContentEntity ;
    iof:describes :PictureSet_0 ;
    iof:hasSimpleExpressionValue "enough resolution to distinguish separate plants"^^xsd:string .

:ActionSpec_0 a iof:ActionSpecification ;
    iof:prescribes :PictureTakingProcess_0 .

:BelowCartRegion_1 a bfo:BFO_0000029 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 1.0 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :CaptureArea_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:CaptureArea_0 a bfo:BFO_0000029 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:Objective_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :PictureTakingProcess_0 ;
    iof:prescribes :PictureSet_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ActionSpec_0,
        :Objective_0 ;
    iof:prescribes :PictureTakingProcess_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The prototype shall be able to take pictures of the crops in a circle with a diameter of 1 meter and below the cart with enough resolution to distinguish separate plants."^^xsd:string ;
    iof:isAbout :Objective_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:PictureSet_0 a iof:InformationContentEntity ;
    iof:isSpecifiedOutputOf :PictureTakingProcess_0 .

:PictureTakingProcess_0 a iof:PlannedProcess ;
    iof:hasSpecifiedOutput :PictureSet_0 ;
    iof:prescribedBy :PlanSpec_0 .

