@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/14#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Cart_0 ;
    iof:satisfiesRequirement :Req_0 .

:Objective_0 a iof:ObjectiveSpecification ;
    iof:prescribes :PayloadMassCapability_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The cart shall carry a payload of at least 120 kilograms" ;
    iof:isAbout :Objective_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 120.0 ;
    qudt:unit qudtu:KiloGM ;
    iof:isValueExpressionOfAtSomeTime :PayloadMassCapability_0 .

qudtqk:Mass a qudt:QuantityKind .

qudtu:KiloGM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Mass .

:Cart_0 a iof:MaterialArtifact ;
    iof:hasCapability :PayloadMassCapability_0 .

:PayloadMassCapability_0 a iof:Capability ;
    iof:capabilityOf :Cart_0 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

