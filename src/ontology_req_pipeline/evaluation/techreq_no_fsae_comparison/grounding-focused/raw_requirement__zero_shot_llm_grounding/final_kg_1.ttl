@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix : <http://example.org/req/1#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:CoolingCondition_NoExtraCooling a bfo:BFO_0000002 .

:CoolingCondition_WaterCooling a bfo:BFO_0000002 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Component_0,
        :CoolingCondition_NoExtraCooling,
        :CoolingCondition_WaterCooling ;
    iof:satisfiesRequirement :Req_0 .

:Objective_0 a iof:ObjectiveSpecification ;
    iof:prescribes :TemperatureQuality_NoExtraCooling,
        :TemperatureQuality_WaterCooling .

:QuantityKind_Temperature a qudt:QuantityKind .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "In design solutions the temperature range is from 0 °C up to 85 °C without any extra cooling of components, but with water cooling 125 °C." ;
    iof:isAbout :Objective_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 85.0 ;
    qudt:minInclusive 0.0 ;
    qudt:unit :Unit_DEG_C ;
    iof:isValueExpressionOfAtSomeTime :TemperatureQuality_NoExtraCooling .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 125.0 ;
    qudt:unit :Unit_DEG_C ;
    iof:isValueExpressionOfAtSomeTime :TemperatureQuality_WaterCooling .

:TemperatureQuality_NoExtraCooling a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :Component_0 .

:TemperatureQuality_WaterCooling a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :Component_0 .

:Unit_DEG_C a qudt:Unit ;
    qudt:hasQuantityKind :QuantityKind_Temperature .

:Component_0 a bfo:BFO_0000040 .

