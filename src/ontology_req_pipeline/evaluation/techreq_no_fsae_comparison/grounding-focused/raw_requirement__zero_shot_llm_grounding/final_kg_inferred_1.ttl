@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/1#> a owl:Ontology .

<http://example.org/req/1#CoolingCondition_NoExtraCooling> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/1#CoolingCondition_WaterCooling> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/1#DesignSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/1#Component_0>,
        <http://example.org/req/1#CoolingCondition_NoExtraCooling>,
        <http://example.org/req/1#CoolingCondition_WaterCooling> ;
    ns2:satisfiesRequirement <http://example.org/req/1#Req_0> .

<http://example.org/req/1#Objective_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:prescribes <http://example.org/req/1#TemperatureQuality_NoExtraCooling>,
        <http://example.org/req/1#TemperatureQuality_WaterCooling> .

<http://example.org/req/1#QuantityKind_Temperature> a ns1:QuantityKind,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/1#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "In design solutions the temperature range is from 0 °C up to 85 °C without any extra cooling of components, but with water cooling 125 °C." ;
    ns2:isAbout <http://example.org/req/1#Objective_0> ;
    ns2:requirementSatisfiedBy <http://example.org/req/1#DesignSpec_0> .

<http://example.org/req/1#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 8.5e+01,
        85.0 ;
    ns1:minInclusive 0e+00,
        0.0 ;
    ns1:unit <http://example.org/req/1#Unit_DEG_C> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/1#TemperatureQuality_NoExtraCooling> .

<http://example.org/req/1#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:numericValue 125.0,
        1.25e+02 ;
    ns1:unit <http://example.org/req/1#Unit_DEG_C> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/1#TemperatureQuality_WaterCooling> .

<http://example.org/req/1#TemperatureQuality_NoExtraCooling> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/1#VE_req0_c0> ;
    ns2:qualityOf <http://example.org/req/1#Component_0> .

<http://example.org/req/1#TemperatureQuality_WaterCooling> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/1#VE_req0_c1> ;
    ns2:qualityOf <http://example.org/req/1#Component_0> .

<http://example.org/req/1#Unit_DEG_C> a ns1:Unit,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasQuantityKind <http://example.org/req/1#QuantityKind_Temperature> .

<http://example.org/req/1#Component_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing .

