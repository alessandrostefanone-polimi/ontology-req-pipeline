@prefix : <http://example.org/req/2#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:SolidRock_0 a iof:RawMaterial .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 0.2 ;
    qudt:unit :Unit_M3-PER-HR ;
    iof:isValueExpressionOfAtSomeTime :CrushingCapability_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 7.5 ;
    qudt:unit qudtu:KiloW ;
    iof:isValueExpressionOfAtSomeTime :Power_0 .

:Crusher_0 a iof:MaterialArtifact ;
    iof:hasCapability :CrushingCapability_0 ;
    iof:hasQuality :Power_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Crusher_0,
        :CrushingCapability_0 ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :CrushingCapability_0 .

:QuantityKind_VolumeFlowRate a qudt:QuantityKind .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The crusher must be able to crush solid rock 0,2 m3/h and with maximum power of 7,5 kW (reserved)." ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:Unit_M3-PER-HR a qudt:Unit ;
    qudt:hasQuantityKind :QuantityKind_VolumeFlowRate .

qudtqk:Power a qudt:QuantityKind .

qudtu:KiloW a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Power .

:Power_0 a bfo:BFO_0000019 .

:CrushingCapability_0 a iof:Capability .

