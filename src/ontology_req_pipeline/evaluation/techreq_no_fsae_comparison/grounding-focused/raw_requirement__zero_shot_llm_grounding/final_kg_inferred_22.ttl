@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/22#> a owl:Ontology .

<http://example.org/req/22#CubeSat> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact .

<http://example.org/req/22#CubeSatEnvelopeIdentifier> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignativeInformationContentEntity,
        ns1:Identifier,
        ns1:InformationContentEntity,
        ns1:PhysicalLocationIdentifier ;
    ns1:designates <http://example.org/req/22#CubeSatStaticEnvelope> .

<http://example.org/req/22#OutsideCubeSatEnvelopeIdentifier> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignativeInformationContentEntity,
        ns1:Identifier,
        ns1:InformationContentEntity,
        ns1:PhysicalLocationIdentifier ;
    ns1:designates <http://example.org/req/22#OutsideCubeSatStaticEnvelope> .

<http://example.org/req/22#CubeSatStaticEnvelope> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000029>,
        <http://purl.obolibrary.org/obo/BFO_0000141>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/22#DesignSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/22#PassiveMagnetMagneticField_OutsideCubeSatEnvelope> ;
    ns1:satisfiesRequirement <http://example.org/req/22#Req_0> .

<http://example.org/req/22#Objective_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:prescribes <http://example.org/req/22#PassiveMagnetMagneticField_OutsideCubeSatEnvelope> .

<http://example.org/req/22#OutsideCubeSatStaticEnvelope> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000029>,
        <http://purl.obolibrary.org/obo/BFO_0000141>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/22#PassiveMagnet> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact .

<http://example.org/req/22#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The magnetic field of any passive magnets shall be limited to 0.5 Gauss above Earth’s magnetic field, outside the CubeSat static envelope." ;
    ns1:isAbout <http://example.org/req/22#Objective_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/22#DesignSpec_0> .

<http://example.org/req/22#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 5e-01,
        0.5 ;
    ns2:unit <http://qudt.org/vocab/unit/GAUSS> .

<http://qudt.org/vocab/unit/GAUSS> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/MagneticFluxDensity> .

<http://example.org/req/22#PassiveMagnetMagneticField_OutsideCubeSatEnvelope> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/22#VE_req0_c0> ;
    ns1:qualityOf <http://example.org/req/22#PassiveMagnet> .

