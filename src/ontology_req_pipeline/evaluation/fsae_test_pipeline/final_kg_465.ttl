@prefix : <http://example.org/req/465#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:BodyworkEdgeCollection a bfo:BFO_0000040 ;
    rdfs:label "forward facing edges on the Bodywork that could contact people, including the nose"@en ;
    iof:hasQuality :ForwardFacingRadiusQuality .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :BodyworkEdgeCollection ;
    iof:satisfiesRequirement :Req_0 .

:ForwardFacingRadiusQuality a bfo:BFO_0000019 ;
    rdfs:label "forward facing edge forward-facing radius"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "7.2.4 All forward facing edges on the Bodywork that could contact people, including the nose, must have forward facing radii minimum 38 mm" ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "minimum forward facing radius 38 mm"@en ;
    qudt:minInclusive 3.8e+01 ;
    qudt:unit qudtu:MilliM .

qudtqk:Radius a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Radius .

