@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/190#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:ComponentEnvelope_F_1_15 a iof:InformationContentEntity ;
    rdfs:label "Component Envelope F.1.15" .

:ExternalItem a bfo:BFO_0000040 ;
    rdfs:label "External Item" .

:HoopToBraceNode a bfo:BFO_0000040 ;
    rdfs:label "Hoop to Brace node" .

:MainHoop a iof:MaterialArtifact ;
    rdfs:label "Main Hoop" .

:MainHoopBrace a iof:MaterialArtifact ;
    rdfs:label "Main Hoop Brace" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any item which meets all three of: - Located outside the Component Envelope F.1.15 - Located above 350 mm from the ground - Could load the Main Hoop, Main Hoop Brace, or Shoulder Harness Mounting during a rollover F.5.11.2 External Items must meet one of the two conditions: a. Be attached at a Hoop to Brace node or a fully Triangulated structural node without the ability to create a moment at the node b" ;
    iof:requirementSatisfiedBy :PlanSpec_ExternalItemsAttachment .

:Rollover_F_5_11_2 a bfo:BFO_0000015 ;
    rdfs:label "rollover F.5.11.2" .

:ShoulderHarnessMounting a iof:MaterialArtifact ;
    rdfs:label "Shoulder Harness Mounting" .

:TriangulatedStructuralNode a bfo:BFO_0000040 ;
    rdfs:label "fully triangulated structural node" .

:Proc_ExternalItemAttachment a iof:PlannedProcess ;
    rdfs:label "Attachment of external item" ;
    iof:prescribedBy :PlanSpec_ExternalItemsAttachment .

:PlanSpec_ExternalItemsAttachment a iof:PlanSpecification ;
    rdfs:label "Plan specification for external items attachment conditions" ;
    iof:prescribes :Proc_ExternalItemAttachment .

