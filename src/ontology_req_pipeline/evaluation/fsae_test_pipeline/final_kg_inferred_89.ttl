@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/89#> a owl:Ontology .

<http://example.org/req/89#T_8_2_Ref> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    ns1:isAbout <http://example.org/req/89#ObjSpec_0> .

<http://example.org/req/89#V_3_2_1_Ref> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    ns1:isAbout <http://example.org/req/89#ObjSpec_0> .

<http://example.org/req/89#BearingSet_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000030,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact .

<http://example.org/req/89#CriticalFastenerRole_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000017,
        ns2:BFO_0000020,
        ns2:BFO_0000023,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:roleOf <http://example.org/req/89#FastenerSet_0> .

<http://example.org/req/89#DesignSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/89#BearingSet_0>,
        <http://example.org/req/89#FastenerSet_0>,
        <http://example.org/req/89#FrontWheelSet_0>,
        <http://example.org/req/89#RodEndSet_0>,
        <http://example.org/req/89#SteeringWheel_0>,
        <http://example.org/req/89#SuspensionSystem_0> ;
    ns1:satisfiesRequirement <http://example.org/req/89#Req_0> .

<http://example.org/req/89#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "3.1.4 Fasteners in the Suspension system are Critical Fasteners, see T.8.2 V.3.1.5 All spherical rod ends and spherical bearings on the suspension and steering must be one of: - Mounted in double shear - Captured by having a screw/bolt head or washer with an outside diameter that is larger than spherical bearing housing inside diameter. ## V.3.2 Steering V.3.2.1 The Steering Wheel must be mechanically connected to the front wheels" ;
    ns1:isAbout <http://example.org/req/89#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/89#DesignSpec_0>,
        <http://example.org/req/89#PlanSpec_0> .

<http://example.org/req/89#RodEndSet_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000030,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact .

<http://example.org/req/89#SteeringConnectionProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns2:BFO_0000057 <http://example.org/req/89#FrontWheelSet_0>,
        <http://example.org/req/89#SteeringWheel_0> ;
    ns1:prescribedBy <http://example.org/req/89#PlanSpec_0> .

<http://example.org/req/89#SuspensionSystem_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000027,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:EngineeredSystem,
        ns1:System .

<http://example.org/req/89#FastenerSet_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000030,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    ns1:hasRole <http://example.org/req/89#CriticalFastenerRole_0> .

<http://example.org/req/89#FrontWheelSet_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000030,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact .

<http://example.org/req/89#PlanSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/89#ObjSpec_0> ;
    ns1:prescribes <http://example.org/req/89#SteeringConnectionProcess_0> .

<http://example.org/req/89#SteeringWheel_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000030,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact .

<http://example.org/req/89#ObjSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
