@prefix : <http://example.org/req/225#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "An inspection hole approximately 4 mm in diameter must be drilled through a low stress location of every monocoque section regulated by the Structural Equivalency Spreadsheet This inspection hole is not required in the Vertical Side Impact Structure F.7.5.3.b" ;
    iof:isAbout :ObjSpec_0,
        :ObjSpec_1 ;
    iof:requirementSatisfiedBy :PlanSpec_0,
        :PlanSpec_1 .

:ActSpec_0 a iof:ActionSpecification ;
    iof:prescribes :DrillingProcess_0 .

:ActSpec_1 a iof:ActionSpecification ;
    iof:prescribes :NonDrillingSituation_1 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 4e-03 ;
    qudt:minInclusive 4e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Diameter_InspectionHole_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:Diameter_InspectionHole_0 a bfo:BFO_0000019 ;
    iof:qualityOf :InspectionHole_0 .

:LowStressLocation_0 a bfo:BFO_0000029 ;
    rdfs:label "low stress location" ;
    iof:isAvailableToAtSomeTime :MonocoqueSection_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :DrillingProcess_0,
        :InspectionHole_0,
        :LowStressLocation_0,
        :MonocoqueSection_0,
        :SES_0 .

:ObjSpec_1 a iof:ObjectiveSpecification ;
    iof:prescribes :NonDrillingSituation_1,
        :VerticalSideImpactStructure_1 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ActSpec_0,
        :ObjSpec_0 ;
    iof:prescribes :DrillingProcess_0 .

:PlanSpec_1 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ActSpec_1,
        :ObjSpec_1 ;
    iof:prescribes :NonDrillingSituation_1 .

:SES_0 a iof:InformationContentEntity ;
    rdfs:label "Structural Equivalency Spreadsheet" ;
    iof:isAbout :MonocoqueSection_0 .

:VerticalSideImpactStructure_1 a bfo:BFO_0000040 ;
    rdfs:label "Vertical Side Impact Structure F.7.5.3.b" .

:DrillingProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :InspectionHole_0,
        :LowStressLocation_0,
        :MonocoqueSection_0 ;
    iof:prescribedBy :PlanSpec_0 .

:NonDrillingSituation_1 a bfo:BFO_0000015 ;
    bfo:BFO_0000057 :InspectionHole_0,
        :VerticalSideImpactStructure_1 ;
    iof:prescribedBy :PlanSpec_1 .

:InspectionHole_0 a bfo:BFO_0000040 ;
    iof:hasQuality :Diameter_InspectionHole_0 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:MonocoqueSection_0 a bfo:BFO_0000040 ;
    rdfs:label "monocoque section regulated by SES" ;
    iof:isSubjectOf :SES_0 .

