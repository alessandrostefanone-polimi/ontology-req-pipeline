@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/514#> a owl:Ontology .

<http://example.org/req/514#IC_2_2_2> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "IC.2.2.2" .

<http://example.org/req/514#Req1_ShieldingObjective> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/514#ShieldingProcess> ;
    ns1:prescribes <http://example.org/req/514#ImpactDirectionCharacteristic>,
        <http://example.org/req/514#ProtectiveStructure> .

<http://example.org/req/514#VE_req1_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxExclusive 3.5e-01 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/514#HeightAboveGround> .

<http://example.org/req/514#AirIntakeSystem> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    ns1:prescribedBy <http://example.org/req/514#Req1_Spec> .

<http://example.org/req/514#DS_IntakeSystem> a ns3:BFO_0000001,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/514#F_6_4> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "F.6.4" .

<http://example.org/req/514#F_7_5> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "F.7.5" .

<http://example.org/req/514#HeightAboveGround> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:qualityOf <http://example.org/req/514#PortionOfAirIntakeSystem> .

<http://example.org/req/514#IC_1_2> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "IC.1.2" .

<http://example.org/req/514#IC_2_2_1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "IC.2.2.1" .

<http://example.org/req/514#IntakeSystemComplianceProcess> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:achievesAtSomeTime <http://example.org/req/514#Req0_ComplianceObjective> ;
    ns1:hasSpecifiedOutput <http://example.org/req/514#IntakeSystem> ;
    ns1:prescribedBy <http://example.org/req/514#IC_2_2_1> .

<http://example.org/req/514#ObjSpec_Overall> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification .

<http://example.org/req/514#PS_Shielding> a ns3:BFO_0000001,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/514#Req0_ComplianceObjective> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/514#IntakeSystemComplianceProcess> ;
    ns1:prescribes <http://example.org/req/514#IC_1_2> .

<http://example.org/req/514#Req1_Enum_Rear> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "rear impact direction" .

<http://example.org/req/514#Req1_Enum_Side> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "side impact direction" .

<http://qudt.org/vocab/unit/M> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Height> .

<http://example.org/req/514#ImpactDirectionCharacteristic> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    ns1:isSubjectOf <http://example.org/req/514#Req1_Enum_Rear>,
        <http://example.org/req/514#Req1_Enum_Side> .

<http://example.org/req/514#IntakeSystem> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    ns1:prescribedBy <http://example.org/req/514#Req0_Spec> .

<http://example.org/req/514#PortionOfAirIntakeSystem> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialComponent ;
    ns1:componentPartOfAtSomeTime <http://example.org/req/514#AirIntakeSystem> .

<http://example.org/req/514#ProtectiveStructure> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    ns1:prescribedBy <http://example.org/req/514#F_6_4>,
        <http://example.org/req/514#F_7_5> .

<http://example.org/req/514#Req0_Spec> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/514#IntakeSystem> ;
    ns1:satisfiesRequirement <http://example.org/req/514#Req_0> .

<http://example.org/req/514#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "2 AIR INTAKE SYSTEM ## IC.2.1 General ## IC.2.2 Intake System Location IC.2.2.1 The Intake System must meet IC.1.2 IC.2.2.2 Any portion of the air intake system that is less than 350 mm above the ground must be shielded from side or rear impacts by structure built per F.6.4 / F.7.5 as applicable. ## IC.2.3 Intake System Mounting IC.2.3.1" ;
    ns1:isAbout <http://example.org/req/514#ObjSpec_Overall> ;
    ns1:requirementSatisfiedBy <http://example.org/req/514#DS_IntakeSystem>,
        <http://example.org/req/514#PS_Shielding>,
        <http://example.org/req/514#Req0_Spec>,
        <http://example.org/req/514#Req1_Spec> .

<http://example.org/req/514#ShieldingProcess> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns3:BFO_0000057 <http://example.org/req/514#PortionOfAirIntakeSystem>,
        <http://example.org/req/514#ProtectiveStructure> ;
    ns1:hasProcessCharacteristic <http://example.org/req/514#ImpactDirectionCharacteristic> ;
    ns1:prescribedBy <http://example.org/req/514#Req1_Spec> .

<http://example.org/req/514#Req1_Spec> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/514#ShieldingProcess> ;
    ns1:satisfiesRequirement <http://example.org/req/514#Req_0> .

