@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/556#> a owl:Ontology .

<http://example.org/req/556#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Brake System Plausibility Device - BSPD IC.4.8.1 A standalone nonprogrammable circuit must be used to monitor the electronic throttle control" ;
    ns1:isAbout <http://example.org/req/556#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/556#PlanSpec_0> .

<http://example.org/req/556#ActionSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/556#MonitoringProcess_0> .

<http://example.org/req/556#Circuit_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/556#ElectronicThrottleControl_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/556#ObjSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:prescribes <http://example.org/req/556#MonitoringProcess_0> .

<http://example.org/req/556#PlanSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/556#ActionSpec_0>,
        <http://example.org/req/556#ObjSpec_0> ;
    ns1:prescribes <http://example.org/req/556#MonitoringProcess_0> .

<http://example.org/req/556#MonitoringProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:hasInput <http://example.org/req/556#ElectronicThrottleControl_0> ;
    ns1:hasParticipantAtSomeTime <http://example.org/req/556#Circuit_0> ;
    ns1:prescribedBy <http://example.org/req/556#PlanSpec_0> .

