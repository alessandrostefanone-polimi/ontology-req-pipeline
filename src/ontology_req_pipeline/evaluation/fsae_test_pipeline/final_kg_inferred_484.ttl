@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/484#> a owl:Ontology .

<http://example.org/req/484#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Must trigger due to a longitudinal impact load which decelerates the vehicle at between 8 g and 11 g depending on the duration of the deceleration (refer to spec sheet of the Sensata device)" ;
    ns1:requirementSatisfiedBy <http://example.org/req/484#PlanSpec_0> .

<http://example.org/req/484#PlanSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/484#TriggeringProcess_0> .

<http://example.org/req/484#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "longitudinal impact deceleration between 78.4532 and 107.87315 m/s^2" ;
    ns2:maxInclusive 1.078731e+02 ;
    ns2:minInclusive 7.84532e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/M-PER-SEC2> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/484#LongitudinalDecel_0> .

<http://qudt.org/vocab/unit/M-PER-SEC2> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/LinearAcceleration> .

<http://example.org/req/484#LongitudinalDecel_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "longitudinal impact deceleration" ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/484#VE_req0_c0> ;
    ns1:processCharacteristicOf <http://example.org/req/484#TriggeringProcess_0> .

<http://example.org/req/484#TriggeringProcess_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Triggering due to longitudinal impact deceleration" ;
    ns1:hasProcessCharacteristic <http://example.org/req/484#LongitudinalDecel_0> .

