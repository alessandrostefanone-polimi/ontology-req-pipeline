    ns1:prescribes <http://example.org/req/355#Design_0> ;
    ns1:satisfiesRequirement <http://example.org/req/355#Req_0> .

<http://example.org/req/355#HeatSource_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
