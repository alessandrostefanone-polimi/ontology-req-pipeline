        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "air gap between heat source and panel",
        "air gap between heat source and panel"@en ;
    ns1:componentPartOfAtSomeTime <http://example.org/req/355#Design_0> .

<http://example.org/req/355#AirGap_0_Thickness> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
