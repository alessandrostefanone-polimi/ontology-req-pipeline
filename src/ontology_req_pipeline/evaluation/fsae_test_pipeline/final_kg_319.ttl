@prefix : <http://example.org/req/319#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:SegmentC_0 a bfo:BFO_0000040 ;
    rdfs:label "Segment c" .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :MechanicalConnection_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The mechanical connections at each corner must be 50 mm or less from the corner of the Segment c" ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "distance from Segment c corner ≤ 0.05 m" ;
    qudt:maxInclusive 5e-02 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :DistanceFromSegmentCorner_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:DistanceFromSegmentCorner_0 a bfo:BFO_0000019 ;
    rdfs:label "distance from the corner of the Segment c" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :MechanicalConnection_0 .

:MechanicalConnection_0 a bfo:BFO_0000040 ;
    rdfs:label "mechanical connection at corner" ;
    iof:hasQuality :DistanceFromSegmentCorner_0 .

