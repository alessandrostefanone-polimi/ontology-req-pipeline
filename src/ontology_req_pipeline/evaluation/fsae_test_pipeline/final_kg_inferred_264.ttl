        ns1:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns3:PlannedProcess ;
    ns3:prescribedBy <http://example.org/req/264#PlanSpec_Overall> .

<http://example.org/req/264#Qual_BulkheadStiffness> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000019,
        ns1:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns3:qualityOf <http://example.org/req/264#BaselineFrontBulkhead> .

<http://example.org/req/264#Qual_BulkheadStrength> a ns1:BFO_0000001,
