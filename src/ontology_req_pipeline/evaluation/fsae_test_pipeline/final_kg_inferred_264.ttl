<http://example.org/req/264#Req0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns3:InformationContentEntity,
        ns3:RequirementSpecification ;
    ns3:isAbout <http://example.org/req/264#ObjSpec_VerificationMethod> ;
    ns3:requirementSatisfiedBy <http://example.org/req/264#PlanSpec_VerificationMethod> .

<http://example.org/req/264#Req3> a ns1:BFO_0000001,
