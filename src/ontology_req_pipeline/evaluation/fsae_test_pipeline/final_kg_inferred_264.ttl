<http://example.org/req/264#VE_req4_c0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns3:InformationContentEntity,
        ns3:ValueExpression ;
    ns2:maxInclusive 3.15576e+07 ;
    ns2:minInclusive 3.15576e+07 ;
    ns2:unit <http://qudt.org/vocab/unit/SEC> ;
    ns3:isValueExpressionOfAtAllTimes <http://example.org/req/264#TestDataValidityState> .

<http://qudt.org/vocab/unit/SEC> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Time> .

<http://example.org/req/264#BaselineFrontBulkhead> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns3:hasQuality <http://example.org/req/264#Qual_BulkheadStiffness>,
        <http://example.org/req/264#Qual_BulkheadStrength> .

