        ns3:InformationContentEntity,
        ns3:RequirementSpecification ;
    ns3:isAbout <http://example.org/req/264#ObjSpec_TestFixtureChassisEquiv> ;
    ns3:requirementSatisfiedBy <http://example.org/req/264#DesignSpec_TestFixture> .

<http://example.org/req/264#Req4> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns3:InformationContentEntity,
        ns3:RequirementSpecification ;
    ns3:isAbout <http://example.org/req/264#ObjSpec_TestDataValidity> ;
