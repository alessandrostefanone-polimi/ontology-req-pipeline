@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/852#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Proc_SubmissionOfCostReport a bfo:BFO_0000015 ;
    rdfs:label "Submission of the Cost Report" .

:DR_DocumentRequirements a iof:InformationContentEntity ;
    rdfs:label "DR Document Requirements section" .

:DS_LateSubmissionPenalties a iof:DesignSpecification ;
    rdfs:label "Late Submission Penalties for Late Submission of Cost Report" ;
    iof:isAbout :Obj_LateSubmissionPenaltyPolicy ;
    iof:prescribedBy :DR_DocumentRequirements ;
    iof:prescribes :Penalty_LateSubmission ;
    iof:satisfiesRequirement :Req_0 .

:Obj_CostReportSupplementSubmission a iof:ObjectiveSpecification ;
    rdfs:label "Objective for allowing submission of Cost Report supplement" ;
    iof:isAchievedByAtSomeTime :Proc_SubmitCostReportSupplement ;
    iof:prescribes :CostReportSupplement .

:Obj_LateSubmissionPenaltyPolicy a iof:ObjectiveSpecification ;
    rdfs:label "Objective for late submission penalty policy" ;
    iof:isAchievedByAtSomeTime :Proc_ImposeLateSubmissionPenalty ;
    iof:prescribes :Penalty_LateSubmission .

:Proc_ImposeLateSubmissionPenalty a bfo:BFO_0000015 ;
    rdfs:label "Process of imposing late submission penalties" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Late Submission Penalties for Late Submission of Cost Report will be imposed as given in section DR Document Requirements. ### 5.3.7 Cost Addendum 5.3.7.1 A supplement to the Cost Report that reflects any changes or corrections made after the submission of the Cost Report may be submitted" ;
    iof:requirementSatisfiedBy :DS_LateSubmissionPenalties,
        :PS_CostReportSupplementSubmission .

:CostReport a iof:InformationContentEntity ;
    rdfs:label "Cost Report" .

:CostReportSupplement a iof:InformationContentEntity ;
    rdfs:label "Supplement to the Cost Report" ;
    iof:isAbout :CostReport .

:PS_CostReportSupplementSubmission a iof:PlanSpecification ;
    rdfs:label "Plan for submission of Cost Report supplement" ;
    iof:isAbout :Obj_CostReportSupplementSubmission ;
    iof:prescribes :Proc_SubmitCostReportSupplement .

:Penalty_LateSubmission a bfo:BFO_0000002 ;
    rdfs:label "Late submission penalty for Cost Report" .

:Proc_SubmitCostReportSupplement a iof:PlannedProcess ;
    rdfs:label "Submission of Cost Report supplement" ;
    iof:hasInput :CostReport ;
    iof:hasSpecifiedOutput :CostReportSupplement ;
    iof:prescribedBy :PS_CostReportSupplementSubmission .

