@prefix : <http://example.org/req/403#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:BrakePedalFabricatedSteelOrAl_2_0 a iof:ObjectiveSpecification ;
    rdfs:label "Brake Pedal fabricated from steel or aluminum"@en ;
    iof:prescribes :BrakePedal_2 .

:BrakePedalMachinedSteelAlTi_2_1 a iof:ObjectiveSpecification ;
    rdfs:label "Brake Pedal machined from steel, aluminum or titanium"@en ;
    iof:prescribes :BrakePedal_2 .

:BrakeSystem_3 a bfo:BFO_0000040 ;
    rdfs:label "Brake System"@en .

:ChassisMounting_3 a bfo:BFO_0000040 ;
    rdfs:label "Chassis mounting for brake pedal"@en .

:CriticalFastenerClassification_1 a iof:ObjectiveSpecification ;
    rdfs:label "Brake fasteners classified as Critical Fasteners"@en ;
    iof:prescribes :BrakeFastenerSet_1 .

:FailureEvent_3 a iof:Event ;
    rdfs:label "Failure of Brake System, pedal box, chassis mounting, or pedal adjustment"@en ;
    iof:recognizedByAtSomeTime :FailureObserver_3 .

:PedalAdjustment_3 a bfo:BFO_0000040 ;
    rdfs:label "Pedal adjustment mechanism"@en .

:PedalBox_3 a bfo:BFO_0000040 ;
    rdfs:label "Pedal box"@en .

:Req3_Objective_3 a iof:ObjectiveSpecification ;
    rdfs:label "Brake Pedal design withstands minimum force without failure"@en ;
    iof:isAchievedByAtSomeTime :WithstandForceProcess_3 ;
    iof:prescribes :WithstandForceProcess_3 .

:VE_req3_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Minimum withstand force 2000 N"@en ;
    qudt:minInclusive 2e+03 ;
    qudt:unit qudtu:N ;
    iof:isValueExpressionOfAtSomeTime :WithstandForceProcess_3 .

:VehicleChassisLowerSurface_0 a bfo:BFO_0000040 ;
    rdfs:label "Lower surface of chassis (side view reference)"@en .

:BrakePedalDesign_3 a iof:DesignSpecification ;
    rdfs:label "Brake Pedal and associated components design"@en ;
    iof:prescribes :BrakePedalAssembly_3 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :BrakeFastenerSet_1,
        :BrakePedalDesign_3,
        :BrakePedal_2,
        :BrakeSystemPortion_0 ;
    iof:satisfiesRequirement :Req_0 .

:FailureObserver_3 a iof:Agent ;
    rdfs:label "Agent recognizing brake system failures"@en .

:Req0_Objective_0 a iof:ObjectiveSpecification ;
    rdfs:label "No projection of sprung brake components below chassis in side view"@en ;
    iof:isAchievedByAtSomeTime :SideViewCondition_0 ;
    iof:prescribes :BrakeSystemPortion_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "In side view any portion of the Brake System that is mounted on the sprung part of the vehicle must not project below the lower surface of the chassis T.3.1.10 Fasteners in the Brake System are Critical Fasteners, see T.8.2 ## T.3.2 Brake Pedal, Pedal Box and Mounting T.3.2.1 The Brake Pedal must be one of: - Fabricated from steel or aluminum - Machined from steel, aluminum or titanium T.3.2.2 The Brake Pedal and associated components design must withstand a minimum force of 2000 N without any failure of the Brake System, pedal box, chassis mounting, or pedal adjustment" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:SideViewCondition_0 a bfo:BFO_0000015 ;
    rdfs:label "Side view observation condition"@en ;
    iof:achievesAtSomeTime :Req0_Objective_0 .

qudtqk:Force a qudt:QuantityKind .

qudtu:N a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Force .

:BrakeFastenerSet_1 a bfo:BFO_0000040 ;
    rdfs:label "Fasteners in the Brake System"@en .

:BrakeSystemPortion_0 a bfo:BFO_0000040 ;
    rdfs:label "Portion of Brake System on sprung part of vehicle"@en .

:BrakePedalAssembly_3 a bfo:BFO_0000040 ;
    rdfs:label "Brake Pedal and associated components"@en .

:BrakePedal_2 a bfo:BFO_0000040 ;
    rdfs:label "Brake Pedal"@en .

:WithstandForceProcess_3 a bfo:BFO_0000015 ;
    rdfs:label "Application of force to brake pedal assembly"@en ;
    iof:hasInput :BrakePedalAssembly_3 ;
    iof:hasSpecifiedOutput :BrakePedalAssembly_3 .

