@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/205#> a owl:Ontology .

<http://example.org/req/205#FrontBulkhead> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Front Bulkhead",
        "Front Bulkhead"@en .

<http://example.org/req/205#FrontHoop> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Front Hoop",
        "Front Hoop"@en .

<http://example.org/req/205#UpperSideImpactMember> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Upper Side Impact member",
        "Upper Side Impact member"@en .

<http://example.org/req/205#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "distance <= 50 mm from top surface of Front Bulkhead",
        "distance <= 50 mm from top surface of Front Bulkhead"@en ;
    ns2:maxInclusive 5e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/205#DistanceFromFrontBulkheadTop> .

<http://example.org/req/205#VE_req0_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "attachment zone between -50 mm and +100 mm relative to Upper Side Impact member",
        "attachment zone between -50 mm and +100 mm relative to Upper Side Impact member"@en ;
    ns2:maxInclusive 1e-01 ;
    ns2:minInclusive -5e-02 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/205#AttachmentZoneRelUpperSideImpact> .

<http://example.org/req/205#AttachmentZoneRelUpperSideImpact> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "attachment zone relative to the Upper Side Impact member",
        "attachment zone relative to the Upper Side Impact member"@en ;
    ns1:qualityOf <http://example.org/req/205#UpperSupportMember> .

<http://example.org/req/205#DS_UpperSupportAttachment> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/205#UpperSupportMember> ;
    ns1:satisfiesRequirement <http://example.org/req/205#Req_0> .

<http://example.org/req/205#DistanceFromFrontBulkheadTop> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "distance from the top surface of the Front Bulkhead",
        "distance from the top surface of the Front Bulkhead"@en ;
    ns1:qualityOf <http://example.org/req/205#UpperSupportMember> .

<http://example.org/req/205#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The upper support member must be attached 50 mm or less from the top surface of the Front Bulkhead, and attach to the Front Hoop inside a zone extending 100 mm above and 50 mm below the Upper Side Impact member" ;
    ns1:requirementSatisfiedBy <http://example.org/req/205#DS_UpperSupportAttachment> .

<http://qudt.org/vocab/unit/M> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/205#UpperSupportMember> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "upper support member",
        "upper support member"@en .

