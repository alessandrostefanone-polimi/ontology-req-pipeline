@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/647#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Accumulator_3,
        :DummyConnector_2,
        :HVD_0,
        :Interlock_1,
        :PrechargeCircuit_3,
        :ShutdownCircuit_1 ;
    iof:satisfiesRequirement :Req_0 .

:DummyUseReq_2 a iof:ObjectiveSpecification ;
    rdfs:label "Dummy connector may be used to restore isolation to meet EV.6.1.2" ;
    iof:isAbout :IsolationRestoreProcess_2 .

:HVDMarkingInfo_0 a iof:InformationContentEntity ;
    rdfs:label "\"HVD\" marking text" .

:HVDMarking_0 a bfo:BFO_0000019 ;
    rdfs:label "HVD marking" ;
    iof:describedBy :HVDMarkingInfo_0 .

:HVDRemoval_1 a bfo:BFO_0000015 ;
    rdfs:label "HVD removal process" ;
    bfo:BFO_0000057 :HVD_0 .

:InterlockOpenProcess_1 a bfo:BFO_0000015 ;
    rdfs:label "Interlock opening shutdown circuit" ;
    bfo:BFO_0000057 :Interlock_1,
        :ShutdownCircuit_1 ;
    iof:hasProcessCharacteristic :OpenState_1 ;
    iof:occursDuring :HVDRemoval_1 .

:InterlockReq_1 a iof:ObjectiveSpecification ;
    rdfs:label "Interlock opens shutdown circuit when HVD removed" ;
    iof:isAbout :InterlockOpenProcess_1 .

:IsolationRestoreProcess_2 a bfo:BFO_0000015 ;
    rdfs:label "Restore isolation to meet EV.6.1.2" ;
    bfo:BFO_0000057 :DummyConnector_2 .

:MarkingReq_0 a iof:ObjectiveSpecification ;
    rdfs:label "Marking requirement for HVD" ;
    iof:isAbout :HVD_0 .

:OpenState_1 a iof:ProcessCharacteristic ;
    rdfs:label "Shutdown circuit open state" .

:PrechargeReq_3 a iof:ObjectiveSpecification ;
    rdfs:label "Accumulator must contain a Precharge Circuit" ;
    iof:isAbout :Accumulator_3 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Clearly marked with \"HVD\" EV.5.5.2 An Interlock EV.7.8 must Open the Shutdown Circuit EV.7.2.2 when the HVD is removed EV.5.5.3 A dummy connector or similar may be used to restore isolation to meet EV.6.1.2 # EV.5.6 Precharge and Discharge Circuits EV.5.6.1 The Accumulator must contain a Precharge Circuit" ;
    iof:isAbout :DummyUseReq_2,
        :InterlockReq_1,
        :MarkingReq_0,
        :PrechargeReq_3 ;
    iof:requirementSatisfiedBy :DS_0 .

:Accumulator_3 a bfo:BFO_0000040 ;
    rdfs:label "Accumulator" ;
    iof:hasComponentPartAtSomeTime :PrechargeCircuit_3 .

:DummyConnector_2 a bfo:BFO_0000040 ;
    rdfs:label "Dummy connector or similar" .

:Interlock_1 a bfo:BFO_0000040 ;
    rdfs:label "Interlock EV.7.8" .

:PrechargeCircuit_3 a bfo:BFO_0000040 ;
    rdfs:label "Precharge Circuit" .

:ShutdownCircuit_1 a bfo:BFO_0000040 ;
    rdfs:label "Shutdown Circuit EV.7.2.2" .

:HVD_0 a bfo:BFO_0000040 ;
    rdfs:label "HVD" ;
    iof:hasQuality :HVDMarking_0 .

