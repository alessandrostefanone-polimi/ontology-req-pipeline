        <http://example.org/req/284#Proc_PedalClearance>,
        <http://example.org/req/284#Proc_Tabs> .

<http://example.org/req/284#ObjSpec_PedalClearance> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
