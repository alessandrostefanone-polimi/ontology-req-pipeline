    ns1:prescribes <http://example.org/req/284#Tabs_Attachment> ;
    ns1:satisfiesRequirement <http://example.org/req/284#Req_0> .

<http://example.org/req/284#FullTravelAndAdjustment> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "full travel and adjustment of pedal assembly" .

<http://example.org/req/284#PS_PedalClearance> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
