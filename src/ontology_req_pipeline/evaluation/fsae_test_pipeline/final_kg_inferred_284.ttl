    ns2:BFO_0000110 <http://example.org/req/284#ObjSpec_Tabs> ;
    ns1:prescribes <http://example.org/req/284#Proc_Tabs> .

<http://example.org/req/284#State_PedalFullTravel> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "pedal assembly at full travel and adjustment" ;
    ns1:processCharacteristicOf <http://example.org/req/284#FullTravelAndAdjustment> .

<http://example.org/req/284#Tabs_Attachment> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
