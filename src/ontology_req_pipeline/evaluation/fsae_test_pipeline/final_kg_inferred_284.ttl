    ns1:isAchievedByAtSomeTime <http://example.org/req/284#Proc_Tabs> ;
    ns1:prescribes <http://example.org/req/284#Rel_Tabs_Extension> .

<http://example.org/req/284#PS_AttachmentPoints> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/284#ObjSpec_AttachmentPoints> ;
    ns1:prescribes <http://example.org/req/284#Proc_AttachmentPoints> .

<http://example.org/req/284#PS_Tabs> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
