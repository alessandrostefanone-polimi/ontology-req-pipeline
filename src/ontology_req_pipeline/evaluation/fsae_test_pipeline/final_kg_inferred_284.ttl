        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:hasProcessCharacteristic <http://example.org/req/284#Rel_AttachmentPoints_AIP> ;
    ns1:prescribedBy <http://example.org/req/284#PS_AttachmentPoints> .

<http://example.org/req/284#Proc_PedalClearance> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:hasProcessCharacteristic <http://example.org/req/284#Rel_Pedal_Clearance> ;
    ns1:prescribedBy <http://example.org/req/284#PS_PedalClearance> .

<http://example.org/req/284#Proc_Tabs> a ns2:BFO_0000001,
