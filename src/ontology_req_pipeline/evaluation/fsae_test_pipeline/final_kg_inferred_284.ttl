        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "attachment points for the front wing and bodywork mounts" ;
    ns1:prescribedBy <http://example.org/req/284#DS_AttachmentPoints> .

<http://example.org/req/284#ObjSpec_AttachmentPoints> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/284#Proc_AttachmentPoints> ;
    ns1:prescribes <http://example.org/req/284#Rel_AttachmentPoints_AIP> .

<http://example.org/req/284#ObjSpec_Overall> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
