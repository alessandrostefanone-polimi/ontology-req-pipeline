@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/284#> a owl:Ontology .

<http://example.org/req/284#ObjSpec_PedalState> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/284#FullTravelAndAdjustment> ;
    ns1:prescribes <http://example.org/req/284#State_PedalFullTravel> .

<http://example.org/req/284#PedalAssembly> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "pedal assembly" .

<http://example.org/req/284#RearFace_AIP> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "rear face of Anti Intrusion Plate" ;
    ns2:BFO_0000110 <http://example.org/req/284#AIP> .

<http://example.org/req/284#VE_req1_c0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns3:maxInclusive 2.5e+01 ;
    ns3:quantityKind <http://qudt.org/vocab/quantitykind/Length> ;
    ns3:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/284#Rel_Tabs_Extension> .

<http://example.org/req/284#VE_req2_c1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns3:minInclusive 2.5e+01 ;
    ns3:quantityKind <http://qudt.org/vocab/quantitykind/Length> ;
    ns3:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/284#Rel_Pedal_Clearance> .

<http://example.org/req/284#AIP> a ns2:BFO_0000001,
