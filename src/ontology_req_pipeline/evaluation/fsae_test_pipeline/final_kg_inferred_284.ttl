    ns1:prescribes <http://example.org/req/284#AP_AttachmentPoints> ;
    ns1:satisfiesRequirement <http://example.org/req/284#Req_0> .

<http://example.org/req/284#DS_Tabs> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
