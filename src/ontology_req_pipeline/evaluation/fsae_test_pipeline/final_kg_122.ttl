@prefix : <http://example.org/req/122#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:BareEdgeFeature a bfo:BFO_0000019 ;
    iof:qualityOf :PanelEdge .

:BottomSurfaceArea a bfo:BFO_0000019 ;
    iof:qualityOf :BottomSkin .

:SkinMaterialB a bfo:BFO_0000040 .

:TopSurfaceArea a bfo:BFO_0000019 ;
    iof:qualityOf :TopSkin .

:BottomSkin a bfo:BFO_0000040 ;
    bfo:BFO_0000175 :TestPanel .

:DS_TestPanelDimensions a iof:DesignSpecification ;
    iof:prescribes :TestPanel ;
    iof:satisfiesRequirement :Req_0 .

:DS_TestPanelEdges a iof:DesignSpecification ;
    iof:prescribes :TestPanel ;
    iof:satisfiesRequirement :Req_0 .

:DS_TestPanelSurfaceArea a iof:DesignSpecification ;
    iof:prescribes :TestPanel ;
    iof:satisfiesRequirement :Req_0 .

:DimQuality_Option1 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :TestPanel .

:DimQuality_Option2 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :TestPanel .

:PS_TestPanelSupport a iof:PlanSpecification ;
    iof:prescribes :SupportProcess ;
    iof:satisfiesRequirement :Req_0 .

:PanelEdge a bfo:BFO_0000040 ;
    bfo:BFO_0000175 :TestPanel .

:TopSkin a bfo:BFO_0000040 ;
    bfo:BFO_0000175 :TestPanel .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.38e+02 ;
    qudt:minInclusive 1.38e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :DimQuality_Option1 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.75e+02 ;
    qudt:minInclusive 2.75e+02 ;
    qudt:unit qudtu:M2 ;
    iof:isValueExpressionOfAtSomeTime :DimQuality_Option2 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 4e+02 ;
    qudt:minInclusive 4e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :SpanDistance .

qudtqk:CartesianArea a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

qudtqk:MigrationLength a qudt:QuantityKind .

qudtu:M2 a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:CartesianArea .

:SpanDistance a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 ;
    iof:processCharacteristicOf :SupportProcess .

:SupportProcess a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :TestPanel ;
    iof:hasProcessCharacteristic :SpanDistance .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length,
        qudtqk:MigrationLength .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Refer to F.4.3.4 a. Test panels must: - Measure one of the two options: $138 \\mathrm{~mm} \\times 500 \\mathrm{~mm}$ OR $275 \\mathrm{~mm} \\times 500 \\mathrm{~mm}$ - Be supported by a span distance of 400 mm - Have equal surface area for the top and bottom skin - Have bare edges, without skin material b" ;
    iof:requirementSatisfiedBy :DS_TestPanelDimensions,
        :DS_TestPanelEdges,
        :DS_TestPanelSurfaceArea,
        :PS_TestPanelSupport .

:TestPanel a iof:MaterialArtifact .

