@prefix : <http://example.org/req/166#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A straight line measuring 490 mm will connect the centers of the two 200 mm circles" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:ConnectProcess_0 a iof:PlannedProcess ;
    iof:hasInput :Circle_1,
        :Circle_2 ;
    iof:hasSpecifiedOutput :Line_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :ConnectProcess_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 4.9e+02 ;
    qudt:minInclusive 4.9e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Line_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Circle_1 a bfo:BFO_0000040 ;
    rdfs:label "circle 1"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c4 .

:Circle_2 a bfo:BFO_0000040 ;
    rdfs:label "circle 2"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c4 .

:Line_0 a bfo:BFO_0000040 ;
    rdfs:label "straight line connecting circle centers"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:VE_req0_c4 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e-01 ;
    qudt:minInclusive 2e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Circle_1,
        :Circle_2 .

