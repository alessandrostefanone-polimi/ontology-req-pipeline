@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/443#> a owl:Ontology .

<http://example.org/req/443#ActSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/443#ScatterShieldInclusionProcess_0> .

<http://example.org/req/443#MotorConditionProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:comment "when one or both: - The motor casing rotates around the stator - The motor case is perforated" .

<http://example.org/req/443#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Minimum thickness for steel: 2.0 mm T.5.3.2 A Scatter Shield must be included around the Motor(s) when one or both: - The motor casing rotates around the stator - The motor case is perforated T.5.3.3" ;
    ns1:isAbout <http://example.org/req/443#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/443#PlanSpec_0> .

<http://example.org/req/443#Motor_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:isInputOf <http://example.org/req/443#ScatterShieldInclusionProcess_0> .

<http://example.org/req/443#ObjSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/443#ScatterShieldInclusionProcess_0> ;
    ns1:prescribes <http://example.org/req/443#ScatterShield_0> .

<http://example.org/req/443#PlanSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/443#ActSpec_0>,
        <http://example.org/req/443#ObjSpec_0> ;
    ns1:prescribes <http://example.org/req/443#ScatterShieldInclusionProcess_0> .

<http://example.org/req/443#ScatterShield_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:isOutputOf <http://example.org/req/443#ScatterShieldInclusionProcess_0> ;
    ns1:satisfiesRequirement <http://example.org/req/443#Req_0> .

<http://example.org/req/443#ScatterShieldInclusionProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns2:BFO_0000057 <http://example.org/req/443#Motor_0>,
        <http://example.org/req/443#ScatterShield_0> ;
    ns1:hasInput <http://example.org/req/443#Motor_0> ;
    ns1:hasSpecifiedOutput <http://example.org/req/443#ScatterShield_0> ;
    ns1:occursDuring <http://example.org/req/443#MotorConditionProcess_0> ;
    ns1:prescribedBy <http://example.org/req/443#PlanSpec_0> .

