@prefix : <http://example.org/req/259#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_WeldLength a iof:DesignSpecification ;
    iof:prescribes :WeldLengthQuality ;
    iof:satisfiesRequirement :Req_0 .

:DS_WeldSpaceRatio a iof:DesignSpecification ;
    iof:prescribes :WeldSpaceRatioQuality ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_WeldLength a iof:ObjectiveSpecification ;
    iof:prescribes :WeldLengthQuality .

:ObjSpec_WeldSpaceRatio a iof:ObjectiveSpecification ;
    iof:prescribes :WeldSpaceRatioQuality .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :WeldLengthQuality .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :WeldSpaceRatioQuality .

qudtqk:Length a qudt:QuantityKind .

qudtqk:MigrationLength a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:MigrationLength .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The accepted methods of attachment are: a. Welding - All weld lengths must be 25 mm or longer - If interrupted, the weld/space ratio must be 1:1 or higher b" ;
    iof:isAbout :ObjSpec_WeldLength,
        :ObjSpec_WeldSpaceRatio ;
    iof:requirementSatisfiedBy :DS_WeldLength,
        :DS_WeldSpaceRatio .

:Weld a bfo:BFO_0000040 .

:WeldLengthQuality a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 ;
    iof:qualityOf :Weld .

:WeldSpaceRatioQuality a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 ;
    iof:qualityOf :Weld .

