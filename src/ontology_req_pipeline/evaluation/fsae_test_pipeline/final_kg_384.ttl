@prefix : <http://example.org/req/384#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AttachByOneOfFour_1 a iof:PlannedProcess ;
    rdfs:label "Attachment of Shoulder Belts by one of four methods" ;
    iof:prescribedBy :PS_1 .

:BoltOrClipToTabOrBracket_4 a iof:PlannedProcess ;
    rdfs:label "Bolt or clip to tab or bracket on Shoulder Harness Mounting bar" ;
    iof:prescribedBy :PS_4 .

:BoltThroughInsertOrMonocoque_3 a iof:PlannedProcess ;
    rdfs:label "Bolt through welded tube insert or tested monocoque attachment" ;
    iof:prescribedBy :PS_3 .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "Design spec for Shoulder Belt Mount Spacing" ;
    iof:prescribes :ShoulderBeltMountSpacing_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The Shoulder Belt Mount Spacing must be between 175 mm and 235 mm , center to center T.2.6.3 The Shoulder Belts must attach by one of the four: a. Wrap around the Shoulder Harness Mounting bar b. Bolt through a welded tube insert or tested monocoque attachment F.7.9 c. Bolt or clip to a tab or bracket (T.2.4.3 ) on the Shoulder Harness Mounting bar d. Wrap around physically tested hardware attached to a monocoque T.2.6.4" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1,
        :PS_2,
        :PS_3,
        :PS_4,
        :PS_5 .

:ShoulderBeltMount_0 a bfo:BFO_0000040 ;
    rdfs:label "Shoulder Belt Mount (design-level bearer of spacing quality)" .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression for Shoulder Belt Mount Spacing between 175 mm and 235 mm" ;
    qudt:maxInclusive 2.35e+02 ;
    qudt:minInclusive 1.75e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :ShoulderBeltMountSpacing_0 .

:WrapAroundMountingBar_2 a iof:PlannedProcess ;
    rdfs:label "Wrap around the Shoulder Harness Mounting bar" ;
    iof:prescribedBy :PS_2 .

:WrapAroundTestedHardwareOnMonocoque_5 a iof:PlannedProcess ;
    rdfs:label "Wrap around physically tested hardware attached to a monocoque" ;
    iof:prescribedBy :PS_5 .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:PS_1 a iof:PlanSpecification ;
    rdfs:label "Plan spec: Shoulder Belts attach by one of four methods" ;
    iof:isAbout :ObjSpec_0 ;
    iof:prescribes :AttachByOneOfFour_1 .

:PS_2 a iof:PlanSpecification ;
    rdfs:label "Plan spec: Wrap around the Shoulder Harness Mounting bar" ;
    iof:isAbout :ObjSpec_0 ;
    iof:prescribes :WrapAroundMountingBar_2 .

:PS_3 a iof:PlanSpecification ;
    rdfs:label "Plan spec: Bolt through welded tube insert or tested monocoque attachment" ;
    iof:isAbout :ObjSpec_0 ;
    iof:prescribes :BoltThroughInsertOrMonocoque_3 .

:PS_4 a iof:PlanSpecification ;
    rdfs:label "Plan spec: Bolt or clip to tab or bracket on Shoulder Harness Mounting bar" ;
    iof:isAbout :ObjSpec_0 ;
    iof:prescribes :BoltOrClipToTabOrBracket_4 .

:PS_5 a iof:PlanSpecification ;
    rdfs:label "Plan spec: Wrap around physically tested hardware attached to a monocoque" ;
    iof:isAbout :ObjSpec_0 ;
    iof:prescribes :WrapAroundTestedHardwareOnMonocoque_5 .

:ShoulderBeltMountSpacing_0 a bfo:BFO_0000019 ;
    rdfs:label "Shoulder Belt Mount Spacing" ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 ;
    iof:qualityOf :ShoulderBeltMount_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for shoulder belt mounting and attachment" .

