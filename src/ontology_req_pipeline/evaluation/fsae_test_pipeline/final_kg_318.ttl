@prefix : <http://example.org/req/318#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_AccumulatorAttachmentConfig a iof:DesignSpecification ;
    rdfs:label "Design spec: accumulator container corner attachment configuration"@en ;
    iof:prescribes :AttachmentConfiguration ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_AttachmentConfig a iof:ObjectiveSpecification ;
    rdfs:label "Objective: accumulator container corner attachment configuration"@en ;
    iof:prescribes :AttachmentConfiguration .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Alternate materials Equivalent to 2 mm thickness steel F.10.5.5 Teams must justify the Accumulator Container attachment using one of the two methods: - Corner Attachments and Analysis per F.10.5.6 and F.10.5.8 - Load Based Analysis per F.10.5.7 and F.10.5.8 F.10.5.6 Accumulator Attachment - Corner Attachments a. Eight or more attachments are required for any configuration" ;
    iof:isAbout :ObjSpec_AttachmentConfig ;
    iof:requirementSatisfiedBy :DS_AccumulatorAttachmentConfig .

:VE_req3_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression: attachments count >= 8"@en ;
    qudt:minInclusive 8e+00 ;
    qudt:unit qudtu:COUNT ;
    iof:isValueExpressionOfAtAllTimes :AttachmentsCountQuality .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtu:COUNT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

:AttachmentConfiguration a bfo:BFO_0000040 ;
    rdfs:label "Accumulator container corner attachment configuration"@en ;
    iof:hasQuality :AttachmentsCountQuality ;
    iof:hasValueExpressionAtAllTimes :VE_req3_c0 .

:AttachmentsCountQuality a bfo:BFO_0000019 ;
    rdfs:label "Number of attachments in configuration"@en .

