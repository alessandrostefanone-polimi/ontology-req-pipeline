@prefix : <http://example.org/req/448#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:BellyPan_0 a iof:MaterialArtifact .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "5.5.3 Flammable liquid and vapors or other leaks must not collect or contact the driver T.5.5.4 Two holes of minimum diameter 25 mm each must be provided in the structure or belly pan at the locations: a" ;
    iof:requirementSatisfiedBy :DesignSpec_0,
        :PlanSpec_0 .

:Structure_0 a iof:MaterialArtifact .

:Driver_0 a iof:Person .

:FlammableLeak_0 a bfo:BFO_0000040 .

:Hole_0 a bfo:BFO_0000040 ;
    iof:hasQuality :Hole_0_Diameter .

:Hole_1 a bfo:BFO_0000040 ;
    iof:hasQuality :Hole_1_Diameter .

:LeakProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :Driver_0,
        :FlammableLeak_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :LeakProcess_0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e+00 ;
    qudt:minInclusive 2e+00 ;
    qudt:unit qudtu:COUNT ;
    iof:isValueExpressionOfAtSomeTime :HoleSet_0 .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Hole_0_Diameter,
        :Hole_1_Diameter .

qudtqk:CharacteristicNumber a qudt:QuantityKind .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:COUNT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:CharacteristicNumber .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :HoleSet_0 .

:HoleSet_0 a bfo:BFO_0000040 ;
    iof:hasComponentPartAtSomeTime :Hole_0,
        :Hole_1 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0,
        :VE_req1_c1 ;
    iof:prescribedBy :DesignSpec_0 .

:Hole_0_Diameter a bfo:BFO_0000019 .

:Hole_1_Diameter a bfo:BFO_0000019 .

