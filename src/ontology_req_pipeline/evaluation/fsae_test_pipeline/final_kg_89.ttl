    iof:hasRole :CriticalFastenerRole_0 .

:FrontWheelSet_0 a iof:MaterialArtifact .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :SteeringConnectionProcess_0 .

:SteeringWheel_0 a iof:MaterialArtifact .

:ObjSpec_0 a iof:ObjectiveSpecification .

