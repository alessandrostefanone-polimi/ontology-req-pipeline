: a owl:Ontology .

:T_8_2_Ref a iof:InformationContentEntity ;
    iof:isAbout :ObjSpec_0 .

:V_3_2_1_Ref a iof:InformationContentEntity ;
    iof:isAbout :ObjSpec_0 .

:BearingSet_0 a iof:MaterialArtifact .

:CriticalFastenerRole_0 a bfo:BFO_0000023 ;
    iof:roleOf :FastenerSet_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :BearingSet_0,
