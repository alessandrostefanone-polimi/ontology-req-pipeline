@prefix : <http://example.org/req/728#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:MaxSegmentVoltage a bfo:BFO_0000019 ;
    rdfs:label "maximum segment voltage"@en .

:VE_req3_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression: Sense wire length < 25 mm"@en ;
    qudt:maxExclusive 2.5e-02 ;
    qudt:quantityKind qudtqk:Length ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :SenseWireLength .

:DS_AMSArchitecture a iof:DesignSpecification ;
    rdfs:label "Design spec: AMS architecture"@en ;
    iof:prescribes :AMS ;
    iof:satisfiesRequirement :Req_0 .

:DS_AMSBoardOCP a iof:DesignSpecification ;
    rdfs:label "Design spec: AMS board OCP"@en ;
    iof:prescribes :AMSBoard ;
    iof:satisfiesRequirement :Req_0 .

:DS_OvercurrentProtectionVoltage a iof:DesignSpecification ;
    rdfs:label "Design spec: OCP voltage rating"@en ;
    iof:prescribes :OvercurrentProtection ;
    iof:satisfiesRequirement :Req_0 .

:DS_SenseWireLength a iof:DesignSpecification ;
    rdfs:label "Design spec: Sense wire length"@en ;
    iof:prescribes :VoltageSenseWire ;
    iof:satisfiesRequirement :Req_0 .

:OCP_VoltageRating a bfo:BFO_0000019 ;
    rdfs:label "voltage rating of the Overcurrent Protection"@en ;
    iof:qualityOf :OvercurrentProtection .

:ObjSpec_AMSArchitecture a iof:ObjectiveSpecification ;
    rdfs:label "Objective: AMS architecture and cell measurement configuration"@en ;
    iof:prescribes :AMS .

:ObjSpec_AMSBoardOCP a iof:ObjectiveSpecification ;
    rdfs:label "Objective: AMS board has Overcurrent Protection"@en ;
    iof:prescribes :AMSBoard .

:ObjSpec_OvercurrentProtectionOptionality a iof:ObjectiveSpecification ;
    rdfs:label "Objective: OCP optionality on voltage sense wire"@en ;
    iof:prescribes :OvercurrentProtection .

:ObjSpec_OvercurrentProtectionVoltage a iof:ObjectiveSpecification ;
    rdfs:label "Objective: OCP voltage rating vs max segment voltage"@en ;
    iof:prescribes :OCP_VoltageRating .

:ObjSpec_SenseWireLength a iof:ObjectiveSpecification ;
    rdfs:label "Objective: Sense wire length limit"@en ;
    iof:prescribes :SenseWireLength .

:PS_OvercurrentProtectionOptionality a iof:PlanSpecification ;
    rdfs:label "Plan spec: OCP requirement on voltage sense wire"@en ;
    iof:prescribes :OvercurrentProtection ;
    iof:satisfiesRequirement :Req_0 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:AMS a bfo:BFO_0000040 ;
    rdfs:label "AMS"@en .

:AMSBoard a bfo:BFO_0000040 ;
    rdfs:label "AMS board"@en .

:SenseWireLength a bfo:BFO_0000019 ;
    rdfs:label "Sense wire length"@en ;
    iof:qualityOf :VoltageSenseWire .

:VoltageSenseWire a bfo:BFO_0000040 ;
    rdfs:label "voltage sense wire"@en .

qudtqk:Length a qudt:QuantityKind .

:OvercurrentProtection a bfo:BFO_0000040 ;
    rdfs:label "Overcurrent Protection device"@en .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "EV.7.4.5: The voltage rating of the Overcurrent Protection must be equal to or higher than the maximum segment voltage. Overcurrent Protection is not required on a voltage sense wire if all three of the following conditions are met: AMS is a distributed AMS system (one cell measurement per board); Sense wire length is less than 25 mm; AMS board has Overcurrent Protection. (EV.7.5 Accumulator Temperature EV.7.5.1 context omitted)."@en ;
    iof:isAbout :ObjSpec_AMSArchitecture,
        :ObjSpec_AMSBoardOCP,
        :ObjSpec_OvercurrentProtectionOptionality,
        :ObjSpec_OvercurrentProtectionVoltage,
        :ObjSpec_SenseWireLength ;
    iof:requirementSatisfiedBy :DS_AMSArchitecture,
        :DS_AMSBoardOCP,
        :DS_OvercurrentProtectionVoltage,
        :DS_SenseWireLength,
        :PS_OvercurrentProtectionOptionality .

