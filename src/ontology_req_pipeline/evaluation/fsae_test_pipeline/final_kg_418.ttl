@prefix : <http://example.org/req/418#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 0e+00 ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:PERCENT ;
    iof:isValueExpressionOfAtSomeTime :OpenCircuitInputEffect_0 .

:CircuitAction_0 a bfo:BFO_0000015 ;
    iof:hasInput :OpenCircuitInput_0 .

:Circuit_0 a bfo:BFO_0000040 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Circuit_0,
        :PedalSensor_0,
        :Resistor_0 ;
    iof:satisfiesRequirement :Req_0 .

:OpenCircuitInputEffect_0 a iof:ProcessCharacteristic ;
    iof:processCharacteristicOf :CircuitAction_0 .

:OpenCircuitInput_0 a bfo:BFO_0000040 .

:PedalSensor_0 a iof:MaterialArtifact .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The circuit must have a pull-up or pull-down resistor to bring an open circuit input to $0 \\%$ Pedal Travel - An OEM pedal sensor with opposite slopes" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:Resistor_0 a iof:MaterialArtifact .

qudtqk:OpeningRatio a qudt:QuantityKind .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:OpeningRatio .

