@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/163#> a owl:Ontology .

<http://example.org/req/163#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "A two dimensional template used to represent the 95th percentile male is made to the following dimensions (see figure below): - A circle of diameter 200 mm will represent the hips and buttocks" ;
    ns1:isAbout <http://example.org/req/163#ObjSpec_req0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/163#PlanSpec_req0> .

<http://example.org/req/163#VE_req0_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 2e+02 ;
    ns2:minInclusive 2e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/163#Diameter_req0> .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://example.org/req/163#Circle_req0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Circle representing the hips and buttocks (req 0)",
        "Circle representing the hips and buttocks (req 0)"@en ;
    ns1:hasQuality <http://example.org/req/163#Diameter_req0> .

<http://example.org/req/163#Diameter_req0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Diameter of circle (req 0)",
        "Diameter of circle (req 0)"@en ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/163#VE_req0_c0> .

<http://example.org/req/163#ObjSpec_req0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/163#Proc_req0> ;
    ns1:prescribes <http://example.org/req/163#Circle_req0> .

<http://example.org/req/163#PlanSpec_req0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns3:BFO_0000110 <http://example.org/req/163#ObjSpec_req0> ;
    ns1:prescribes <http://example.org/req/163#Proc_req0> .

<http://example.org/req/163#Proc_req0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:hasSpecifiedOutput <http://example.org/req/163#Circle_req0> ;
    ns1:prescribedBy <http://example.org/req/163#PlanSpec_req0> .

