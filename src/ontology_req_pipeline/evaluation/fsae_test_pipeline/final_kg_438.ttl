@prefix : <http://example.org/req/438#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Cond_AllConditions a bfo:BFO_0000015 ;
    rdfs:label "Condition – all operating conditions" .

:DrivetrainPart a bfo:BFO_0000040 ;
    rdfs:label "Drivetrain part that spins" .

:EngineRunning a bfo:BFO_0000015 ;
    rdfs:label "Process – engine running" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Stay aligned with the belt under all conditions T.5.2.9 Attachment Fasteners - All fasteners attaching scatter shields and guards must be 6 mm or 1/4\" minimum diameter Critical Fasteners, see T.8.2 T.5.2.10 Finger Guards a. Must cover any drivetrain parts that spin while the vehicle is stationary with the engine running" ;
    iof:requirementSatisfiedBy :DS_AttachmentFasteners,
        :PS_AlignmentWithBelt,
        :PS_FingerGuards .

:VehicleStationary a bfo:BFO_0000015 ;
    rdfs:label "Process – vehicle stationary" .

:DS_AttachmentFasteners a iof:DesignSpecification ;
    rdfs:label "Design spec – attachment fasteners for scatter shields and guards" ;
    iof:prescribes :Fastener_Attachment .

:Fastener_Attachment a bfo:BFO_0000040 ;
    rdfs:label "Attachment fastener for scatter shields and guards" ;
    iof:hasQuality :Q_Diameter_Fastener .

:PS_AlignmentWithBelt a iof:PlanSpecification ;
    rdfs:label "Plan spec – stay aligned with the belt under all conditions" ;
    iof:prescribes :Proc_AlignmentWithBelt .

:PS_FingerGuards a iof:PlanSpecification ;
    rdfs:label "Plan spec – finger guards coverage" ;
    iof:prescribes :Proc_FingerGuardCoverage .

:Proc_AlignmentWithBelt a iof:PlannedProcess ;
    rdfs:label "Process – alignment with belt" .

:Proc_FingerGuardCoverage a iof:PlannedProcess ;
    rdfs:label "Process – finger guards covering drivetrain parts" .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression – fastener diameter ≥ 6 mm" ;
    qudt:minInclusive 6e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Q_Diameter_Fastener .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression – fastener diameter ≥ 0.00635 m (1/4 in)" ;
    qudt:minInclusive 6.35e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :Q_Diameter_Fastener .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

qudtqk:Diameter a qudt:QuantityKind .

:Q_Diameter_Fastener a bfo:BFO_0000019 ;
    rdfs:label "Diameter of attachment fastener" ;
    iof:hasValueExpressionAtAllTimes :VE_req1_c0,
        :VE_req1_c1 .

