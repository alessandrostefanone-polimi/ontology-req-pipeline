@prefix : <http://example.org/req/927#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "10.1.3 Course Operation a. Vehicles will enter and exit through gates on a 3.0 m wide path that is tangential to the circles where they meet" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:CourseOperationProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :Vehicle_0 ;
    iof:hasInput :Gate_0 ;
    iof:hasSpecifiedOutput :Path_0 .

:Gate_0 a bfo:BFO_0000040 .

:PathGeometry_0 a bfo:BFO_0000019 .

:Path_0 a bfo:BFO_0000040 ;
    iof:hasQuality :PathGeometry_0,
        :PathWidth_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :CourseOperationProcess_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3e+00 ;
    qudt:minInclusive 3e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :PathWidth_0 .

:Vehicle_0 a bfo:BFO_0000040 .

qudtqk:Width a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Width .

:PathWidth_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 .

