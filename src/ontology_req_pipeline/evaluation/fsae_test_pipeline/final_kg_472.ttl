@prefix : <http://example.org/req/472#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Region_0 ;
    iof:satisfiesRequirement :Req_0 .

:Region_0 a bfo:BFO_0000004 ;
    rdfs:label "Forward/outboard region relative to front wheel axles and chassis"@en ;
    iof:hasQuality :HeightAboveGround_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Forward of the centerline of the front wheel axles and outboard of two vertical planes parallel to the centerline of the chassis touching the inside of the front tires at the height of the hubs must be no higher than 250 mm above the ground T.7.7.2" ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.5e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :HeightAboveGround_0 .

qudtqk:Height a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:HeightAboveGround_0 a bfo:BFO_0000019 ;
    rdfs:label "height above the ground"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

