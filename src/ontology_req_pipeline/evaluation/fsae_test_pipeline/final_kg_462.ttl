@prefix : <http://example.org/req/462#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_ForwardFacingEdgesRadius a iof:DesignSpecification ;
    rdfs:label "Design specification for forward facing edges radii" ;
    iof:prescribes :ForwardFacingEdge_Horiz,
        :ForwardFacingEdge_Vert ;
    iof:satisfiesRequirement :Req_0 .

:EdgeManufacturingProcess_Horiz a iof:ManufacturingProcess ;
    rdfs:label "Manufacturing process for horizontal forward facing edges" ;
    iof:hasProcessCharacteristic :HorizRadius_ForwardFacingEdges ;
    iof:hasSpecifiedOutput :ForwardFacingEdge_Horiz ;
    iof:prescribedBy :PS_ForwardFacingEdgesRadius .

:EdgeManufacturingProcess_Vert a iof:ManufacturingProcess ;
    rdfs:label "Manufacturing process for vertical forward facing edges" ;
    iof:hasProcessCharacteristic :VertRadius_ForwardFacingEdges ;
    iof:hasSpecifiedOutput :ForwardFacingEdge_Vert ;
    iof:prescribedBy :PS_ForwardFacingEdgesRadius .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Minimum radius for horizontal edges (req_idx=0, constraint_idx=1)" ;
    qudt:minInclusive 5e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :HorizRadius_ForwardFacingEdges .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Minimum radius for vertical edges (req_idx=0, constraint_idx=2)" ;
    qudt:minInclusive 3e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :VertRadius_ForwardFacingEdges .

:VE_req1_c3 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Minimum radius for horizontal edges (req_idx=1, constraint_idx=3)" ;
    qudt:minInclusive 5e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :HorizRadius_ForwardFacingEdges .

:VE_req1_c4 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Minimum radius for vertical edges (req_idx=1, constraint_idx=4)" ;
    qudt:minInclusive 3e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :VertRadius_ForwardFacingEdges .

qudtqk:Radius a qudt:QuantityKind .

:ForwardFacingEdge_Horiz a bfo:BFO_0000040 ;
    rdfs:label "Forward facing horizontal edge that could contact a pedestrian" ;
    iof:hasQuality :HorizRadius_ForwardFacingEdges .

:ForwardFacingEdge_Vert a bfo:BFO_0000040 ;
    rdfs:label "Forward facing vertical edge that could contact a pedestrian" ;
    iof:hasQuality :VertRadius_ForwardFacingEdges .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: minimum radii for forward facing edges contacting pedestrians" ;
    iof:prescribes :HorizRadius_ForwardFacingEdges,
        :VertRadius_ForwardFacingEdges .

:Req_0 a iof:RequirementSpecification ;
    rdfs:label "Requirement on minimum radii of forward facing edges contacting pedestrians" ;
    rdfs:comment "Refer to IN.8.2 T.7.1.4 All forward facing edges that could contact a pedestrian (wings, end plates, and undertrays) must have a minimum radius of 5 mm for all horizontal edges and 3 mm for vertical edges" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_ForwardFacingEdgesRadius,
        :PS_ForwardFacingEdgesRadius .

:PS_ForwardFacingEdgesRadius a iof:PlanSpecification ;
    rdfs:label "Plan specification for achieving forward facing edges radii" ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :EdgeManufacturingProcess_Horiz,
        :EdgeManufacturingProcess_Vert ;
    iof:satisfiesRequirement :Req_0 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Radius .

:HorizRadius_ForwardFacingEdges a bfo:BFO_0000019 ;
    rdfs:label "Radius of horizontal forward facing edges" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1,
        :VE_req1_c3 .

:VertRadius_ForwardFacingEdges a bfo:BFO_0000019 ;
    rdfs:label "Radius of vertical forward facing edges" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2,
        :VE_req1_c4 .

