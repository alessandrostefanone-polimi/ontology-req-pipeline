@prefix : <http://example.org/req/136#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AlignmentInfo_0 a iof:InformationContentEntity ;
    rdfs:comment "aligned coaxially with the punch" ;
    iof:describes :AlignmentQuality_0 .

:SupportProcess_0 a bfo:BFO_0000015 ;
    bfo:BFO_0000057 :Fixture_0,
        :Sample_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3.2e+01 ;
    qudt:minInclusive 3.2e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Hole_0 .

:AlignmentQuality_0 a bfo:BFO_0000019 ;
    iof:qualityOf :Hole_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Fixture_0,
        :Hole_0,
        :Punch_0,
        :Sample_0 ;
    iof:satisfiesRequirement :Req_0 .

:Punch_0 a bfo:BFO_0000040 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The fixture must support the entire sample, except for a 32 mm hole aligned coaxially with the punch" ;
    iof:requirementSatisfiedBy :DS_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:Fixture_0 a bfo:BFO_0000040 .

:Sample_0 a bfo:BFO_0000040 .

:Hole_0 a bfo:BFO_0000040 .

