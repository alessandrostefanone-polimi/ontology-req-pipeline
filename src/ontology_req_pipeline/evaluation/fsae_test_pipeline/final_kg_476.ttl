@prefix : <http://example.org/req/476#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Chassis a bfo:BFO_0000040 ;
    rdfs:label "Chassis"@en .

:Shoulder_Belt_Mount a bfo:BFO_0000040 ;
    rdfs:label "Shoulder Belt Mount"@en .

:T_2_6 a iof:InformationContentEntity ;
    rdfs:label "T.2.6"@en .

:DS_Req0 a iof:DesignSpecification ;
    rdfs:comment "Design specification corresponding to requirement 0: All Low Voltage Batteries and onboard power supplies must be securely mounted inside the Chassis below the height of the Shoulder Belt Mount T.2.6" ;
    iof:prescribes :LV_Battery_And_PSU_Assembly .

:DS_Req2 a iof:DesignSpecification ;
    rdfs:comment "Design specification corresponding to requirement 2: The hot (ungrounded) terminal must be insulated" ;
    iof:prescribes :Hot_Ungrounded_Terminal .

:Hot_Ungrounded_Terminal a iof:MaterialArtifact ;
    rdfs:label "Hot (ungrounded) terminal"@en ;
    iof:satisfiesRequirement :Req_0 .

:LV_Battery_And_PSU_Assembly a iof:MaterialArtifact ;
    rdfs:label "Low Voltage Batteries and onboard power supplies assembly"@en ;
    iof:satisfiesRequirement :Req_0 .

:PS_Req1 a iof:PlanSpecification ;
    rdfs:comment "Plan specification corresponding to requirement 1: All Low Voltage batteries must have Overcurrent Protection that trips at or below the maximum specified discharge current of the cells" ;
    iof:prescribes :Overcurrent_Protection_Trip_Process .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Trip current value expression (≤ 0.0 m, as normalized)"@en ;
    qudt:maxInclusive 0e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Trip_Current_Characteristic .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

:Overcurrent_Protection_Trip_Process a iof:PlannedProcess ;
    rdfs:label "Overcurrent protection trip process"@en ;
    iof:hasProcessCharacteristic :Trip_Current_Characteristic ;
    iof:satisfiesRequirement :Req_0 .

:Trip_Current_Characteristic a iof:ProcessCharacteristic ;
    rdfs:label "Trip current characteristic"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 ;
    iof:processCharacteristicOf :Overcurrent_Protection_Trip_Process .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any voltage more than 60 V DC or 25 V AC RMS T.9.1.2 Low Voltage - LV Any voltage less than and including 60 V DC or 25 V AC RMS T.9.1.3 Normally Open A type of electrical relay or contactor that allows current flow only in the energized state ## T.9.2 Low Voltage Batteries T.9.2.1 All Low Voltage Batteries and onboard power supplies must be securely mounted inside the Chassis below the height of the Shoulder Belt Mount T.2.6 T.9.2.2 All Low Voltage batteries must have Overcurrent Protection that trips at or below the maximum specified discharge current of the cells T.9.2.3 The hot (ungrounded) terminal must be insulated" ;
    iof:requirementSatisfiedBy :DS_Req0,
        :DS_Req2,
        :PS_Req1 .

