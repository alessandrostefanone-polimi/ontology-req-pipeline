@prefix : <http://example.org/req/550#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The power to the electronic throttle must be immediately shut down, if throttle position differs by more than $10 \\%$ from the expected target TPS position for more than one second" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "difference between throttle position and expected target TPS position > 10 percent" ;
    qudt:minExclusive 1e+01 ;
    qudt:unit qudtu:PERCENT ;
    iof:isValueExpressionOfAtSomeTime :ThrottlePositionDifference_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "duration of difference condition > 1 second" ;
    qudt:minExclusive 1e+00 ;
    qudt:unit qudtu:SEC ;
    iof:isValueExpressionOfAtSomeTime :DifferenceDuration_0 .

:ElectronicThrottle_0 a iof:EngineeredSystem ;
    rdfs:label "electronic throttle" .

:ShutdownProcess_0 a iof:PlannedProcess ;
    rdfs:label "Shutdown of power to the electronic throttle" ;
    bfo:BFO_0000057 :ElectronicThrottle_0 ;
    iof:prescribedBy :PlanSpec_0 .

qudtqk:DimensionlessRatio a qudt:QuantityKind .

qudtqk:Time a qudt:QuantityKind .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DimensionlessRatio .

qudtu:SEC a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Time .

:DifferenceConditionProcess_0 a iof:PlannedProcess ;
    rdfs:label "process where throttle position differs from expected target TPS position" ;
    iof:hasProcessCharacteristic :DifferenceDuration_0,
        :ThrottlePositionDifference_0 ;
    iof:prescribedBy :PlanSpec_0 .

:DifferenceDuration_0 a iof:ProcessCharacteristic ;
    rdfs:label "duration of difference condition" ;
    iof:processCharacteristicOf :DifferenceConditionProcess_0 .

:ThrottlePositionDifference_0 a iof:ProcessCharacteristic ;
    rdfs:label "difference between throttle position and expected target TPS position" ;
    iof:processCharacteristicOf :DifferenceConditionProcess_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :ShutdownProcess_0 .

