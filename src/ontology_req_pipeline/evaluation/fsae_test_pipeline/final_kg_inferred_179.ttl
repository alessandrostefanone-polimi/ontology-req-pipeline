@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/179#> a owl:Ontology .

<http://example.org/req/179#BottomTubes_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "bottom tubes of the Major Structure of the Chassis",
        "bottom tubes of the Major Structure of the Chassis"@en ;
    ns1:BFO_0000175 <http://example.org/req/179#MajorStructureChassis_0> .

<http://example.org/req/179#FrontViewProcess_0> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        ns1:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "front view of the vehicle",
        "front view of the vehicle"@en .

<http://example.org/req/179#MainHoopAttachmentLocation_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000029,
        ns1:BFO_0000141,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "location where the Main Hoop is attached to the bottom tubes of the Major Structure of the Chassis",
        "location where the Main Hoop is attached to the bottom tubes of the Major Structure of the Chassis"@en .

<http://example.org/req/179#Vehicle_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "vehicle",
        "vehicle"@en .

<http://example.org/req/179#DS_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/179#MainHoop_0> ;
    ns2:satisfiesRequirement <http://example.org/req/179#Req_0> .

<http://example.org/req/179#MajorStructureChassis_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Major Structure of the Chassis",
        "Major Structure of the Chassis"@en .

<http://example.org/req/179#ObjSpec_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:prescribes <http://example.org/req/179#VMembersDistance_0> .

<http://example.org/req/179#Req_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "In the front view of the vehicle, the vertical members of the Main Hoop must be minimum 380 mm apart (inside dimension) at the location where the Main Hoop is attached to the bottom tubes of the Major Structure of the Chassis" ;
    ns2:isAbout <http://example.org/req/179#ObjSpec_0> ;
    ns2:requirementSatisfiedBy <http://example.org/req/179#DS_0> .

<http://example.org/req/179#VE_req0_c1> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns3:minInclusive 3.8e-01 ;
    ns3:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/179#VMembersDistance_0> .

<http://qudt.org/vocab/unit/M> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/179#MainHoop_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000030,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact ;
    rdfs:label "Main Hoop",
        "Main Hoop"@en ;
    ns1:BFO_0000110 <http://example.org/req/179#VMembers_0> .

<http://example.org/req/179#VMembers_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "vertical members of the Main Hoop",
        "vertical members of the Main Hoop"@en ;
    ns1:BFO_0000175 <http://example.org/req/179#MainHoop_0> ;
    ns2:hasQuality <http://example.org/req/179#VMembersDistance_0> .

<http://example.org/req/179#VMembersDistance_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000019,
        ns1:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "distance between vertical members (inside dimension)",
        "distance between vertical members (inside dimension)"@en ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/179#VE_req0_c1> ;
    ns2:qualityOf <http://example.org/req/179#VMembers_0> .

