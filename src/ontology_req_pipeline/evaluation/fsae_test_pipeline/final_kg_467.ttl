@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/467#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Without a driver in the vehicle The intent is to standardize the measurement, see GR.6.4.1 T.7.3.2 Head Restraint Plane A transverse vertical plane through the rearmost portion of the front face of the driver head restraint support, excluding any padding, set (if adjustable) in its fully rearward position T.7.3.3 Rear Aerodynamic Zone The volume that is: - Rearward of the Head Restraint Plane - Inboard of two vertical planes parallel to the centerline of the chassis touching the inside of the rear tires at the height of the hub centerline ## T.7.4 Location Any part of any Aerodynamic Device or Bodywork must meet V.1.1 and V.1.4.1 ## T.7.5" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:ConformanceResult_0 a iof:InformationContentEntity ;
    rdfs:label "Conformance of aerodynamic device/bodywork parts to V.1.1 and V.1.4.1" ;
    iof:describes :AerodynamicPart_0 ;
    iof:isAbout :AerodynamicPart_0 ;
    iof:isSubjectOf :StdRef_V_1_1,
        :StdRef_V_1_4_1 .

:PlannedProcess_0 a iof:PlannedProcess ;
    rdfs:comment "Process in which aerodynamic devices or bodywork are evaluated against standards V.1.1 and V.1.4.1." ;
    iof:hasInput :AerodynamicPart_0 ;
    iof:hasSpecifiedOutput :ConformanceResult_0 ;
    iof:prescribedBy :PlanSpec_0 .

:StdRef_V_1_1 a iof:InformationContentEntity ;
    rdfs:label "V.1.1" .

:StdRef_V_1_4_1 a iof:InformationContentEntity ;
    rdfs:label "V.1.4.1" .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :PlannedProcess_0 .

:AerodynamicPart_0 a bfo:BFO_0000040 ;
    rdfs:label "Any part of any Aerodynamic Device or Bodywork" .

