@prefix : <http://example.org/req/284#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:ObjSpec_PedalState a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :FullTravelAndAdjustment ;
    iof:prescribes :State_PedalFullTravel .

:PedalAssembly a bfo:BFO_0000040 ;
    rdfs:label "pedal assembly" .

:RearFace_AIP a bfo:BFO_0000040 ;
    rdfs:label "rear face of Anti Intrusion Plate" ;
    bfo:BFO_0000110 :AIP .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.5e+01 ;
    qudt:quantityKind qudtqk:Length ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Rel_Tabs_Extension .

:VE_req2_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.5e+01 ;
    qudt:quantityKind qudtqk:Length ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Rel_Pedal_Clearance .

:AIP a bfo:BFO_0000040 ;
    rdfs:label "Anti Intrusion Plate" .

:AP_AttachmentPoints a bfo:BFO_0000040 ;
    rdfs:label "attachment points for the front wing and bodywork mounts" ;
    iof:prescribedBy :DS_AttachmentPoints .

:ObjSpec_AttachmentPoints a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :Proc_AttachmentPoints ;
    iof:prescribes :Rel_AttachmentPoints_AIP .

:ObjSpec_Overall a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :Proc_AttachmentPoints,
        :Proc_PedalClearance,
        :Proc_Tabs .

:ObjSpec_PedalClearance a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :Proc_PedalClearance ;
    iof:prescribes :Rel_Pedal_Clearance .

:ObjSpec_Tabs a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :Proc_Tabs ;
    iof:prescribes :Rel_Tabs_Extension .

:PS_AttachmentPoints a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_AttachmentPoints ;
    iof:prescribes :Proc_AttachmentPoints .

:PS_Tabs a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_Tabs ;
    iof:prescribes :Proc_Tabs .

:State_PedalFullTravel a iof:ProcessCharacteristic ;
    rdfs:label "pedal assembly at full travel and adjustment" ;
    iof:processCharacteristicOf :FullTravelAndAdjustment .

:Tabs_Attachment a bfo:BFO_0000040 ;
    rdfs:label "tabs for wing and bodywork attachment" ;
    iof:prescribedBy :DS_Tabs .

:DS_AttachmentPoints a iof:DesignSpecification ;
    iof:prescribes :AP_AttachmentPoints ;
    iof:satisfiesRequirement :Req_0 .

:DS_Tabs a iof:DesignSpecification ;
    iof:prescribes :Tabs_Attachment ;
    iof:satisfiesRequirement :Req_0 .

:FullTravelAndAdjustment a bfo:BFO_0000015 ;
    rdfs:label "full travel and adjustment of pedal assembly" .

:PS_PedalClearance a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_PedalClearance ;
    iof:prescribes :Proc_PedalClearance .

:Rel_AttachmentPoints_AIP a iof:ProcessCharacteristic ;
    rdfs:label "position relation: attachment points aft of Anti Intrusion Plate" ;
    iof:processCharacteristicOf :Proc_AttachmentPoints .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The attachment points for the front wing and bodywork mounts should be aft of the Anti Intrusion Plate. Tabs for wing and bodywork attachment must not extend more than 25 mm forward of the Anti Intrusion Plate. Pedal assembly at full travel and adjustment must have a minimum 25 mm clearance to the rear face of the Anti Intrusion Plate." ;
    iof:isAbout :ObjSpec_Overall ;
    iof:requirementSatisfiedBy :DS_AttachmentPoints,
        :DS_Tabs,
        :PS_PedalClearance .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Rel_Pedal_Clearance a iof:ProcessCharacteristic ;
    rdfs:label "clearance between pedal assembly and rear face of Anti Intrusion Plate" ;
    iof:processCharacteristicOf :Proc_PedalClearance .

:Rel_Tabs_Extension a iof:ProcessCharacteristic ;
    rdfs:label "extension of tabs forward of Anti Intrusion Plate" ;
    iof:processCharacteristicOf :Proc_Tabs .

qudtqk:Length a qudt:QuantityKind .

:Proc_AttachmentPoints a iof:PlannedProcess ;
    iof:hasProcessCharacteristic :Rel_AttachmentPoints_AIP ;
    iof:prescribedBy :PS_AttachmentPoints .

:Proc_PedalClearance a iof:PlannedProcess ;
    iof:hasProcessCharacteristic :Rel_Pedal_Clearance ;
    iof:prescribedBy :PS_PedalClearance .

:Proc_Tabs a iof:PlannedProcess ;
    iof:hasProcessCharacteristic :Rel_Tabs_Extension ;
    iof:prescribedBy :PS_Tabs .

