@prefix : <http://example.org/req/306#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AluminumFloorThickness a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 ;
    iof:qualityOf :AluminumFloorPanel .

:AluminumWallThickness a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req4_c1 ;
    iof:qualityOf :AluminumWallPanel .

:DS_FloorBottom a iof:DesignSpecification ;
    iof:prescribes :FloorOrBottom ;
    iof:satisfiesRequirement :Req_0 .

:DS_VerticalWalls a iof:DesignSpecification ;
    iof:prescribes :VerticalWallsCoversLids ;
    iof:satisfiesRequirement :Req_0 .

:EquivalentFloorMaterial a bfo:BFO_0000040 ;
    iof:componentPartOfAtSomeTime :FloorOrBottom .

:EquivalentWallMaterial a bfo:BFO_0000040 ;
    iof:componentPartOfAtSomeTime :VerticalWallsCoversLids .

:FastenerJointStrength a bfo:BFO_0000019 ;
    iof:qualityOf :FasteningProcess .

:PS_FastenedJoint a iof:PlanSpecification ;
    iof:prescribes :FasteningProcess ;
    iof:satisfiesRequirement :Req_0 .

:PS_WeldedJoint a iof:PlanSpecification ;
    iof:prescribes :WeldingProcess ;
    iof:satisfiesRequirement :Req_0 .

:SteelFloorThickness a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :SteelFloorPanel .

:SteelWallThickness a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req3_c1 ;
    iof:qualityOf :SteelWallPanel .

:WeldLength a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req7_c0 ;
    iof:processCharacteristicOf :WeldingProcess .

:WeldSpaceRatio a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req6_c0 ;
    iof:processCharacteristicOf :WeldingProcess .

:WeldedJointStrength a bfo:BFO_0000019 ;
    iof:qualityOf :WeldingProcess .

:AluminumFloorPanel a bfo:BFO_0000040 ;
    iof:componentPartOfAtSomeTime :FloorOrBottom .

:AluminumWallPanel a bfo:BFO_0000040 ;
    iof:componentPartOfAtSomeTime :VerticalWallsCoversLids .

:SteelFloorPanel a bfo:BFO_0000040 ;
    iof:componentPartOfAtSomeTime :FloorOrBottom .

:SteelWallPanel a bfo:BFO_0000040 ;
    iof:componentPartOfAtSomeTime :VerticalWallsCoversLids .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.25e-03 ;
    qudt:unit qudtu:M .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3.2e+00 ;
    qudt:unit qudtu:MilliM .

:VE_req3_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 9e-01 ;
    qudt:unit qudtu:MilliM .

:VE_req4_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.3e+00 ;
    qudt:unit qudtu:MilliM .

:VE_req6_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1e+00 ;
    qudt:unit qudtu:UNITLESS .

:VE_req7_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

qudtu:UNITLESS a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

:FasteningProcess a iof:PlannedProcess .

qudtqk:Thickness a qudt:QuantityKind .

:FloorOrBottom a bfo:BFO_0000040 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "External Structure F.10.2.1 The Floor or Bottom must be made from one of the three: a. Steel 1.25 mm minimum thickness b. Aluminum 3.2 mm minimum thickness c. Equivalent Alternate / Composite materials ( F.4.1, F.4.3) F.10.2.2 Vertical Walls, Covers and Lids must be made from one of the three: a. Steel 0.9 mm minimum thickness b. Aluminum 2.3 mm minimum thickness c. Equivalent Alternate / Composite materials ( F.4.1, F.4.3) F.10.2.3 The accepted methods of joining walls to walls and walls to floor are: a. Welding - Welds may be continuous or interrupted. - If interrupted, the weld/space ratio must be 1:1 or higher - All weld lengths must be more than 25 mm b. Fasteners Combined strength of the fasteners must be Equivalent to the strength of the welded joint ( F.10.2.3.a above)" .

:VerticalWallsCoversLids a bfo:BFO_0000040 .

:WeldingProcess a iof:PlannedProcess .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length,
        qudtqk:Thickness .

