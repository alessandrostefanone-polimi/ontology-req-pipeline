@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/111#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:DesignSpec_Req0 a iof:DesignSpecification ;
    rdfs:label "Non-structural tubing definition based on F.3.2.1.o and F.3.3.2"@en ;
    iof:isAbout :Ref_F_3_2_1_o,
        :Ref_F_3_3_2 ;
    iof:prescribes :NonStructuralTubing_Req0 ;
    iof:satisfiesRequirement :Req_0 .

:MinRequirementsInfo_Req1 a iof:InformationContentEntity ;
    rdfs:label "all four minimum requirements for each Size specified"@en .

:Ref_F_3_2_1_o a iof:InformationContentEntity ;
    rdfs:label "F.3.2.1.o Structural Tubing"@en .

:Ref_F_3_3_2 a iof:InformationContentEntity ;
    rdfs:label "F.3.3.2 Applicability Non Structural Tubing"@en .

:Tube_Req1 a bfo:BFO_0000040 ;
    rdfs:label "tube subject to minimum requirements per size"@en ;
    iof:isSubjectOf :MinRequirementsInfo_Req1 ;
    iof:prescribedBy :DesignSpec_Req1 .

:ComplianceAssessmentProcess_Req0 a iof:PlannedProcess ;
    rdfs:label "assessing compliance to any rule"@en ;
    iof:achievesAtSomeTime :ObjSpec_Req0 ;
    iof:prescribedBy :PlanSpec_Req0 .

:DesignSpec_Req1 a iof:DesignSpecification ;
    rdfs:label "Minimum requirements for steel tubing sizes"@en ;
    iof:prescribes :Tube_Req1 ;
    iof:satisfiesRequirement :Req_0 .

:NonStructuralTubing_Req0 a bfo:BFO_0000040 ;
    rdfs:label "tubing which does NOT meet structural tubing requirements"@en ;
    iof:prescribedBy :DesignSpec_Req0 .

:PlanSpec_Req0 a iof:PlanSpecification ;
    rdfs:label "Plan for compliance assessment handling of non-structural tubing"@en ;
    bfo:BFO_0000110 :ObjSpec_Req0 ;
    iof:prescribes :ComplianceAssessmentProcess_Req0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Definition Any tubing which does NOT meet F.3.2.1.o Structural Tubing F.3.3.2 Applicability Non Structural Tubing is ignored when assessing compliance to any rule ## F.3.4 Steel Tubing and Material F.3.4.1 Minimum Requirements for Steel Tubing A tube must meet all four minimum requirements for each Size specified: Tube Minimum Area Moment of Inertia Minimum Cross Sectional Area Minimum Outside Diameter or Square Width Minimum Wall Thickness Example Sizes of Round Tube :--: :--: :--: :--: :--: :--: :--: a. Size A $11320 \\mathrm{~mm}^{4}$ $173 \\mathrm{~mm}^{2}$ 25.0 mm 2.0 mm $\\begin{aligned} & 1.0^{\\prime \\prime} \\times 0.095^{\\prime \\prime} \\\\ & 25 \\times 2.5 \\mathrm{~mm} \\end{aligned}$ b" ;
    iof:isAbout :ObjSpec_Req0 ;
    iof:requirementSatisfiedBy :DesignSpec_Req1,
        :PlanSpec_Req0 .

:ObjSpec_Req0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for handling non-structural tubing in compliance assessment"@en ;
    iof:prescribes :ComplianceAssessmentProcess_Req0,
        :NonStructuralTubing_Req0 .

