@prefix : <http://example.org/req/571#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :FuelFillerNeck_1 ;
    iof:satisfiesRequirement :Req_0 .

:PS_1 a iof:PlanSpecification ;
    iof:prescribes :FuelLevelReadingProcess_1 ;
    iof:satisfiesRequirement :Req_0 .

:FuelFillerNeck_1 a bfo:BFO_0000040 ;
    iof:hasComponentPartAtSomeTime :SightTube_1 ;
    iof:hasProcessCharacteristic :TiltFromVertical_0 .

:FuelLevelInformation_1 a iof:InformationContentEntity ;
    iof:isAbout :FuelLevel_1 .

:FuelLevelReadingProcess_1 a iof:PlannedProcess ;
    iof:hasInput :SightTube_1 ;
    iof:hasSpecifiedOutput :FuelLevelInformation_1 .

:FuelLevel_1 a bfo:BFO_0000019 ;
    iof:qualityOf :FuelTank_1 .

:FuelTank_1 a bfo:BFO_0000040 .

:SightTubeEquipmentRole_1 a iof:EquipmentRole ;
    iof:roleOf :SightTube_1 .

:SightTubeFuelResistance_1 a bfo:BFO_0000019 ;
    iof:qualityOf :SightTube_1 .

:SightTubeTransparency_1 a bfo:BFO_0000019 ;
    iof:qualityOf :SightTube_1 .

:SightTubeVisibleHeight_1 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c2 .

:TiltFromVertical_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 5.235988e-01 ;
    qudt:unit qudtu:RAD .

:VE_req1_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.25e-01 ;
    qudt:unit qudtu:M .

qudtqk:Height a qudt:QuantityKind .

qudtqk:Tilt a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

qudtu:RAD a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Tilt .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Angled no more than 30 degrees from the vertical. The Fuel Filler Neck must be accompanied by a clear fuel resistant sight tube for reading the fuel level which must be: a. Visible vertical height: 125 mm minimum." .

:SightTube_1 a bfo:BFO_0000040 ;
    iof:hasProcessCharacteristic :SightTubeVisibleHeight_1 ;
    iof:hasQuality :SightTubeFuelResistance_1,
        :SightTubeTransparency_1 ;
    iof:hasRole :SightTubeEquipmentRole_1 .

