@prefix : <http://example.org/req/572#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_FuelLevelLineLocation a iof:DesignSpecification ;
    iof:prescribes :FuelLevelLine ;
    iof:satisfiesRequirement :Req_0 .

:FuelLevelLine a bfo:BFO_0000040 ;
    rdfs:label "permanent, non movable fuel level line"@en ;
    iof:hasQuality :FuelLevelLineLocation .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "[img-23.jpeg](img-23.jpeg) IC.5.4.5 Fuel Level Line - A permanent, non movable fuel level line must be located between 12 mm and 25 mm below the top of the visible portion of the sight tube" ;
    iof:requirementSatisfiedBy :DS_FuelLevelLineLocation .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.5e+01 ;
    qudt:minInclusive 1.2e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :FuelLevelLineLocation .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:FuelLevelLineLocation a bfo:BFO_0000019 ;
    rdfs:label "location of fuel level line relative to top of visible portion of sight tube"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

