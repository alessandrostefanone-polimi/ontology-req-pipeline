@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/509#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:StdRef_req0_c0 a iof:InformationContentEntity ;
    rdfs:label "SFI 3.2A/5"@en .

:StdRef_req0_c1 a iof:InformationContentEntity ;
    rdfs:label "SFI 3.4/5"@en .

:StdRef_req0_c2 a iof:InformationContentEntity ;
    rdfs:label "FIA Standard 1986"@en .

:StdRef_req0_c3 a iof:InformationContentEntity ;
    rdfs:label "FIA Standard 8856-2000"@en .

:StdRef_req0_c4 a iof:InformationContentEntity ;
    rdfs:label "FIA Standard 8856-2018"@en .

:ApprovedDriverSuit a bfo:BFO_0000040 ;
    rdfs:label "approved driver suit"@en .

:CompetitorGroup a iof:GroupOfAgents ;
    rdfs:label "all competitors"@en .

:FireRetardantUnderwear a bfo:BFO_0000040 ;
    rdfs:label "fire retardant underwear (long pants and long sleeve shirt)"@en .

:RacingSuitType a bfo:BFO_0000040 ;
    rdfs:label "racing suit (type constrained by standards and labeling)"@en ;
    iof:hasQuality :SuitLabeling,
        :SuitStandardConformance .

:SuitDesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :RacingSuitType ;
    iof:satisfiesRequirement :Req_0 .

:SuitLabeling a bfo:BFO_0000019 ;
    rdfs:label "suit labeling status"@en ;
    rdfs:comment "Indicates that the suit is labeled to reflect which standard(s) it meets."@en .

:SuitStandardConformance a bfo:BFO_0000019 ;
    rdfs:label "suit standard conformance"@en .

:UnderclothingPlanSpec_1 a iof:PlanSpecification ;
    iof:prescribes :UnderclothingWearingProcessType ;
    iof:satisfiesRequirement :Req_0 .

:UnderclothingWearingProcessType a iof:PlannedProcess ;
    rdfs:label "process of competitors wearing fire retardant underwear under driver suit"@en ;
    iof:hasInput :ApprovedDriverSuit,
        :FireRetardantUnderwear ;
    iof:hasParticipantAtSomeTime :CompetitorGroup .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Each suit must meet one or more of the following standards and be labeled as such: - $\\quad$ SFI 3.2A/5 (or higher ex: /10, /15, /20) - $\\quad$ SFI 3.4/5 (or higher ex: /10, /15, /20) - FIA Standard 1986 - FIA Standard 8856-2000 - FIA Standard 8856-2018 VE.3.3.2 Underclothing All competitors should wear fire retardant underwear (long pants and long sleeve shirt) under their approved Driver Suit" ;
    iof:requirementSatisfiedBy :SuitDesignSpec_0,
        :UnderclothingPlanSpec_1 .

