@prefix : <http://example.org/req/495#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Exposed around the lower $180^{\\circ}$ of its circumference over a minimum length of 280 mm g. Access from the rear of the tube must be unobstructed for 300 mm or more of its length h" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :UnobstructedLength_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:AccessFromRear_0 a iof:ProcessCharacteristic ;
    iof:processCharacteristicOf :AccessProcess_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :AccessProcess_0 ;
    iof:prescribes :AccessFromRear_0,
        :UnobstructedLength_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:hasContinuantPartAtAllTimes :ObjSpec_0 ;
    iof:prescribes :AccessProcess_0 .

:Tube_0 a bfo:BFO_0000040 .

:UnobstructedLength_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :Tube_0 .

:AccessProcess_0 a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :Tube_0 ;
    iof:hasProcessCharacteristic :AccessFromRear_0 ;
    iof:prescribedBy :PlanSpec_0 .

