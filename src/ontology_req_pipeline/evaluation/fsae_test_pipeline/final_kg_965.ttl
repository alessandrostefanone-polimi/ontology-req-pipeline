@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/965#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:ApplicabilityConstraint_Req0 a iof:InformationContentEntity ;
    rdfs:label "Applicability of continuation to rules D.12.1.4 and D.12.4" ;
    iof:isAbout :Proc_VehicleContinuation ;
    iof:prescribes :Rule_D_12_1_4,
        :Rule_D_12_4 .

:Event_VehicleStallOrConeIngest a iof:Event ;
    rdfs:label "Vehicle stalls or ingests a cone event" ;
    iof:recognizedByAtSomeTime :RaceOfficial .

:BlackFlag a bfo:BFO_0000040 ;
    rdfs:label "Black Flag" .

:DS_VehicleContinuation a iof:DesignSpecification ;
    rdfs:label "Design specification for vehicle continuation after stall or cone ingestion" ;
    iof:prescribes :Vehicle_It ;
    iof:satisfiesRequirement :Req_0 .

:DesignatedLocation a bfo:BFO_0000029 ;
    rdfs:label "Designated location for Black Flag display" .

:PC_BlackFlagShown a iof:ProcessCharacteristic ;
    rdfs:label "Display of Black Flag" .

:PC_PermissionToContinue a iof:ProcessCharacteristic ;
    rdfs:label "Permission for vehicle to continue" .

:PS_VehicleContinuation a iof:PlanSpecification ;
    rdfs:label "Plan specification for allowing vehicle to continue" ;
    bfo:BFO_0000110 :Obj_Req0 ;
    iof:prescribes :Proc_VehicleContinuation .

:RaceOfficial a iof:Agent ;
    rdfs:label "Race official" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If a vehicle stalls, or ingests a cone, etc., it may be allowed to continue, subject to D.12.1.4 and D.12.4 ## D.12.10 Endurance Event - Black Flags D.12.10.1 A Black Flag will be shown at the designated location D.12.10.2" ;
    iof:isAbout :Obj_Req0,
        :Obj_Req1 ;
    iof:requirementSatisfiedBy :DS_VehicleContinuation,
        :PS_BlackFlagDisplay .

:Rule_D_12_1_4 a iof:InformationContentEntity ;
    rdfs:label "Rule D.12.1.4" .

:Rule_D_12_4 a iof:InformationContentEntity ;
    rdfs:label "Rule D.12.4" .

:Obj_Req0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for vehicle continuation after stall or cone ingestion" ;
    iof:prescribes :Proc_VehicleContinuation .

:Obj_Req1 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for Black Flag display at designated location" ;
    iof:prescribes :Proc_BlackFlagDisplay .

:PS_BlackFlagDisplay a iof:PlanSpecification ;
    rdfs:label "Plan specification for Black Flag display" ;
    bfo:BFO_0000110 :Obj_Req1 ;
    iof:prescribes :Proc_BlackFlagDisplay .

:Proc_BlackFlagDisplay a iof:PlannedProcess ;
    rdfs:label "Process of showing Black Flag" ;
    bfo:BFO_0000057 :BlackFlag,
        :DesignatedLocation ;
    iof:hasProcessCharacteristic :PC_BlackFlagShown ;
    iof:prescribedBy :PS_BlackFlagDisplay .

:Vehicle_It a bfo:BFO_0000040 ;
    rdfs:label "Vehicle referred to as 'it'" .

:Proc_VehicleContinuation a iof:PlannedProcess ;
    rdfs:label "Process of allowing vehicle to continue" ;
    bfo:BFO_0000057 :Vehicle_It ;
    iof:hasProcessCharacteristic :PC_PermissionToContinue ;
    iof:prescribedBy :PS_VehicleContinuation .

