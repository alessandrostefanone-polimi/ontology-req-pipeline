<http://example.org/req/509#UnderclothingPlanSpec_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/509#UnderclothingWearingProcessType> ;
    ns1:satisfiesRequirement <http://example.org/req/509#Req_0> .

<http://example.org/req/509#UnderclothingWearingProcessType> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "process of competitors wearing fire retardant underwear under driver suit",
        "process of competitors wearing fire retardant underwear under driver suit"@en ;
    ns1:hasInput <http://example.org/req/509#ApprovedDriverSuit>,
        <http://example.org/req/509#FireRetardantUnderwear> ;
    ns1:hasParticipantAtSomeTime <http://example.org/req/509#CompetitorGroup> .

<http://example.org/req/509#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Each suit must meet one or more of the following standards and be labeled as such: - $\\quad$ SFI 3.2A/5 (or higher ex: /10, /15, /20) - $\\quad$ SFI 3.4/5 (or higher ex: /10, /15, /20) - FIA Standard 1986 - FIA Standard 8856-2000 - FIA Standard 8856-2018 VE.3.3.2 Underclothing All competitors should wear fire retardant underwear (long pants and long sleeve shirt) under their approved Driver Suit" ;
    ns1:requirementSatisfiedBy <http://example.org/req/509#SuitDesignSpec_0>,
        <http://example.org/req/509#UnderclothingPlanSpec_1> .

