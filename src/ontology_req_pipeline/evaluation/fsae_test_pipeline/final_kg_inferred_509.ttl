<http://example.org/req/509#FireRetardantUnderwear> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "fire retardant underwear (long pants and long sleeve shirt)",
        "fire retardant underwear (long pants and long sleeve shirt)"@en .

<http://example.org/req/509#RacingSuitType> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "racing suit (type constrained by standards and labeling)",
        "racing suit (type constrained by standards and labeling)"@en ;
    ns1:hasQuality <http://example.org/req/509#SuitLabeling>,
        <http://example.org/req/509#SuitStandardConformance> .

<http://example.org/req/509#SuitDesignSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/509#RacingSuitType> ;
    ns1:satisfiesRequirement <http://example.org/req/509#Req_0> .

<http://example.org/req/509#SuitLabeling> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "suit labeling status",
        "suit labeling status"@en ;
    rdfs:comment "Indicates that the suit is labeled to reflect which standard(s) it meets.",
        "Indicates that the suit is labeled to reflect which standard(s) it meets."@en .

<http://example.org/req/509#SuitStandardConformance> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
