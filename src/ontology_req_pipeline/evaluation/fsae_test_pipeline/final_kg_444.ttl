@prefix : <http://example.org/req/444#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:LC_Oil a bfo:BFO_0000040 ;
    rdfs:label "oil (for liquid coolant requirement)" .

:LC_PlainWater_NoAdditives a bfo:BFO_0000040 ;
    rdfs:label "plain water with no additives (for liquid coolant requirement)" .

:Mat_Al6061T6 a bfo:BFO_0000040 ;
    rdfs:label "aluminum alloy 6061-T6" .

:Mat_Steel a bfo:BFO_0000040 ;
    rdfs:label "steel" .

:PlainWater_NoAdditives a bfo:BFO_0000040 ;
    rdfs:label "plain water with no additives" .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "Design specification for Motor Scatter Shield" ;
    iof:prescribes :MotorScatterShield_Design ;
    iof:satisfiesRequirement :Req_0 .

:LiquidCoolant_Subject a bfo:BFO_0000040 ;
    rdfs:label "Liquid coolant for electric motors / accumulators / HV electronics" .

:MSS_Material a bfo:BFO_0000019 ;
    rdfs:label "Motor Scatter Shield material quality" .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for Motor Scatter Shield design" ;
    iof:prescribes :MotorScatterShield_Design .

:ObjSpec_1 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for water cooled engine coolant" ;
    iof:prescribes :WaterCooledEngine_CoolantProcess .

:ObjSpec_2 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for liquid coolant for electric motors / accumulators / HV electronics" ;
    iof:prescribes :LiquidCoolant_UseProcess .

:PS_1 a iof:PlanSpecification ;
    rdfs:label "Plan specification for water cooled engine coolant use" ;
    iof:prescribes :WaterCooledEngine_CoolantProcess ;
    iof:satisfiesRequirement :Req_0 .

:PS_2 a iof:PlanSpecification ;
    rdfs:label "Plan specification for liquid coolant types" ;
    iof:prescribes :LiquidCoolant_UseProcess ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Minimum thickness >= 1.0 mm (0.001 m)" ;
    qudt:minInclusive 1e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :MSS_Thickness .

:WaterCooledEngine_Coolant a bfo:BFO_0000040 ;
    rdfs:label "Coolant fluid for water cooled engines" .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

:LiquidCoolant_UseProcess a iof:PlannedProcess ;
    rdfs:label "Liquid coolant use process for electric motors / accumulators / HV electronics" ;
    iof:hasInput :LiquidCoolant_Subject .

:MSS_Thickness a bfo:BFO_0000019 ;
    rdfs:label "Motor Scatter Shield thickness quality" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:MotorScatterShield_Design a bfo:BFO_0000002 ;
    rdfs:label "Motor Scatter Shield design target" ;
    iof:hasQuality :MSS_Material,
        :MSS_Thickness .

:WaterCooledEngine_CoolantProcess a iof:PlannedProcess ;
    rdfs:label "Coolant use process for water cooled engines" ;
    iof:hasInput :WaterCooledEngine_Coolant .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The Motor Scatter Shield must be: - Made from aluminum alloy 6061-T6 or steel - Minimum thickness: 1.0 mm ## T.5.4 Coolant Fluid T.5.4.1 Water cooled engines must use only plain water with no additives of any kind T.5.4.2 Liquid coolant for electric motors, Accumulators or HV electronics must be one of: - plain water with no additives - oil T.5.4.3 (EV only)" ;
    iof:isAbout :ObjSpec_0,
        :ObjSpec_1,
        :ObjSpec_2 ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1,
        :PS_2 .

