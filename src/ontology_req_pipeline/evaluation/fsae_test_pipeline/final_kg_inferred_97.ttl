@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/97#> a owl:Ontology .

<http://example.org/req/97#AngularPositionState> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialState ;
    rdfs:label "Any angular position state of steering wheel" ;
    ns2:BFO_0000057 <http://example.org/req/97#SteeringWheel> .

<http://example.org/req/97#Obj_SteeringWheelAttachment> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: steering wheel attached to column with quick disconnect" ;
    ns1:isAbout <http://example.org/req/97#DS_SteeringWheelAttachment> ;
    ns1:isSubjectOf <http://example.org/req/97#Req_0> .

<http://example.org/req/97#Obj_SteeringWheelCompliance> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: steering wheel meets T.1.4.4 V.3.3.2 in any angular position" ;
    ns1:isAbout <http://example.org/req/97#DS_SteeringWheelCompliance> ;
    ns1:isSubjectOf <http://example.org/req/97#Req_0> ;
    ns1:prescribes <http://example.org/req/97#T_1_4_4_V_3_3_2> .

<http://example.org/req/97#QuickDisconnect> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Quick Disconnect" .

<http://example.org/req/97#SteeringColumn> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Steering Column" .

<http://example.org/req/97#T_1_4_4_V_3_3_2> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "T.1.4.4 V.3.3.2" .

<http://example.org/req/97#DS_SteeringWheelAttachment> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Design spec: steering wheel attached to column with quick disconnect" ;
    ns1:isAbout <http://example.org/req/97#Obj_SteeringWheelAttachment> ;
    ns1:prescribes <http://example.org/req/97#QuickDisconnect>,
        <http://example.org/req/97#SteeringColumn>,
        <http://example.org/req/97#SteeringWheel> ;
    ns1:satisfiesRequirement <http://example.org/req/97#Req_0> .

<http://example.org/req/97#DS_SteeringWheelCompliance> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Design spec: steering wheel compliance with T.1.4.4 V.3.3.2" ;
    ns1:isAbout <http://example.org/req/97#Obj_SteeringWheelCompliance> ;
    ns1:prescribes <http://example.org/req/97#SteeringWheel> ;
    ns1:satisfiesRequirement <http://example.org/req/97#Req_0> .

<http://example.org/req/97#SteeringWheel> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Steering Wheel" .

<http://example.org/req/97#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "In any angular position, the Steering Wheel must meet T.1.4.4 V.3.3.2 The Steering Wheel must be attached to the column with a quick disconnect" ;
    ns1:requirementSatisfiedBy <http://example.org/req/97#DS_SteeringWheelAttachment>,
        <http://example.org/req/97#DS_SteeringWheelCompliance> .

