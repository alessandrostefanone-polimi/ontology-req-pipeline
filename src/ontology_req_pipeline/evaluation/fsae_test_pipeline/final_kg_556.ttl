@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/556#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Brake System Plausibility Device - BSPD IC.4.8.1 A standalone nonprogrammable circuit must be used to monitor the electronic throttle control" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:ActionSpec_0 a iof:ActionSpecification ;
    iof:prescribes :MonitoringProcess_0 .

:Circuit_0 a bfo:BFO_0000040 .

:ElectronicThrottleControl_0 a bfo:BFO_0000040 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :MonitoringProcess_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ActionSpec_0,
        :ObjSpec_0 ;
    iof:prescribes :MonitoringProcess_0 .

:MonitoringProcess_0 a iof:PlannedProcess ;
    iof:hasInput :ElectronicThrottleControl_0 ;
    iof:hasParticipantAtSomeTime :Circuit_0 ;
    iof:prescribedBy :PlanSpec_0 .

