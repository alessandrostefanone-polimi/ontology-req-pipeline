@prefix : <http://example.org/req/491#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:StickerAreaLocation_0 a bfo:BFO_0000019 ;
    rdfs:label "location of inspection sticker area"@en ;
    iof:qualityOf :InspectionStickerArea_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :StickerSpace_0,
        :Vehicle_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "1.4 Inspection Sticker The vehicle must have space for the Inspection Sticker(s) IN.13.2 that is: - A clear and unobstructed area, minimum 25 cm wide $\\times 20 \\mathrm{~cm}$ high - Located on the upper front surface of the nose along the vehicle centerline ## VE.1.5 Transponder / RFID Tag VE.1.5.1" ;
    iof:requirementSatisfiedBy :DS_0 .

:StickerAreaWidth_0 a bfo:BFO_0000019 ;
    rdfs:label "width of inspection sticker area"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 ;
    iof:qualityOf :InspectionStickerArea_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "minimum width 0.25 m for inspection sticker area"@en ;
    qudt:minInclusive 2.5e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :StickerAreaWidth_0 .

qudtqk:Width a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Width .

:InspectionStickerArea_0 a bfo:BFO_0000040 ;
    rdfs:label "inspection sticker clear unobstructed area"@en ;
    iof:componentPartOfAtSomeTime :StickerSpace_0 .

:StickerSpace_0 a bfo:BFO_0000040 ;
    rdfs:label "space for Inspection Sticker(s) IN.13.2"@en ;
    iof:componentPartOfAtSomeTime :Vehicle_0 .

:Vehicle_0 a bfo:BFO_0000040 ;
    rdfs:label "vehicle (subject of requirement 0)"@en .

