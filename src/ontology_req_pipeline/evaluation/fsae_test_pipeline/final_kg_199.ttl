@prefix : <http://example.org/req/199#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Cond_0_0 a bfo:BFO_0000015 ;
    rdfs:label "condition: braces not welded to steel frame members (Req199, req_idx=0, constraint_idx=0)" .

:Material_1_1 a bfo:BFO_0000019 ;
    rdfs:label "material quality: steel (Req199, req_idx=1, constraint_idx=1)" ;
    iof:qualityOf :MountingPlate_1 .

:Rel_0_1 a bfo:BFO_0000016 ;
    rdfs:label "secure attachment disposition (Req199, req_idx=0, constraint_idx=1)" ;
    iof:dispositionOf :Braces_0 .

:Rel_0_2 a bfo:BFO_0000016 ;
    rdfs:label "attachment-to-frame disposition (Req199, req_idx=0, constraint_idx=2)" ;
    iof:dispositionOf :Braces_0 .

:Rel_0_3 a bfo:BFO_0000016 ;
    rdfs:label "use of critical fasteners disposition (Req199, req_idx=0, constraint_idx=3)" ;
    iof:dispositionOf :Braces_0 .

:RollHoopBracing_1 a bfo:BFO_0000040 ;
    rdfs:label "roll hoop bracing (Req199, req_idx=1)" .

:VE_req0_c4 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "value expression: fastener diameter >= 8 mm (Req199, req_idx=0, constraint_idx=4)" ;
    qudt:minInclusive 8e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :FastenerDiameter_0 .

:VE_req0_c5 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "value expression: fastener diameter >= 0.3125 in (Req199, req_idx=0, constraint_idx=5)" ;
    qudt:minInclusive 3.125e-01 ;
    qudt:unit qudtu:IN ;
    iof:isValueExpressionOfAtSomeTime :FastenerDiameter_0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "value expression: thickness >= 2.0 mm (Req199, req_idx=1, constraint_idx=0)" ;
    qudt:minInclusive 2e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Thickness_1_0 .

:DS_Req199_0 a iof:DesignSpecification ;
    iof:prescribes :Braces_0,
        :CriticalFastener_0,
        :Frame_0 ;
    iof:satisfiesRequirement :Req_0 .

:DS_Req199_1 a iof:DesignSpecification ;
    iof:prescribes :MountingPlate_1 ;
    iof:satisfiesRequirement :Req_0 .

:Frame_0 a bfo:BFO_0000040 ;
    rdfs:label "frame (Req199, req_idx=0)" .

:Thickness_1_0 a bfo:BFO_0000019 ;
    rdfs:label "thickness quality (Req199, req_idx=1)" ;
    iof:qualityOf :MountingPlate_1 .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:IN a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:CriticalFastener_0 a bfo:BFO_0000040 ;
    rdfs:label "critical fastener (Req199, req_idx=0)" .

:FastenerDiameter_0 a bfo:BFO_0000019 ;
    rdfs:label "fastener diameter quality (Req199, req_idx=0)" ;
    iof:qualityOf :CriticalFastener_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Other Bracing Requirements F.5.13.1 Where the braces are not welded to steel Frame Members, the braces must be securely attached to the Frame using 8 mm or 5/16\" minimum diameter Critical Fasteners, see T.8.2 F.5.13.2 Mounting plates welded to Roll Hoop Bracing must be 2.0 mm ( 0.080 in) minimum thickness steel" ;
    iof:requirementSatisfiedBy :DS_Req199_0,
        :DS_Req199_1 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter,
        qudtqk:Thickness .

:MountingPlate_1 a bfo:BFO_0000040 ;
    rdfs:label "mounting plate welded to roll hoop bracing (Req199, req_idx=1)" .

:Braces_0 a bfo:BFO_0000040 ;
    rdfs:label "braces (Req199, req_idx=0)" .

