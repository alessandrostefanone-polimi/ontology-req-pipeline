@prefix : <http://example.org/req/488#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Placement_0 a bfo:BFO_0000019 ;
    rdfs:label "Placement of name on both sides of the vehicle"@en ;
    iof:qualityOf :NameMarking_0 .

:Vehicle_0 a bfo:BFO_0000040 ;
    rdfs:label "Vehicle"@en .

:NameCharSet_0 a bfo:BFO_0000019 ;
    rdfs:label "Name character set"@en ;
    iof:qualityOf :NameMarking_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for vehicle name marking"@en ;
    iof:prescribes :NameMarking_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 5e-02 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :NameHeight_0 .

qudtqk:Height a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :NameMarking_0 ;
    iof:satisfiesRequirement :Req_0 .

:NameHeight_0 a bfo:BFO_0000019 ;
    rdfs:label "Name character height"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 ;
    iof:qualityOf :NameMarking_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The name must be in Roman characters minimum 50 mm high on both sides of the vehicle" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:NameMarking_0 a bfo:BFO_0000002 ;
    rdfs:label "Vehicle name marking"@en ;
    iof:hasQuality :NameCharSet_0,
        :NameHeight_0 ;
    iof:prescribedBy :DesignSpec_0 ;
    iof:satisfiesRequirement :Req_0 .

