@prefix : <http://example.org/req/855#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AddedItem_1 a bfo:BFO_0000040 .

:CostAddendum_0 a bfo:BFO_0000031 .

:CostReport_0 a bfo:BFO_0000031 .

:CostedItem_1 a bfo:BFO_0000040 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:CostingProcess_1 a iof:PlannedProcess ;
    iof:hasInput :AddedItem_1 ;
    iof:hasSpecifiedOutput :CostedItem_1 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :CostAddendum_0,
        :CostReport_0 ;
    iof:satisfiesRequirement :Req_0 .

:PS_1 a iof:PlanSpecification ;
    iof:prescribes :CostingProcess_1 ;
    iof:satisfiesRequirement :Req_0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.25e+02 ;
    qudt:minInclusive 1.25e+02 ;
    qudt:unit qudtu:PERCENT .

qudtqk:PositiveDimensionlessRatio a qudt:QuantityKind .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:PositiveDimensionlessRatio .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.7.6 Changes to the Cost Report in the Cost Addendum will incur additional cost: a. Added items will be cost at $125 \\%$ of the table cost: + (1.25 x Cost) b" ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1 .

