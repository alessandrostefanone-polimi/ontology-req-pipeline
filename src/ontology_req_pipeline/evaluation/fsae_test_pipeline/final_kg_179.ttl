@prefix : <http://example.org/req/179#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:BottomTubes_0 a bfo:BFO_0000040 ;
    rdfs:label "bottom tubes of the Major Structure of the Chassis"@en ;
    bfo:BFO_0000175 :MajorStructureChassis_0 .

:FrontViewProcess_0 a iof:PlannedProcess ;
    rdfs:label "front view of the vehicle"@en .

:MainHoopAttachmentLocation_0 a bfo:BFO_0000029 ;
    rdfs:label "location where the Main Hoop is attached to the bottom tubes of the Major Structure of the Chassis"@en .

:Vehicle_0 a bfo:BFO_0000040 ;
    rdfs:label "vehicle"@en .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :MainHoop_0 ;
    iof:satisfiesRequirement :Req_0 .

:MajorStructureChassis_0 a bfo:BFO_0000040 ;
    rdfs:label "Major Structure of the Chassis"@en .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :VMembersDistance_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "In the front view of the vehicle, the vertical members of the Main Hoop must be minimum 380 mm apart (inside dimension) at the location where the Main Hoop is attached to the bottom tubes of the Major Structure of the Chassis" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3.8e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :VMembersDistance_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:MainHoop_0 a iof:MaterialArtifact ;
    rdfs:label "Main Hoop"@en ;
    bfo:BFO_0000110 :VMembers_0 .

:VMembers_0 a bfo:BFO_0000040 ;
    rdfs:label "vertical members of the Main Hoop"@en ;
    bfo:BFO_0000175 :MainHoop_0 ;
    iof:hasQuality :VMembersDistance_0 .

:VMembersDistance_0 a bfo:BFO_0000019 ;
    rdfs:label "distance between vertical members (inside dimension)"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :VMembers_0 .

