@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/690#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "mm 4 mm EV.6.5.8 Teams must be prepared to show spacing on team built equipment For inaccessible circuitry, spare boards or appropriate photographs must be available for inspection" ;
    iof:requirementSatisfiedBy :PlanSpec_0,
        :PlanSpec_1 .

:InspectionProcess_1 a iof:PlannedProcess ;
    rdfs:label "inspection process" ;
    bfo:BFO_0000057 :InaccessibleCircuitry_1 .

:InspectionSupportProcess_1 a iof:PlannedProcess ;
    rdfs:label "Process of providing spare boards or photographs for inspection" ;
    bfo:BFO_0000057 :InaccessibleCircuitry_1,
        :InspectionProcess_1,
        :Photographs_1,
        :SpareBoards_1 ;
    iof:prescribedBy :PlanSpec_1 .

:Photographs_1 a iof:InformationContentEntity ;
    rdfs:label "appropriate photographs" .

:ShowSpacingProcess_0 a iof:PlannedProcess ;
    rdfs:label "Process where teams show spacing on team built equipment" ;
    bfo:BFO_0000057 :TeamBuiltEquipment_0,
        :Team_0 ;
    iof:prescribedBy :PlanSpec_0 .

:SpareBoards_1 a iof:MaterialArtifact ;
    rdfs:label "spare boards" .

:TeamBuiltEquipment_0 a iof:MaterialArtifact ;
    rdfs:label "team built equipment" .

:Team_0 a iof:GroupOfAgents ;
    rdfs:label "Teams" .

:InaccessibleCircuitry_1 a bfo:BFO_0000040 ;
    rdfs:label "inaccessible circuitry" .

:PlanSpec_0 a iof:PlanSpecification ;
    rdfs:label "Plan for teams showing spacing on team built equipment" ;
    iof:prescribes :ShowSpacingProcess_0 .

:PlanSpec_1 a iof:PlanSpecification ;
    rdfs:label "Plan for availability of spare boards or photographs for inspection" ;
    iof:prescribes :InspectionSupportProcess_1 .

