@prefix : <http://example.org/req/798#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "All teams with a system voltage of 500 V or more will be measured with 500 V" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:MeasICE_0 a iof:InformationContentEntity,
        iof:MeasurementInformationContentEntity ;
    bfo:BFO_0000110 :VE_req0_c3 ;
    iof:describes :TestVoltage_0 ;
    iof:isOutputOf :MeasProc_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :MeasProc_0 .

:SysVoltage_0 a bfo:BFO_0000019 ;
    rdfs:label "system voltage quality"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :System_0 .

:Team_Collection_0 a bfo:BFO_0000027 ;
    rdfs:label "All teams with required system voltage"@en .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "system voltage >= 500 V"@en ;
    qudt:minInclusive 5e+02 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtSomeTime :SysVoltage_0 .

qudtqk:Voltage a qudt:QuantityKind .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :MeasProc_0 .

:System_0 a bfo:BFO_0000040 ;
    rdfs:label "team system"@en ;
    bfo:BFO_0000056 :MeasProc_0 .

:TestVoltage_0 a bfo:BFO_0000019 ;
    rdfs:label "test voltage quality"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c3 ;
    iof:qualityOf :System_0 .

:VE_req0_c3 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "test voltage = 500 V"@en ;
    qudt:maxInclusive 5e+02 ;
    qudt:minInclusive 5e+02 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtSomeTime :TestVoltage_0 .

qudtu:V a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Voltage .

:MeasProc_0 a iof:MeasurementProcess,
        iof:PlannedProcess ;
    bfo:BFO_0000057 :Team_Collection_0 ;
    iof:hasSpecifiedOutput :MeasICE_0 .

