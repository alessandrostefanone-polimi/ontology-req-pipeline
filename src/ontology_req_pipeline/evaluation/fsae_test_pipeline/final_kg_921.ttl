@prefix : <http://example.org/req/921#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Cone a bfo:BFO_0000040 .

:Course a bfo:BFO_0000040 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :CourseWidthQuality ;
    iof:satisfiesRequirement :Req_0 .

:PS_1 a iof:PlanSpecification ;
    iof:prescribes :ConePlacementProcess ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 4.9e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :CourseWidthQuality .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 6e+00 ;
    qudt:minInclusive 6e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :ConeSpacingCharacteristic .

qudtqk:Length a qudt:QuantityKind .

qudtqk:Width a qudt:QuantityKind .

:ConePlacementProcess a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :Cone ;
    iof:hasProcessCharacteristic :ConeSpacingCharacteristic .

:ConeSpacingCharacteristic a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 ;
    iof:processCharacteristicOf :ConePlacementProcess .

:CourseWidthQuality a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :Course .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Course width will be minimum 4.9 m wide as measured between the inner edges of the bases of the course edge cones D.9.1.3 Cones are placed along the course edges at intervals, approximately 6 m" ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length,
        qudtqk:Width .

