@prefix : <http://example.org/req/658#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_1_DesignSpec a iof:DesignSpecification ;
    rdfs:label "TSMP color design specification" ;
    iof:prescribedBy :Req_1_ObjSpec ;
    iof:prescribes :TSMPs ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for TSMPs under accumulator charging" ;
    iof:isAchievedByAtSomeTime :TSMPs_ChargingAvailability_Process ;
    iof:prescribes :TSMPs .

:Req_1_ObjSpec a iof:ObjectiveSpecification ;
    rdfs:label "Objective for TSMP color" .

:TSMP_Charging_Plan a iof:PlanSpecification ;
    rdfs:label "Plan for TSMP behavior during accumulator charging" ;
    iof:prescribes :TSMPs_ChargingAvailability_Process .

:TSMP_Connector_0_TypeRole a bfo:BFO_0000023 ;
    rdfs:label "connector type role: shrouded banana jack" ;
    iof:roleOf :TSMP_Connector_0 .

:TSMP_DesignSpec a iof:DesignSpecification ;
    rdfs:label "TSMP design specification" ;
    iof:prescribes :TSMPs ;
    iof:satisfiesRequirement :Req_0 .

:TSMPs_Availability_Characteristic a iof:ProcessCharacteristic ;
    rdfs:label "availability of TSMPs during accumulator charging" .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Required diameter = 4 mm for TSMP connector" ;
    qudt:maxInclusive 4e+00 ;
    qudt:minInclusive 4e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :TSMP_Connector_0_Diameter .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Available during charging of any Accumulator(s) EV.5.8.3 The TSMPs must be: a. 4 mm shrouded banana jacks rated to an appropriate voltage level b. Color" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :TSMP_DesignSpec .

:TSMP_Connector_0 a iof:MaterialArtifact ;
    rdfs:label "TSMP connector (shrouded banana jack)" ;
    iof:hasQuality :TSMP_Connector_0_Diameter ;
    iof:hasRole :TSMP_Connector_0_TypeRole .

:TSMP_Connector_0_Diameter a bfo:BFO_0000019 ;
    rdfs:label "diameter of TSMP connector" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:TSMPs_ChargingAvailability_Process a iof:PlannedProcess ;
    rdfs:label "TSMP availability during accumulator charging" ;
    iof:hasProcessCharacteristic :TSMPs_Availability_Characteristic ;
    iof:prescribedBy :TSMP_Charging_Plan .

:TSMPs a iof:MaterialArtifact ;
    rdfs:label "TSMPs" ;
    iof:hasComponentPartAtSomeTime :TSMP_Connector_0 .

