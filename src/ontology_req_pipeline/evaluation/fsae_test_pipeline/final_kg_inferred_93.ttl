@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/93#> a owl:Ontology .

<http://example.org/req/93#Req0_Constraint0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:comment "req_idx=0, constraint_idx=0; attachment type of steering rack to chassis is mechanical (relation/enum constraint)." ;
    ns1:isAbout <http://example.org/req/93#MechanicalAttachment_SR_to_Chassis> ;
    ns1:isSubjectOf <http://example.org/req/93#Req_0> .

<http://example.org/req/93#Req0_Constraint1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:comment "req_idx=0, constraint_idx=1; steering rack is attached to Chassis F.5.14 V.3.2.7 (relation/entity_ref constraint)." ;
    ns1:isAbout <http://example.org/req/93#Chassis_F_5_14_V_3_2_7>,
        <http://example.org/req/93#SteeringRack> ;
    ns1:isSubjectOf <http://example.org/req/93#Req_0> .

<http://example.org/req/93#Req1_Constraint0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:comment "req_idx=1, constraint_idx=0; all joints between components attaching steering wheel to rack are mechanical (enum constraint)." ;
    ns1:isAbout <http://example.org/req/93#JointChain_SW_to_SR> ;
    ns1:isSubjectOf <http://example.org/req/93#Req_0> .

<http://example.org/req/93#Req1_Constraint1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:comment "req_idx=1, constraint_idx=1; joints must be visible at Technical Inspection (boolean/textual constraint)." ;
    ns1:isAbout <http://example.org/req/93#JointChain_SW_to_SR>,
        <http://example.org/req/93#TechnicalInspection>,
        <http://example.org/req/93#VisibilityAtTechnicalInspection> ;
    ns1:isSubjectOf <http://example.org/req/93#Req_0> .

<http://example.org/req/93#DS_AttachmentSteeringRackToChassis> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/93#Chassis_F_5_14_V_3_2_7>,
        <http://example.org/req/93#SteeringRack> ;
    ns1:satisfiesRequirement <http://example.org/req/93#Req_0> .

<http://example.org/req/93#MechanicalAttachment_SR_to_Chassis> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "mechanical attachment between steering rack and chassis",
        "mechanical attachment between steering rack and chassis"@en ;
    ns2:BFO_0000057 <http://example.org/req/93#Chassis_F_5_14_V_3_2_7>,
        <http://example.org/req/93#SteeringRack> .

<http://example.org/req/93#PS_JointsSteeringWheelToRack> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/93#JointChain_SW_to_SR>,
        <http://example.org/req/93#TechnicalInspection> ;
    ns1:satisfiesRequirement <http://example.org/req/93#Req_0> .

<http://example.org/req/93#SteeringWheel> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "steering wheel",
        "steering wheel"@en .

<http://example.org/req/93#VisibilityAtTechnicalInspection> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "visibility of joints at Technical Inspection",
        "visibility of joints at Technical Inspection"@en ;
    ns1:processCharacteristicOf <http://example.org/req/93#TechnicalInspection> .

<http://example.org/req/93#Chassis_F_5_14_V_3_2_7> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Chassis F.5.14 V.3.2.7",
        "Chassis F.5.14 V.3.2.7"@en .

<http://example.org/req/93#JointChain_SW_to_SR> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "joints between all components attaching the steering wheel to the steering rack",
        "joints between all components attaching the steering wheel to the steering rack"@en ;
    ns1:hasComponentPartAtSomeTime <http://example.org/req/93#SteeringRack>,
        <http://example.org/req/93#SteeringWheel> .

<http://example.org/req/93#TechnicalInspection> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Technical Inspection",
        "Technical Inspection"@en .

<http://example.org/req/93#SteeringRack> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "steering rack",
        "steering rack"@en .

<http://example.org/req/93#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The steering rack must be mechanically attached to the Chassis F.5.14 V.3.2.7 Joints between all components attaching the Steering Wheel to the steering rack must be mechanical and be visible at Technical Inspection" ;
    ns1:requirementSatisfiedBy <http://example.org/req/93#DS_AttachmentSteeringRackToChassis>,
        <http://example.org/req/93#PS_JointsSteeringWheelToRack> .

