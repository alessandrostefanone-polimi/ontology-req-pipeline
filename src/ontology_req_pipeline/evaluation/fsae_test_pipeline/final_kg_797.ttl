@prefix : <http://example.org/req/797#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "All vehicles with a maximum nominal operation voltage below 500 V will be measured with the next available voltage level" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:MeasurementProcess_0 a iof:PlannedProcess ;
    iof:hasInput :VehicleSet_0 ;
    iof:hasSpecifiedOutput :VoltageLevel_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :MeasurementProcess_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxExclusive 5e+02 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtAllTimes :MaxNominalOpVoltage_0 .

:VehicleSet_0 a bfo:BFO_0000040 ;
    iof:hasQuality :MaxNominalOpVoltage_0 .

:VoltageLevel_0 a bfo:BFO_0000040 .

qudtqk:Voltage a qudt:QuantityKind .

qudtu:V a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Voltage .

:MaxNominalOpVoltage_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

