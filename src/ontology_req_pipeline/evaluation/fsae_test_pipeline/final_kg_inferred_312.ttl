@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/312#> a owl:Ontology .

<http://example.org/req/312#DesignSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/312#MountingSystem_0> ;
    ns2:satisfiesRequirement <http://example.org/req/312#Req_0> .

<http://example.org/req/312#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "This mounting system design must withstand the following accelerations: 40 g in the longitudinal direction (forward/aft) 40 g in the lateral direction (left/right) 20 g in the vertical direction (up/down) c. Calculations and/or tests proving these requirements are met must be included in the SES. d" ;
    ns2:requirementSatisfiedBy <http://example.org/req/312#DesignSpec_0> .

<http://example.org/req/312#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 3.92266e+02 ;
    ns1:minInclusive 3.92266e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/M-PER-SEC2> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/312#LongitudinalAccelerationTolerance_0> .

<http://example.org/req/312#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 3.92266e+02 ;
    ns1:minInclusive 3.92266e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/M-PER-SEC2> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/312#LateralAccelerationTolerance_0> .

<http://example.org/req/312#VE_req0_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 1.96133e+02 ;
    ns1:minInclusive 1.96133e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/M-PER-SEC2> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/312#VerticalAccelerationTolerance_0> .

<http://example.org/req/312#LateralAccelerationTolerance_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "lateral acceleration tolerance" ;
    ns2:hasValueExpressionAtAllTimes <http://example.org/req/312#VE_req0_c1> ;
    ns2:qualityOf <http://example.org/req/312#MountingSystem_0> .

<http://example.org/req/312#LongitudinalAccelerationTolerance_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "longitudinal acceleration tolerance" ;
    ns2:hasValueExpressionAtAllTimes <http://example.org/req/312#VE_req0_c0> ;
    ns2:qualityOf <http://example.org/req/312#MountingSystem_0> .

<http://example.org/req/312#VerticalAccelerationTolerance_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "vertical acceleration tolerance" ;
    ns2:hasValueExpressionAtAllTimes <http://example.org/req/312#VE_req0_c2> ;
    ns2:qualityOf <http://example.org/req/312#MountingSystem_0> .

<http://qudt.org/vocab/unit/M-PER-SEC2> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Acceleration>,
        <http://qudt.org/vocab/quantitykind/LinearAcceleration> .

<http://example.org/req/312#MountingSystem_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact ;
    rdfs:label "mounting system" ;
    ns2:hasQuality <http://example.org/req/312#LateralAccelerationTolerance_0>,
        <http://example.org/req/312#LongitudinalAccelerationTolerance_0>,
        <http://example.org/req/312#VerticalAccelerationTolerance_0> .

