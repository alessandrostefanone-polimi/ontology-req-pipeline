@prefix : <http://example.org/req/279#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :CIA_0 ;
    iof:satisfiesRequirement :Req_0 .

:LSIS_Top_0 a bfo:BFO_0000029 ;
    rdfs:label "top of Lower Side Impact Structure" ;
    bfo:BFO_0000082 :LSIS_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "length >= 200 mm" ;
    qudt:minInclusive 2e+02 ;
    qudt:quantityKind qudtqk:Length ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :MountingLength_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "width >= 0.2 m" ;
    qudt:minInclusive 2e-01 ;
    qudt:quantityKind qudtqk:Width ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :MountingWidth_0 .

:VE_req0_c4 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "height <= 0.22 m" ;
    qudt:maxInclusive 2.2e-01 ;
    qudt:quantityKind qudtqk:Height ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :IntersectionHeight_0 .

:LSIS_0 a bfo:BFO_0000040 ;
    rdfs:label "Lower Side Impact Structure" .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :IntersectionHeight_0,
        :IntersectionPlane_0,
        :MountingArea_0,
        :MountingLength_0,
        :MountingWidth_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A Custom Impact Attenuator must mount with an area of 200 mm or more long and 200 mm or more wide that intersects a plane parallel to the ground that is no more than 220 mm above the lowest point on the top of the Lower Side Impact Structure F.8.5.7 Impact Attenuator Orientation a" ;
    iof:isAbout :ObjSpec_0 .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:CIA_0 a bfo:BFO_0000040 ;
    rdfs:label "Custom Impact Attenuator" ;
    iof:hasComponentPartAtSomeTime :MountingArea_0 .

:IntersectionHeight_0 a bfo:BFO_0000019 ;
    rdfs:label "height above lowest point on top of LSIS" ;
    iof:qualityOf :IntersectionPlane_0 .

:IntersectionPlane_0 a bfo:BFO_0000029 ;
    rdfs:label "intersection plane parallel to ground" .

qudtqk:Height a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

qudtqk:Width a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height,
        qudtqk:Width .

:MountingLength_0 a bfo:BFO_0000019 ;
    rdfs:label "mounting length" ;
    iof:qualityOf :MountingArea_0 .

:MountingWidth_0 a bfo:BFO_0000019 ;
    rdfs:label "mounting width" ;
    iof:qualityOf :MountingArea_0 .

:MountingArea_0 a bfo:BFO_0000019 ;
    rdfs:label "mounting area" ;
    iof:hasComponentPartAtSomeTime :MountingLength_0,
        :MountingWidth_0 ;
    iof:qualityOf :CIA_0 .

