@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/671#> a owl:Ontology .

<http://example.org/req/671#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "6.1.2 Contact with any Tractive System connections with a 100 mm long, 6 mm diameter insulated test probe must not be possible when the Tractive System enclosures are in place" ;
    ns2:requirementSatisfiedBy <http://example.org/req/671#PlanSpec_0> .

<http://example.org/req/671#ContactPossible_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "Contact between test probe and Tractive System connections is possible",
        "Contact between test probe and Tractive System connections is possible"@en .

<http://example.org/req/671#EnclosuresInPlace_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "Tractive System enclosures are in place",
        "Tractive System enclosures are in place"@en .

<http://example.org/req/671#NoContactProcess_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "Process in which contact with Tractive System connections is not possible using the specified test probe when enclosures are in place",
        "Process in which contact with Tractive System connections is not possible using the specified test probe when enclosures are in place"@en ;
    ns2:hasInput <http://example.org/req/671#TestProbe_0>,
        <http://example.org/req/671#TractiveSystemConnections_0>,
        <http://example.org/req/671#TractiveSystemEnclosures_0> ;
    ns2:hasProcessCharacteristic <http://example.org/req/671#ContactPossible_0>,
        <http://example.org/req/671#EnclosuresInPlace_0> .

<http://example.org/req/671#PlanSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/671#NoContactProcess_0> .

<http://example.org/req/671#ProbeDiameter_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "test probe diameter",
        "test probe diameter"@en .

<http://example.org/req/671#TestProbe_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "insulated test probe",
        "insulated test probe"@en ;
    ns2:hasQuality <http://example.org/req/671#ProbeDiameter_0>,
        <http://example.org/req/671#ProbeLength_0> .

<http://example.org/req/671#TractiveSystemConnections_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Tractive System connections",
        "Tractive System connections"@en .

<http://example.org/req/671#TractiveSystemEnclosures_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Tractive System enclosures",
        "Tractive System enclosures"@en .

<http://example.org/req/671#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 1e-01 ;
    ns1:minInclusive 1e-01 ;
    ns1:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/671#ProbeLength_0> .

<http://qudt.org/vocab/unit/M> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/671#ProbeLength_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "test probe length",
        "test probe length"@en ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/671#VE_req0_c1> .

