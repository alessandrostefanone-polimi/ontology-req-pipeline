@prefix : <http://example.org/req/731#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The temperature of a minimum of $20 \\%$ of the cells must be monitored by the AMS b" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:AMS_b a iof:EngineeredSystem .

:CellPopulation_0 a bfo:BFO_0000040 .

:MonitoringProcess_0 a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :AMS_b,
        :CellPopulation_0 ;
    iof:hasProcessCharacteristic :MonitoredTemperatureFraction_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :MonitoringProcess_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e+01 ;
    qudt:unit qudtu:PERCENT ;
    iof:isValueExpressionOfAtSomeTime :MonitoredTemperatureFraction_0 .

qudtqk:PositiveDimensionlessRatio a qudt:QuantityKind .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:PositiveDimensionlessRatio .

:MonitoredTemperatureFraction_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

