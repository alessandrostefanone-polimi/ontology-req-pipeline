@prefix : <http://example.org/req/415#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Each spring must be capable of returning the pedal to $0 \\%$ Pedal Travel with the other disconnected" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:Pedal_0 a bfo:BFO_0000040 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :PedalReturnProcess_0 .

:Spring_0 a bfo:BFO_0000040 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 0e+00 ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:PERCENT ;
    iof:isValueExpressionOfAtSomeTime :PedalTravel_0 .

qudtqk:PositiveDimensionlessRatio a qudt:QuantityKind .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:PositiveDimensionlessRatio .

:PedalReturnProcess_0 a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :Pedal_0,
        :Spring_0 ;
    iof:hasProcessCharacteristic :PedalTravel_0 .

:PedalTravel_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:processCharacteristicOf :PedalReturnProcess_0 .

