@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/232#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Adhesive a bfo:BFO_0000040 .

:FrontHoop a bfo:BFO_0000040 .

:Monocoque a bfo:BFO_0000040 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A small gap in the laminate (approximately 25 mm ) exists for inspection of the Front Hoop F.5.7.6 F.7.4.4 Adhesive must not be the sole method of attaching the Front Hoop to the monocoque" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :AttachFrontHoopProcess .

:FrontHoopAttachmentCharacteristic a iof:ProcessCharacteristic ;
    iof:processCharacteristicOf :AttachFrontHoopProcess .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :AttachFrontHoopProcess ;
    iof:prescribes :FrontHoopAttachmentCharacteristic .

:AttachFrontHoopProcess a iof:PlannedProcess ;
    iof:hasProcessCharacteristic :FrontHoopAttachmentCharacteristic .

