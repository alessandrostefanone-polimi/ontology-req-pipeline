@prefix : <http://example.org/req/559#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:BrakingSensor a bfo:BFO_0000040 ;
    rdfs:label "Braking sensor" .

:ThrottleSensor a bfo:BFO_0000040 ;
    rdfs:label "Throttle sensor" .

:BSPD_Monitoring_Design a iof:PlanSpecification ;
    rdfs:label "BSPD monitoring and response design" ;
    iof:prescribes :BSPD_Monitoring_Process,
        :BSPD_Reset_Process,
        :BSPD_Shutdown_Response_Process ;
    iof:satisfiesRequirement :Req_0 .

:BSPD_Reset_Process a iof:PlannedProcess ;
    rdfs:label "BSPD reset process" ;
    bfo:BFO_0000057 :BSPD,
        :PrimaryMasterSwitch ;
    iof:hasInput :ShutdownCircuit .

:BSPD_Shutdown_Response_Process a iof:PlannedProcess ;
    rdfs:label "BSPD shutdown response process" ;
    bfo:BFO_0000057 :BSPD,
        :ShutdownCircuit ;
    iof:hasInput :BSPD_Monitoring_Process .

:BrakeSignalLoss_Duration a iof:ProcessCharacteristic ;
    rdfs:label "Duration of loss of signal from braking sensor(s)" ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c0 ;
    iof:processCharacteristicOf :BrakeSignalLoss .

:CondGroup1_Duration a iof:ProcessCharacteristic ;
    rdfs:label "Duration of combined hard braking and throttle condition" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 ;
    iof:processCharacteristicOf :BSPD_Monitoring_Process .

:CondGroup1_HardBraking a iof:ProcessCharacteristic ;
    rdfs:label "Hard braking demand condition present" ;
    iof:processCharacteristicOf :HardBrakingDemand .

:CondGroup1_ThrottleOpening a iof:ProcessCharacteristic ;
    rdfs:label "Throttle opening condition" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c2 ;
    iof:processCharacteristicOf :Throttle .

:PowerRemoval_Event a iof:Event ;
    rdfs:label "Removal of power from the BSPD circuit" .

:PrimaryMasterSwitch a bfo:BFO_0000040 ;
    rdfs:label "Primary Master Switch" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "4.8.3 The BSPD must monitor for the following conditions: a. Both of the following for more than one second: - Demand for Hard Braking IC.4.6 - Throttle more than 10% open IC.4.4 b. Loss of signal from the braking sensor(s) for more than 100 msec c. Loss of signal from the throttle sensor(s) for more than 100 msec d. Removal of power from the BSPD circuit IC.4.8.4 When any of the above conditions exist, the BSPD must Open the Shutdown Circuit IC.9.2.2 IC.4.8.5 The BSPD must only be reset by cycling the Primary Master Switch IC.9.3 OFF and ON IC.4.8.6" ;
    iof:requirementSatisfiedBy :BSPD_Monitoring_Design .

:Throttle a bfo:BFO_0000040 ;
    rdfs:label "Throttle" .

:ThrottleSignalLoss_Duration a iof:ProcessCharacteristic ;
    rdfs:label "Duration of loss of signal from throttle sensor(s)" ;
    iof:hasValueExpressionAtSomeTime :VE_req3_c1 ;
    iof:processCharacteristicOf :ThrottleSignalLoss .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Duration > 1 s for combined condition" ;
    qudt:minExclusive 1e+00 ;
    qudt:unit qudtu:SEC .

:VE_req1_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Throttle opening > 10 percent" ;
    qudt:minExclusive 1e+01 ;
    qudt:unit qudtu:PERCENT .

:VE_req2_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Brake signal loss duration > 0.1 s" ;
    qudt:minExclusive 1e-01 ;
    qudt:unit qudtu:SEC .

:VE_req3_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Throttle signal loss duration > 0.1 s" ;
    qudt:minExclusive 1e-01 ;
    qudt:unit qudtu:SEC .

qudtqk:OpeningRatio a qudt:QuantityKind .

qudtqk:Time a qudt:QuantityKind .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:OpeningRatio .

:BrakeSignalLoss a bfo:BFO_0000015 ;
    rdfs:label "Loss of signal from braking sensor(s)" .

:HardBrakingDemand a bfo:BFO_0000015 ;
    rdfs:label "Demand for Hard Braking" .

:ShutdownCircuit a bfo:BFO_0000040 ;
    rdfs:label "Shutdown Circuit" .

:ThrottleSignalLoss a bfo:BFO_0000015 ;
    rdfs:label "Loss of signal from throttle sensor(s)" .

:BSPD a bfo:BFO_0000040 ;
    rdfs:label "BSPD" .

:BSPD_Monitoring_Process a iof:PlannedProcess ;
    rdfs:label "BSPD monitoring process" ;
    bfo:BFO_0000057 :BSPD ;
    bfo:BFO_0000117 :BrakeSignalLoss,
        :HardBrakingDemand,
        :PowerRemoval_Event,
        :ThrottleSignalLoss ;
    iof:hasProcessCharacteristic :BrakeSignalLoss_Duration,
        :CondGroup1_Duration,
        :CondGroup1_HardBraking,
        :CondGroup1_ThrottleOpening,
        :ThrottleSignalLoss_Duration .

qudtu:SEC a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Time .

