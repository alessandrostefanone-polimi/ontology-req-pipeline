@prefix : <http://example.org/req/287#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:ImpactScenario_0 a bfo:BFO_0000015 ;
    bfo:BFO_0000057 :Vehicle_0 ;
    iof:hasProcessCharacteristic :ImpactVelocity_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Energy absorbed must be more than 7350 J When: - Total mass of Vehicle is 300 kg - Impact velocity is $7.0 \\mathrm{~m} / \\mathrm{s}$ F.8.8.3 When using the Standard Impact Attenuator, the SES must meet the following: a. Test data will not be submitted b" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:DesignSpec_0 a iof:PlanSpecification ;
    iof:prescribes :EnergyAbsorptionProcess_0,
        :Vehicle_0 .

:EnergyAbsorptionProcess_0 a bfo:BFO_0000015 ;
    iof:hasProcessCharacteristic :EnergyAbsorbed_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 7.35e+03 ;
    qudt:unit qudtu:J ;
    iof:isValueExpressionOfAtSomeTime :EnergyAbsorbed_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3e+02 ;
    qudt:minInclusive 3e+02 ;
    qudt:unit qudtu:KiloGM ;
    iof:isValueExpressionOfAtSomeTime :VehicleMass_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 7e+00 ;
    qudt:minInclusive 7e+00 ;
    qudt:unit qudtu:KiloGM-PER-SEC ;
    iof:isValueExpressionOfAtSomeTime :ImpactVelocity_0 .

qudtqk:Energy a qudt:QuantityKind .

qudtqk:Mass a qudt:QuantityKind .

qudtqk:MassFlowRate a qudt:QuantityKind .

qudtu:J a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Energy .

qudtu:KiloGM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Mass .

qudtu:KiloGM-PER-SEC a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:MassFlowRate .

:EnergyAbsorbed_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:ImpactVelocity_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 .

:VehicleMass_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:Vehicle_0 a bfo:BFO_0000040 ;
    iof:hasQuality :VehicleMass_0 .

