@prefix : <http://example.org/req/397#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :PaddingAssembly_0 ;
    iof:satisfiesRequirement :Req_0 .

:InspectionHole_0 a bfo:BFO_0000040 ;
    iof:hasQuality :InspectionHoleDiameter_0 .

:PaddingAssembly_0 a iof:Assembly ;
    iof:hasComponentPartAtSomeTime :Padding_0,
        :RollBar_0 .

:Padding_0 a iof:MaterialArtifact ;
    iof:hasComponentPartAtSomeTime :InspectionHole_0 ;
    iof:hasQuality :Area_0,
        :Height_0,
        :Thickness_0,
        :TotalHeightAdjustment_0 ;
    iof:satisfiesRequirement :Req_0 .

:RollBar_0 a iof:MaterialArtifact .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.35e+02 ;
    qudt:unit qudtu:CentiM2 ;
    iof:isValueExpressionOfAtSomeTime :Area_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.75e+01 ;
    qudt:unit qudtu:CentiM ;
    iof:isValueExpressionOfAtSomeTime :TotalHeightAdjustment_0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.8e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Height_0 .

:VE_req2_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e+01 ;
    qudt:minInclusive 2e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :InspectionHoleDiameter_0 .

:VE_req3_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.2e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Thickness_0 .

qudtqk:CartesianArea a qudt:QuantityKind .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:CentiM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

qudtu:CentiM2 a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:CartesianArea .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:Area_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:Height_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:InspectionHoleDiameter_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c1 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Meet one of the following: - minimum area of $235 \\mathrm{~cm}^{2}$ AND minimum total height adjustment of 17.5 cm - minimum height of 28 cm e. Be covered with a thin, flexible material that contains a $\\sim 20 \\mathrm{~mm}$ diameter inspection hole in a surface other than the front surface ## T.2.9 Roll Bar Padding Any portion of the roll bar, roll bar bracing or Chassis which might be contacted by the driver's helmet must be covered with a minimum thickness of 12 mm of padding which meets SFI Spec 45.1 or FIA 8857-2001" ;
    iof:requirementSatisfiedBy :DS_0 .

:Thickness_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req3_c1 .

:TotalHeightAdjustment_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

qudtqk:Height a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter,
        qudtqk:Thickness .

