@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/476#> a owl:Ontology .

<http://example.org/req/476#Chassis> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Chassis",
        "Chassis"@en .

<http://example.org/req/476#Shoulder_Belt_Mount> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Shoulder Belt Mount",
        "Shoulder Belt Mount"@en .

<http://example.org/req/476#T_2_6> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "T.2.6",
        "T.2.6"@en .

<http://example.org/req/476#DS_Req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:comment "Design specification corresponding to requirement 0: All Low Voltage Batteries and onboard power supplies must be securely mounted inside the Chassis below the height of the Shoulder Belt Mount T.2.6" ;
    ns1:prescribes <http://example.org/req/476#LV_Battery_And_PSU_Assembly> .

<http://example.org/req/476#DS_Req2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:comment "Design specification corresponding to requirement 2: The hot (ungrounded) terminal must be insulated" ;
    ns1:prescribes <http://example.org/req/476#Hot_Ungrounded_Terminal> .

<http://example.org/req/476#Hot_Ungrounded_Terminal> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    rdfs:label "Hot (ungrounded) terminal",
        "Hot (ungrounded) terminal"@en ;
    ns1:satisfiesRequirement <http://example.org/req/476#Req_0> .

<http://example.org/req/476#LV_Battery_And_PSU_Assembly> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    rdfs:label "Low Voltage Batteries and onboard power supplies assembly",
        "Low Voltage Batteries and onboard power supplies assembly"@en ;
    ns1:satisfiesRequirement <http://example.org/req/476#Req_0> .

<http://example.org/req/476#PS_Req1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:comment "Plan specification corresponding to requirement 1: All Low Voltage batteries must have Overcurrent Protection that trips at or below the maximum specified discharge current of the cells" ;
    ns1:prescribes <http://example.org/req/476#Overcurrent_Protection_Trip_Process> .

<http://example.org/req/476#VE_req1_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Trip current value expression (≤ 0.0 m, as normalized)",
        "Trip current value expression (≤ 0.0 m, as normalized)"@en ;
    ns2:maxInclusive 0e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/476#Trip_Current_Characteristic> .

<http://qudt.org/vocab/unit/M> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Thickness> .

<http://example.org/req/476#Overcurrent_Protection_Trip_Process> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Overcurrent protection trip process",
        "Overcurrent protection trip process"@en ;
    ns1:hasProcessCharacteristic <http://example.org/req/476#Trip_Current_Characteristic> ;
    ns1:satisfiesRequirement <http://example.org/req/476#Req_0> .

<http://example.org/req/476#Trip_Current_Characteristic> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "Trip current characteristic",
        "Trip current characteristic"@en ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/476#VE_req1_c1> ;
    ns1:processCharacteristicOf <http://example.org/req/476#Overcurrent_Protection_Trip_Process> .

<http://example.org/req/476#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Any voltage more than 60 V DC or 25 V AC RMS T.9.1.2 Low Voltage - LV Any voltage less than and including 60 V DC or 25 V AC RMS T.9.1.3 Normally Open A type of electrical relay or contactor that allows current flow only in the energized state ## T.9.2 Low Voltage Batteries T.9.2.1 All Low Voltage Batteries and onboard power supplies must be securely mounted inside the Chassis below the height of the Shoulder Belt Mount T.2.6 T.9.2.2 All Low Voltage batteries must have Overcurrent Protection that trips at or below the maximum specified discharge current of the cells T.9.2.3 The hot (ungrounded) terminal must be insulated" ;
    ns1:requirementSatisfiedBy <http://example.org/req/476#DS_Req0>,
        <http://example.org/req/476#DS_Req2>,
        <http://example.org/req/476#PS_Req1> .

