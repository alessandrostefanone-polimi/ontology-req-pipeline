@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/111#> a owl:Ontology .

<http://example.org/req/111#DesignSpec_Req0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Non-structural tubing definition based on F.3.2.1.o and F.3.3.2",
        "Non-structural tubing definition based on F.3.2.1.o and F.3.3.2"@en ;
    ns1:isAbout <http://example.org/req/111#Ref_F_3_2_1_o>,
        <http://example.org/req/111#Ref_F_3_3_2> ;
    ns1:prescribes <http://example.org/req/111#NonStructuralTubing_Req0> ;
    ns1:satisfiesRequirement <http://example.org/req/111#Req_0> .

<http://example.org/req/111#MinRequirementsInfo_Req1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "all four minimum requirements for each Size specified",
        "all four minimum requirements for each Size specified"@en .

<http://example.org/req/111#Ref_F_3_2_1_o> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "F.3.2.1.o Structural Tubing",
        "F.3.2.1.o Structural Tubing"@en .

<http://example.org/req/111#Ref_F_3_3_2> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "F.3.3.2 Applicability Non Structural Tubing",
        "F.3.3.2 Applicability Non Structural Tubing"@en .

<http://example.org/req/111#Tube_Req1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "tube subject to minimum requirements per size",
        "tube subject to minimum requirements per size"@en ;
    ns1:isSubjectOf <http://example.org/req/111#MinRequirementsInfo_Req1> ;
    ns1:prescribedBy <http://example.org/req/111#DesignSpec_Req1> .

<http://example.org/req/111#ComplianceAssessmentProcess_Req0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "assessing compliance to any rule",
        "assessing compliance to any rule"@en ;
    ns1:achievesAtSomeTime <http://example.org/req/111#ObjSpec_Req0> ;
    ns1:prescribedBy <http://example.org/req/111#PlanSpec_Req0> .

<http://example.org/req/111#DesignSpec_Req1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Minimum requirements for steel tubing sizes",
        "Minimum requirements for steel tubing sizes"@en ;
    ns1:prescribes <http://example.org/req/111#Tube_Req1> ;
    ns1:satisfiesRequirement <http://example.org/req/111#Req_0> .

<http://example.org/req/111#NonStructuralTubing_Req0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "tubing which does NOT meet structural tubing requirements",
        "tubing which does NOT meet structural tubing requirements"@en ;
    ns1:prescribedBy <http://example.org/req/111#DesignSpec_Req0> .

<http://example.org/req/111#PlanSpec_Req0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan for compliance assessment handling of non-structural tubing",
        "Plan for compliance assessment handling of non-structural tubing"@en ;
    ns2:BFO_0000110 <http://example.org/req/111#ObjSpec_Req0> ;
    ns1:prescribes <http://example.org/req/111#ComplianceAssessmentProcess_Req0> .

<http://example.org/req/111#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Definition Any tubing which does NOT meet F.3.2.1.o Structural Tubing F.3.3.2 Applicability Non Structural Tubing is ignored when assessing compliance to any rule ## F.3.4 Steel Tubing and Material F.3.4.1 Minimum Requirements for Steel Tubing A tube must meet all four minimum requirements for each Size specified: Tube Minimum Area Moment of Inertia Minimum Cross Sectional Area Minimum Outside Diameter or Square Width Minimum Wall Thickness Example Sizes of Round Tube :--: :--: :--: :--: :--: :--: :--: a. Size A $11320 \\mathrm{~mm}^{4}$ $173 \\mathrm{~mm}^{2}$ 25.0 mm 2.0 mm $\\begin{aligned} & 1.0^{\\prime \\prime} \\times 0.095^{\\prime \\prime} \\\\ & 25 \\times 2.5 \\mathrm{~mm} \\end{aligned}$ b" ;
    ns1:isAbout <http://example.org/req/111#ObjSpec_Req0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/111#DesignSpec_Req1>,
        <http://example.org/req/111#PlanSpec_Req0> .

<http://example.org/req/111#ObjSpec_Req0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective for handling non-structural tubing in compliance assessment",
        "Objective for handling non-structural tubing in compliance assessment"@en ;
    ns1:prescribes <http://example.org/req/111#ComplianceAssessmentProcess_Req0>,
        <http://example.org/req/111#NonStructuralTubing_Req0> .

