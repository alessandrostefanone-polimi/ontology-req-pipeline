@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/287#> a owl:Ontology .

<http://example.org/req/287#ImpactScenario_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    ns3:BFO_0000057 <http://example.org/req/287#Vehicle_0> ;
    ns2:hasProcessCharacteristic <http://example.org/req/287#ImpactVelocity_0> .

<http://example.org/req/287#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "Energy absorbed must be more than 7350 J When: - Total mass of Vehicle is 300 kg - Impact velocity is $7.0 \\mathrm{~m} / \\mathrm{s}$ F.8.8.3 When using the Standard Impact Attenuator, the SES must meet the following: a. Test data will not be submitted b" ;
    ns2:requirementSatisfiedBy <http://example.org/req/287#DesignSpec_0> .

<http://example.org/req/287#DesignSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/287#EnergyAbsorptionProcess_0>,
        <http://example.org/req/287#Vehicle_0> .

<http://example.org/req/287#EnergyAbsorptionProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasProcessCharacteristic <http://example.org/req/287#EnergyAbsorbed_0> .

<http://example.org/req/287#VE_req0_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:minExclusive 7.35e+03 ;
    ns1:unit <http://qudt.org/vocab/unit/J> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/287#EnergyAbsorbed_0> .

<http://example.org/req/287#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 3e+02 ;
    ns1:minInclusive 3e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/KiloGM> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/287#VehicleMass_0> .

<http://example.org/req/287#VE_req0_c2> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 7e+00 ;
    ns1:minInclusive 7e+00 ;
    ns1:unit <http://qudt.org/vocab/unit/KiloGM-PER-SEC> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/287#ImpactVelocity_0> .

<http://qudt.org/vocab/unit/J> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Energy> .

<http://qudt.org/vocab/unit/KiloGM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Mass> .

<http://qudt.org/vocab/unit/KiloGM-PER-SEC> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/MassFlowRate> .

<http://example.org/req/287#EnergyAbsorbed_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/287#VE_req0_c0> .

<http://example.org/req/287#ImpactVelocity_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/287#VE_req0_c2> .

<http://example.org/req/287#VehicleMass_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/287#VE_req0_c1> .

<http://example.org/req/287#Vehicle_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasQuality <http://example.org/req/287#VehicleMass_0> .

