@prefix : <http://example.org/req/856#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Removed items will be credited $75 \\%$ of the table cost: - ( $0.75 \\times$ Cost) ### 5.3.8 Cost Tables 5.3.8.1 All costs in the Cost Report must come from the standardized Cost Tables. 5.3.8.2" ;
    iof:requirementSatisfiedBy :DesignSpec_0,
        :PlanSpec_1 .

:TableCost_Req0 a bfo:BFO_0000019 ;
    rdfs:label "Table cost quality" ;
    iof:qualityOf :RemovedItems_Req0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "75 percent of table cost" ;
    qudt:maxInclusive 7.5e+01 ;
    qudt:minInclusive 7.5e+01 ;
    qudt:unit qudtu:PERCENT ;
    iof:isValueExpressionOfAtSomeTime :CreditAmount_Req0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "0.75 times cost (dimensionless ratio)" ;
    qudt:maxInclusive 7.5e-01 ;
    qudt:minInclusive 7.5e-01 ;
    qudt:unit qudtu:UNITLESS ;
    iof:isValueExpressionOfAtSomeTime :CreditAmount_Req0 .

:CostReport_Req1 a iof:InformationContentEntity ;
    rdfs:label "Cost Report" .

:CostSourcingProcess_Req1 a iof:PlannedProcess ;
    rdfs:label "Process of sourcing all costs in the Cost Report from standardized Cost Tables" ;
    iof:hasInput :CostReport_Req1,
        :StandardizedCostTables_Req1 .

:DesignSpec_0 a iof:DesignSpecification ;
    rdfs:label "Design specification for crediting removed items" ;
    iof:prescribes :CreditAmount_Req0 .

:PlanSpec_1 a iof:PlanSpecification ;
    rdfs:label "Plan specification for sourcing costs from standardized Cost Tables" ;
    iof:prescribes :CostSourcingProcess_Req1 .

:StandardizedCostTables_Req1 a iof:InformationContentEntity ;
    rdfs:label "Standardized Cost Tables" .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtqk:PositiveDimensionlessRatio a qudt:QuantityKind .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:PositiveDimensionlessRatio .

qudtu:UNITLESS a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

:RemovedItems_Req0 a bfo:BFO_0000040 ;
    rdfs:label "Removed items" .

:CreditAmount_Req0 a bfo:BFO_0000019 ;
    rdfs:label "Credit amount for removed items" ;
    iof:qualityOf :RemovedItems_Req0 .

