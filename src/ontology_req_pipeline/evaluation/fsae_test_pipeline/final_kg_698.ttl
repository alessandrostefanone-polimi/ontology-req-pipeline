@prefix : <http://example.org/req/698#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If conductor ampacity is reduced below the ampacity of the upstream Overcurrent Protection, the reduced conductor longer than 150 mm must have additional Overcurrent Protection" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:Agent_0 a iof:Agent .

:AmpacityReductionEvent_0 a iof:Event ;
    iof:recognizedByAtSomeTime :Agent_0 .

:ConductorLength_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :Conductor_0 .

:OvercurrentProtectionProcess_0 a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :Conductor_0,
        :OvercurrentProtection_Additional,
        :OvercurrentProtection_Upstream .

:OvercurrentProtection_Additional a bfo:BFO_0000040 .

:OvercurrentProtection_Upstream a bfo:BFO_0000040 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :PlannedProcess_0 .

:PlannedProcess_0 a iof:PlannedProcess ;
    iof:hasInput :Conductor_0 ;
    iof:hasOccurrentPart :AmpacityReductionEvent_0,
        :OvercurrentProtectionProcess_0 ;
    iof:hasSpecifiedOutput :Conductor_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 1.5e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :ConductorLength_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Conductor_0 a bfo:BFO_0000040 .

