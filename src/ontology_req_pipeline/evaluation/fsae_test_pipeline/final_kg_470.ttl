@prefix : <http://example.org/req/470#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:RearAeroZone a iof:MaterialArtifact ;
    rdfs:label "Rear Aerodynamic Zone" ;
    iof:hasQuality :RearAeroZone_HeightAboveGround .

:RearAeroZone_DesignSpec a iof:DesignSpecification ;
    rdfs:label "Rear Aerodynamic Zone design specification" ;
    iof:prescribes :RearAeroZone ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "In the Rear Aerodynamic Zone must be no higher than 1200 mm above the ground b" ;
    iof:requirementSatisfiedBy :RearAeroZone_DesignSpec .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "height above ground <= 1.2 m" ;
    qudt:maxInclusive 1.2e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :RearAeroZone_HeightAboveGround .

qudtqk:Height a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:RearAeroZone_HeightAboveGround a bfo:BFO_0000019 ;
    rdfs:label "height above the ground of Rear Aerodynamic Zone" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

