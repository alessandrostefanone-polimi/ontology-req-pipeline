@prefix : <http://example.org/req/419#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The intent is that in a short circuit the APPSs will only agree at 0\\% Pedal Travel T.4.2.4 Implausibility is defined as a deviation of more than 10\\% Pedal Travel between the sensors or other failure as defined in this Section T.4.2" ;
    iof:requirementSatisfiedBy :Plan_0 .

:APPSs_0 a bfo:BFO_0000040 ;
    rdfs:label "APPSs (accelerator pedal position sensors system)"@en .

:Deviation_Quality_0 a bfo:BFO_0000019 ;
    rdfs:label "deviation between the sensors (Pedal Travel)"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c3 ;
    iof:qualityOf :SensorSet_0 .

:ImplausibilityProcess_0 a iof:PlannedProcess ;
    rdfs:label "implausibility condition process (deviation between sensors)"@en .

:PedalTravel_Quality_0 a bfo:BFO_0000019 ;
    rdfs:label "Pedal Travel"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :APPSs_0 .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :ImplausibilityProcess_0,
        :ShortCircuitProcess_0 .

:SensorSet_0 a bfo:BFO_0000040 ;
    rdfs:label "set of sensors for pedal travel measurement"@en .

:ShortCircuitProcess_0 a iof:PlannedProcess ;
    rdfs:label "short circuit process (context for APPS agreement requirement)"@en .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression for 0% Pedal Travel (APPSs agreement point)"@en ;
    qudt:maxInclusive 0e+00 ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:PERCENT ;
    iof:isValueExpressionOfAtSomeTime :PedalTravel_Quality_0 .

:VE_req0_c3 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression for deviation between sensors > 10% Pedal Travel"@en ;
    qudt:minExclusive 1e+01 ;
    qudt:unit qudtu:PERCENT ;
    iof:isValueExpressionOfAtSomeTime :Deviation_Quality_0 .

qudtqk:DimensionlessRatio a qudt:QuantityKind .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DimensionlessRatio .

