<http://example.org/req/206#> a owl:Ontology .

<http://example.org/req/206#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "vertical separation > 0.1 m (req 0, constraint 0)",
        "vertical separation > 0.1 m (req 0, constraint 0)"@en ;
    ns1:minExclusive 1e-01 ;
    ns1:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/206#VerticalSeparation_Req0> .

<http://example.org/req/206#VE_req1_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "vertical offset > 0.1 m (req 1, constraint 0)",
        "vertical offset > 0.1 m (req 1, constraint 0)"@en ;
    ns1:minExclusive 1e-01 ;
    ns1:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/206#VerticalOffset_Req1> .

<http://example.org/req/206#DS_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/206#AdditionalMember>,
        <http://example.org/req/206#MainHoop>,
        <http://example.org/req/206#TriangulatedBracing>,
        <http://example.org/req/206#UpperSideImpactMember>,
        <http://example.org/req/206#UpperSupportMember> ;
    ns2:satisfiesRequirement <http://example.org/req/206#Req_0> .

<http://example.org/req/206#LoadTransferProcess_AdditionalMember> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "load transfer to Main Hoop via additional member from junction of Upper Support Member with Front Hoop",
        "load transfer to Main Hoop via additional member from junction of Upper Support Member with Front Hoop"@en ;
    ns2:hasInput <http://example.org/req/206#AdditionalMember>,
        <http://example.org/req/206#TriangulatedBracing> ;
    ns2:hasSpecifiedOutput <http://example.org/req/206#MainHoop> ;
    ns2:prescribedBy <http://example.org/req/206#PS_0> .

<http://example.org/req/206#LoadTransferProcess_UpperSideImpact> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "load transfer to Main Hoop via Upper Side Impact member",
        "load transfer to Main Hoop via Upper Side Impact member"@en ;
    ns2:hasInput <http://example.org/req/206#TriangulatedBracing>,
        <http://example.org/req/206#UpperSideImpactMember> ;
    ns2:hasSpecifiedOutput <http://example.org/req/206#MainHoop> ;
    ns2:prescribedBy <http://example.org/req/206#PS_0> .

<http://example.org/req/206#VerticalOffset_Req1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "vertical offset between upper support member and Upper Side Impact member (req 1)",
        "vertical offset between upper support member and Upper Side Impact member (req 1)"@en ;
    ns2:qualityOf <http://example.org/req/206#UpperSupportMember> .

<http://example.org/req/206#VerticalSeparation_Req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "vertical separation between upper support member and Upper Side Impact member (req 0)",
        "vertical separation between upper support member and Upper Side Impact member (req 0)"@en ;
