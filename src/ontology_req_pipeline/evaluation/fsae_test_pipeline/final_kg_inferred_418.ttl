@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/418#> a owl:Ontology .

<http://example.org/req/418#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 0e+00 ;
    ns2:minInclusive 0e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/PERCENT> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/418#OpenCircuitInputEffect_0> .

<http://example.org/req/418#CircuitAction_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasInput <http://example.org/req/418#OpenCircuitInput_0> .

<http://example.org/req/418#Circuit_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/418#DesignSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/418#Circuit_0>,
        <http://example.org/req/418#PedalSensor_0>,
        <http://example.org/req/418#Resistor_0> ;
    ns1:satisfiesRequirement <http://example.org/req/418#Req_0> .

<http://example.org/req/418#OpenCircuitInputEffect_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    ns1:processCharacteristicOf <http://example.org/req/418#CircuitAction_0> .

<http://example.org/req/418#OpenCircuitInput_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/418#PedalSensor_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact .

<http://example.org/req/418#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The circuit must have a pull-up or pull-down resistor to bring an open circuit input to $0 \\%$ Pedal Travel - An OEM pedal sensor with opposite slopes" ;
    ns1:requirementSatisfiedBy <http://example.org/req/418#DesignSpec_0> .

<http://example.org/req/418#Resistor_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact .

<http://qudt.org/vocab/unit/PERCENT> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/OpeningRatio> .

