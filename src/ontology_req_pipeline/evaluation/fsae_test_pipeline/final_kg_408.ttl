@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/408#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:EV_7_2_2 a iof:InformationContentEntity ;
    rdfs:label "EV.7.2.2 reference" .

:IC_9_2_2 a iof:InformationContentEntity ;
    rdfs:label "IC.9.2.2 reference" .

:T_3_3_4 a iof:InformationContentEntity ;
    rdfs:label "T.3.3.4 reference" .

:T_3_3_5 a iof:InformationContentEntity ;
    rdfs:label "T.3.3.5 reference" .

:BOTS_1 a bfo:BFO_0000040 ;
    rdfs:label "BOTS" .

:BOTS_OFF_Triggers_Open_1 a iof:ProcessCharacteristic ;
    rdfs:label "BOTS OFF operation causes shutdown circuit to be open" ;
    iof:processCharacteristicOf :BOTS_OFF_Operation_1 .

:DS_Req0 a iof:DesignSpecification ;
    rdfs:label "Design spec for BOTS OFF shutdown behavior" ;
    iof:prescribes :ShutdownCircuit_1 ;
    iof:satisfiesRequirement :Req_0 .

:OS_Req0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: BOTS OFF opens shutdown circuit" ;
    iof:isAchievedByAtSomeTime :BOTS_OFF_Operation_1 ;
    iof:prescribes :ShutdownCircuitState_Open .

:OS_Req1 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: repeated operation does not reset or restore power" ;
    iof:isAchievedByAtSomeTime :RepeatedSwitchOperation_1 ;
    iof:prescribes :NoPowerResetOrRestore_1 .

:PS_Req0 a iof:PlanSpecification ;
    rdfs:label "Plan spec for BOTS OFF operation" ;
    bfo:BFO_0000110 :OS_Req0 ;
    iof:prescribes :BOTS_OFF_Operation_1 .

:PowerSupply_1 a bfo:BFO_0000040 ;
    rdfs:label "Power" .

:Switch_1 a bfo:BFO_0000040 ;
    rdfs:label "Switch" .

:NoPowerResetOrRestore_1 a iof:ProcessCharacteristic ;
    rdfs:label "No reset or restore of power during repeated switch operation" ;
    iof:processCharacteristicOf :RepeatedSwitchOperation_1 .

:PS_Req1 a iof:PlanSpecification ;
    rdfs:label "Plan spec for repeated switch operation behavior" ;
    bfo:BFO_0000110 :OS_Req1 ;
    iof:prescribes :RepeatedSwitchOperation_1 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.3.3 Operation of the BOTS to the OFF position must Open the Shutdown Circuit IC.9.2.2 / EV.7.2.2 T.3.3.4 Repeated operation of the switch must not reset or restore power T.3.3.5" ;
    iof:requirementSatisfiedBy :DS_Req0,
        :PS_Req1 .

:ShutdownCircuitState_Open a bfo:BFO_0000019 ;
    rdfs:label "Open state of Shutdown Circuit when BOTS is OFF" .

:ShutdownCircuit_1 a bfo:BFO_0000040 ;
    rdfs:label "Shutdown Circuit" ;
    iof:hasQuality :ShutdownCircuitState_Open .

:BOTS_OFF_Operation_1 a iof:PlannedProcess ;
    rdfs:label "Operation of the BOTS to the OFF position" ;
    bfo:BFO_0000057 :BOTS_1,
        :ShutdownCircuit_1 ;
    iof:hasProcessCharacteristic :BOTS_OFF_Triggers_Open_1 ;
    iof:prescribedBy :PS_Req0 .

:RepeatedSwitchOperation_1 a iof:PlannedProcess ;
    rdfs:label "Repeated operation of the switch" ;
    bfo:BFO_0000057 :PowerSupply_1,
        :Switch_1 ;
    iof:hasProcessCharacteristic :NoPowerResetOrRestore_1 ;
    iof:prescribedBy :PS_Req1 .

