@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/122#> a owl:Ontology .

<http://example.org/req/122#BareEdgeFeature> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:qualityOf <http://example.org/req/122#PanelEdge> .

<http://example.org/req/122#BottomSurfaceArea> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:qualityOf <http://example.org/req/122#BottomSkin> .

<http://example.org/req/122#SkinMaterialB> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/122#TopSurfaceArea> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:qualityOf <http://example.org/req/122#TopSkin> .

<http://example.org/req/122#BottomSkin> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns3:BFO_0000175 <http://example.org/req/122#TestPanel> .

<http://example.org/req/122#DS_TestPanelDimensions> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/122#TestPanel> ;
    ns1:satisfiesRequirement <http://example.org/req/122#Req_0> .

<http://example.org/req/122#DS_TestPanelEdges> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/122#TestPanel> ;
    ns1:satisfiesRequirement <http://example.org/req/122#Req_0> .

<http://example.org/req/122#DS_TestPanelSurfaceArea> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/122#TestPanel> ;
    ns1:satisfiesRequirement <http://example.org/req/122#Req_0> .

<http://example.org/req/122#DimQuality_Option1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/122#VE_req0_c0> ;
    ns1:qualityOf <http://example.org/req/122#TestPanel> .

<http://example.org/req/122#DimQuality_Option2> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/122#VE_req0_c1> ;
    ns1:qualityOf <http://example.org/req/122#TestPanel> .

<http://example.org/req/122#PS_TestPanelSupport> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/122#SupportProcess> ;
    ns1:satisfiesRequirement <http://example.org/req/122#Req_0> .

<http://example.org/req/122#PanelEdge> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns3:BFO_0000175 <http://example.org/req/122#TestPanel> .

<http://example.org/req/122#TopSkin> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns3:BFO_0000175 <http://example.org/req/122#TestPanel> .

<http://example.org/req/122#VE_req0_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 1.38e+02 ;
    ns2:minInclusive 1.38e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/122#DimQuality_Option1> .

<http://example.org/req/122#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 2.75e+02 ;
    ns2:minInclusive 2.75e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/M2> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/122#DimQuality_Option2> .

<http://example.org/req/122#VE_req1_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 4e+02 ;
    ns2:minInclusive 4e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/122#SpanDistance> .

<http://qudt.org/vocab/unit/M2> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/CartesianArea> .

<http://example.org/req/122#SpanDistance> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/122#VE_req1_c0> ;
    ns1:processCharacteristicOf <http://example.org/req/122#SupportProcess> .

<http://example.org/req/122#SupportProcess> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:hasParticipantAtSomeTime <http://example.org/req/122#TestPanel> ;
    ns1:hasProcessCharacteristic <http://example.org/req/122#SpanDistance> .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length>,
        <http://qudt.org/vocab/quantitykind/MigrationLength> .

<http://example.org/req/122#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Refer to F.4.3.4 a. Test panels must: - Measure one of the two options: $138 \\mathrm{~mm} \\times 500 \\mathrm{~mm}$ OR $275 \\mathrm{~mm} \\times 500 \\mathrm{~mm}$ - Be supported by a span distance of 400 mm - Have equal surface area for the top and bottom skin - Have bare edges, without skin material b" ;
    ns1:requirementSatisfiedBy <http://example.org/req/122#DS_TestPanelDimensions>,
        <http://example.org/req/122#DS_TestPanelEdges>,
        <http://example.org/req/122#DS_TestPanelSurfaceArea>,
        <http://example.org/req/122#PS_TestPanelSupport> .

<http://example.org/req/122#TestPanel> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact .

