@prefix : <http://example.org/req/206#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "vertical separation > 0.1 m (req 0, constraint 0)"@en ;
    qudt:minExclusive 1e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :VerticalSeparation_Req0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "vertical offset > 0.1 m (req 1, constraint 0)"@en ;
    qudt:minExclusive 1e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :VerticalOffset_Req1 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :AdditionalMember,
        :MainHoop,
        :TriangulatedBracing,
        :UpperSideImpactMember,
        :UpperSupportMember ;
    iof:satisfiesRequirement :Req_0 .

:LoadTransferProcess_AdditionalMember a iof:PlannedProcess ;
    rdfs:label "load transfer to Main Hoop via additional member from junction of Upper Support Member with Front Hoop"@en ;
    iof:hasInput :AdditionalMember,
        :TriangulatedBracing ;
    iof:hasSpecifiedOutput :MainHoop ;
    iof:prescribedBy :PS_0 .

:LoadTransferProcess_UpperSideImpact a iof:PlannedProcess ;
    rdfs:label "load transfer to Main Hoop via Upper Side Impact member"@en ;
    iof:hasInput :TriangulatedBracing,
        :UpperSideImpactMember ;
    iof:hasSpecifiedOutput :MainHoop ;
    iof:prescribedBy :PS_0 .

:VerticalOffset_Req1 a bfo:BFO_0000019 ;
    rdfs:label "vertical offset between upper support member and Upper Side Impact member (req 1)"@en ;
    iof:qualityOf :UpperSupportMember .

:VerticalSeparation_Req0 a bfo:BFO_0000019 ;
    rdfs:label "vertical separation between upper support member and Upper Side Impact member (req 0)"@en ;
    iof:qualityOf :UpperSupportMember .

qudtqk:Height a qudt:QuantityKind .

:AdditionalMember a bfo:BFO_0000040 ;
    rdfs:label "additional member transmitting load from the junction of the Upper Support Member with the Front Hoop"@en .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If the upper support member is further than 100 mm above the Upper Side Impact member, then properly Triangulated bracing is required to transfer load to the Main Hoop by one of: - the Upper Side Impact member - an additional member transmitting load from the junction of the Upper Support Member with the Front Hoop c" ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_0 .

:UpperSideImpactMember a bfo:BFO_0000040 ;
    rdfs:label "Upper Side Impact member"@en .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:MainHoop a bfo:BFO_0000040 ;
    rdfs:label "Main Hoop"@en .

:PS_0 a iof:PlanSpecification ;
    iof:prescribes :LoadTransferProcess_AdditionalMember,
        :LoadTransferProcess_UpperSideImpact ;
    iof:satisfiesRequirement :Req_0 .

:TriangulatedBracing a bfo:BFO_0000040 ;
    rdfs:label "properly Triangulated bracing"@en .

:UpperSupportMember a bfo:BFO_0000040 ;
    rdfs:label "upper support member"@en .

