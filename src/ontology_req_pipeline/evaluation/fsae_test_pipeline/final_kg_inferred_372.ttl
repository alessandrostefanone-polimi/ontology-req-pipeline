<http://example.org/req/372#> a owl:Ontology .

<http://example.org/req/372#BracketFastenedState_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialState ;
    ns3:BFO_0000057 <http://example.org/req/372#Bracket_0>,
        <http://example.org/req/372#Chassis_0> ;
    ns3:BFO_0000117 <http://example.org/req/372#FasteningProcess_0> .

<http://example.org/req/372#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "Attachment of tabs or brackets must meet the following: a. Where brackets are fastened to the chassis, no less than two 6 mm or $1 / 4^{\\prime \\prime}$ minimum diameter Critical Fasteners, see T.8.2 or stronger must be used to attach the bracket to the chassis" ;
    ns2:requirementSatisfiedBy <http://example.org/req/372#PlanSpec_0> .

<http://example.org/req/372#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:minInclusive 2e+00 ;
    ns1:unit <http://qudt.org/vocab/unit/NUM-PER-M3> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/372#FastenerCount_Quality_0> .

<http://example.org/req/372#VE_req0_c2> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:minInclusive 6e-03 ;
    ns1:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/372#FastenerDiameter_Quality_0> .

<http://example.org/req/372#AttachBracketProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns2:hasInput <http://example.org/req/372#Bracket_0>,
        <http://example.org/req/372#Chassis_0> ;
    ns2:hasSpecifiedOutput <http://example.org/req/372#BracketChassisAssembly_0> .

<http://example.org/req/372#BracketChassisAssembly_0> a ns3:BFO_0000001,
