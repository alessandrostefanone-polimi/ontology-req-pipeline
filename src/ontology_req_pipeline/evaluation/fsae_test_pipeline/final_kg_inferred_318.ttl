@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/318#> a owl:Ontology .

<http://example.org/req/318#DS_AccumulatorAttachmentConfig> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Design spec: accumulator container corner attachment configuration",
        "Design spec: accumulator container corner attachment configuration"@en ;
    ns1:prescribes <http://example.org/req/318#AttachmentConfiguration> ;
    ns1:satisfiesRequirement <http://example.org/req/318#Req_0> .

<http://example.org/req/318#ObjSpec_AttachmentConfig> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: accumulator container corner attachment configuration",
        "Objective: accumulator container corner attachment configuration"@en ;
    ns1:prescribes <http://example.org/req/318#AttachmentConfiguration> .

<http://example.org/req/318#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Alternate materials Equivalent to 2 mm thickness steel F.10.5.5 Teams must justify the Accumulator Container attachment using one of the two methods: - Corner Attachments and Analysis per F.10.5.6 and F.10.5.8 - Load Based Analysis per F.10.5.7 and F.10.5.8 F.10.5.6 Accumulator Attachment - Corner Attachments a. Eight or more attachments are required for any configuration" ;
    ns1:isAbout <http://example.org/req/318#ObjSpec_AttachmentConfig> ;
    ns1:requirementSatisfiedBy <http://example.org/req/318#DS_AccumulatorAttachmentConfig> .

<http://example.org/req/318#VE_req3_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Value expression: attachments count >= 8",
        "Value expression: attachments count >= 8"@en ;
    ns2:minInclusive 8e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/COUNT> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/318#AttachmentsCountQuality> .

<http://qudt.org/vocab/unit/COUNT> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Dimensionless> .

<http://example.org/req/318#AttachmentConfiguration> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Accumulator container corner attachment configuration",
        "Accumulator container corner attachment configuration"@en ;
    ns1:hasQuality <http://example.org/req/318#AttachmentsCountQuality> ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/318#VE_req3_c0> .

<http://example.org/req/318#AttachmentsCountQuality> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Number of attachments in configuration",
        "Number of attachments in configuration"@en .

