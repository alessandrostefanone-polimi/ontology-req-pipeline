@prefix : <http://example.org/req/576#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:FillerNeck_1 a bfo:BFO_0000040 ;
    iof:hasComponentPartAtSomeTime :FuelCap_1 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :GasCan_0 ;
    iof:satisfiesRequirement :Req_0 .

:FuelCap_1 a bfo:BFO_0000040 ;
    iof:hasQuality :FuelCap_1_PressureResistance,
        :FuelCap_1_VibrationResistance .

:FuelCap_1_PressureResistance a bfo:BFO_0000019 .

:FuelCap_1_VibrationResistance a bfo:BFO_0000019 .

:FuelCrew_2 a iof:GroupOfAgents .

:FuelingPolicyProcess_2 a iof:PlannedProcess ;
    bfo:BFO_0000057 :FuelCrew_2,
        :Officials_2 .

:GasCan_0 a bfo:BFO_0000040 ;
    iof:hasComponentPartAtSomeTime :Spout_0 ;
    iof:hasQuality :GasCan_0_Depth,
        :GasCan_0_Height,
        :GasCan_0_Width .

:ObjSpec_0 a iof:ObjectiveSpecification .

:Officials_2 a iof:GroupOfAgents .

:PS_1 a iof:PlanSpecification ;
    iof:prescribes :RolloverEvent_1 ;
    iof:satisfiesRequirement :Req_0 .

:PS_2 a iof:PlanSpecification ;
    iof:prescribes :FuelingPolicyProcess_2 ;
    iof:satisfiesRequirement :Req_0 .

:RolloverEvent_1 a iof:Event .

:Spout_0 a bfo:BFO_0000040 ;
    iof:hasQuality :Spout_0_Length .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.5e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :GasCan_0_Width .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.5e-01 ;
    qudt:minInclusive 2.5e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :GasCan_0_Depth .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3.5e-01 ;
    qudt:minInclusive 3.5e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :GasCan_0_Height .

:VE_req0_c4 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.5e-01 ;
    qudt:minInclusive 2.5e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Spout_0_Length .

qudtqk:Depth a qudt:QuantityKind .

qudtqk:Height a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

qudtqk:Width a qudt:QuantityKind .

:GasCan_0_Depth a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:GasCan_0_Height a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 .

:GasCan_0_Width a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:Spout_0_Length a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c4 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The gas can is minimum 25 cm wide $\\times 25 \\mathrm{~cm}$ deep $\\times 35 \\mathrm{~cm}$ high, with a 25 cm spout at the top IC.5.4.8 The filler neck must have a fuel cap that can withstand severe vibrations or high pressures such as could occur during a vehicle rollover event # IC.5.5 Fuel Tank Filling IC.5.5.1 Fueling / Refueling policies and procedures are at the discretion of the fuel crew and officials" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1,
        :PS_2 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Depth,
        qudtqk:Height,
        qudtqk:Length,
        qudtqk:Width .

