@prefix : <http://example.org/req/625#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:PlanSpecification ;
    iof:prescribes :APPS_0,
        :BSE_0,
        :BrakeMonitoringProcess_0,
        :BrakePedalPlausibilityProcess_0,
        :BrakeSystemProcess_0,
        :MotorPowerSystem_0 ;
    iof:satisfiesRequirement :Req_0 .

:EV_4_5 a iof:InformationContentEntity .

:EV_4_6 a iof:InformationContentEntity .

:EV_4_7_1 a iof:InformationContentEntity .

:EV_4_7_1_Ref a iof:InformationContentEntity .

:EV_4_7_2 a iof:InformationContentEntity .

:MechanicalBrakes_0 a iof:MaterialArtifact .

:Req_0_1 a iof:RequirementSpecification ;
    iof:isAbout :ObjSpec_Monitoring_0 ;
    iof:requirementSatisfiedBy :Plan_BrakePedalPlausibility_0 .

:Req_0_2 a iof:RequirementSpecification ;
    iof:isAbout :ObjSpec_BrakeEngaged_0 ;
    iof:requirementSatisfiedBy :Plan_BrakePedalPlausibility_0 .

:Req_0_3 a iof:RequirementSpecification ;
    iof:isAbout :ObjSpec_PedalTravel_0 ;
    iof:requirementSatisfiedBy :Plan_BrakePedalPlausibility_0 .

:Req_0_4 a iof:RequirementSpecification ;
    iof:isAbout :ObjSpec_PowerShutdown_0 ;
    iof:requirementSatisfiedBy :Plan_BrakePedalPlausibility_0 .

:T_3_2_4 a iof:InformationContentEntity .

:T_4_3 a iof:InformationContentEntity .

:VE_req3_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 2.5e+01 ;
    qudt:quantityKind qudtqk:PositiveDimensionlessRatio ;
    qudt:unit qudtu:PERCENT ;
    iof:isValueExpressionOfAtSomeTime :PedalTravel_0 .

:ActionSpec_Monitoring_0 a iof:ActionSpecification ;
    iof:prescribes :BrakeMonitoringProcess_0 .

:BrakeEngagedState_0 a iof:MaterialState ;
    iof:hasProcessCharacteristic :BrakeEngagedCharacteristic_0 .

:DS_BSE_0 a iof:DesignSpecification ;
    iof:prescribes :BSE_0 ;
    iof:satisfiesRequirement :Req_0_0 .

:ObjSpec_BSE_0 a iof:ObjectiveSpecification ;
    iof:prescribes :BSE_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "4.6 Brake System Encoder - BSE Refer to T.4.3 for specific requirements of the BSE ## EV.4.7 APPS / Brake Pedal Plausibility Check EV.4.7.1 Must monitor for the two conditions: - The mechanical brakes are engaged EV.4.6, T.3.2.4 - The APPS signals more than 25% Pedal Travel EV.4.5 EV.4.7.2 If the two conditions in EV.4.7.1 occur at the same time: a. Power to the Motor(s) must be immediately and completely shut down b" ;
    iof:requirementSatisfiedBy :Plan_BrakePedalPlausibility_0 .

:Req_0_0 a iof:RequirementSpecification ;
    iof:isAbout :ObjSpec_BSE_0 ;
    iof:requirementSatisfiedBy :DS_BSE_0 .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:PositiveDimensionlessRatio .

:BrakeEngagedCharacteristic_0 a iof:ProcessCharacteristic .

:BrakePedalPlausibilityProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :APPS_0,
        :BrakeSystemProcess_0,
        :MotorPowerSystem_0 ;
    iof:prescribedBy :Plan_BrakePedalPlausibility_0 .

:MotorPowerState_0 a bfo:BFO_0000019 .

:MotorPowerSystem_0 a iof:MaterialArtifact ;
    iof:hasQuality :MotorPowerState_0 .

:ObjSpec_BrakeEngaged_0 a iof:ObjectiveSpecification ;
    iof:prescribes :BrakeEngagedState_0 .

:ObjSpec_Monitoring_0 a iof:ObjectiveSpecification ;
    iof:prescribes :BrakeMonitoringProcess_0 .

:ObjSpec_PedalTravel_0 a iof:ObjectiveSpecification ;
    iof:prescribes :PedalTravel_0 .

:ObjSpec_PowerShutdown_0 a iof:ObjectiveSpecification ;
    iof:prescribes :MotorPowerState_0 .

qudtqk:PositiveDimensionlessRatio a qudt:QuantityKind .

:APPS_0 a iof:MaterialArtifact ;
    iof:hasQuality :PedalTravel_0 .

:BSE_0 a iof:MaterialArtifact .

:BrakeMonitoringProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :APPS_0,
        :BrakeSystemProcess_0 ;
    iof:prescribedBy :Plan_BrakePedalPlausibility_0 .

:BrakeSystemProcess_0 a iof:PlannedProcess ;
    iof:hasProcessCharacteristic :BrakeEngagedCharacteristic_0 .

:PedalTravel_0 a bfo:BFO_0000019 .

:Plan_BrakePedalPlausibility_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ActionSpec_Monitoring_0,
        :ObjSpec_BrakeEngaged_0,
        :ObjSpec_Monitoring_0,
        :ObjSpec_PedalTravel_0,
        :ObjSpec_PowerShutdown_0 ;
    iof:prescribes :BrakePedalPlausibilityProcess_0 .

