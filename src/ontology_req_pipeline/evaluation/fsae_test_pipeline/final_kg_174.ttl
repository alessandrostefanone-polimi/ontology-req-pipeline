@prefix : <http://example.org/req/174#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:FrontHoop_Hole_Diameter_QK a iof:InformationContentEntity ;
    rdfs:label "Diameter quantity kind for Front Hoop hole"@en ;
    iof:describes :VE_req0_c2 ;
    iof:isAbout :FrontHoop_Hole_0 .

:FrontHoop_0 a bfo:BFO_0000040 ;
    rdfs:label "Front Hoop"@en ;
    iof:hasComponentPartAtSomeTime :FrontHoop_Hole_0 .

:FrontHoop_DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :FrontHoop_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "5.7.7 A Front Hoop that is not steel must have a 4 mm hole drilled in a location to access during Technical Inspection" ;
    iof:requirementSatisfiedBy :FrontHoop_DesignSpec_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Front Hoop hole diameter = 4 mm"@en ;
    qudt:maxInclusive 4e-03 ;
    qudt:minInclusive 4e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :FrontHoop_Hole_0 .

:FrontHoop_Hole_0 a bfo:BFO_0000040 ;
    rdfs:label "Front Hoop drilled hole"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c2 .

