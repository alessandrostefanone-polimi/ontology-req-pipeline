@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/944#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The Endurance event will consist of multiple laps over a closed course to a total distance of approximately 22 km" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:EnduranceEvent_0 a iof:PlannedProcess ;
    rdfs:label "Endurance event (requirement 0)" ;
    iof:hasProcessCharacteristic :Laps_0,
        :TotalDistance_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :EnduranceEvent_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "minimum number of laps (>= 2)" ;
    qudt:minInclusive 2e+00 ;
    qudt:unit qudtu:COUNT ;
    iof:isValueExpressionOfAtSomeTime :Laps_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "total distance (exactly 35405.568 m)" ;
    qudt:maxInclusive 3.540557e+04 ;
    qudt:minInclusive 3.540557e+04 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :TotalDistance_0 .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtqk:Distance a qudt:QuantityKind .

qudtu:COUNT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Distance .

:Laps_0 a iof:ProcessCharacteristic ;
    rdfs:label "number of laps in Endurance event" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:TotalDistance_0 a iof:ProcessCharacteristic ;
    rdfs:label "total distance of Endurance event" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 .

