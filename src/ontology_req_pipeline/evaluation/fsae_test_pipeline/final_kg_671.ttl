@prefix : <http://example.org/req/671#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "6.1.2 Contact with any Tractive System connections with a 100 mm long, 6 mm diameter insulated test probe must not be possible when the Tractive System enclosures are in place" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:ContactPossible_0 a iof:ProcessCharacteristic ;
    rdfs:label "Contact between test probe and Tractive System connections is possible"@en .

:EnclosuresInPlace_0 a iof:ProcessCharacteristic ;
    rdfs:label "Tractive System enclosures are in place"@en .

:NoContactProcess_0 a iof:PlannedProcess ;
    rdfs:label "Process in which contact with Tractive System connections is not possible using the specified test probe when enclosures are in place"@en ;
    iof:hasInput :TestProbe_0,
        :TractiveSystemConnections_0,
        :TractiveSystemEnclosures_0 ;
    iof:hasProcessCharacteristic :ContactPossible_0,
        :EnclosuresInPlace_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :NoContactProcess_0 .

:ProbeDiameter_0 a bfo:BFO_0000019 ;
    rdfs:label "test probe diameter"@en .

:TestProbe_0 a bfo:BFO_0000040 ;
    rdfs:label "insulated test probe"@en ;
    iof:hasQuality :ProbeDiameter_0,
        :ProbeLength_0 .

:TractiveSystemConnections_0 a bfo:BFO_0000040 ;
    rdfs:label "Tractive System connections"@en .

:TractiveSystemEnclosures_0 a bfo:BFO_0000040 ;
    rdfs:label "Tractive System enclosures"@en .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1e-01 ;
    qudt:minInclusive 1e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :ProbeLength_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:ProbeLength_0 a bfo:BFO_0000019 ;
    rdfs:label "test probe length"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

