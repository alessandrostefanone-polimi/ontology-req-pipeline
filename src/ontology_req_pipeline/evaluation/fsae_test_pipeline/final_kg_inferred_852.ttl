@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/852#> a owl:Ontology .

<http://example.org/req/852#Proc_SubmissionOfCostReport> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Submission of the Cost Report" .

<http://example.org/req/852#DR_DocumentRequirements> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "DR Document Requirements section" .

<http://example.org/req/852#DS_LateSubmissionPenalties> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Late Submission Penalties for Late Submission of Cost Report" ;
    ns1:isAbout <http://example.org/req/852#Obj_LateSubmissionPenaltyPolicy> ;
    ns1:prescribedBy <http://example.org/req/852#DR_DocumentRequirements> ;
    ns1:prescribes <http://example.org/req/852#Penalty_LateSubmission> ;
    ns1:satisfiesRequirement <http://example.org/req/852#Req_0> .

<http://example.org/req/852#Obj_CostReportSupplementSubmission> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective for allowing submission of Cost Report supplement" ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/852#Proc_SubmitCostReportSupplement> ;
    ns1:prescribes <http://example.org/req/852#CostReportSupplement> .

<http://example.org/req/852#Obj_LateSubmissionPenaltyPolicy> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective for late submission penalty policy" ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/852#Proc_ImposeLateSubmissionPenalty> ;
    ns1:prescribes <http://example.org/req/852#Penalty_LateSubmission> .

<http://example.org/req/852#Proc_ImposeLateSubmissionPenalty> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Process of imposing late submission penalties" .

<http://example.org/req/852#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Late Submission Penalties for Late Submission of Cost Report will be imposed as given in section DR Document Requirements. ### 5.3.7 Cost Addendum 5.3.7.1 A supplement to the Cost Report that reflects any changes or corrections made after the submission of the Cost Report may be submitted" ;
    ns1:requirementSatisfiedBy <http://example.org/req/852#DS_LateSubmissionPenalties>,
        <http://example.org/req/852#PS_CostReportSupplementSubmission> .

<http://example.org/req/852#CostReport> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "Cost Report" .

<http://example.org/req/852#CostReportSupplement> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "Supplement to the Cost Report" ;
    ns1:isAbout <http://example.org/req/852#CostReport> .

<http://example.org/req/852#PS_CostReportSupplementSubmission> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan for submission of Cost Report supplement" ;
    ns1:isAbout <http://example.org/req/852#Obj_CostReportSupplementSubmission> ;
    ns1:prescribes <http://example.org/req/852#Proc_SubmitCostReportSupplement> .

<http://example.org/req/852#Penalty_LateSubmission> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Late submission penalty for Cost Report" .

<http://example.org/req/852#Proc_SubmitCostReportSupplement> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Submission of Cost Report supplement" ;
    ns1:hasInput <http://example.org/req/852#CostReport> ;
    ns1:hasSpecifiedOutput <http://example.org/req/852#CostReportSupplement> ;
    ns1:prescribedBy <http://example.org/req/852#PS_CostReportSupplementSubmission> .

