@prefix : <http://example.org/req/276#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 2.5e-02 ;
    qudt:unit qudtu:M .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :WeldLengthQuality_0 ;
    iof:satisfiesRequirement :Req_0 .

:FastenerDiameter_1 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c2 ;
    iof:qualityOf :CriticalFastener_1 .

:ImpactAttenuator_1 a bfo:BFO_0000040 .

:NumCriticalFasteners_1 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 ;
    iof:processCharacteristicOf :BoltedAttachmentProcess_1 .

:PS_1 a iof:PlanSpecification ;
    iof:prescribes :BoltedAttachmentProcess_1 ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c0_lowerBound a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:numericValue 2.5e-02 ;
    qudt:quantityKind qudtqk:Length ;
    qudt:unit qudtu:M .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 8e+00 ;
    qudt:quantityKind qudtqk:Dimensionless ;
    qudt:unit qudtu:COUNT .

:VE_req1_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 8e-03 ;
    qudt:quantityKind qudtqk:Diameter ;
    qudt:unit qudtu:M .

:WeldLengthQuality_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0_lowerBound ;
    iof:qualityOf :WeldedJoint_0 .

:WeldedJoint_0 a bfo:BFO_0000040 .

qudtu:COUNT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

:BoltedAttachmentProcess_1 a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :CriticalFastener_1,
        :ImpactAttenuator_1 ;
    iof:hasProcessCharacteristic :FastenerDiameter_1,
        :NumCriticalFasteners_1 .

:CriticalFastener_1 a bfo:BFO_0000040 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "All weld lengths must be more than 25 mm. If the Impact Attenuator is attached by bolting: it must have no less than eight 8 mm minimum diameter Critical Fasteners. Source: F.8.5.5, T.8.2." ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1 .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter,
        qudtqk:Length .

