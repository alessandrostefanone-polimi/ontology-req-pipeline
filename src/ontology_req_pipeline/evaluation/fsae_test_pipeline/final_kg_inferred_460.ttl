@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/460#> a owl:Ontology .

<http://example.org/req/460#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The shields must be steel or aluminum with a minimum thickness of 1 mm" ;
    ns1:requirementSatisfiedBy <http://example.org/req/460#ShieldDesign_0> .

<http://example.org/req/460#ShieldDesign_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/460#Shield_0> ;
    ns1:satisfiesRequirement <http://example.org/req/460#Req_0> .

<http://example.org/req/460#ShieldMaterial_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:comment "Material of the shield constrained to be steel or aluminum (enum constraint: steel OR aluminum)." ;
    ns1:qualityOf <http://example.org/req/460#Shield_0> .

<http://example.org/req/460#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 1e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/460#ShieldThickness_0> .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Thickness> .

<http://example.org/req/460#ShieldThickness_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/460#VE_req0_c1> ;
    ns1:qualityOf <http://example.org/req/460#Shield_0> .

<http://example.org/req/460#Shield_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasQuality <http://example.org/req/460#ShieldMaterial_0>,
        <http://example.org/req/460#ShieldThickness_0> .

