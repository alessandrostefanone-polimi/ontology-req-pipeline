@prefix : <http://example.org/req/394#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Cap_WithstandLateralVerticalForce a iof:Capability ;
    rdfs:label "Capability to withstand lateral or vertical force" ;
    bfo:BFO_0000054 :Proc_WithstandLateralVerticalForce ;
    iof:capabilityOf :HeadRestraintAssembly .

:Cap_WithstandRearwardForce a iof:Capability ;
    rdfs:label "Capability to withstand rearward force" ;
    bfo:BFO_0000054 :Proc_WithstandRearwardForce ;
    iof:capabilityOf :HeadRestraintAssembly .

:DS_HeadRestraintStrength a iof:DesignSpecification ;
    iof:prescribes :HeadRestraintAssembly ;
    iof:satisfiesRequirement :Req_0 .

:PS_WithstandLateralVerticalForce a iof:PlanSpecification ;
    rdfs:label "Plan for lateral/vertical head restraint load case" ;
    iof:prescribes :Proc_WithstandLateralVerticalForce .

:PS_WithstandRearwardForce a iof:PlanSpecification ;
    rdfs:label "Plan for rearward head restraint load case" ;
    iof:prescribes :Proc_WithstandRearwardForce .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Head Restraint Protection (if used) F.5.10 T.2.8.4 The Head Restraint, attachment and mounting must be strong enough to withstand a minimum force of: a. 900 N applied in a rearward direction b. 300 N applied in a lateral or vertical direction T.2.8.5 For all drivers, the Head Restraint must be located and adjusted where: a" ;
    iof:requirementSatisfiedBy :DS_HeadRestraintStrength .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Minimum rearward force ≥ 900 N" ;
    qudt:minInclusive 9e+02 ;
    qudt:unit qudtu:N ;
    iof:isValueExpressionOfAtSomeTime :PC_Req0_Force .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Minimum lateral/vertical force ≥ 300 N" ;
    qudt:minInclusive 3e+02 ;
    qudt:unit qudtu:N ;
    iof:isValueExpressionOfAtSomeTime :PC_Req1_Force .

qudtqk:Force a qudt:QuantityKind .

:PC_Req0_Force a iof:ProcessCharacteristic ;
    rdfs:label "Applied rearward force for requirement 0" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:processCharacteristicOf :Proc_WithstandRearwardForce .

:PC_Req1_Force a iof:ProcessCharacteristic ;
    rdfs:label "Applied lateral/vertical force for requirement 1" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 ;
    iof:processCharacteristicOf :Proc_WithstandLateralVerticalForce .

qudtu:N a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Force .

:Proc_WithstandLateralVerticalForce a iof:PlannedProcess ;
    rdfs:label "Head restraint lateral/vertical load case process" ;
    iof:hasParticipantAtSomeTime :HeadRestraintAssembly ;
    iof:hasProcessCharacteristic :PC_Req1_Force ;
    iof:prescribedBy :PS_WithstandLateralVerticalForce .

:Proc_WithstandRearwardForce a iof:PlannedProcess ;
    rdfs:label "Head restraint rearward load case process" ;
    iof:hasParticipantAtSomeTime :HeadRestraintAssembly ;
    iof:hasProcessCharacteristic :PC_Req0_Force ;
    iof:prescribedBy :PS_WithstandRearwardForce .

:HeadRestraintAssembly a iof:MaterialArtifact ;
    rdfs:label "Head Restraint, attachment and mounting" ;
    iof:hasCapability :Cap_WithstandLateralVerticalForce,
        :Cap_WithstandRearwardForce .

