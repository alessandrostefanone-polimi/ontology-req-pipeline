@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/550#> a owl:Ontology .

<http://example.org/req/550#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "The power to the electronic throttle must be immediately shut down, if throttle position differs by more than $10 \\%$ from the expected target TPS position for more than one second" ;
    ns2:requirementSatisfiedBy <http://example.org/req/550#PlanSpec_0> .

<http://example.org/req/550#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "difference between throttle position and expected target TPS position > 10 percent" ;
    ns1:minExclusive 1e+01 ;
    ns1:unit <http://qudt.org/vocab/unit/PERCENT> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/550#ThrottlePositionDifference_0> .

<http://example.org/req/550#VE_req0_c2> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "duration of difference condition > 1 second" ;
    ns1:minExclusive 1e+00 ;
    ns1:unit <http://qudt.org/vocab/unit/SEC> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/550#DifferenceDuration_0> .

<http://example.org/req/550#ElectronicThrottle_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000027,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:EngineeredSystem,
        ns2:System ;
    rdfs:label "electronic throttle" .

<http://example.org/req/550#ShutdownProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "Shutdown of power to the electronic throttle" ;
    ns3:BFO_0000057 <http://example.org/req/550#ElectronicThrottle_0> ;
    ns2:prescribedBy <http://example.org/req/550#PlanSpec_0> .

<http://qudt.org/vocab/unit/PERCENT> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/DimensionlessRatio> .

<http://qudt.org/vocab/unit/SEC> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Time> .

<http://example.org/req/550#DifferenceConditionProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "process where throttle position differs from expected target TPS position" ;
    ns2:hasProcessCharacteristic <http://example.org/req/550#DifferenceDuration_0>,
        <http://example.org/req/550#ThrottlePositionDifference_0> ;
    ns2:prescribedBy <http://example.org/req/550#PlanSpec_0> .

<http://example.org/req/550#DifferenceDuration_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "duration of difference condition" ;
    ns2:processCharacteristicOf <http://example.org/req/550#DifferenceConditionProcess_0> .

<http://example.org/req/550#ThrottlePositionDifference_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "difference between throttle position and expected target TPS position" ;
    ns2:processCharacteristicOf <http://example.org/req/550#DifferenceConditionProcess_0> .

<http://example.org/req/550#PlanSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/550#ShutdownProcess_0> .

