@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/443#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:ActSpec_0 a iof:ActionSpecification ;
    iof:prescribes :ScatterShieldInclusionProcess_0 .

:MotorConditionProcess_0 a bfo:BFO_0000015 ;
    rdfs:comment "when one or both: - The motor casing rotates around the stator - The motor case is perforated" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Minimum thickness for steel: 2.0 mm T.5.3.2 A Scatter Shield must be included around the Motor(s) when one or both: - The motor casing rotates around the stator - The motor case is perforated T.5.3.3" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:Motor_0 a bfo:BFO_0000040 ;
    iof:isInputOf :ScatterShieldInclusionProcess_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :ScatterShieldInclusionProcess_0 ;
    iof:prescribes :ScatterShield_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ActSpec_0,
        :ObjSpec_0 ;
    iof:prescribes :ScatterShieldInclusionProcess_0 .

:ScatterShield_0 a bfo:BFO_0000040 ;
    iof:isOutputOf :ScatterShieldInclusionProcess_0 ;
    iof:satisfiesRequirement :Req_0 .

:ScatterShieldInclusionProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :Motor_0,
        :ScatterShield_0 ;
    iof:hasInput :Motor_0 ;
    iof:hasSpecifiedOutput :ScatterShield_0 ;
    iof:occursDuring :MotorConditionProcess_0 ;
    iof:prescribedBy :PlanSpec_0 .

