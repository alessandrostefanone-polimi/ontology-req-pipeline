@prefix : <http://example.org/req/922#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The foremost part of the vehicle will be staged at 0.30 m behind the starting line b" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :StagingProcess_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3e-01 ;
    qudt:minInclusive 3e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :PosBehindStartLine_0 .

:VehicleForemostPart_0 a bfo:BFO_0000040 .

qudtqk:Displacement a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Displacement .

:PosBehindStartLine_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:processCharacteristicOf :StagingProcess_0 .

:StagingProcess_0 a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :VehicleForemostPart_0 ;
    iof:hasProcessCharacteristic :PosBehindStartLine_0 .

