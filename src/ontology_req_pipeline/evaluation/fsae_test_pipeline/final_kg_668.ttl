@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/668#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:EV a iof:InformationContentEntity ;
    rdfs:label "EV" .

:EV_5_10 a iof:InformationContentEntity ;
    rdfs:label "EV.5.10" .

:EV_7_8 a iof:InformationContentEntity ;
    rdfs:label "EV.7.8" .

:IN_4_7_1 a iof:InformationContentEntity ;
    rdfs:label "IN.4.7.1" .

:Req0_OptionConstraint_0 a iof:InformationContentEntity ;
    rdfs:label "Requirement 0 option constraint 0 (one of the two)" ;
    iof:isSubjectOf :Req_0 .

:Req1_ActionConstraint_0 a iof:InformationContentEntity ;
    rdfs:label "Requirement 1 action constraint 0 (Open the Shutdown Circuit EV.7.2.2)" ;
    iof:isSubjectOf :Req_0 ;
    iof:prescribes :ShutdownCircuit_EV_7_2_2 .

:Req2_ActionConstraint_0 a iof:InformationContentEntity ;
    rdfs:label "Requirement 2 action constraint 0 (Be sealed at Tech Inspection IN.4.7.1)" ;
    iof:isSubjectOf :Req_0 ;
    iof:prescribes :TractiveSystemConnectorOutsideHousing .

:TSAL a bfo:BFO_0000040 ;
    rdfs:label "TSAL" .

:TechInspection_IN_4_7_1 a iof:InformationContentEntity ;
    rdfs:label "Tech Inspection IN.4.7.1" .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Interlock_EV_7_8,
        :ShutdownCircuit_EV_7_2_2,
        :TractiveSystemConnectorOutsideHousing ;
    iof:satisfiesRequirement :Req_0 .

:Interlock_EV_7_8 a bfo:BFO_0000040 ;
    rdfs:label "Interlock EV.7.8" .

:ShutdownCircuit_EV_7_2_2 a bfo:BFO_0000040 ;
    rdfs:label "Shutdown Circuit EV.7.2.2" .

:TractiveSystemConnectorOutsideHousing a bfo:BFO_0000040 ;
    rdfs:label "Tractive System connectors outside of a housing" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "From a point 1.6 m vertically from ground level, inside a 3 m horizontal radius from the TSAL c. In direct sunlight # EV.5.10 Connectors Tractive System connectors outside of a housing must meet one of the two: - Contain an Interlock EV.7.8 which must Open the Shutdown Circuit EV.7.2.2 - Be sealed at Tech Inspection IN.4.7.1 ## EV" ;
    iof:requirementSatisfiedBy :DS_0 .

