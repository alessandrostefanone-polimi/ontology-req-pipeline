@prefix : <http://example.org/req/570#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:FuelFillerCap a iof:MaterialArtifact ;
    rdfs:label "Fuel Filler cap" .

:FuelFillerNeck a iof:MaterialArtifact ;
    rdfs:label "Fuel Filler Neck" .

:FuelTank a iof:MaterialArtifact ;
    rdfs:label "Fuel Tank" .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Portion_FuelFillerNeck_NearestCap ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :Process_HeightRealization ;
    iof:prescribes :HeightAboveFuelTank_TopLevel .

:Portion_FuelFillerNeck_NearestCap a bfo:BFO_0000040 ;
    rdfs:label "Portion of the Fuel Filler Neck nearest to the Fuel Filler cap" ;
    iof:hasQuality :HeightAboveFuelTank_TopLevel .

:Process_HeightRealization a bfo:BFO_0000015 ;
    rdfs:label "Process realizing required height above Fuel Tank" ;
    iof:hasProcessCharacteristic :HeightAboveFuelTank_TopLevel .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The portion of the Fuel Filler Neck nearest to the Fuel Filler cap must be: a. Minimum 125 mm vertical height above the top level of the Fuel Tank b" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.25e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :HeightAboveFuelTank_TopLevel .

qudtqk:Height a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:HeightAboveFuelTank_TopLevel a bfo:BFO_0000019 ;
    rdfs:label "Vertical height above the top level of the Fuel Tank" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

