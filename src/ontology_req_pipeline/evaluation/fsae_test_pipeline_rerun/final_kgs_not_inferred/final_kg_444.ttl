@prefix : <http://example.org/req/444#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1e-03 ;
    qudt:minInclusive 1e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :MotorScatterShield_Thickness .

:VE_req2_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 0e+00 ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:BEAT ;
    iof:isValueExpressionOfAtSomeTime :CoolantAdditiveAmount .

:DS_MotorScatterShield a iof:DesignSpecification ;
    iof:prescribes :MotorScatterShield ;
    iof:satisfiesRequirement :Req_0 .

:ElectricMotorOrAccumulatorOrHVElectronics a bfo:BFO_0000040 .

:LiquidCoolant a bfo:BFO_0000040 .

:LiquidCoolantSelectionProcess a iof:PlannedProcess ;
    iof:hasInput :ElectricMotorOrAccumulatorOrHVElectronics,
        :LiquidCoolant .

:MotorScatterShield a bfo:BFO_0000040 ;
    iof:hasQuality :MotorScatterShield_Thickness .

:PS_LiquidCoolantSelection a iof:PlanSpecification ;
    iof:prescribes :LiquidCoolantSelectionProcess ;
    iof:satisfiesRequirement :Req_0 .

:PS_WaterCooledEngineCoolant a iof:PlanSpecification ;
    iof:prescribes :WaterCooledEngineCoolantUse ;
    iof:satisfiesRequirement :Req_0 .

:PlainWaterCoolant a bfo:BFO_0000040 .

:WaterCooledEngine a bfo:BFO_0000040 .

:WaterCooledEngineCoolantUse a iof:PlannedProcess ;
    iof:hasInput :PlainWaterCoolant,
        :WaterCooledEngine ;
    iof:hasProcessCharacteristic :CoolantAdditiveAmount .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:BEAT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

:CoolantAdditiveAmount a iof:ProcessCharacteristic .

:MotorScatterShield_Thickness a bfo:BFO_0000019 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The Motor Scatter Shield must be: - Made from aluminum alloy 6061-T6 or steel - Minimum thickness: 1.0 mm ## T.5.4 Coolant Fluid T.5.4.1 Water cooled engines must use only plain water with no additives of any kind T.5.4.2 Liquid coolant for electric motors, Accumulators or HV electronics must be one of: - plain water with no additives - oil T.5.4.3 (EV only)" ;
    iof:requirementSatisfiedBy :DS_MotorScatterShield,
        :PS_LiquidCoolantSelection,
        :PS_WaterCooledEngineCoolant .

