@prefix : <http://example.org/req/699#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_OvercurrentProtectionDistance a iof:DesignSpecification ;
    iof:prescribes :OvercurrentProtectionDevice ;
    iof:satisfiesRequirement :Req_0 .

:OvercurrentProtectionDevice a bfo:BFO_0000040 ;
    rdfs:label "additional Overcurrent Protection"@en ;
    iof:hasQuality :DistanceFromSourceEnd .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "This additional Overcurrent Protection must be: a. 150 mm or less from the source end of the reduced conductor b" ;
    iof:requirementSatisfiedBy :DS_OvercurrentProtectionDistance .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.5e+02 ;
    qudt:unit qudtu:MIL_LENGTH ;
    iof:isValueExpressionOfAtSomeTime :DistanceFromSourceEnd .

qudtqk:Distance a qudt:QuantityKind .

qudtu:MIL_LENGTH a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Distance .

:DistanceFromSourceEnd a bfo:BFO_0000019 ;
    rdfs:label "distance from the source end of the reduced conductor"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

