@prefix : <http://example.org/req/385#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_Req0 a iof:DesignSpecification ;
    iof:prescribes :Bolt_Req0 ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :BoltDiameter_Req0 .

:VE_req1_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3.490659e-01 ;
    qudt:unit qudtu:RAD ;
    iof:isValueExpressionOfAtSomeTime :ASBeltSideViewAngle_Req1 .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:PlaneAngle a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

qudtu:RAD a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:PlaneAngle .

:ASBeltMountingProcess_Req1 a iof:PlannedProcess ;
    rdfs:label "Anti-Submarine Belt mounting process (Req 1)" ;
    iof:hasProcessCharacteristic :ASBeltSideViewAngle_Req1 ;
    iof:prescribedBy :PS_Req1 .

:ASBeltSideViewAngle_Req1 a iof:ProcessCharacteristic ;
    rdfs:label "Anti-Submarine Belt Side View Angle (Req 1)" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c2 ;
    iof:processCharacteristicOf :ASBeltMountingProcess_Req1 .

:BoltDiameter_Req0 a bfo:BFO_0000019 ;
    rdfs:label "Diameter of bolt (Req 0)" ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 ;
    iof:qualityOf :Bolt_Req0 .

:Bolt_Req0 a bfo:BFO_0000040 ;
    rdfs:label "Bolt used to attach a Shoulder Belt (Req 0)" ;
    iof:hasQuality :BoltDiameter_Req0 ;
    iof:satisfiesRequirement :Req_0 .

:PS_Req1 a iof:PlanSpecification ;
    iof:prescribes :ASBeltMountingProcess_Req1 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any bolt used to attach a Shoulder Belt, directly to the chassis or to an intermediate bracket, is a Critical Fasteners, see T.8.2, with a minimum diameter that is the smaller of: - The bolt diameter specified by the manufacturer - 10 mm or $3 / 8^{\\prime \\prime}$ ## T.2.7 Anti-Submarine Belt Mounting T.2.7.1 The Anti-Submarine Belt of a 5 point harness must be mounted with the mounting point in line with or slightly forward of the driver's Chest to Groin Line with an Anti-Submarine Belt Side View Angle no more than $20^{\\circ}$" ;
    iof:requirementSatisfiedBy :DS_Req0,
        :PS_Req1 .

