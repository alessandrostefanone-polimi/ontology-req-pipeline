@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/190#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:ComponentEnvelope_F_1_15 a iof:InformationContentEntity ;
    rdfs:label "Component Envelope F.1.15"@en .

:MainHoop a bfo:BFO_0000040 ;
    rdfs:label "Main Hoop"@en .

:MainHoopBrace a bfo:BFO_0000040 ;
    rdfs:label "Main Hoop Brace"@en .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any item which meets all three of: - Located outside the Component Envelope F.1.15 - Located above 350 mm from the ground - Could load the Main Hoop, Main Hoop Brace, or Shoulder Harness Mounting during a rollover F.5.11.2 External Items must meet one of the two conditions: a. Be attached at a Hoop to Brace node or a fully Triangulated structural node without the ability to create a moment at the node b" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:Rollover_F_5_11_2 a bfo:BFO_0000015 ;
    rdfs:label "Rollover F.5.11.2"@en .

:ShoulderHarnessMounting a bfo:BFO_0000040 ;
    rdfs:label "Shoulder Harness Mounting"@en .

:AttachAtHoopBrace_req0_c1 a iof:InformationContentEntity ;
    rdfs:label "Constraint req0_c1: attached at Hoop to Brace node"@en ;
    iof:describes :CondGroup_g1 ;
    iof:isAbout :ExternalItem,
        :HoopToBraceNode .

:AttachAtTriangulatedNode_req0_c2 a iof:InformationContentEntity ;
    rdfs:label "Constraint req0_c2: attached at fully triangulated structural node"@en ;
    iof:describes :CondGroup_g1 ;
    iof:isAbout :ExternalItem,
        :TriangulatedStructuralNode .

:CondAltConstraint_req0_c0 a iof:InformationContentEntity ;
    rdfs:label "Constraint req0_c0: one of two conditions"@en ;
    iof:describes :CondGroup_g0 ;
    iof:isAbout :CondGroup_g0 .

:HoopToBraceNode a bfo:BFO_0000040 ;
    rdfs:label "Hoop to Brace node"@en .

:NoMomentConstraint_req0_c3 a iof:InformationContentEntity ;
    rdfs:label "Constraint req0_c3: without ability to create a moment at the node"@en ;
    iof:describes :CondGroup_g0 ;
    iof:isAbout :ExternalItem .

:TriangulatedStructuralNode a bfo:BFO_0000040 ;
    rdfs:label "Fully triangulated structural node"@en .

:ExternalItemAttachmentProcess a iof:PlannedProcess ;
    rdfs:label "Attachment of External Item"@en ;
    bfo:BFO_0000057 :ExternalItem ;
    iof:hasProcessCharacteristic :CondGroup_g0,
        :CondGroup_g1 ;
    iof:prescribedBy :PlanSpec_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :ExternalItemAttachmentProcess .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :ExternalItemAttachmentProcess .

:CondGroup_g1 a iof:ProcessCharacteristic ;
    rdfs:label "Condition group g1 (OR): attachment location alternatives"@en ;
    iof:isSubjectOf :AttachAtHoopBrace_req0_c1,
        :AttachAtTriangulatedNode_req0_c2 .

:CondGroup_g0 a iof:ProcessCharacteristic ;
    rdfs:label "Condition group g0 (AND): overall condition alternatives and no-moment constraint"@en ;
    iof:isSubjectOf :CondAltConstraint_req0_c0,
        :NoMomentConstraint_req0_c3 .

:ExternalItem a bfo:BFO_0000040 ;
    rdfs:label "External Item"@en .

