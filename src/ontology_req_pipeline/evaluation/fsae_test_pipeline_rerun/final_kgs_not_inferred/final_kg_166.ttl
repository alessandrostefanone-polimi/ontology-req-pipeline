@prefix : <http://example.org/req/166#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Circle_0 a bfo:BFO_0000040 ;
    rdfs:label "circle (representative of the two 200 mm circles)" ;
    iof:hasQuality :Circle_0_Diameter .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Circle_0,
        :Line_0 ;
    iof:satisfiesRequirement :Req_0 .

:Line_0 a bfo:BFO_0000040 ;
    rdfs:label "straight line connecting circle centers" ;
    iof:hasQuality :Line_0_Length .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A straight line measuring 490 mm will connect the centers of the two 200 mm circles" ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 4.9e-01 ;
    qudt:minInclusive 4.9e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :Line_0_Length .

:VE_req0_c4 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e-01 ;
    qudt:minInclusive 2e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :Circle_0_Diameter .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

:Circle_0_Diameter a bfo:BFO_0000019 ;
    rdfs:label "diameter of circle" ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c4 .

:Line_0_Length a bfo:BFO_0000019 ;
    rdfs:label "length of straight line" ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter,
        qudtqk:Length .

