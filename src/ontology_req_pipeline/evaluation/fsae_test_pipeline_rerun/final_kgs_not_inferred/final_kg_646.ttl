@prefix : <http://example.org/req/646#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Accumulator_0 a bfo:BFO_0000040 ;
    rdfs:label "Accumulator"@en .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "Design spec for capacitor holding AIRs closed"@en ;
    iof:prescribes :AIRs_0,
        :Capacitor_0 ;
    iof:satisfiesRequirement :Req_0 .

:PS_0 a iof:PlanSpecification ;
    rdfs:label "Plan for capacitor holding AIRs closed after shutdown circuit opens"@en ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :CapHoldProcess_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A capacitor may be used to hold the AIRs closed for up to 250 ms after the Shutdown Circuit Opens EV.7.2.2 ## EV.5.5 High Voltage Disconnect - HVD A High Voltage Disconnect (HVD) must be included to quickly disconnect one or both poles of the Accumulator EV.11.3.2 EV.5.5.1 The High Voltage Disconnect (HVD) must be: a" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1,
        :PS_2 .

:ShutdownCircuitOpen_0 a bfo:BFO_0000015 ;
    rdfs:label "Shutdown Circuit Opens process"@en .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "hold time ≤ 0.25 s"@en ;
    qudt:maxInclusive 2.5e-01 ;
    qudt:unit qudtu:SEC ;
    iof:isValueExpressionOfAtSomeTime :HoldTime_0 .

qudtqk:Time a qudt:QuantityKind .

qudtu:SEC a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Time .

:AIRs_0 a bfo:BFO_0000040 ;
    rdfs:label "AIRs"@en .

:Capacitor_0 a bfo:BFO_0000040 ;
    rdfs:label "capacitor used to hold AIRs closed"@en .

:HVDBeProcess_2 a iof:PlannedProcess ;
    rdfs:label "process expressing that HVD must be of a certain type"@en ;
    bfo:BFO_0000057 :HVD_0 ;
    iof:prescribedBy :PS_2 .

:HVDDisconnectProcess_1 a iof:PlannedProcess ;
    rdfs:label "HVD disconnection of one or both accumulator poles"@en ;
    bfo:BFO_0000057 :Accumulator_0,
        :HVD_0 ;
    iof:prescribedBy :PS_1 .

:HVD_0 a bfo:BFO_0000040 ;
    rdfs:label "High Voltage Disconnect (HVD)"@en .

:HoldTime_0 a iof:ProcessCharacteristic ;
    rdfs:label "hold time of AIRs closed by capacitor"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:processCharacteristicOf :CapHoldProcess_0 .

:PS_1 a iof:PlanSpecification ;
    rdfs:label "Plan for including HVD to disconnect accumulator poles"@en ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :HVDDisconnectProcess_1 .

:PS_2 a iof:PlanSpecification ;
    rdfs:label "Plan related to HVD being of a certain type"@en ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :HVDBeProcess_2 .

:CapHoldProcess_0 a iof:PlannedProcess ;
    rdfs:label "process of capacitor holding AIRs closed"@en ;
    bfo:BFO_0000057 :AIRs_0,
        :Capacitor_0 ;
    iof:hasProcessCharacteristic :HoldTime_0 ;
    iof:occursDuring :ShutdownCircuitOpen_0 ;
    iof:prescribedBy :PS_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objectives for capacitor use and HVD behavior"@en ;
    iof:isAchievedByAtSomeTime :CapHoldProcess_0,
        :HVDBeProcess_2,
        :HVDDisconnectProcess_1 .

