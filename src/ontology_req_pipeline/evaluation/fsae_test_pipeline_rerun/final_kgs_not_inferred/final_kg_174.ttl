@prefix : <http://example.org/req/174#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:LocationToAccess_0 a bfo:BFO_0000029 ;
    rdfs:label "Location to access during Technical Inspection"@en .

:TechnicalInspection_0 a iof:PlannedProcess ;
    rdfs:label "Technical Inspection"@en .

:FrontHoopHoleDesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :FrontHoop_0,
        :Hole_0 ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_FrontHoopHole_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Hole_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "5.7.7 A Front Hoop that is not steel must have a 4 mm hole drilled in a location to access during Technical Inspection" ;
    iof:isAbout :ObjSpec_FrontHoopHole_0 ;
    iof:requirementSatisfiedBy :FrontHoopHoleDesignSpec_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 4e-03 ;
    qudt:minInclusive 4e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Hole_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:FrontHoop_0 a bfo:BFO_0000040 ;
    rdfs:label "Front Hoop (non-steel)"@en .

:Hole_0 a bfo:BFO_0000019 ;
    rdfs:label "Access hole in Front Hoop"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 ;
    iof:qualityOf :FrontHoop_0 .

