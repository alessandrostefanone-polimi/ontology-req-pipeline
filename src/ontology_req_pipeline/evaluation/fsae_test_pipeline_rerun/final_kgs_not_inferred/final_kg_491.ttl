@prefix : <http://example.org/req/491#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:InspectionStickerReqRef_0 a iof:InformationContentEntity .

:AreaClarity_0 a bfo:BFO_0000019 .

:ObjSpec_0 a iof:ObjectiveSpecification .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The vehicle must have space for the Inspection Sticker(s) IN.13.2 that is: - A clear and unobstructed area, minimum 25 cm wide $\\times 20 \\mathrm{~cm}$ high - Located on the upper front surface of the nose along the vehicle centerline" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :Spec_0 .

:Spec_0 a iof:DesignSpecification ;
    iof:prescribes :StickerArea_0,
        :Vehicle_0 ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.5e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :StickerArea_0 .

:VehicleNoseUpperFrontCenterline_0 a bfo:BFO_0000029 .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

:StickerArea_0 a bfo:BFO_0000040 ;
    bfo:BFO_0000082 :VehicleNoseUpperFrontCenterline_0 ;
    bfo:BFO_0000175 :Vehicle_0 ;
    iof:hasQuality :AreaClarity_0 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 .

:Vehicle_0 a bfo:BFO_0000040 .

