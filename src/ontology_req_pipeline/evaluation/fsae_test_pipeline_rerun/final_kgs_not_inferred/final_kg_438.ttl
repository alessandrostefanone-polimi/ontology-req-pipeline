@prefix : <http://example.org/req/438#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AllConditions_0 a bfo:BFO_0000015 .

:DrivetrainPart_0 a bfo:BFO_0000040 .

:AlignmentCharacteristic_0 a iof:ProcessCharacteristic .

:BeltAlignmentProcess_0 a iof:PlannedProcess ;
    iof:hasProcessCharacteristic :AlignmentCharacteristic_0 ;
    iof:prescribedBy :DS_0 .

:Fastener_0 a bfo:BFO_0000040 ;
    iof:hasQuality :FastenerDiameter_0 .

:FingerGuard_0 a bfo:BFO_0000040 .

:ObjSpec_0 a iof:ObjectiveSpecification .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Stay aligned with the belt under all conditions T.5.2.9 Attachment Fasteners - All fasteners attaching scatter shields and guards must be 6 mm or 1/4\" minimum diameter Critical Fasteners, see T.8.2 T.5.2.10 Finger Guards a. Must cover any drivetrain parts that spin while the vehicle is stationary with the engine running" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 6e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :FastenerDiameter_0 .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 6.35e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :FastenerDiameter_0 .

:VehicleStationaryEngineRunning_0 a iof:PlannedProcess ;
    iof:prescribedBy :DS_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:DS_0 a iof:PlanSpecification ;
    iof:prescribes :BeltAlignmentProcess_0,
        :Fastener_0,
        :FingerGuard_0,
        :VehicleStationaryEngineRunning_0 ;
    iof:satisfiesRequirement :Req_0 .

:FastenerDiameter_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0,
        :VE_req1_c1 .

