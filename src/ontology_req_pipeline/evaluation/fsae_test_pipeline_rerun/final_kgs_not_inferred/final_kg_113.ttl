@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/113#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:EquivalenceAssessment_Req0 a iof:InformationContentEntity ;
    rdfs:label "Equivalence of the Welded tube and reinforcement"@en ;
    iof:isAbout :NonWeldedTube,
        :WeldedTubeAssembly ;
    iof:prescribes :EquivalenceProcess_Req0 .

:AltMaterialUseProcess a bfo:BFO_0000015 ;
    rdfs:label "Use of alternative materials"@en ;
    iof:hasOutput :AlternativeMaterial .

:ApplicationContext_Req1 a iof:InformationContentEntity ;
    rdfs:label "Applications shown as permitted in F.3.2.1"@en ;
    iof:isSubjectOf :SES_F3_2_1_Req1 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :NonWeldedTube,
        :WeldedTubeAssembly ;
    iof:satisfiesRequirement :Req_0 .

:DS_1 a iof:DesignSpecification ;
    iof:prescribes :AlternativeMaterial,
        :ApplicationContext_Req1 ;
    iof:satisfiesRequirement :Req_0 .

:DS_2 a iof:PlanSpecification ;
    iof:prescribes :AltMaterialUseProcess,
        :SES_Document ;
    iof:satisfiesRequirement :Req_0 .

:EquivalenceEvidence_Req0 a iof:InformationContentEntity ;
    rdfs:label "Evidence showing equivalence of welded tube and reinforcement to original non-welded tube"@en ;
    iof:isSubjectOf :SES_F3_2_1_Req0,
        :SES_F3_5,
        :SES_F3_5_1 .

:EquivalenceProcess_Req0 a bfo:BFO_0000015 ;
    rdfs:label "Process demonstrating equivalence between welded and non-welded tube"@en ;
    iof:hasOutput :EquivalenceEvidence_Req0 .

:MaterialEvidenceDocumentation a iof:InformationContentEntity ;
    rdfs:label "Documentation evidence for material type (purchase receipt, shipping document or letter of donation)"@en ;
    iof:isAbout :AlternativeMaterial .

:MaterialPropertiesDocumentation a iof:InformationContentEntity ;
    rdfs:label "Documentation of material properties"@en ;
    iof:isAbout :AlternativeMaterial .

:MaterialTypeDocumentation a iof:InformationContentEntity ;
    rdfs:label "Documentation of material type"@en ;
    iof:isAbout :AlternativeMaterial .

:SES_Document a iof:InformationContentEntity ;
    rdfs:label "SES document"@en ;
    iof:hasContinuantPartAtAllTimes :MaterialEvidenceDocumentation,
        :MaterialPropertiesDocumentation,
        :MaterialTypeDocumentation .

:SES_F3_2_1_Req0 a iof:InformationContentEntity ;
    rdfs:label "SES section F.3.2.1 (referenced in requirement 0)"@en .

:SES_F3_2_1_Req1 a iof:InformationContentEntity ;
    rdfs:label "SES section F.3.2.1 (referenced in requirement 1)"@en .

:SES_F3_5 a iof:InformationContentEntity ;
    rdfs:label "SES section F.3.5 Alternative Tubing Materials"@en .

:SES_F3_5_1 a iof:InformationContentEntity ;
    rdfs:label "SES section F.3.5.1"@en .

:NonWeldedTube a iof:MaterialArtifact ;
    rdfs:label "Original non-welded tube"@en .

:WeldedTubeAssembly a iof:MaterialArtifact ;
    rdfs:label "Welded tube with reinforcement"@en .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Young's Modulus (E) $=200 \\mathrm{GPa}(29,000 \\mathrm{ksi})$ Yield Strength (Sy) $=305 \\mathrm{MPa}(44.2 \\mathrm{ksi})$ Ultimate Strength (Su) $=365 \\mathrm{MPa}(52.9 \\mathrm{ksi})$ b. Welded Properties for discontinuous material such as joint calculations: Yield Strength (Sy) $=180 \\mathrm{MPa}(26 \\mathrm{ksi})$ Ultimate Strength (Su) $=300 \\mathrm{MPa}(43.5 \\mathrm{ksi})$ F.3.4.3 Where Welded tubing reinforcements are required (such as inserts for bolt holes or material to support suspension cutouts), Equivalence of the Welded tube and reinforcement must be shown to the original Non Welded tube in the SES # F.3.5 Alternative Tubing Materials F.3.5.1 Alternative Materials may be used for applications shown as permitted in F.3.2.1 F.3.5.2 If any Alternative Materials are used, the SES must contain: a. Documentation of material type, (purchase receipt, shipping document or letter of donation) and the material properties" ;
    iof:requirementSatisfiedBy :DS_0,
        :DS_1,
        :DS_2 .

:AlternativeMaterial a bfo:BFO_0000040 ;
    rdfs:label "Alternative material"@en .

