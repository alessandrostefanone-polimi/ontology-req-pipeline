@prefix : <http://example.org/req/333#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AccumulatorContainer_1 a bfo:BFO_0000040 ;
    rdfs:label "Accumulator Container" .

:NonCrushableItem_1 a bfo:BFO_0000040 ;
    rdfs:label "Non Crushable Item" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If used, the mounts or plate must be 25 mm or more larger at both the top and bottom of the upper and lower tubes F.11.2.3 All Non Crushable Items should have a minimum 25 mm clearance to the surface of the Accumulator Container" ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1 .

:Clearance_1 a iof:ProcessCharacteristic ;
    rdfs:label "clearance between Non Crushable Items and Accumulator Container" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 ;
    iof:processCharacteristicOf :ClearanceProcess_1 .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "Design specification for mounts or plate size relative to tubes" ;
    iof:prescribes :MountsOrPlate_0 .

:MountsOrPlate_0 a bfo:BFO_0000040 ;
    rdfs:label "mounts or plate (upper/lower tubes interface)" ;
    iof:hasQuality :SizeDiff_0 .

:PS_1 a iof:PlanSpecification ;
    rdfs:label "Plan specification for clearance of Non Crushable Items to Accumulator Container" ;
    iof:prescribes :ClearanceProcess_1 .

:SizeDiff_0 a bfo:BFO_0000019 ;
    rdfs:label "size difference of mounts or plate vs tubes" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "value expression for minimum size difference (req 0, constraint 1)" ;
    qudt:minInclusive 2.5e-02 ;
    qudt:unit qudtu:M .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "value expression for minimum clearance (req 1, constraint 1)" ;
    qudt:minInclusive 2.5e-02 ;
    qudt:unit qudtu:M .

qudtqk:Length a qudt:QuantityKind .

qudtqk:NonNegativeLength a qudt:QuantityKind .

:ClearanceProcess_1 a iof:PlannedProcess ;
    rdfs:label "process ensuring clearance between Non Crushable Items and Accumulator Container" ;
    iof:hasProcessCharacteristic :Clearance_1 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length,
        qudtqk:NonNegativeLength .

