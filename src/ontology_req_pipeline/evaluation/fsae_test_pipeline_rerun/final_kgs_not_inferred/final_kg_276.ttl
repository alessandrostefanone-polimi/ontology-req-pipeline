@prefix : <http://example.org/req/276#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:CriticalFastener_1 a bfo:BFO_0000040 ;
    rdfs:label "Critical Fastener" .

:ImpactAttenuator_1 a bfo:BFO_0000040 ;
    rdfs:label "Impact Attenuator" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "All weld lengths must be more than 25 mm F.8.5.5 If the Impact Attenuator is attached by bolting: a. Must have no less than eight 8 mm or $5 / 16^{\\prime \\prime}$ minimum diameter Critical Fasteners, T.8.2 b" ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1 .

:BoltedAttachmentProcess_1 a iof:PlannedProcess ;
    rdfs:label "Process of attaching Impact Attenuator by bolting" ;
    iof:hasProcessCharacteristic :FastenerDiameter_1,
        :NumCriticalFasteners_1 .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "Design specification for weld lengths" ;
    iof:prescribes :WeldLengthQuality_0 .

:FastenerDiameter_1 a iof:ProcessCharacteristic ;
    rdfs:label "fastener diameter" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c2 .

:NumCriticalFasteners_1 a iof:ProcessCharacteristic ;
    rdfs:label "number of Critical Fasteners" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 .

:PS_1 a iof:PlanSpecification ;
    rdfs:label "Plan specification for bolted Impact Attenuator attachment" ;
    iof:prescribes :BoltedAttachmentProcess_1 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression for minimum weld length > 25 mm" ;
    qudt:minExclusive 2.5e-02 ;
    qudt:unit qudtu:M .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression for minimum number of Critical Fasteners ≥ 8" ;
    qudt:minInclusive 8e+00 ;
    qudt:unit qudtu:BEAT .

:VE_req1_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression for minimum fastener diameter ≥ 8 mm" ;
    qudt:minInclusive 8e-03 ;
    qudt:unit qudtu:M .

:WeldLengthQuality_0 a bfo:BFO_0000019 ;
    rdfs:label "weld length quality" ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

qudtu:BEAT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter,
        qudtqk:Length .

