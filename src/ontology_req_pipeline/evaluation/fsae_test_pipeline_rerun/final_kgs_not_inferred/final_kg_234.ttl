@prefix : <http://example.org/req/234#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :SideImpactZonePortion_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The portion of the Side Impact Zone that is vertically between the upper surface of the floor and 320 mm above the lowest point of the upper surface of the floor (see figure above) must have: a. Equivalence to minimum two (2) Steel Tubes (F.3.2.1.e) per F.4.4 b" ;
    iof:requirementSatisfiedBy :DS_0 .

:SideImpactZone_0 a bfo:BFO_0000040 ;
    rdfs:label "Side Impact Zone" .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e+00 ;
    qudt:unit qudtu:BEAT ;
    iof:isValueExpressionOfAtSomeTime :SideImpactZonePortion_0 .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtu:BEAT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

:SideImpactZonePortion_0 a bfo:BFO_0000040 ;
    rdfs:label "Portion of Side Impact Zone between floor surface and 320 mm above" ;
    iof:componentPartOfAtSomeTime :SideImpactZone_0 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

