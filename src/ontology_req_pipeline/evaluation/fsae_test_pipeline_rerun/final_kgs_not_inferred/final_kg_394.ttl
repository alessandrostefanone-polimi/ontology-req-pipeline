@prefix : <http://example.org/req/394#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_HeadRestraintStrength a iof:DesignSpecification ;
    iof:prescribes :HeadRestraintAssembly ;
    iof:satisfiesRequirement :Req_0 .

:Plan_HeadRestraintStrength a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_HeadRestraintStrength ;
    iof:prescribes :HeadRestraintStrengthTestProcess .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Head Restraint Protection (if used) F.5.10 T.2.8.4 The Head Restraint, attachment and mounting must be strong enough to withstand a minimum force of: a. 900 N applied in a rearward direction b. 300 N applied in a lateral or vertical direction T.2.8.5 For all drivers, the Head Restraint must be located and adjusted where: a" ;
    iof:isAbout :ObjSpec_HeadRestraintStrength .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:N ;
    iof:isValueExpressionOfAtSomeTime :PC_HeadRestraintForceCapability .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 9e+02 ;
    qudt:unit qudtu:N ;
    iof:isValueExpressionOfAtSomeTime :PC_HeadRestraintForceCapability .

:VE_req0_c1_Direction a iof:ValueExpression ;
    iof:hasSimpleExpressionValue "rearward direction" ;
    iof:isValueExpressionOfAtSomeTime :PC_HeadRestraintForceCapability .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3e+02 ;
    qudt:unit qudtu:N ;
    iof:isValueExpressionOfAtSomeTime :PC_HeadRestraintForceCapability .

:VE_req1_c0_Direction_Lateral a iof:ValueExpression ;
    iof:hasSimpleExpressionValue "lateral direction" ;
    iof:isValueExpressionOfAtSomeTime :PC_HeadRestraintForceCapability .

:VE_req1_c0_Direction_Vertical a iof:ValueExpression ;
    iof:hasSimpleExpressionValue "vertical direction" ;
    iof:isValueExpressionOfAtSomeTime :PC_HeadRestraintForceCapability .

qudtqk:Force a qudt:QuantityKind .

:HeadRestraintAssembly a iof:Assembly ;
    iof:hasProcessCharacteristic :PC_HeadRestraintForceCapability .

:HeadRestraintStrengthTestProcess a iof:PlannedProcess ;
    iof:achievesAtSomeTime :ObjSpec_HeadRestraintStrength ;
    iof:hasProcessCharacteristic :PC_HeadRestraintForceCapability ;
    iof:hasSpecifiedOutput :HeadRestraintAssembly ;
    iof:prescribedBy :Plan_HeadRestraintStrengthTest .

:ObjSpec_HeadRestraintStrength a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :HeadRestraintStrengthTestProcess ;
    iof:prescribes :PC_HeadRestraintForceCapability .

qudtu:N a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Force .

:PC_HeadRestraintForceCapability a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0,
        :VE_req0_c1,
        :VE_req0_c1_Direction,
        :VE_req1_c0,
        :VE_req1_c0_Direction_Lateral,
        :VE_req1_c0_Direction_Vertical .

