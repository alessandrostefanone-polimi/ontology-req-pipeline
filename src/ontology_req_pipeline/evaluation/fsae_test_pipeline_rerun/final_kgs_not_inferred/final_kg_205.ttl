@prefix : <http://example.org/req/205#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:FrontBulkhead a bfo:BFO_0000040 .

:FrontHoop a bfo:BFO_0000040 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The upper support member must be attached 50 mm or less from the top surface of the Front Bulkhead, and attach to the Front Hoop inside a zone extending 100 mm above and 50 mm below the Upper Side Impact member" ;
    iof:requirementSatisfiedBy :DS_UpperSupportMemberAttachment .

:UpperSideImpactMember a bfo:BFO_0000040 .

:DS_UpperSupportMemberAttachment a iof:DesignSpecification ;
    iof:prescribes :UpperSupportMember .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 5e-02 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Q_DistanceFromFrontBulkheadTopSurface .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1e-01 ;
    qudt:minInclusive -5e-02 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Q_AttachmentVerticalPositionToFrontHoop .

qudtqk:Height a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

:Q_AttachmentVerticalPositionToFrontHoop a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :UpperSupportMember .

:Q_DistanceFromFrontBulkheadTopSurface a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :UpperSupportMember .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height,
        qudtqk:Length .

:UpperSupportMember a bfo:BFO_0000040 ;
    iof:hasQuality :Q_AttachmentVerticalPositionToFrontHoop,
        :Q_DistanceFromFrontBulkheadTopSurface .

