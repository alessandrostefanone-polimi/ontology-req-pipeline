@prefix : <http://example.org/req/136#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Hole_0 a bfo:BFO_0000040 ;
    bfo:BFO_0000050 :Sample_0 ;
    iof:hasQuality :HoleDiameter_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :SupportProcess_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The fixture must support the entire sample, except for a 32 mm hole aligned coaxially with the punch" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:SupportFunction_0 a iof:DesignedFunction ;
    iof:prescribedBy :DesignSpec_0 .

:SupportProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :Fixture_0,
        :Sample_0 ;
    iof:prescribedBy :PlanSpec_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3.2e-02 ;
    qudt:minInclusive 3.2e-02 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :HoleDiameter_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Fixture_0 ;
    iof:satisfiesRequirement :Req_0 .

:Fixture_0 a iof:MaterialArtifact ;
    iof:hasFunction :SupportFunction_0 .

:HoleDiameter_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:Sample_0 a bfo:BFO_0000040 .

