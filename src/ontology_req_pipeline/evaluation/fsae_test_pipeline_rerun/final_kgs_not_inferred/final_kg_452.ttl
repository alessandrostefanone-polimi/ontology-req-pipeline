@prefix : <http://example.org/req/452#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any catch can on the cooling system must vent through a hose with a minimum internal diameter of 3 mm down to the bottom levels of the Chassis. ## T. 6 PRESSURIZED SYSTEMS ##" ;
    iof:requirementSatisfiedBy :VentHoseDesignSpec_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :VentHoseInternalDiameter_0 .

:VentHoseDesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :VentHose_0 ;
    iof:satisfiesRequirement :Req_0 .

:VentHose_0 a bfo:BFO_0000040 ;
    iof:hasQuality :VentHoseInternalDiameter_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:VentHoseInternalDiameter_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c2 .

