@prefix : <http://example.org/req/611#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :VoltageQuality_0 ;
    iof:satisfiesRequirement :Req_0 .

:PS_1 a iof:PlanSpecification ;
    iof:prescribes :PowertrainProcess_1 ;
    iof:satisfiesRequirement :Req_0 .

:PowertrainProcess_1 a iof:PlannedProcess ;
    rdfs:label "Powertrain operation process"@en ;
    iof:hasProcessCharacteristic :RegenCharacteristic_1,
        :VehicleSpeed_1 .

:RegenCharacteristic_1 a iof:ProcessCharacteristic ;
    rdfs:label "regenerate energy behavior (must not regenerate)"@en .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Voltage <= 600 V"@en ;
    qudt:maxInclusive 6e+02 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtAllTimes :VoltageQuality_0 .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Vehicle speed between 0 and 5 km/h"@en ;
    qudt:maxInclusive 5e+00 ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:KILOM-PER-HR ;
    iof:isValueExpressionOfAtSomeTime :VehicleSpeed_1 .

qudtqk:ElectricPotentialDifference a qudt:QuantityKind .

qudtqk:VehicleVelocity a qudt:QuantityKind .

qudtu:KILOM-PER-HR a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:VehicleVelocity .

qudtu:V a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:ElectricPotentialDifference .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.3.2 The maximum permitted voltage that may occur between any two points must not exceed 600 V DC EV.3.3.3 The powertrain must not regenerate energy when vehicle speed is between 0 and $5 \\mathrm{~km} /" ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1 .

:VehicleSpeed_1 a iof:ProcessCharacteristic ;
    rdfs:label "vehicle speed during which regeneration is constrained"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 .

:VoltageQuality_0 a bfo:BFO_0000019 ;
    rdfs:label "maximum permitted voltage between any two points"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

