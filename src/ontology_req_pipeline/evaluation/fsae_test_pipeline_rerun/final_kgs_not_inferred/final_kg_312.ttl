@prefix : <http://example.org/req/312#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:SES_0 a iof:InformationContentEntity ;
    rdfs:label "SES"@en ;
    iof:prescribes :VerificationProcess_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :MountingSystem_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "This mounting system design must withstand the following accelerations: 40 g in the longitudinal direction (forward/aft) 40 g in the lateral direction (left/right) 20 g in the vertical direction (up/down) c. Calculations and/or tests proving these requirements are met must be included in the SES. d" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0,
        :PlanSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3.92266e+02 ;
    qudt:minInclusive 3.92266e+02 ;
    qudt:unit qudtu:M-PER-SEC2 ;
    iof:isValueExpressionOfAtAllTimes :LongitudinalAccel_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3.92266e+02 ;
    qudt:minInclusive 3.92266e+02 ;
    qudt:unit qudtu:M-PER-SEC2 ;
    iof:isValueExpressionOfAtAllTimes :LateralAccel_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.96133e+02 ;
    qudt:minInclusive 1.96133e+02 ;
    qudt:unit qudtu:M-PER-SEC2 ;
    iof:isValueExpressionOfAtAllTimes :VerticalAccel_0 .

qudtqk:LinearAcceleration a qudt:QuantityKind .

:MountingSystem_0 a iof:MaterialArtifact ;
    rdfs:label "mounting system"@en ;
    iof:hasQuality :LateralAccel_0,
        :LongitudinalAccel_0,
        :VerticalAccel_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :VerificationProcess_0 .

:LateralAccel_0 a bfo:BFO_0000019 ;
    rdfs:label "lateral acceleration withstand capability"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 .

:LongitudinalAccel_0 a bfo:BFO_0000019 ;
    rdfs:label "longitudinal acceleration withstand capability"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :LateralAccel_0,
        :LongitudinalAccel_0,
        :MountingSystem_0,
        :VerificationProcess_0,
        :VerticalAccel_0 .

:VerificationProcess_0 a iof:PlannedProcess ;
    rdfs:label "calculations and/or tests proving accelerations are met"@en ;
    iof:achievesAtSomeTime :ObjSpec_0 ;
    iof:prescribedBy :PlanSpec_0 .

:VerticalAccel_0 a bfo:BFO_0000019 ;
    rdfs:label "vertical acceleration withstand capability"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c2 .

qudtu:M-PER-SEC2 a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:LinearAcceleration .

