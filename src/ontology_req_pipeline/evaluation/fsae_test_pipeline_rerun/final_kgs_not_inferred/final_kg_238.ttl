@prefix : <http://example.org/req/238#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :MainHoop,
        :MainHoopMountingPlate ;
    iof:satisfiesRequirement :Req_0 .

:Monocoque a iof:MaterialArtifact ;
    rdfs:label "monocoque"@en .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :MainHoopAttachmentProcess .

:PlanSpec_1 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :PlateManufacturingProcess .

:PlateMaterialRole a bfo:BFO_0000023 ;
    rdfs:label "steel material role of Main Hoop mounting plate"@en ;
    iof:roleOf :MainHoopMountingPlate .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "7.6 Main Hoop Attachment F.7.6.1 The Main Hoop must be mechanically attached to the monocoque a. Main Hoop mounting plates must be 2.0 mm minimum thickness steel b" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e-03 ;
    qudt:quantityKind qudtqk:Thickness ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :PlateThickness .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

:MainHoop a iof:MaterialArtifact ;
    rdfs:label "Main Hoop"@en .

:MainHoopAttachmentProcess a iof:PlannedProcess ;
    bfo:BFO_0000057 :MainHoop,
        :Monocoque ;
    iof:prescribedBy :PlanSpec_0 .

:PlateManufacturingProcess a iof:ManufacturingProcess ;
    iof:hasSpecifiedOutput :MainHoopMountingPlate ;
    iof:prescribedBy :PlanSpec_1 .

:PlateThickness a bfo:BFO_0000019 ;
    rdfs:label "thickness of Main Hoop mounting plate"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req1_c1 .

qudtqk:Thickness a qudt:QuantityKind .

:MainHoopMountingPlate a iof:MaterialArtifact ;
    rdfs:label "Main Hoop mounting plate"@en ;
    iof:hasQuality :PlateThickness ;
    iof:hasRole :PlateMaterialRole .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :MainHoopAttachmentProcess,
        :PlateManufacturingProcess .

