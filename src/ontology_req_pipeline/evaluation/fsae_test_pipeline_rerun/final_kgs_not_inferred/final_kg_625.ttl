@prefix : <http://example.org/req/625#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:BSE_0 a iof:MaterialArtifact .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :APPS_0,
        :BSE_0,
        :MechanicalBrakes_0,
        :MotorPower_0,
        :PedalTravel_Quality_0 ;
    iof:satisfiesRequirement :Req_0 .

:MechanicalBrakes_0 a iof:MaterialArtifact .

:MotorPower_0 a bfo:BFO_0000040 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "4.6 Brake System Encoder - BSE Refer to T.4.3 for specific requirements of the BSE ## EV.4.7 APPS / Brake Pedal Plausibility Check EV.4.7.1 Must monitor for the two conditions: - The mechanical brakes are engaged EV.4.6, T.3.2.4 - The APPS signals more than 25\\% Pedal Travel EV.4.5 EV.4.7.2 If the two conditions in EV.4.7.1 occur at the same time: a. Power to the Motor(s) must be immediately and completely shut down b" ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req3_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 2.5e-01 ;
    qudt:unit qudtu:NUM ;
    iof:isValueExpressionOfAtSomeTime :PedalTravel_Quality_0 .

qudtqk:DimensionlessRatio a qudt:QuantityKind .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DimensionlessRatio .

:APPS_0 a iof:MaterialArtifact .

:PedalTravel_Quality_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req3_c0 ;
    iof:qualityOf :APPS_0 .

