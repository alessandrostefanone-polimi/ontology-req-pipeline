@prefix : <http://example.org/req/668#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "From a point 1.6 m vertically from ground level, inside a 3 m horizontal radius from the TSAL c. In direct sunlight # EV.5.10 Connectors Tractive System connectors outside of a housing must meet one of the two: - Contain an Interlock EV.7.8 which must Open the Shutdown Circuit EV.7.2.2 - Be sealed at Tech Inspection IN.4.7.1 ## EV" ;
    iof:requirementSatisfiedBy :DS_ObservationPoint,
        :PS_ConnectorsCompliance,
        :PS_InterlockOperation,
        :PS_SealingAtInspection .

:TSAL_c a bfo:BFO_0000040 .

:ConnectorsComplianceProcess a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :TractiveSystemConnectorsOutsideHousing .

:DS_ObservationPoint a iof:DesignSpecification ;
    iof:prescribes :ObservationPoint .

:InterlockOperationProcess a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :Interlock_EV_7_8,
        :ShutdownCircuit_EV_7_2_2 .

:Interlock_EV_7_8 a bfo:BFO_0000040 .

:ObservationPoint a bfo:BFO_0000040 ;
    iof:hasQuality :ObservationPointHeight,
        :ObservationPointHorizontalRadiusConstraint .

:PS_ConnectorsCompliance a iof:PlanSpecification ;
    iof:prescribes :ConnectorsComplianceProcess .

:PS_InterlockOperation a iof:PlanSpecification ;
    iof:prescribes :InterlockOperationProcess .

:PS_SealingAtInspection a iof:PlanSpecification ;
    iof:prescribes :SealingAtInspectionProcess .

:SealingAtInspectionProcess a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :TechInspection_IN_4_7_1 .

:ShutdownCircuit_EV_7_2_2 a bfo:BFO_0000015 .

:TechInspection_IN_4_7_1 a bfo:BFO_0000015 .

:TractiveSystemConnectorsOutsideHousing a bfo:BFO_0000040 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.6e+00 ;
    qudt:minInclusive 1.6e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :ObservationPointHeight .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :ObservationPointHorizontalRadiusConstraint .

qudtqk:Height a qudt:QuantityKind .

qudtqk:Radius a qudt:QuantityKind .

:ObservationPointHeight a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:ObservationPointHorizontalRadiusConstraint a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height,
        qudtqk:Radius .

