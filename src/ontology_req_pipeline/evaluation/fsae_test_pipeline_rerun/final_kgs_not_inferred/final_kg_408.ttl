@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/408#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:EV_7_2_2 a iof:InformationContentEntity ;
    rdfs:label "EV.7.2.2" .

:IC_9_2_2 a iof:InformationContentEntity ;
    rdfs:label "IC.9.2.2" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.3.3 Operation of the BOTS to the OFF position must Open the Shutdown Circuit IC.9.2.2 / EV.7.2.2 T.3.3.4 Repeated operation of the switch must not reset or restore power T.3.3.5" ;
    iof:isAbout :ObjSpec_0,
        :ObjSpec_1 ;
    iof:requirementSatisfiedBy :Spec_0,
        :Spec_1 .

:T_3_3_4 a iof:InformationContentEntity ;
    rdfs:label "T.3.3.4" .

:T_3_3_5 a iof:InformationContentEntity ;
    rdfs:label "T.3.3.5" .

:BOTS a bfo:BFO_0000040 ;
    rdfs:label "BOTS" .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: BOTS OFF operation opens shutdown circuit" ;
    iof:isAchievedByAtSomeTime :Proc_BOTS_Off_Operation ;
    iof:prescribes :Proc_Open_Shutdown_Circuit .

:ObjSpec_1 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: repeated switch operation does not reset or restore power" ;
    iof:isAchievedByAtSomeTime :Proc_Repeated_Switch_Operation ;
    iof:prescribes :Proc_Not_Reset_Or_Restore_Power .

:Shutdown_Circuit a bfo:BFO_0000040 ;
    rdfs:label "Shutdown Circuit" .

:Switch a bfo:BFO_0000040 ;
    rdfs:label "switch" .

:Proc_BOTS_Off_Operation a iof:PlannedProcess ;
    rdfs:label "Operation of the BOTS to the OFF position" ;
    iof:hasParticipantAtSomeTime :BOTS ;
    iof:prescribedBy :Spec_0 .

:Proc_Not_Reset_Or_Restore_Power a iof:PlannedProcess ;
    rdfs:label "Non-restoration of power under repeated switch operation" ;
    iof:prescribedBy :Spec_1 .

:Proc_Open_Shutdown_Circuit a iof:PlannedProcess ;
    rdfs:label "Opening of the Shutdown Circuit" ;
    iof:hasParticipantAtSomeTime :Shutdown_Circuit ;
    iof:prescribedBy :Spec_0 .

:Proc_Repeated_Switch_Operation a iof:PlannedProcess ;
    rdfs:label "Repeated operation of the switch" ;
    iof:hasParticipantAtSomeTime :Switch ;
    iof:prescribedBy :Spec_1 .

:Spec_0 a iof:PlanSpecification ;
    rdfs:label "Plan spec for BOTS OFF operation opening shutdown circuit" ;
    iof:prescribes :Proc_BOTS_Off_Operation,
        :Proc_Open_Shutdown_Circuit .

:Spec_1 a iof:PlanSpecification ;
    rdfs:label "Plan spec for repeated switch operation not restoring power" ;
    iof:prescribes :Proc_Not_Reset_Or_Restore_Power,
        :Proc_Repeated_Switch_Operation .

