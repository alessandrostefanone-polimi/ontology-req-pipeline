@prefix : <http://example.org/req/357#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:GapDesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :GapBetweenPanels_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If multiple panels are used, gaps between panels must not exceed 3 mm ## T.1.8 Firewall(s) T.1.8.1" ;
    iof:requirementSatisfiedBy :GapDesignSpec_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :GapBetweenPanels_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:GapBetweenPanels_0 a bfo:BFO_0000019 ;
    rdfs:label "gap size between panels"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

