@prefix : <http://example.org/req/571#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0_0 a iof:RequirementSpecification ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :FuelFillerNeck_0,
        :SightTube_0 ;
    iof:satisfiesRequirement :Req_0 .

:DS_0_1 a iof:DesignSpecification ;
    iof:prescribes :SightTube_0 ;
    iof:satisfiesRequirement :Req_1_1 .

:FuelFillerNeck_0 a bfo:BFO_0000040 .

:OrientationProcess_0 a bfo:BFO_0000015 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Angled no more than $30^{\\circ}$ from the vertical IC.5.4.3 The Fuel Filler Neck must be accompanied by a clear fuel resistant sight tube for reading the fuel level which must be: a. Visible vertical height: 125 mm minimum b" ;
    iof:isAbout :ObjSpec_0,
        :ObjSpec_1 ;
    iof:requirementSatisfiedBy :DS_0 .

:Req_1_1 a iof:RequirementSpecification ;
    iof:isAbout :ObjSpec_1 ;
    iof:requirementSatisfiedBy :DS_0_1 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 5.235988e-01 ;
    qudt:unit qudtu:RAD ;
    iof:isValueExpressionOfAtSomeTime :Tilt_0 .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.25e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Height_0 .

:VisibilityProcess_0 a bfo:BFO_0000015 .

qudtqk:Height a qudt:QuantityKind .

qudtqk:Tilt a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

qudtu:RAD a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Tilt .

:Height_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 ;
    iof:processCharacteristicOf :VisibilityProcess_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Tilt_0 .

:ObjSpec_1 a iof:ObjectiveSpecification ;
    iof:prescribes :Height_0 .

:SightTube_0 a bfo:BFO_0000040 .

:Tilt_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:processCharacteristicOf :OrientationProcess_0 .

