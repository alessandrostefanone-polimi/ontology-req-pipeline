@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/89#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:CriticalFastener a bfo:BFO_0000040 ;
    iof:hasRole :CriticalFastenerRole .

:Req0_Constraint0 a iof:InformationContentEntity ;
    rdfs:comment "Fasteners in the Suspension system are Critical Fasteners" ;
    iof:isAbout :CriticalFastenerRole .

:Req1_Constraint0 a iof:InformationContentEntity ;
    rdfs:comment "All spherical rod ends and spherical bearings on the suspension and steering must be one of the specified mounting configurations" ;
    iof:isAbout :SphericalJointMountingProcess .

:Req2_Constraint0 a iof:InformationContentEntity ;
    rdfs:comment "Mounted in double shear" ;
    iof:isAbout :DoubleShearMountingConfiguration .

:Req3_Constraint0 a iof:InformationContentEntity ;
    rdfs:comment "Captured by having a screw/bolt head or washer" ;
    iof:isAbout :CapturingConfiguration .

:Req3_Constraint1 a iof:InformationContentEntity ;
    rdfs:comment "Outside diameter of the screw/bolt head or washer is larger than spherical bearing housing inside diameter" ;
    iof:isAbout :OutsideDiameter,
        :SphericalBearingHousingInsideDiameter .

:Req4_Constraint0 a iof:InformationContentEntity ;
    rdfs:comment "The Steering Wheel must be mechanically connected to the front wheels" ;
    iof:isAbout :MechanicalConnectionToFrontWheels .

:CapturingConfiguration a bfo:BFO_0000019 .

:DoubleShearMountingConfiguration a bfo:BFO_0000019 .

:FrontWheels a bfo:BFO_0000040 .

:MechanicalConnectionToFrontWheels a bfo:BFO_0000019 ;
    iof:qualityOf :SteeringWheel .

:OutsideDiameter a bfo:BFO_0000019 ;
    iof:qualityOf :ScrewBoltHeadOrWasher .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.1.4 Fasteners in the Suspension system are Critical Fasteners, see T.8.2 V.3.1.5 All spherical rod ends and spherical bearings on the suspension and steering must be one of: - Mounted in double shear - Captured by having a screw/bolt head or washer with an outside diameter that is larger than spherical bearing housing inside diameter. ## V.3.2 Steering V.3.2.1 The Steering Wheel must be mechanically connected to the front wheels" ;
    iof:requirementSatisfiedBy :SphericalJointMountingPlanSpec,
        :SteeringConnectionPlanSpec,
        :SuspensionFastenerDesignSpec .

:ScrewBoltHeadOrWasher a bfo:BFO_0000040 .

:SphericalBearingHousingInsideDiameter a bfo:BFO_0000019 ;
    iof:qualityOf :SphericalBearing .

:SphericalJointMountingPlanSpec a iof:PlanSpecification ;
    iof:prescribes :SphericalJointMountingProcess .

:SphericalRodEnd a bfo:BFO_0000040 .

:SteeringConnectionPlanSpec a iof:PlanSpecification ;
    iof:prescribes :SteeringConnectionProcess .

:SteeringConnectionProcess a iof:PlannedProcess ;
    bfo:BFO_0000057 :FrontWheels,
        :SteeringWheel .

:SuspensionFastener a bfo:BFO_0000040 ;
    bfo:BFO_0000176 :SuspensionSystem .

:SuspensionFastenerDesignSpec a iof:DesignSpecification ;
    iof:prescribes :SuspensionFastener ;
    iof:satisfiesRequirement :Req_0 .

:SuspensionSystem a bfo:BFO_0000040 .

:CriticalFastenerRole a bfo:BFO_0000023 .

:SphericalBearing a bfo:BFO_0000040 .

:SphericalJointMountingProcess a iof:PlannedProcess ;
    bfo:BFO_0000057 :SphericalBearing,
        :SphericalRodEnd .

:SteeringWheel a bfo:BFO_0000040 .

