@prefix : <http://example.org/req/648#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The Precharge Circuit must: a. Be able to charge the Intermediate Circuit to minimum $90 \\%$ of the Accumulator voltage before closing the second AIR b" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:Accumulator_0 a bfo:BFO_0000040 ;
    rdfs:label "Accumulator" .

:CloseSecondAIR_0 a bfo:BFO_0000015 ;
    rdfs:label "closing the second AIR" ;
    bfo:BFO_0000057 :SecondAIR_0 .

:IntermediateCircuit_0 a bfo:BFO_0000040 ;
    rdfs:label "Intermediate Circuit" .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :PrechargeProcess_0 .

:PrechargeCircuit_0 a bfo:BFO_0000040 ;
    rdfs:label "Precharge Circuit" .

:SecondAIR_0 a bfo:BFO_0000040 ;
    rdfs:label "second AIR" .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 9e-01 ;
    qudt:unit qudtu:NUM ;
    iof:isValueExpressionOfAtSomeTime :ChargeLevel_0 .

qudtqk:StateOfCharge a qudt:QuantityKind .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:StateOfCharge .

:ChargeLevel_0 a iof:ProcessCharacteristic ;
    rdfs:label "charge level of Intermediate Circuit relative to Accumulator voltage" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:processCharacteristicOf :PrechargeProcess_0 .

:PrechargeProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :Accumulator_0,
        :IntermediateCircuit_0,
        :PrechargeCircuit_0 ;
    iof:before :CloseSecondAIR_0 ;
    iof:hasProcessCharacteristic :ChargeLevel_0 .

