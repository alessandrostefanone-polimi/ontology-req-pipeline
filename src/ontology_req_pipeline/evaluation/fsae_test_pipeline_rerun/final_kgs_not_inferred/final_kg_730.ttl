@prefix : <http://example.org/req/730#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The temperature sensor used must be in direct contact with one of: - The negative terminal itself - The negative terminal busbar less than 10 mm away from the cell terminal EV.7.5.5 For lithium based cells, a" ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxExclusive 1e-02 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Distance_NegBusbar_CellTerminal_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :CellTerminal_0,
        :NegBusbar_0,
        :NegTerminal_0,
        :TempSensor_0 .

:DistanceRelation_0 a bfo:BFO_0000015 ;
    bfo:BFO_0000057 :CellTerminal_0,
        :NegBusbar_0 ;
    iof:hasProcessCharacteristic :Distance_NegBusbar_CellTerminal_0 .

:NegTerminal_0 a bfo:BFO_0000040 .

:TempSensor_0 a bfo:BFO_0000040 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:CellTerminal_0 a bfo:BFO_0000040 .

:Distance_NegBusbar_CellTerminal_0 a iof:ProcessCharacteristic ;
    iof:processCharacteristicOf :DistanceRelation_0 .

:NegBusbar_0 a bfo:BFO_0000040 .

