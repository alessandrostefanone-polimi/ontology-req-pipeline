@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/111#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:NonStructTubingSpec_0 a iof:InformationContentEntity ;
    rdfs:comment "F.3.3.2 Applicability Non Structural Tubing" .

:NonStructuralTubing_0 a bfo:BFO_0000040 ;
    rdfs:comment "Any tubing which does NOT meet F.3.2.1.o Structural Tubing F.3.3.2 Applicability Non Structural Tubing is ignored when assessing compliance to any rule" .

:Req_0_0 a iof:RequirementSpecification ;
    rdfs:comment "Any tubing which does NOT meet F.3.2.1.o Structural Tubing F.3.3.2 Applicability Non Structural Tubing is ignored when assessing compliance to any rule" ;
    iof:isAbout :ObjSpec_0_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:Req_1_0 a iof:RequirementSpecification ;
    rdfs:comment "A tube must meet all four minimum requirements for each Size specified:" ;
    iof:isAbout :ObjSpec_1_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:RuleRef_anyRule_0 a iof:InformationContentEntity ;
    rdfs:comment "any rule" .

:StructTubingSpec_0 a iof:InformationContentEntity ;
    rdfs:comment "F.3.2.1.o Structural Tubing" .

:ObjSpec_0_0 a iof:ObjectiveSpecification ;
    iof:prescribes :AssessComplianceProcess_0 .

:ObjSpec_1_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Tube_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Definition Any tubing which does NOT meet F.3.2.1.o Structural Tubing F.3.3.2 Applicability Non Structural Tubing is ignored when assessing compliance to any rule ## F.3.4 Steel Tubing and Material F.3.4.1 Minimum Requirements for Steel Tubing A tube must meet all four minimum requirements for each Size specified: Tube Minimum Area Moment of Inertia Minimum Cross Sectional Area Minimum Outside Diameter or Square Width Minimum Wall Thickness Example Sizes of Round Tube :--: :--: :--: :--: :--: :--: :--: a. Size A $11320 \\mathrm{~mm}^{4}$ $173 \\mathrm{~mm}^{2}$ 25.0 mm 2.0 mm $\\begin{aligned} & 1.0^{\\prime \\prime} \\times 0.095^{\\prime \\prime} \\\\ & 25 \\times 2.5 \\mathrm{~mm} \\end{aligned}$ b" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0,
        :PlanSpec_0 .

:RuleSet_0 a iof:InformationContentEntity .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :AssessComplianceProcess_0,
        :Tube_0 .

:AssessComplianceProcess_0 a iof:PlannedProcess ;
    iof:hasInput :RuleSet_0 ;
    iof:hasParticipantAtSomeTime :Tube_0 ;
    iof:prescribedBy :PlanSpec_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Tube_0 ;
    iof:satisfiesRequirement :Req_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :AssessComplianceProcess_0 .

:Tube_0 a bfo:BFO_0000040 ;
    iof:prescribedBy :DesignSpec_0 .

