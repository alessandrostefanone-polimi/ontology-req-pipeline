@prefix : <http://example.org/req/465#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Bodywork_0 a bfo:BFO_0000040 ;
    rdfs:label "Bodywork" .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :BodyworkEdgeSet_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "7.2.4 All forward facing edges on the Bodywork that could contact people, including the nose, must have forward facing radii minimum 38 mm" ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "minimum forward facing radius 38 mm" ;
    qudt:minInclusive 3.8e-02 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :ForwardFacingRadius_0 .

qudtqk:Radius a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Radius .

:BodyworkEdgeSet_0 a bfo:BFO_0000040 ;
    rdfs:label "forward facing edges on the Bodywork that could contact people, including the nose" ;
    iof:componentPartOfAtSomeTime :Bodywork_0 ;
    iof:hasQuality :ForwardFacingRadius_0 .

:ForwardFacingRadius_0 a bfo:BFO_0000019 ;
    rdfs:label "forward facing radius of forward facing edges on the Bodywork that could contact people, including the nose" ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 ;
    iof:qualityOf :BodyworkEdgeSet_0 .

