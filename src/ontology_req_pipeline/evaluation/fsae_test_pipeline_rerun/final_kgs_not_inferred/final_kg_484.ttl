@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/484#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Must trigger due to a longitudinal impact load which decelerates the vehicle at between 8 g and 11 g depending on the duration of the deceleration (refer to spec sheet of the Sensata device)" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :TriggerProcess_0 .

:TriggerProcess_0 a iof:PlannedProcess ;
    rdfs:label "Triggering process due to longitudinal impact load" ;
    iof:hasProcessCharacteristic :DecelerationChar_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Required vehicle deceleration between 78.4532 and 107.87315 m/s^2" ;
    qudt:maxInclusive 1.078731e+02 ;
    qudt:minInclusive 7.84532e+01 ;
    qudt:unit qudtu:M-PER-SEC2 ;
    iof:isValueExpressionOfAtSomeTime :DecelerationChar_0 .

qudtqk:Acceleration a qudt:QuantityKind .

qudtu:M-PER-SEC2 a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Acceleration .

:DecelerationChar_0 a iof:ProcessCharacteristic ;
    rdfs:label "Vehicle longitudinal deceleration during impact" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

