@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/671#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Connections_TractiveSystem a bfo:BFO_0000040 ;
    rdfs:label "Tractive System connections" .

:TestProbe_Insulated a iof:MaterialArtifact ;
    rdfs:label "insulated test probe (100 mm long, 6 mm diameter)" ;
    rdfs:comment "Referenced in constraint req0_c1 as the probe used to attempt contact; dimensional details are captured textually because no normalized quantitative data was provided." .

:Enclosures_TractiveSystem a bfo:BFO_0000040 ;
    rdfs:label "Tractive System enclosures" .

:ObjSpec_ContactNotPossible a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :PlannedProc_ContactPrevention ;
    iof:prescribes :PC_ContactWithConnections .

:Proc_EnclosuresInPlaceState a iof:MaterialState ;
    bfo:BFO_0000057 :Enclosures_TractiveSystem ;
    rdfs:comment "Constraint req0_c2: state where the Tractive System enclosures are in place; condition under which contact must not be possible." .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "6.1.2 Contact with any Tractive System connections with a 100 mm long, 6 mm diameter insulated test probe must not be possible when the Tractive System enclosures are in place" ;
    iof:isAbout :ObjSpec_ContactNotPossible ;
    iof:requirementSatisfiedBy :PlanSpec_ContactPrevention .

:PC_ContactWithConnections a iof:ProcessCharacteristic ;
    rdfs:comment "Constraint req0_c0: contact with any Tractive System connections with the specified test probe must not be possible." ;
    iof:processCharacteristicOf :PlannedProc_ContactPrevention .

:PlanSpec_ContactPrevention a iof:PlanSpecification ;
    iof:prescribes :PlannedProc_ContactPrevention ;
    iof:satisfiesRequirement :Req_0 .

:PlannedProc_ContactPrevention a iof:PlannedProcess ;
    iof:hasProcessCharacteristic :PC_ContactWithConnections ;
    iof:occursDuring :Proc_EnclosuresInPlaceState ;
    iof:prescribedBy :PlanSpec_ContactPrevention .

