: a owl:Ontology .

:RefDoc_F_5_7_6 a iof:InformationContentEntity ;
    rdfs:label "F.5.7.6"@en ;
    iof:isAbout :FrontHoopRef_0 .

:RefDoc_F_7_4_4 a iof:InformationContentEntity ;
    rdfs:label "F.7.4.4"@en .

:Adhesive_0 a bfo:BFO_0000040 ;
    rdfs:label "Adhesive"@en .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Adhesive_0,
        :FrontHoop_0,
        :Monocoque_0 ;
    iof:satisfiesRequirement :Req_0 .

:FrontHoopRef_0 a bfo:BFO_0000040 ;
    rdfs:label "Front Hoop (referenced in F.5.7.6)"@en .

:FrontHoop_0 a bfo:BFO_0000040 ;
    rdfs:label "Front Hoop"@en .

:Monocoque_0 a bfo:BFO_0000040 ;
    rdfs:label "monocoque"@en .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A small gap in the laminate (approximately 25 mm ) exists for inspection of the Front Hoop F.5.7.6 F.7.4.4 Adhesive must not be the sole method of attaching the Front Hoop to the monocoque" ;
    iof:requirementSatisfiedBy :DS_0 .

