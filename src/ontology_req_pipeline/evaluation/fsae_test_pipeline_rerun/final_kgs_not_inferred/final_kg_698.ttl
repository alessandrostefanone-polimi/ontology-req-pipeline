@prefix : <http://example.org/req/698#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Conductor_0_ComponentRole a iof:MaterialComponentRole ;
    iof:roleOf :Conductor_0 .

:Conductor_0_MaterialProductRole a iof:MaterialProductRole ;
    iof:roleOf :Conductor_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Conductor_0 ;
    iof:satisfiesRequirement :Req_0 .

:OCP_Additional_0 a bfo:BFO_0000040 ;
    iof:hasRole :OCP_Additional_0_EquipmentRole .

:OCP_Additional_0_EquipmentRole a iof:EquipmentRole ;
    iof:roleOf :OCP_Additional_0 .

:OCP_Upstream_0 a bfo:BFO_0000040 ;
    iof:hasRole :OCP_Upstream_0_EquipmentRole .

:OCP_Upstream_0_EquipmentRole a iof:EquipmentRole ;
    iof:roleOf :OCP_Upstream_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If conductor ampacity is reduced below the ampacity of the upstream Overcurrent Protection, the reduced conductor longer than 150 mm must have additional Overcurrent Protection" ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 1.5e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Conductor_0_Length .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Conductor_0_Length a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:Conductor_0 a bfo:BFO_0000040 ;
    iof:hasQuality :Conductor_0_Length ;
    iof:hasRole :Conductor_0_ComponentRole,
        :Conductor_0_MaterialProductRole .

