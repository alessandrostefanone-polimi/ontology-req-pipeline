@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/965#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Section_D_12_10 a iof:InformationContentEntity ;
    rdfs:label "D.12.10 Endurance Event - Black Flags" ;
    iof:isAbout :Proc_1 .

:Vehicle_0 a bfo:BFO_0000040 ;
    rdfs:label "vehicle (implicit subject 'it')" .

:BlackFlag_0 a bfo:BFO_0000040 ;
    rdfs:label "Black Flag" .

:DesignatedLocation_0 a bfo:BFO_0000029 ;
    rdfs:label "designated location for Black Flag" .

:Event_StallOrCone a iof:Event ;
    rdfs:label "vehicle stalls or ingests a cone" ;
    iof:recognizedByAtSomeTime :RaceOfficial_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: allow vehicle to continue after stall / cone ingestion" ;
    iof:isAchievedByAtSomeTime :Proc_0 ;
    iof:isSubjectOf :Req_0 .

:ObjSpec_1 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: Black Flag shown at designated location" ;
    iof:isAchievedByAtSomeTime :Proc_1 ;
    iof:isSubjectOf :Req_0 .

:RaceOfficial_0 a iof:Agent ;
    rdfs:label "race official (implicit)" .

:Rule_D_12_1_4 a iof:InformationContentEntity ;
    rdfs:label "Rule D.12.1.4" .

:Rule_D_12_4 a iof:InformationContentEntity ;
    rdfs:label "Rule D.12.4" .

:PlanSpec_0 a iof:PlanSpecification ;
    rdfs:label "Plan for allowing stalled / cone-ingesting vehicle to continue" ;
    iof:isSubjectOf :Req_0 ;
    iof:prescribes :Proc_0 .

:PlanSpec_1 a iof:PlanSpecification ;
    rdfs:label "Plan for showing Black Flag at designated location" ;
    iof:isSubjectOf :Req_0 ;
    iof:prescribes :Proc_1 .

:Proc_0 a iof:PlannedProcess ;
    rdfs:label "Continuation of vehicle after stall / cone ingestion" ;
    bfo:BFO_0000117 :Event_StallOrCone ;
    iof:isSubjectOf :Rule_D_12_1_4,
        :Rule_D_12_4 ;
    iof:prescribedBy :PlanSpec_0 .

:Proc_1 a iof:PlannedProcess ;
    rdfs:label "Process of showing Black Flag" ;
    bfo:BFO_0000057 :BlackFlag_0,
        :DesignatedLocation_0 ;
    iof:prescribedBy :PlanSpec_1 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If a vehicle stalls, or ingests a cone, etc., it may be allowed to continue, subject to D.12.1.4 and D.12.4 ## D.12.10 Endurance Event - Black Flags D.12.10.1 A Black Flag will be shown at the designated location D.12.10.2" ;
    iof:isAbout :ObjSpec_0,
        :ObjSpec_1 ;
    iof:requirementSatisfiedBy :PlanSpec_0,
        :PlanSpec_1 .

