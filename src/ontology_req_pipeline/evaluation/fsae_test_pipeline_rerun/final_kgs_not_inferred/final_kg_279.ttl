@prefix : <http://example.org/req/279#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:LowerSideImpactStructure_0 a iof:MaterialArtifact ;
    rdfs:label "Lower Side Impact Structure" .

:OrientationSpecRef_0 a iof:InformationContentEntity ;
    rdfs:label "F.8.5.7 Impact Attenuator Orientation" .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :ImpactAttenuator_0 ;
    iof:satisfiesRequirement :Req_0 .

:IA_MaterialProductRole_0 a iof:MaterialProductRole ;
    iof:roleOf :ImpactAttenuator_0 .

:MountingProcess_0 a iof:PlannedProcess ;
    rdfs:label "mounting of impact attenuator" ;
    iof:hasParticipantAtSomeTime :ImpactAttenuator_0 ;
    iof:hasProcessCharacteristic :MountingHeightAboveRef_0 .

:ObjSpec_0 a iof:ObjectiveSpecification .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A Custom Impact Attenuator must mount with an area of 200 mm or more long and 200 mm or more wide that intersects a plane parallel to the ground that is no more than 220 mm above the lowest point on the top of the Lower Side Impact Structure F.8.5.7 Impact Attenuator Orientation a" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :IA_Length_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :IA_Width_0 .

:VE_req0_c3 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.2e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :MountingHeightAboveRef_0 .

qudtqk:Height a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

qudtqk:Width a qudt:QuantityKind .

:IA_Length_0 a bfo:BFO_0000019 ;
    rdfs:label "impact attenuator mounting length" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:IA_Width_0 a bfo:BFO_0000019 ;
    rdfs:label "impact attenuator mounting width" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:MountingHeightAboveRef_0 a iof:ProcessCharacteristic ;
    rdfs:label "height of mounting plane above reference structure" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c3 ;
    iof:processCharacteristicOf :MountingProcess_0 .

:ImpactAttenuator_0 a iof:MaterialArtifact ;
    rdfs:label "Custom Impact Attenuator" ;
    iof:hasQuality :IA_Length_0,
        :IA_Width_0 ;
    iof:hasRole :IA_MaterialProductRole_0 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height,
        qudtqk:Length,
        qudtqk:Width .

