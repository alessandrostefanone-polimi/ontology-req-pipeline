@prefix : <http://example.org/req/514#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:F_6_4 a iof:InformationContentEntity ;
    rdfs:label "F.6.4" .

:F_7_5 a iof:InformationContentEntity ;
    rdfs:label "F.7.5" .

:IC_1_2 a iof:InformationContentEntity ;
    rdfs:label "IC.1.2" ;
    iof:designates :IC_1_2_Requirement .

:IC_2_2_1 a iof:InformationContentEntity ;
    rdfs:label "IC.2.2.1" ;
    iof:designates :Req0_Objective .

:IC_2_2_2 a iof:InformationContentEntity ;
    rdfs:label "IC.2.2.2" ;
    iof:designates :Req1_Objective .

:Portion_AirIntakeSystem_Req1 a bfo:BFO_0000040 ;
    rdfs:label "Portion of air intake system (Req1 subject)" ;
    bfo:BFO_0000175 :AirIntakeSystem ;
    iof:hasQuality :HeightAboveGround_Req1_c0 ;
    iof:prescribedBy :DS_IntakeSystemCompliance .

:AirIntakeSystem a bfo:BFO_0000040 ;
    rdfs:label "Air intake system" .

:ImpactDirection_Req1_c2 a iof:ProcessCharacteristic ;
    rdfs:label "Impact direction (side or rear) for shielding (Req1, constraint 2)" .

:IntakeSystem a bfo:BFO_0000040 ;
    rdfs:label "Intake System" .

:PS_IntakeSystemShielding a iof:PlanSpecification ;
    rdfs:label "Plan spec: Shielding of low-height intake portions" ;
    iof:isAbout :Req1_Objective ;
    iof:prescribes :ShieldingProcess ;
    iof:satisfiesRequirement :Req_0 .

:ShieldingProcess a iof:PlannedProcess ;
    rdfs:label "Shielding process for low-height intake portions" ;
    iof:hasInput :ShieldingStructure ;
    iof:hasProcessCharacteristic :ImpactDirection_Req1_c2 .

:ShieldingStructure a bfo:BFO_0000040 ;
    rdfs:label "Shielding structure built per F.6.4 / F.7.5" .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression: height above ground < 0.35 m" ;
    qudt:maxExclusive 3.5e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :HeightAboveGround_Req1_c0 .

qudtqk:Height a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:DS_IntakeSystemCompliance a iof:DesignSpecification ;
    rdfs:label "Design spec: Intake System compliance with IC.1.2" ;
    iof:isAbout :Req0_Objective ;
    iof:prescribes :IntakeSystem ;
    iof:satisfiesRequirement :IC_1_2_Requirement,
        :Req_0 .

:HeightAboveGround_Req1_c0 a bfo:BFO_0000019 ;
    rdfs:label "Height above the ground (Req1, constraint 0)" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:Req0_Objective a iof:ObjectiveSpecification ;
    rdfs:label "Objective: Intake System meets IC.1.2" ;
    iof:prescribes :IC_1_2_Requirement .

:Req1_Objective a iof:ObjectiveSpecification ;
    rdfs:label "Objective: Shield low-height intake portions from side/rear impacts" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "2 AIR INTAKE SYSTEM ## IC.2.1 General ## IC.2.2 Intake System Location IC.2.2.1 The Intake System must meet IC.1.2 IC.2.2.2 Any portion of the air intake system that is less than 350 mm above the ground must be shielded from side or rear impacts by structure built per F.6.4 / F.7.5 as applicable. ## IC.2.3 Intake System Mounting IC.2.3.1" ;
    iof:requirementSatisfiedBy :DS_IntakeSystemCompliance,
        :PS_IntakeSystemShielding .

:IC_1_2_Requirement a iof:RequirementSpecification ;
    rdfs:label "Referenced requirement IC.1.2" .

