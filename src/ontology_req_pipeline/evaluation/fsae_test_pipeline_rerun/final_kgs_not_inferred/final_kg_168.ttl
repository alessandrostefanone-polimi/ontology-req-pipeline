@prefix : <http://example.org/req/168#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "5.6.5 Driver Template Position The Driver Template will be positioned as follows: - The seat will be adjusted to the rearmost position - The pedals will be placed in the most forward position - The bottom 200 mm circle will be placed on the seat bottom where the distance between the center of this circle and the rearmost face of the pedals is no less than 915 mm - The middle 200 mm circle, representing the shoulders, will be positioned on the seat back" ;
    iof:requirementSatisfiedBy :Plan_0 .

:Distance_BottomCircle_Pedals a iof:ProcessCharacteristic ;
    rdfs:label "Distance between bottom circle center and rearmost face of pedals" ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c2 ;
    iof:processCharacteristicOf :Proc_BottomCirclePlace .

:Proc_MiddleCirclePlace a iof:PlannedProcess ;
    rdfs:label "Middle circle placement process" ;
    bfo:BFO_0000057 :MiddleCircle,
        :Seat ;
    iof:prescribedBy :Plan_0 .

:Proc_PedalPlace a iof:PlannedProcess ;
    rdfs:label "Pedal placement process" ;
    bfo:BFO_0000057 :Pedals ;
    iof:prescribedBy :Plan_0 .

:Proc_SeatAdjust a iof:PlannedProcess ;
    rdfs:label "Seat adjustment process" ;
    bfo:BFO_0000057 :Seat ;
    iof:prescribedBy :Plan_0 .

:VE_req2_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Bottom circle 200 mm" ;
    qudt:maxInclusive 2e-01 ;
    qudt:minInclusive 2e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :BottomCircle .

:VE_req2_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Distance >= 0.915 m" ;
    qudt:minInclusive 9.15e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Distance_BottomCircle_Pedals .

:VE_req3_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Middle circle diameter 200 mm" ;
    qudt:maxInclusive 2e-01 ;
    qudt:minInclusive 2e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :MiddleCircle .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

:BottomCircle a bfo:BFO_0000040 ;
    rdfs:label "Bottom 200 mm circle" ;
    iof:hasValueExpressionAtAllTimes :VE_req2_c0 .

:MiddleCircle a bfo:BFO_0000040 ;
    rdfs:label "Middle 200 mm circle" ;
    iof:hasValueExpressionAtAllTimes :VE_req3_c0 .

:Pedals a bfo:BFO_0000040 ;
    rdfs:label "Pedals" .

:Proc_BottomCirclePlace a iof:PlannedProcess ;
    rdfs:label "Bottom circle placement process" ;
    bfo:BFO_0000057 :BottomCircle,
        :Pedals,
        :Seat ;
    iof:prescribedBy :Plan_0 .

:Seat a bfo:BFO_0000040 ;
    rdfs:label "Driver seat" .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter,
        qudtqk:Length .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :Proc_BottomCirclePlace,
        :Proc_MiddleCirclePlace,
        :Proc_PedalPlace,
        :Proc_SeatAdjust .

