@prefix : <http://example.org/req/797#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "All vehicles with a maximum nominal operation voltage below 500 V will be measured with the next available voltage level" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:NominalOperationVoltage_0 a bfo:BFO_0000019 ;
    rdfs:label "maximum nominal operation voltage of vehicle"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :Vehicle_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :VehicleMeasurementProcess_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "upper bound for nominal operation voltage < 500 V"@en ;
    qudt:maxExclusive 5e+02 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtSomeTime :NominalOperationVoltage_0 .

:VehicleMeasurementProcess_0 a iof:PlannedProcess ;
    rdfs:label "measurement of vehicles with next available voltage level"@en ;
    bfo:BFO_0000057 :Vehicle_0 ;
    iof:hasSpecifiedOutput :VoltageLevel_0 .

:VoltageLevel_0 a bfo:BFO_0000040 ;
    rdfs:label "next available voltage level"@en .

qudtqk:Voltage a qudt:QuantityKind .

qudtu:V a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Voltage .

:Vehicle_0 a bfo:BFO_0000040 ;
    rdfs:label "vehicle (subject of requirement 0)"@en .

