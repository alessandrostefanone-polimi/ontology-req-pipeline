@prefix : <http://example.org/req/451#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:CatchCanType_EngineSystems a bfo:BFO_0000040 ;
    rdfs:label "Catch cans for the engine coolant system and engine lubrication system"@en ;
    iof:hasQuality :Capacity_EngineSystems .

:CatchCanType_OtherSystems a bfo:BFO_0000040 ;
    rdfs:label "Catch cans for vents on other systems containing liquid lubricant or coolant"@en ;
    iof:hasQuality :Capacity_OtherSystems .

:DS_2 a iof:DesignSpecification ;
    iof:prescribes :CatchCanType_EngineSystems ;
    iof:satisfiesRequirement :Req_0 .

:DS_3 a iof:DesignSpecification ;
    iof:prescribes :CatchCanType_OtherSystems ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_2 a iof:ObjectiveSpecification ;
    iof:prescribes :Capacity_EngineSystems .

:ObjSpec_3 a iof:ObjectiveSpecification ;
    iof:prescribes :Capacity_OtherSystems .

:VE_req2_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1e-01 ;
    qudt:unit qudtu:NUM ;
    iof:isValueExpressionOfAtSomeTime :Capacity_EngineSystems .

:VE_req2_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 9e-01 ;
    qudt:unit qudtu:L ;
    iof:isValueExpressionOfAtSomeTime :Capacity_EngineSystems .

:VE_req3_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1e-01 ;
    qudt:unit qudtu:NUM ;
    iof:isValueExpressionOfAtSomeTime :Capacity_OtherSystems .

:VE_req3_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 5e-01 ;
    qudt:unit qudtu:L ;
    iof:isValueExpressionOfAtSomeTime :Capacity_OtherSystems .

qudtqk:CartesianVolume a qudt:QuantityKind .

qudtqk:DimensionlessRatio a qudt:QuantityKind .

qudtqk:PositiveDimensionlessRatio a qudt:QuantityKind .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Located rearwards of the Firewall below the driver's shoulder level c. Positively retained, using no tie wraps or tape T.5.6.3 Catch cans for the engine coolant system and engine lubrication system must have a minimum capacity of $10 \\%$ of the fluid being contained or 0.9 liter, whichever is higher T.5.6.4 Catch cans for any vent on other systems containing liquid lubricant or coolant, including a differential, gearbox, or electric motor, must have a minimum capacity of $10 \\%$ of the fluid being contained or 0.5 liter, whichever is higher T.5.6.5" ;
    iof:isAbout :ObjSpec_2,
        :ObjSpec_3 ;
    iof:requirementSatisfiedBy :DS_2,
        :DS_3 .

qudtu:L a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:CartesianVolume .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DimensionlessRatio,
        qudtqk:PositiveDimensionlessRatio .

:Capacity_EngineSystems a bfo:BFO_0000019 ;
    rdfs:label "capacity of engine coolant and lubrication catch cans"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c0,
        :VE_req2_c1 .

:Capacity_OtherSystems a bfo:BFO_0000019 ;
    rdfs:label "capacity of other-system vent catch cans"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req3_c1,
        :VE_req3_c2 .

