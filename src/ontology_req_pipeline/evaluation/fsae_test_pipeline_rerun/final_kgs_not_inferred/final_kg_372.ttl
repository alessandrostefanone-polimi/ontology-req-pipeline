@prefix : <http://example.org/req/372#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Attachment of tabs or brackets must meet the following: a. Where brackets are fastened to the chassis, no less than two 6 mm or $1 / 4^{\\prime \\prime}$ minimum diameter Critical Fasteners, see T.8.2 or stronger must be used to attach the bracket to the chassis" ;
    iof:isAbout :ObjSpec_AttachTabsBrackets,
        :ObjSpec_BracketAttachmentFasteners ;
    iof:requirementSatisfiedBy :DS_AttachTabsBrackets,
        :PS_BracketAttachmentFasteners .

:Bracket a bfo:BFO_0000040 .

:BracketAttachedToChassis a bfo:BFO_0000040 .

:Chassis a bfo:BFO_0000040 .

:DS_AttachTabsBrackets a iof:DesignSpecification ;
    iof:prescribes :TabsOrBracketsAttachment .

:ObjSpec_AttachTabsBrackets a iof:ObjectiveSpecification ;
    iof:prescribes :TabsOrBracketsAttachment .

:Proc_AttachBracketToChassis a iof:PlannedProcess ;
    iof:hasInput :Bracket,
        :Chassis ;
    iof:hasSpecifiedOutput :BracketAttachedToChassis ;
    iof:prescribedBy :PS_BracketAttachmentFasteners .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e+00 ;
    qudt:unit qudtu:BEAT ;
    iof:isValueExpressionOfAtSomeTime :FastenerCountQuality .

:VE_req1_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 6e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :FastenerDiameterQuality .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtu:BEAT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:Fastener a bfo:BFO_0000040 .

:FastenerCountQuality a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 ;
    iof:qualityOf :Fastener .

:FastenerDiameterQuality a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c2 ;
    iof:qualityOf :Fastener .

:ObjSpec_BracketAttachmentFasteners a iof:ObjectiveSpecification ;
    iof:prescribes :FastenerCountQuality,
        :FastenerDiameterQuality .

:PS_BracketAttachmentFasteners a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_BracketAttachmentFasteners ;
    iof:prescribes :Proc_AttachBracketToChassis .

:TabsOrBracketsAttachment a bfo:BFO_0000002 .

