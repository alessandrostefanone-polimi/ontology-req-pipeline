@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/206#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Bracing_0 a bfo:BFO_0000040 ;
    rdfs:label "properly Triangulated bracing" ;
    bfo:BFO_0000056 :BracingTransferProcess_0 .

:Object_ConditionInterval_0 a bfo:BFO_0000202 ;
    rdfs:label "interval when upper support member is >100 mm above Upper Side Impact member" .

:PlanSpec_0 a iof:PlanSpecification ;
    rdfs:label "Plan: bracing load transfer to Main Hoop" ;
    bfo:BFO_0000110 :Objective_0 ;
    iof:prescribes :BracingTransferProcess_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If the upper support member is further than 100 mm above the Upper Side Impact member, then properly Triangulated bracing is required to transfer load to the Main Hoop by one of: - the Upper Side Impact member - an additional member transmitting load from the junction of the Upper Support Member with the Front Hoop c" ;
    iof:isAbout :Objective_0 .

:Junction_UpperSupport_FrontHoop_0 a bfo:BFO_0000004 ;
    rdfs:label "junction of Upper Support Member with Front Hoop" ;
    bfo:BFO_0000110 :Object_FrontHoop_0,
        :Object_UpperSupportMember_0 .

:LoadPathOption_AdditionalMember_0 a bfo:BFO_0000001 ;
    rdfs:label "load path option via additional member from junction to Front Hoop" ;
    iof:isAbout :Junction_UpperSupport_FrontHoop_0,
        :Object_AdditionalMember_0 .

:LoadPathOption_UpperSideImpact_0 a bfo:BFO_0000001 ;
    rdfs:label "load path option via Upper Side Impact member" ;
    iof:isAbout :Object_UpperSideImpactMember_0 .

:Load_0 a bfo:BFO_0000040 ;
    rdfs:label "load to be transferred" ;
    bfo:BFO_0000056 :BracingTransferProcess_0 .

:Object_AdditionalMember_0 a bfo:BFO_0000040 ;
    rdfs:label "additional member transmitting load from the junction of the Upper Support Member with the Front Hoop" .

:Object_FrontHoop_0 a bfo:BFO_0000040 ;
    rdfs:label "Front Hoop" .

:Object_UpperSideImpactMember_0 a bfo:BFO_0000040 ;
    rdfs:label "Upper Side Impact member" .

:Object_UpperSupportMember_0 a bfo:BFO_0000040 ;
    rdfs:label "upper support member" .

:Object_MainHoop_0 a bfo:BFO_0000040 ;
    rdfs:label "Main Hoop" .

:Objective_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: transfer load from bracing to Main Hoop via allowed load paths when condition holds" ;
    iof:isAchievedByAtSomeTime :BracingTransferProcess_0 ;
    iof:prescribes :Object_MainHoop_0 .

:BracingTransferProcess_0 a iof:PlannedProcess ;
    rdfs:label "load transfer by properly triangulated bracing" ;
    bfo:BFO_0000117 :LoadPathOption_AdditionalMember_0,
        :LoadPathOption_UpperSideImpact_0 ;
    iof:hasInput :Load_0 ;
    iof:hasSpecifiedOutput :Object_MainHoop_0 .

