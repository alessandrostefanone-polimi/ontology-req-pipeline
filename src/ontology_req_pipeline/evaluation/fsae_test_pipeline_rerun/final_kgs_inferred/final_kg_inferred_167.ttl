    ns1:maxInclusive 2e-01 ;
    ns1:minInclusive 2e-01 ;
    ns1:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/167#UpperCircleDiameter_0> .

<http://example.org/req/167#VE_req0_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
