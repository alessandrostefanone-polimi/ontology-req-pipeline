@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/855#> a owl:Ontology .

<http://example.org/req/855#AddedItemsCosting_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasQuality <http://example.org/req/855#CostMultiplier_0>,
        <http://example.org/req/855#CostRate_0> .

<http://example.org/req/855#CostAddendum_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity .

<http://example.org/req/855#CostReport_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity .

<http://example.org/req/855#AdditionalCost_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/855#CostChange_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasQuality <http://example.org/req/855#AdditionalCost_0> .

<http://example.org/req/855#DS_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/855#CostChange_0> ;
    ns1:satisfiesRequirement <http://example.org/req/855#Req_0> .

<http://example.org/req/855#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "3.7.6 Changes to the Cost Report in the Cost Addendum will incur additional cost: a. Added items will be cost at $125 \\%$ of the table cost: + (1.25 x Cost) b" ;
    ns1:requirementSatisfiedBy <http://example.org/req/855#DS_0> .

<http://example.org/req/855#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 1.25e+00 ;
    ns2:minInclusive 1.25e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/NUM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/855#CostRate_0> .

<http://example.org/req/855#VE_req0_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 1.25e+00 ;
    ns2:minInclusive 1.25e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/UNITLESS> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/855#CostMultiplier_0> .

<http://qudt.org/vocab/unit/NUM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/DimensionlessRatio> .

<http://qudt.org/vocab/unit/UNITLESS> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Dimensionless> .

<http://example.org/req/855#CostMultiplier_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/855#VE_req0_c2> .

<http://example.org/req/855#CostRate_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/855#VE_req0_c1> .

