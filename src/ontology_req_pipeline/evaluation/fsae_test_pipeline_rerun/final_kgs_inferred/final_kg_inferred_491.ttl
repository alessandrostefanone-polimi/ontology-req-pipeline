@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix ns3: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/491#> a owl:Ontology .

<http://example.org/req/491#InspectionStickerReqRef_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity .

<http://example.org/req/491#AreaClarity_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/491#ObjSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification .

<http://example.org/req/491#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The vehicle must have space for the Inspection Sticker(s) IN.13.2 that is: - A clear and unobstructed area, minimum 25 cm wide $\\times 20 \\mathrm{~cm}$ high - Located on the upper front surface of the nose along the vehicle centerline" ;
    ns1:isAbout <http://example.org/req/491#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/491#Spec_0> .

<http://example.org/req/491#Spec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/491#StickerArea_0>,
        <http://example.org/req/491#Vehicle_0> ;
    ns1:satisfiesRequirement <http://example.org/req/491#Req_0> .

<http://example.org/req/491#VE_req0_c2> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns3:minInclusive 2.5e-01 ;
    ns3:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/491#StickerArea_0> .

<http://example.org/req/491#VehicleNoseUpperFrontCenterline_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000029,
        ns2:BFO_0000141,
        owl:NamedIndividual,
        owl:Thing .

<http://qudt.org/vocab/unit/M> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/Thickness> .

<http://example.org/req/491#StickerArea_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:BFO_0000082 <http://example.org/req/491#VehicleNoseUpperFrontCenterline_0> ;
    ns2:BFO_0000175 <http://example.org/req/491#Vehicle_0> ;
    ns1:hasQuality <http://example.org/req/491#AreaClarity_0> ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/491#VE_req0_c2> .

<http://example.org/req/491#Vehicle_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

