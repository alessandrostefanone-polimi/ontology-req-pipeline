@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/190#> a owl:Ontology .

<http://example.org/req/190#ComponentEnvelope_F_1_15> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:label "Component Envelope F.1.15",
        "Component Envelope F.1.15"@en .

<http://example.org/req/190#MainHoop> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Main Hoop",
        "Main Hoop"@en .

<http://example.org/req/190#MainHoopBrace> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Main Hoop Brace",
        "Main Hoop Brace"@en .

<http://example.org/req/190#Req_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "Any item which meets all three of: - Located outside the Component Envelope F.1.15 - Located above 350 mm from the ground - Could load the Main Hoop, Main Hoop Brace, or Shoulder Harness Mounting during a rollover F.5.11.2 External Items must meet one of the two conditions: a. Be attached at a Hoop to Brace node or a fully Triangulated structural node without the ability to create a moment at the node b" ;
    ns2:isAbout <http://example.org/req/190#ObjSpec_0> ;
    ns2:requirementSatisfiedBy <http://example.org/req/190#PlanSpec_0> .

<http://example.org/req/190#Rollover_F_5_11_2> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        ns1:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Rollover F.5.11.2",
        "Rollover F.5.11.2"@en .

<http://example.org/req/190#ShoulderHarnessMounting> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Shoulder Harness Mounting",
        "Shoulder Harness Mounting"@en .

<http://example.org/req/190#AttachAtHoopBrace_req0_c1> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DescriptiveInformationContentEntity,
        ns2:InformationContentEntity ;
    rdfs:label "Constraint req0_c1: attached at Hoop to Brace node",
        "Constraint req0_c1: attached at Hoop to Brace node"@en ;
    ns2:describes <http://example.org/req/190#CondGroup_g1> ;
    ns2:isAbout <http://example.org/req/190#ExternalItem>,
        <http://example.org/req/190#HoopToBraceNode> .

<http://example.org/req/190#AttachAtTriangulatedNode_req0_c2> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DescriptiveInformationContentEntity,
        ns2:InformationContentEntity ;
    rdfs:label "Constraint req0_c2: attached at fully triangulated structural node",
        "Constraint req0_c2: attached at fully triangulated structural node"@en ;
    ns2:describes <http://example.org/req/190#CondGroup_g1> ;
    ns2:isAbout <http://example.org/req/190#ExternalItem>,
        <http://example.org/req/190#TriangulatedStructuralNode> .

<http://example.org/req/190#CondAltConstraint_req0_c0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DescriptiveInformationContentEntity,
        ns2:InformationContentEntity ;
    rdfs:label "Constraint req0_c0: one of two conditions",
        "Constraint req0_c0: one of two conditions"@en ;
    ns2:describes <http://example.org/req/190#CondGroup_g0> ;
    ns2:isAbout <http://example.org/req/190#CondGroup_g0> .

<http://example.org/req/190#HoopToBraceNode> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Hoop to Brace node",
        "Hoop to Brace node"@en .

<http://example.org/req/190#NoMomentConstraint_req0_c3> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DescriptiveInformationContentEntity,
        ns2:InformationContentEntity ;
    rdfs:label "Constraint req0_c3: without ability to create a moment at the node",
        "Constraint req0_c3: without ability to create a moment at the node"@en ;
    ns2:describes <http://example.org/req/190#CondGroup_g0> ;
    ns2:isAbout <http://example.org/req/190#ExternalItem> .

<http://example.org/req/190#TriangulatedStructuralNode> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Fully triangulated structural node",
        "Fully triangulated structural node"@en .

<http://example.org/req/190#ExternalItemAttachmentProcess> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        ns1:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "Attachment of External Item",
        "Attachment of External Item"@en ;
    ns1:BFO_0000057 <http://example.org/req/190#ExternalItem> ;
    ns2:hasProcessCharacteristic <http://example.org/req/190#CondGroup_g0>,
        <http://example.org/req/190#CondGroup_g1> ;
    ns2:prescribedBy <http://example.org/req/190#PlanSpec_0> .

<http://example.org/req/190#ObjSpec_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:prescribes <http://example.org/req/190#ExternalItemAttachmentProcess> .

<http://example.org/req/190#PlanSpec_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns1:BFO_0000110 <http://example.org/req/190#ObjSpec_0> ;
    ns2:prescribes <http://example.org/req/190#ExternalItemAttachmentProcess> .

<http://example.org/req/190#CondGroup_g1> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "Condition group g1 (OR): attachment location alternatives",
        "Condition group g1 (OR): attachment location alternatives"@en ;
    ns2:isSubjectOf <http://example.org/req/190#AttachAtHoopBrace_req0_c1>,
        <http://example.org/req/190#AttachAtTriangulatedNode_req0_c2> .

<http://example.org/req/190#CondGroup_g0> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "Condition group g0 (AND): overall condition alternatives and no-moment constraint",
        "Condition group g0 (AND): overall condition alternatives and no-moment constraint"@en ;
    ns2:isSubjectOf <http://example.org/req/190#CondAltConstraint_req0_c0>,
        <http://example.org/req/190#NoMomentConstraint_req0_c3> .

<http://example.org/req/190#ExternalItem> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "External Item",
        "External Item"@en .

