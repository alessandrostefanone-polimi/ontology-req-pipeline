@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/611#> a owl:Ontology .

<http://example.org/req/611#DS_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/611#VoltageQuality_0> ;
    ns2:satisfiesRequirement <http://example.org/req/611#Req_0> .

<http://example.org/req/611#PS_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/611#PowertrainProcess_1> ;
    ns2:satisfiesRequirement <http://example.org/req/611#Req_0> .

<http://example.org/req/611#PowertrainProcess_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "Powertrain operation process",
        "Powertrain operation process"@en ;
    ns2:hasProcessCharacteristic <http://example.org/req/611#RegenCharacteristic_1>,
        <http://example.org/req/611#VehicleSpeed_1> .

<http://example.org/req/611#RegenCharacteristic_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "regenerate energy behavior (must not regenerate)",
        "regenerate energy behavior (must not regenerate)"@en .

<http://example.org/req/611#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "Voltage <= 600 V",
        "Voltage <= 600 V"@en ;
    ns1:maxInclusive 6e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/V> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/611#VoltageQuality_0> .

<http://example.org/req/611#VE_req1_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "Vehicle speed between 0 and 5 km/h",
        "Vehicle speed between 0 and 5 km/h"@en ;
    ns1:maxInclusive 5e+00 ;
    ns1:minInclusive 0e+00 ;
    ns1:unit <http://qudt.org/vocab/unit/KILOM-PER-HR> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/611#VehicleSpeed_1> .

<http://qudt.org/vocab/unit/KILOM-PER-HR> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/VehicleVelocity> .

<http://qudt.org/vocab/unit/V> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/ElectricPotentialDifference> .

<http://example.org/req/611#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "3.3.2 The maximum permitted voltage that may occur between any two points must not exceed 600 V DC EV.3.3.3 The powertrain must not regenerate energy when vehicle speed is between 0 and $5 \\mathrm{~km} /" ;
    ns2:requirementSatisfiedBy <http://example.org/req/611#DS_0>,
        <http://example.org/req/611#PS_1> .

<http://example.org/req/611#VehicleSpeed_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "vehicle speed during which regeneration is constrained",
        "vehicle speed during which regeneration is constrained"@en ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/611#VE_req1_c1> .

<http://example.org/req/611#VoltageQuality_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "maximum permitted voltage between any two points",
        "maximum permitted voltage between any two points"@en ;
    ns2:hasValueExpressionAtAllTimes <http://example.org/req/611#VE_req0_c0> .

