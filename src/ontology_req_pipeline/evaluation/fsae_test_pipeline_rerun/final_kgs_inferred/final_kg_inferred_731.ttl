@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix ns3: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/731#> a owl:Ontology .

<http://example.org/req/731#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The temperature of a minimum of $20 \\%$ of the cells must be monitored by the AMS b" ;
    ns1:isAbout <http://example.org/req/731#ObjSpec_req0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/731#PlanSpec_req0> .

<http://example.org/req/731#AMSb_req0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/731#ActSpec_req0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/731#TempMonitoringProcess_req0> .

<http://example.org/req/731#CellsCoverageQuality_req0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/731#VE_req0_c0> ;
    ns1:qualityOf <http://example.org/req/731#CellsGroup_req0> .

<http://example.org/req/731#VE_req0_c0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns3:minInclusive 2e-01 ;
    ns3:unit <http://qudt.org/vocab/unit/NUM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/731#CellsCoverageQuality_req0> .

<http://qudt.org/vocab/unit/NUM> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/DimensionlessRatio> .

<http://example.org/req/731#CellsGroup_req0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/731#ObjSpec_req0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:prescribes <http://example.org/req/731#TempMonitoringProcess_req0> .

<http://example.org/req/731#PlanSpec_req0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/731#ActSpec_req0>,
        <http://example.org/req/731#ObjSpec_req0> ;
    ns1:prescribes <http://example.org/req/731#TempMonitoringProcess_req0> .

<http://example.org/req/731#TempMonitoringProcess_req0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:hasParticipantAtSomeTime <http://example.org/req/731#AMSb_req0>,
        <http://example.org/req/731#CellsGroup_req0> ;
    ns1:prescribedBy <http://example.org/req/731#PlanSpec_req0> .

