@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/690#> a owl:Ontology .

<http://example.org/req/690#Req_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "mm 4 mm EV.6.5.8 Teams must be prepared to show spacing on team built equipment For inaccessible circuitry, spare boards or appropriate photographs must be available for inspection" ;
    ns2:isAbout <http://example.org/req/690#ObjSpec_0>,
        <http://example.org/req/690#ObjSpec_1> .

<http://example.org/req/690#ActionSpec_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    rdfs:label "action: team shows spacing on team built equipment" ;
    ns2:prescribes <http://example.org/req/690#InspectionProcess_0> .

<http://example.org/req/690#ActionSpec_1> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    rdfs:label "action: maintain availability of spare boards or photographs for inspection" ;
    ns2:prescribes <http://example.org/req/690#AvailabilityProcess_0> .

<http://example.org/req/690#SpareBoardsOrPhotos_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "spare boards or appropriate photographs" .

<http://example.org/req/690#TeamEquipment_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "team built equipment" .

<http://example.org/req/690#Team_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:Agent ;
    rdfs:label "Teams" .

<http://example.org/req/690#ObjSpec_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    rdfs:label "objective: teams prepared to show spacing on team built equipment" ;
    ns2:prescribes <http://example.org/req/690#InspectionProcess_0> .

<http://example.org/req/690#ObjSpec_1> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    rdfs:label "objective: availability of spare boards or appropriate photographs for inspection" ;
    ns2:prescribes <http://example.org/req/690#AvailabilityProcess_0> .

<http://example.org/req/690#PlanSpec_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    rdfs:label "plan for inspection and evidence availability" ;
    ns1:BFO_0000110 <http://example.org/req/690#ActionSpec_0>,
        <http://example.org/req/690#ActionSpec_1>,
        <http://example.org/req/690#ObjSpec_0>,
        <http://example.org/req/690#ObjSpec_1> ;
    ns2:prescribes <http://example.org/req/690#AvailabilityProcess_0>,
        <http://example.org/req/690#InspectionProcess_0> .

<http://example.org/req/690#AvailabilityProcess_0> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        ns1:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "availability of spare boards or appropriate photographs for inspection" ;
    ns1:BFO_0000057 <http://example.org/req/690#SpareBoardsOrPhotos_0> ;
    ns2:prescribedBy <http://example.org/req/690#PlanSpec_0> .

<http://example.org/req/690#InspectionProcess_0> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        ns1:BFO_0000015,
        owl:NamedIndividual,
