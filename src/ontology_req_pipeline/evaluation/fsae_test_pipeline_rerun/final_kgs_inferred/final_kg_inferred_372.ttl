@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/372#> a owl:Ontology .

<http://example.org/req/372#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Attachment of tabs or brackets must meet the following: a. Where brackets are fastened to the chassis, no less than two 6 mm or $1 / 4^{\\prime \\prime}$ minimum diameter Critical Fasteners, see T.8.2 or stronger must be used to attach the bracket to the chassis" ;
    ns1:isAbout <http://example.org/req/372#ObjSpec_AttachTabsBrackets>,
        <http://example.org/req/372#ObjSpec_BracketAttachmentFasteners> ;
    ns1:requirementSatisfiedBy <http://example.org/req/372#DS_AttachTabsBrackets>,
        <http://example.org/req/372#PS_BracketAttachmentFasteners> .

<http://example.org/req/372#Bracket> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/372#BracketAttachedToChassis> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/372#Chassis> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/372#DS_AttachTabsBrackets> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/372#TabsOrBracketsAttachment> .

<http://example.org/req/372#ObjSpec_AttachTabsBrackets> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:prescribes <http://example.org/req/372#TabsOrBracketsAttachment> .

<http://example.org/req/372#Proc_AttachBracketToChassis> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:hasInput <http://example.org/req/372#Bracket>,
        <http://example.org/req/372#Chassis> ;
    ns1:hasSpecifiedOutput <http://example.org/req/372#BracketAttachedToChassis> ;
    ns1:prescribedBy <http://example.org/req/372#PS_BracketAttachmentFasteners> .

<http://example.org/req/372#VE_req1_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 2e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/BEAT> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/372#FastenerCountQuality> .

<http://example.org/req/372#VE_req1_c2> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 6e-03 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/372#FastenerDiameterQuality> .

<http://qudt.org/vocab/unit/BEAT> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Dimensionless> .

<http://qudt.org/vocab/unit/M> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://example.org/req/372#Fastener> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/372#FastenerCountQuality> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/372#VE_req1_c1> ;
    ns1:qualityOf <http://example.org/req/372#Fastener> .

<http://example.org/req/372#FastenerDiameterQuality> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/372#VE_req1_c2> ;
    ns1:qualityOf <http://example.org/req/372#Fastener> .

<http://example.org/req/372#ObjSpec_BracketAttachmentFasteners> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:prescribes <http://example.org/req/372#FastenerCountQuality>,
        <http://example.org/req/372#FastenerDiameterQuality> .

<http://example.org/req/372#PS_BracketAttachmentFasteners> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns3:BFO_0000110 <http://example.org/req/372#ObjSpec_BracketAttachmentFasteners> ;
    ns1:prescribes <http://example.org/req/372#Proc_AttachBracketToChassis> .

<http://example.org/req/372#TabsOrBracketsAttachment> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        owl:NamedIndividual,
        owl:Thing .

