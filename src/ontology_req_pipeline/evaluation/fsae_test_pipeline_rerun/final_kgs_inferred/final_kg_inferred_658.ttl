@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix ns3: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/658#> a owl:Ontology .

<http://example.org/req/658#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Available during charging of any Accumulator(s) EV.5.8.3 The TSMPs must be: a. 4 mm shrouded banana jacks rated to an appropriate voltage level b. Color" ;
    ns1:requirementSatisfiedBy <http://example.org/req/658#TSMP_DesignSpec_0> .

<http://example.org/req/658#TSMP_ComponentRole_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000017,
        ns2:BFO_0000020,
        ns2:BFO_0000023,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialComponentRole ;
    ns1:roleOf <http://example.org/req/658#TSMP_0> .

<http://example.org/req/658#TSMP_DesignSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:isAbout <http://example.org/req/658#TSMP_Objective_0> ;
    ns1:prescribes <http://example.org/req/658#TSMP_0> ;
    ns1:satisfiesRequirement <http://example.org/req/658#Req_0> .

<http://example.org/req/658#TSMP_Use_Plan_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/658#TSMP_Objective_0> .

<http://example.org/req/658#TSMP_Use_Process_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns2:BFO_0000057 <http://example.org/req/658#TSMP_0> ;
    ns1:prescribedBy <http://example.org/req/658#TSMP_Use_Plan_0> .

<http://example.org/req/658#VE_req0_c1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns3:maxInclusive 4e-03 ;
    ns3:minInclusive 4e-03 ;
    ns3:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/658#TSMP_Diameter_0> .

<http://qudt.org/vocab/unit/M> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://example.org/req/658#TSMP_Diameter_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "TSMP connector diameter",
        "TSMP connector diameter"@en ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/658#VE_req0_c1> .

<http://example.org/req/658#TSMP_Objective_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/658#TSMP_Use_Process_0> .

<http://example.org/req/658#TSMP_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialComponent ;
    rdfs:label "TSMPs",
        "TSMPs"@en ;
    ns1:hasQuality <http://example.org/req/658#TSMP_Diameter_0> ;
    ns1:hasRole <http://example.org/req/658#TSMP_ComponentRole_0> .

