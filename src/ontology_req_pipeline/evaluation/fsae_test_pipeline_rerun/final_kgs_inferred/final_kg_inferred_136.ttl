@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/136#> a owl:Ontology .

<http://example.org/req/136#Hole_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns3:BFO_0000050 <http://example.org/req/136#Sample_0> ;
    ns1:hasQuality <http://example.org/req/136#HoleDiameter_0> .

<http://example.org/req/136#PlanSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/136#SupportProcess_0> .

<http://example.org/req/136#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The fixture must support the entire sample, except for a 32 mm hole aligned coaxially with the punch" ;
    ns1:requirementSatisfiedBy <http://example.org/req/136#DesignSpec_0> .

<http://example.org/req/136#SupportFunction_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000016,
        ns3:BFO_0000017,
        ns3:BFO_0000020,
        ns3:BFO_0000034,
        owl:NamedIndividual,
        owl:Thing,
        ns1:Capability,
        ns1:DesignedFunction ;
    ns1:prescribedBy <http://example.org/req/136#DesignSpec_0> .

<http://example.org/req/136#SupportProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns3:BFO_0000057 <http://example.org/req/136#Fixture_0>,
        <http://example.org/req/136#Sample_0> ;
    ns1:prescribedBy <http://example.org/req/136#PlanSpec_0> .

<http://example.org/req/136#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 3.2e-02 ;
    ns2:minInclusive 3.2e-02 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/136#HoleDiameter_0> .

<http://qudt.org/vocab/unit/M> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://example.org/req/136#DesignSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/136#Fixture_0> ;
    ns1:satisfiesRequirement <http://example.org/req/136#Req_0> .

<http://example.org/req/136#Fixture_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    ns1:hasFunction <http://example.org/req/136#SupportFunction_0> .

<http://example.org/req/136#HoleDiameter_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/136#VE_req0_c1> .

<http://example.org/req/136#Sample_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

