    rdfs:label "capacity of engine coolant and lubrication catch cans",
        "capacity of engine coolant and lubrication catch cans"@en ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/451#VE_req2_c0>,
        <http://example.org/req/451#VE_req2_c1> .

<http://example.org/req/451#Capacity_OtherSystems> a <http://purl.obolibrary.org/obo/BFO_0000001>,
