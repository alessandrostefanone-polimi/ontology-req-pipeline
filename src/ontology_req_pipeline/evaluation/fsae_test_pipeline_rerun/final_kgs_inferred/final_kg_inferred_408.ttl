<http://example.org/req/408#ObjSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: BOTS OFF operation opens shutdown circuit" ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/408#Proc_BOTS_Off_Operation> ;
    ns1:prescribes <http://example.org/req/408#Proc_Open_Shutdown_Circuit> .

<http://example.org/req/408#ObjSpec_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: repeated switch operation does not reset or restore power" ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/408#Proc_Repeated_Switch_Operation> ;
    ns1:prescribes <http://example.org/req/408#Proc_Not_Reset_Or_Restore_Power> .

