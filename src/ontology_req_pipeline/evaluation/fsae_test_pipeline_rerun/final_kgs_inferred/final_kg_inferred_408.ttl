<http://example.org/req/408#Proc_BOTS_Off_Operation> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Operation of the BOTS to the OFF position" ;
    ns1:hasParticipantAtSomeTime <http://example.org/req/408#BOTS> ;
