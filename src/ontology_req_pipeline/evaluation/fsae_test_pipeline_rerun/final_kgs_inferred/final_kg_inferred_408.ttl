<http://example.org/req/408#Spec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan spec for BOTS OFF operation opening shutdown circuit" ;
    ns1:prescribes <http://example.org/req/408#Proc_BOTS_Off_Operation>,
