@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/648#> a owl:Ontology .

<http://example.org/req/648#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The Precharge Circuit must: a. Be able to charge the Intermediate Circuit to minimum $90 \\%$ of the Accumulator voltage before closing the second AIR b" ;
    ns1:requirementSatisfiedBy <http://example.org/req/648#PlanSpec_0> .

<http://example.org/req/648#Accumulator_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Accumulator" .

<http://example.org/req/648#CloseSecondAIR_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "closing the second AIR" ;
    ns3:BFO_0000057 <http://example.org/req/648#SecondAIR_0> .

<http://example.org/req/648#IntermediateCircuit_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Intermediate Circuit" .

<http://example.org/req/648#PlanSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/648#PrechargeProcess_0> .

<http://example.org/req/648#PrechargeCircuit_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Precharge Circuit" .

<http://example.org/req/648#SecondAIR_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "second AIR" .

<http://example.org/req/648#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 9e-01 ;
    ns2:unit <http://qudt.org/vocab/unit/NUM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/648#ChargeLevel_0> .

<http://qudt.org/vocab/unit/NUM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/StateOfCharge> .

<http://example.org/req/648#ChargeLevel_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "charge level of Intermediate Circuit relative to Accumulator voltage" ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/648#VE_req0_c1> ;
    ns1:processCharacteristicOf <http://example.org/req/648#PrechargeProcess_0> .

<http://example.org/req/648#PrechargeProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns3:BFO_0000057 <http://example.org/req/648#Accumulator_0>,
        <http://example.org/req/648#IntermediateCircuit_0>,
        <http://example.org/req/648#PrechargeCircuit_0> ;
    ns1:before <http://example.org/req/648#CloseSecondAIR_0> ;
    ns1:hasProcessCharacteristic <http://example.org/req/648#ChargeLevel_0> .

