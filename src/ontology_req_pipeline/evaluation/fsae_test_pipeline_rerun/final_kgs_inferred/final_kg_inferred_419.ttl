@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/419#> a owl:Ontology .

<http://example.org/req/419#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The intent is that in a short circuit the APPSs will only agree at 0\\% Pedal Travel T.4.2.4 Implausibility is defined as a deviation of more than 10\\% Pedal Travel between the sensors or other failure as defined in this Section T.4.2" ;
    ns1:requirementSatisfiedBy <http://example.org/req/419#DS_0>,
        <http://example.org/req/419#PS_1> .

<http://example.org/req/419#ShortCircuitProcess_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "short circuit process context for APPSs" .

<http://example.org/req/419#APPSs_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "APPSs sensor set" ;
    ns1:hasQuality <http://example.org/req/419#PedalTravel_0> .

<http://example.org/req/419#DS_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "APPSs pedal travel agreement design spec" ;
    ns1:prescribes <http://example.org/req/419#APPSs_0> .

<http://example.org/req/419#ImplausibilityAssessmentProcess_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Implausibility assessment between APPS sensors" ;
    ns1:hasProcessCharacteristic <http://example.org/req/419#Deviation_1> .

<http://example.org/req/419#PS_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Implausibility definition plan spec" ;
    ns1:prescribes <http://example.org/req/419#ImplausibilityAssessmentProcess_1> .

<http://example.org/req/419#VE_req0_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Value expression for 0% pedal travel (APPSs, short circuit)" ;
    ns2:maxInclusive 0e+00 ;
    ns2:minInclusive 0e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/NUM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/419#PedalTravel_0> .

<http://example.org/req/419#VE_req1_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Value expression for deviation > 10% pedal travel" ;
    ns2:minExclusive 1e-01 ;
    ns2:unit <http://qudt.org/vocab/unit/NUM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/419#Deviation_1> .

<http://example.org/req/419#Deviation_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "Pedal travel deviation between sensors" ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/419#VE_req1_c1> .

<http://example.org/req/419#PedalTravel_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Pedal travel (APPSs)" ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/419#VE_req0_c2> .

<http://qudt.org/vocab/unit/NUM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/DimensionlessRatio>,
        <http://qudt.org/vocab/quantitykind/PositiveDimensionlessRatio> .

