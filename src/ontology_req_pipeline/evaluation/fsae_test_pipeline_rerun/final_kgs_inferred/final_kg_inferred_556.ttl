@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/556#> a owl:Ontology .

<http://example.org/req/556#Obj_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "objective: circuit monitors electronic throttle control" ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/556#MonitoringProcess_0> ;
    ns1:prescribes <http://example.org/req/556#MonitoringProcessChar_0> .

<http://example.org/req/556#CircuitRole_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000017,
        ns2:BFO_0000020,
        ns2:BFO_0000023,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "standalone nonprogrammable circuit role" ;
    ns1:roleOf <http://example.org/req/556#Circuit_0> .

<http://example.org/req/556#ETC_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000030,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    rdfs:label "electronic throttle control" .

<http://example.org/req/556#MonitoringProcessChar_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "monitoring relation between circuit and electronic throttle control" ;
    ns1:processCharacteristicOf <http://example.org/req/556#MonitoringProcess_0> .

<http://example.org/req/556#Plan_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/556#MonitoringProcess_0> .

<http://example.org/req/556#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Brake System Plausibility Device - BSPD IC.4.8.1 A standalone nonprogrammable circuit must be used to monitor the electronic throttle control" ;
    ns1:requirementSatisfiedBy <http://example.org/req/556#DS_0> .

<http://example.org/req/556#DS_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/556#Circuit_0> ;
    ns1:satisfiesRequirement <http://example.org/req/556#Req_0> .

<http://example.org/req/556#Circuit_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000030,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    rdfs:label "standalone nonprogrammable circuit" ;
    ns1:hasRole <http://example.org/req/556#CircuitRole_0> ;
    ns1:prescribedBy <http://example.org/req/556#DS_0> .

<http://example.org/req/556#MonitoringProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "monitoring of electronic throttle control by circuit" ;
    ns2:BFO_0000057 <http://example.org/req/556#Circuit_0>,
        <http://example.org/req/556#ETC_0> ;
    ns1:prescribedBy <http://example.org/req/556#Plan_0> .

