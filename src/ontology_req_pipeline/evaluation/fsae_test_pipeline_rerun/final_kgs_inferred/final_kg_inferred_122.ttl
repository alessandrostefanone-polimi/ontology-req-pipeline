    rdfs:label "Design specification for test panels" ;
    ns1:prescribes <http://example.org/req/122#TestPanelType> ;
    ns1:satisfiesRequirement <http://example.org/req/122#Req_0> .

<http://example.org/req/122#ObjSpec_TestPanelRequirements> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: test panel geometric and support requirements" .

<http://example.org/req/122#TestPanelType> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
