    rdfs:label "panel edge state (bare vs skinned)" ;
    ns1:qualityOf <http://example.org/req/122#TestPanelType> .

<http://example.org/req/122#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Refer to F.4.3.4 a. Test panels must: - Measure one of the two options: $138 \\mathrm{~mm} \\times 500 \\mathrm{~mm}$ OR $275 \\mathrm{~mm} \\times 500 \\mathrm{~mm}$ - Be supported by a span distance of 400 mm - Have equal surface area for the top and bottom skin - Have bare edges, without skin material b" ;
    ns1:isAbout <http://example.org/req/122#ObjSpec_TestPanelRequirements> ;
    ns1:requirementSatisfiedBy <http://example.org/req/122#DS_TestPanelDesign> .

<http://example.org/req/122#TopSkinArea> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "top skin surface area" ;
    ns1:qualityOf <http://example.org/req/122#TestPanelType> .

<http://qudt.org/vocab/unit/M> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/122#PanelSpanDistance> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "panel support span distance" ;
    ns1:qualityOf <http://example.org/req/122#TestPanelType> .

<http://qudt.org/vocab/unit/MILLIM2> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/CartesianArea> .

<http://example.org/req/122#PanelPlanformArea> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
