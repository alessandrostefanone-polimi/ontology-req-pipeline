<http://example.org/req/122#VE_req1_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Value expression: panel area option 1 (138 mm x 500 mm)" ;
    ns2:maxInclusive 1.38e+02 ;
    ns2:minInclusive 1.38e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/MILLIM2> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/122#PanelPlanformArea> .

<http://example.org/req/122#VE_req1_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
