@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/238#> a owl:Ontology .

<http://example.org/req/238#DesignSpec_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/238#MainHoop>,
        <http://example.org/req/238#MainHoopMountingPlate> ;
    ns2:satisfiesRequirement <http://example.org/req/238#Req_0> .

<http://example.org/req/238#Monocoque> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000030,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact ;
    rdfs:label "monocoque",
        "monocoque"@en .

<http://example.org/req/238#PlanSpec_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns1:BFO_0000110 <http://example.org/req/238#ObjSpec_0> ;
    ns2:prescribes <http://example.org/req/238#MainHoopAttachmentProcess> .

<http://example.org/req/238#PlanSpec_1> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns1:BFO_0000110 <http://example.org/req/238#ObjSpec_0> ;
    ns2:prescribes <http://example.org/req/238#PlateManufacturingProcess> .

<http://example.org/req/238#PlateMaterialRole> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000017,
        ns1:BFO_0000020,
        ns1:BFO_0000023,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "steel material role of Main Hoop mounting plate",
        "steel material role of Main Hoop mounting plate"@en ;
    ns2:roleOf <http://example.org/req/238#MainHoopMountingPlate> .

<http://example.org/req/238#Req_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "7.6 Main Hoop Attachment F.7.6.1 The Main Hoop must be mechanically attached to the monocoque a. Main Hoop mounting plates must be 2.0 mm minimum thickness steel b" ;
    ns2:isAbout <http://example.org/req/238#ObjSpec_0> ;
    ns2:requirementSatisfiedBy <http://example.org/req/238#DesignSpec_0> .

<http://example.org/req/238#VE_req1_c1> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns3:minInclusive 2e-03 ;
    ns3:quantityKind <http://qudt.org/vocab/quantitykind/Thickness> ;
    ns3:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/238#PlateThickness> .

<http://qudt.org/vocab/unit/M> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/Thickness> .

<http://example.org/req/238#MainHoop> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000030,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact ;
    rdfs:label "Main Hoop",
        "Main Hoop"@en .

<http://example.org/req/238#MainHoopAttachmentProcess> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        ns1:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns1:BFO_0000057 <http://example.org/req/238#MainHoop>,
        <http://example.org/req/238#Monocoque> ;
    ns2:prescribedBy <http://example.org/req/238#PlanSpec_0> .

<http://example.org/req/238#PlateManufacturingProcess> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        ns1:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ManufacturingProcess,
        ns2:PlannedProcess ;
    ns2:hasSpecifiedOutput <http://example.org/req/238#MainHoopMountingPlate> ;
    ns2:prescribedBy <http://example.org/req/238#PlanSpec_1> .

<http://example.org/req/238#PlateThickness> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000019,
        ns1:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "thickness of Main Hoop mounting plate",
        "thickness of Main Hoop mounting plate"@en ;
    ns2:hasValueExpressionAtAllTimes <http://example.org/req/238#VE_req1_c1> .

<http://example.org/req/238#MainHoopMountingPlate> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000030,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact ;
    rdfs:label "Main Hoop mounting plate",
        "Main Hoop mounting plate"@en ;
    ns2:hasQuality <http://example.org/req/238#PlateThickness> ;
    ns2:hasRole <http://example.org/req/238#PlateMaterialRole> .

<http://example.org/req/238#ObjSpec_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:isAchievedByAtSomeTime <http://example.org/req/238#MainHoopAttachmentProcess>,
        <http://example.org/req/238#PlateManufacturingProcess> .

