@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix ns3: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/318#> a owl:Ontology .

<http://example.org/req/318#CornerAttachmentAnalysis> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Corner Attachments and Analysis per F.10.5.6 and F.10.5.8" ;
    ns2:BFO_0000057 <http://example.org/req/318#AccumulatorAttachment> ;
    ns1:prescribedBy <http://example.org/req/318#PS_JustificationPlan> .

<http://example.org/req/318#DS_AccumulatorAttachment> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Accumulator Container attachment design specification" ;
    ns1:prescribes <http://example.org/req/318#AccumulatorAttachment> ;
    ns1:satisfiesRequirement <http://example.org/req/318#Req_0> .

<http://example.org/req/318#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Alternate materials Equivalent to 2 mm thickness steel F.10.5.5 Teams must justify the Accumulator Container attachment using one of the two methods: - Corner Attachments and Analysis per F.10.5.6 and F.10.5.8 - Load Based Analysis per F.10.5.7 and F.10.5.8 F.10.5.6 Accumulator Attachment - Corner Attachments a. Eight or more attachments are required for any configuration" ;
    ns1:isAbout <http://example.org/req/318#ObjSpec_AttachmentCount>,
        <http://example.org/req/318#ObjSpec_JustificationMethod>,
        <http://example.org/req/318#ObjSpec_LoadBasedAnalysis> ;
    ns1:requirementSatisfiedBy <http://example.org/req/318#DS_AccumulatorAttachment>,
        <http://example.org/req/318#PS_AttachmentConfigPlan>,
        <http://example.org/req/318#PS_JustificationPlan>,
        <http://example.org/req/318#PS_LoadBasedAnalysisPlan> .

<http://example.org/req/318#Team> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:Agent ;
    rdfs:label "Team" .

<http://example.org/req/318#VE_req3_c0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Value expression: number of attachments ≥ 8" ;
    ns3:minInclusive 8e+00 ;
    ns3:unit <http://qudt.org/vocab/unit/BEAT> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/318#AttachmentCountCharacteristic> .

<http://qudt.org/vocab/unit/BEAT> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/Dimensionless> .

<http://example.org/req/318#JustificationProcess> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Justification of Accumulator Container attachment" ;
    ns2:BFO_0000057 <http://example.org/req/318#Team> ;
    ns1:hasInput <http://example.org/req/318#AccumulatorAttachment> ;
    ns1:prescribedBy <http://example.org/req/318#PS_JustificationPlan> .

<http://example.org/req/318#ObjSpec_AttachmentCount> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: use eight or more attachments for any configuration" ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/318#AttachmentConfigurationProcess> ;
    ns1:prescribes <http://example.org/req/318#AttachmentCountCharacteristic> .

<http://example.org/req/318#ObjSpec_JustificationMethod> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: justify attachment using one of two methods" ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/318#JustificationProcess> ;
    ns1:prescribes <http://example.org/req/318#CornerAttachmentAnalysis>,
        <http://example.org/req/318#LoadBasedAnalysis> .

<http://example.org/req/318#ObjSpec_LoadBasedAnalysis> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: perform Load Based Analysis per F.10.5.7 and F.10.5.8" ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/318#LoadBasedAnalysis> .

<http://example.org/req/318#PS_AttachmentConfigPlan> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan for Accumulator attachment configuration" ;
    ns2:BFO_0000110 <http://example.org/req/318#ObjSpec_AttachmentCount> ;
    ns1:prescribes <http://example.org/req/318#AttachmentConfigurationProcess> .

<http://example.org/req/318#PS_LoadBasedAnalysisPlan> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan for Load Based Analysis" ;
    ns2:BFO_0000110 <http://example.org/req/318#ObjSpec_LoadBasedAnalysis> ;
    ns1:prescribes <http://example.org/req/318#LoadBasedAnalysis> .

<http://example.org/req/318#AttachmentConfigurationProcess> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Configuring attachments for any configuration" ;
    ns2:BFO_0000057 <http://example.org/req/318#AccumulatorAttachment> ;
    ns1:hasProcessCharacteristic <http://example.org/req/318#AttachmentCountCharacteristic> ;
    ns1:prescribedBy <http://example.org/req/318#PS_AttachmentConfigPlan> .

<http://example.org/req/318#AttachmentCountCharacteristic> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "Number of attachments used in configuration" ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/318#VE_req3_c0> ;
    ns1:processCharacteristicOf <http://example.org/req/318#AttachmentConfigurationProcess> .

<http://example.org/req/318#LoadBasedAnalysis> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Load Based Analysis per F.10.5.7 and F.10.5.8" ;
    ns2:BFO_0000057 <http://example.org/req/318#AccumulatorAttachment> ;
    ns1:prescribedBy <http://example.org/req/318#PS_LoadBasedAnalysisPlan> .

<http://example.org/req/318#PS_JustificationPlan> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan for justifying Accumulator Container attachment" ;
    ns2:BFO_0000110 <http://example.org/req/318#ObjSpec_JustificationMethod> ;
    ns1:prescribes <http://example.org/req/318#JustificationProcess> .

<http://example.org/req/318#AccumulatorAttachment> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Accumulator Container attachment" .

