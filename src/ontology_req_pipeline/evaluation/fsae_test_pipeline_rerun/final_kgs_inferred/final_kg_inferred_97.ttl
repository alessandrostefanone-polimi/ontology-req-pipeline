@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/97#> a owl:Ontology .

<http://example.org/req/97#AttachmentObjective_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: steering wheel attached to column with quick disconnect",
        "Objective: steering wheel attached to column with quick disconnect"@en ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/97#AttachmentProcess_0> ;
    ns1:prescribes <http://example.org/req/97#SW_AttachmentRole_0>,
        <http://example.org/req/97#SW_QuickDisconnectRole_0> .

<http://example.org/req/97#ComplianceObjective_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: meet external spec T.1.4.4 V.3.3.2",
        "Objective: meet external spec T.1.4.4 V.3.3.2"@en ;
    ns1:isAbout <http://example.org/req/97#ExternalSpec_T_1_4_4_V_3_3_2> ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/97#SteeringWheelUseProcess_0> .

<http://example.org/req/97#AS_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Action: operate steering wheel in any angular position",
        "Action: operate steering wheel in any angular position"@en ;
    ns1:prescribes <http://example.org/req/97#SteeringWheelUseProcess_0> .

<http://example.org/req/97#AngularPositionState_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "any angular position state of steering wheel",
        "any angular position state of steering wheel"@en ;
    ns1:processCharacteristicOf <http://example.org/req/97#SteeringWheelUseProcess_0> .

<http://example.org/req/97#AttachmentProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Process: attaching steering wheel to column with quick disconnect",
        "Process: attaching steering wheel to column with quick disconnect"@en ;
    ns2:BFO_0000057 <http://example.org/req/97#Column_0>,
        <http://example.org/req/97#QuickDisconnect_0>,
        <http://example.org/req/97#SteeringWheel_0> ;
    ns1:hasSpecifiedOutput <http://example.org/req/97#SteeringWheel_0> ;
    ns1:prescribedBy <http://example.org/req/97#PS_0> .

<http://example.org/req/97#DS_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/97#Column_0>,
        <http://example.org/req/97#QuickDisconnect_0>,
        <http://example.org/req/97#SteeringWheel_0> ;
    ns1:satisfiesRequirement <http://example.org/req/97#Req_0> .

<http://example.org/req/97#ExternalSpec_T_1_4_4_V_3_3_2> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "External specification T.1.4.4 V.3.3.2",
        "External specification T.1.4.4 V.3.3.2"@en .

<http://example.org/req/97#OS_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: steering wheel compliance and attachment in any angular position",
        "Objective: steering wheel compliance and attachment in any angular position"@en ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/97#SteeringWheelUseProcess_0> .

<http://example.org/req/97#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "In any angular position, the Steering Wheel must meet T.1.4.4 V.3.3.2 The Steering Wheel must be attached to the column with a quick disconnect" ;
    ns1:requirementSatisfiedBy <http://example.org/req/97#DS_0>,
        <http://example.org/req/97#PS_0> .

<http://example.org/req/97#Column_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Steering column (design-constrained)",
        "Steering column (design-constrained)"@en .

<http://example.org/req/97#QuickDisconnect_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Quick disconnect (design-constrained)",
        "Quick disconnect (design-constrained)"@en .

<http://example.org/req/97#SW_AttachmentRole_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000017,
        ns2:BFO_0000020,
        ns2:BFO_0000023,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "role: being attached to column",
        "role: being attached to column"@en ;
    ns1:roleOf <http://example.org/req/97#SteeringWheel_0> .

<http://example.org/req/97#SW_QuickDisconnectRole_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000017,
        ns2:BFO_0000020,
        ns2:BFO_0000023,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "role: having quick disconnect",
        "role: having quick disconnect"@en ;
    ns1:roleOf <http://example.org/req/97#SteeringWheel_0> .

<http://example.org/req/97#PS_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/97#AS_0>,
        <http://example.org/req/97#OS_0> ;
    ns1:prescribes <http://example.org/req/97#SteeringWheelUseProcess_0> .

<http://example.org/req/97#SteeringWheelUseProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Process: use / operation of steering wheel over angular positions",
        "Process: use / operation of steering wheel over angular positions"@en ;
    ns2:BFO_0000057 <http://example.org/req/97#SteeringWheel_0> ;
    ns1:hasProcessCharacteristic <http://example.org/req/97#AngularPositionState_0> ;
    ns1:prescribedBy <http://example.org/req/97#PS_0> .

<http://example.org/req/97#SteeringWheel_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Steering Wheel (design-constrained)",
        "Steering Wheel (design-constrained)"@en ;
    ns1:hasRole <http://example.org/req/97#SW_AttachmentRole_0>,
        <http://example.org/req/97#SW_QuickDisconnectRole_0> .

