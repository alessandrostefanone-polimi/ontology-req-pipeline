@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/234#> a owl:Ontology .

<http://example.org/req/234#DS_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/234#SideImpactZonePortion_0> ;
    ns2:satisfiesRequirement <http://example.org/req/234#Req_0> .

<http://example.org/req/234#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "The portion of the Side Impact Zone that is vertically between the upper surface of the floor and 320 mm above the lowest point of the upper surface of the floor (see figure above) must have: a. Equivalence to minimum two (2) Steel Tubes (F.3.2.1.e) per F.4.4 b" ;
    ns2:requirementSatisfiedBy <http://example.org/req/234#DS_0> .

<http://example.org/req/234#SideImpactZone_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Side Impact Zone" .

<http://example.org/req/234#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:minInclusive 2e+00 ;
    ns1:unit <http://qudt.org/vocab/unit/BEAT> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/234#SideImpactZonePortion_0> .

<http://qudt.org/vocab/unit/BEAT> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Dimensionless> .

<http://example.org/req/234#SideImpactZonePortion_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Portion of Side Impact Zone between floor surface and 320 mm above" ;
    ns2:componentPartOfAtSomeTime <http://example.org/req/234#SideImpactZone_0> ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/234#VE_req0_c0> .

