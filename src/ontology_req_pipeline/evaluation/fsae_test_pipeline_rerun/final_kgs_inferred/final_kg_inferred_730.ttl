@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/730#> a owl:Ontology .

<http://example.org/req/730#Req_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "The temperature sensor used must be in direct contact with one of: - The negative terminal itself - The negative terminal busbar less than 10 mm away from the cell terminal EV.7.5.5 For lithium based cells, a" ;
    ns2:requirementSatisfiedBy <http://example.org/req/730#DS_0> .

<http://example.org/req/730#VE_req0_c2> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns3:maxExclusive 1e-02 ;
    ns3:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/730#Distance_NegBusbar_CellTerminal_0> .

<http://example.org/req/730#DS_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/730#CellTerminal_0>,
        <http://example.org/req/730#NegBusbar_0>,
        <http://example.org/req/730#NegTerminal_0>,
        <http://example.org/req/730#TempSensor_0> .

<http://example.org/req/730#DistanceRelation_0> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        ns1:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:BFO_0000057 <http://example.org/req/730#CellTerminal_0>,
        <http://example.org/req/730#NegBusbar_0> ;
    ns2:hasProcessCharacteristic <http://example.org/req/730#Distance_NegBusbar_CellTerminal_0> .

<http://example.org/req/730#NegTerminal_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/730#TempSensor_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://qudt.org/vocab/unit/M> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/730#CellTerminal_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/730#Distance_NegBusbar_CellTerminal_0> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:processCharacteristicOf <http://example.org/req/730#DistanceRelation_0> .

<http://example.org/req/730#NegBusbar_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

