@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/440#> a owl:Ontology .

<http://example.org/req/440#Object_12mm_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasQuality <http://example.org/req/440#Object_12mm_Diameter_0> .

<http://example.org/req/440#Req1_PassageConstraint_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:isAchievedByAtSomeTime <http://example.org/req/440#GuardUsageProcess_0> ;
    ns2:prescribes <http://example.org/req/440#BlockedPassageEvent_0> .

<http://example.org/req/440#BlockedPassageEvent_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:Event ;
    ns2:recognizedByAtSomeTime <http://example.org/req/440#SafetyEngineer_0> .

<http://example.org/req/440#GuardDesignSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/440#Guard_0> ;
    ns2:satisfiesRequirement <http://example.org/req/440#Req_0> .

<http://example.org/req/440#GuardUsagePlan_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns3:BFO_0000110 <http://example.org/req/440#Req0_UsageConstraint_0> ;
    ns2:prescribes <http://example.org/req/440#GuardUsageProcess_0> .

<http://example.org/req/440#Guard_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasComponentPartAtSomeTime <http://example.org/req/440#GuardMaterial_0> .

<http://example.org/req/440#Req0_UsageConstraint_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:isAchievedByAtSomeTime <http://example.org/req/440#GuardUsageProcess_0> ;
    ns2:prescribes <http://example.org/req/440#GuardMaterialRole_0> .

<http://example.org/req/440#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "Mesh or perforated material may be used but must prevent the passage of a 12 mm diameter object through the guard" ;
    ns2:requirementSatisfiedBy <http://example.org/req/440#GuardDesignSpec_0> .

<http://example.org/req/440#SafetyEngineer_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:Agent,
        ns2:Person .

<http://example.org/req/440#VE_req1_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 1.2e-02 ;
    ns1:minInclusive 1.2e-02 ;
    ns1:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/440#Object_12mm_Diameter_0> .

<http://qudt.org/vocab/unit/M> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://example.org/req/440#GuardMaterialRole_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000017,
        ns3:BFO_0000020,
        ns3:BFO_0000023,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:roleOf <http://example.org/req/440#GuardMaterial_0> .

<http://example.org/req/440#Object_12mm_Diameter_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/440#VE_req1_c1> .

<http://example.org/req/440#GuardMaterial_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact ;
    ns2:hasRole <http://example.org/req/440#GuardMaterialRole_0> .

<http://example.org/req/440#GuardUsageProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns3:BFO_0000057 <http://example.org/req/440#GuardMaterial_0> ;
    ns2:prescribedBy <http://example.org/req/440#GuardUsagePlan_0> .

