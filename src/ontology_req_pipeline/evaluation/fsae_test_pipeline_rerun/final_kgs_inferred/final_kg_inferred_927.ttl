@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/927#> a owl:Ontology .

<http://example.org/req/927#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "10.1.3 Course Operation a. Vehicles will enter and exit through gates on a 3.0 m wide path that is tangential to the circles where they meet" ;
    ns2:requirementSatisfiedBy <http://example.org/req/927#PlanSpec_0> .

<http://example.org/req/927#PathTangency_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "Tangency of the vehicle path to the circles" ;
    ns2:processCharacteristicOf <http://example.org/req/927#VehicleGateTransitProcess_0> .

<http://example.org/req/927#PlanSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/927#VehicleGateTransitProcess_0> .

<http://example.org/req/927#VE_req0_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "Required path width = 3.0 m" ;
    ns1:maxInclusive 3e+00 ;
    ns1:minInclusive 3e+00 ;
    ns1:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/927#PathWidth_0> .

<http://example.org/req/927#Vehicle_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:Agent ;
    rdfs:label "Vehicle" .

<http://qudt.org/vocab/unit/M> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Width> .

<http://example.org/req/927#PathWidth_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "Width of the vehicle path at gates" ;
    ns2:hasValueExpressionAtAllTimes <http://example.org/req/927#VE_req0_c0> ;
    ns2:processCharacteristicOf <http://example.org/req/927#VehicleGateTransitProcess_0> .

<http://example.org/req/927#VehicleGateTransitProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "Vehicle entering and exiting through gates on a path" ;
    ns3:BFO_0000057 <http://example.org/req/927#Vehicle_0> ;
    ns2:hasProcessCharacteristic <http://example.org/req/927#PathTangency_0>,
        <http://example.org/req/927#PathWidth_0> .

