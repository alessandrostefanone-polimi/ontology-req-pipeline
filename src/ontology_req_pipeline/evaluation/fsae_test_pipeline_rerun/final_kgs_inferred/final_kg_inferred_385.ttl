@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/385#> a owl:Ontology .

<http://example.org/req/385#DS_Req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/385#Bolt_Req0> ;
    ns2:satisfiesRequirement <http://example.org/req/385#Req_0> .

<http://example.org/req/385#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:minInclusive 0e+00 ;
    ns1:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/385#BoltDiameter_Req0> .

<http://example.org/req/385#VE_req1_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 3.490659e-01 ;
    ns1:unit <http://qudt.org/vocab/unit/RAD> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/385#ASBeltSideViewAngle_Req1> .

<http://qudt.org/vocab/unit/M> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://qudt.org/vocab/unit/RAD> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/PlaneAngle> .

<http://example.org/req/385#ASBeltMountingProcess_Req1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "Anti-Submarine Belt mounting process (Req 1)" ;
    ns2:hasProcessCharacteristic <http://example.org/req/385#ASBeltSideViewAngle_Req1> ;
    ns2:prescribedBy <http://example.org/req/385#PS_Req1> .

<http://example.org/req/385#ASBeltSideViewAngle_Req1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "Anti-Submarine Belt Side View Angle (Req 1)" ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/385#VE_req1_c2> ;
    ns2:processCharacteristicOf <http://example.org/req/385#ASBeltMountingProcess_Req1> .

<http://example.org/req/385#BoltDiameter_Req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Diameter of bolt (Req 0)" ;
    ns2:hasValueExpressionAtAllTimes <http://example.org/req/385#VE_req0_c1> ;
    ns2:qualityOf <http://example.org/req/385#Bolt_Req0> .

<http://example.org/req/385#Bolt_Req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Bolt used to attach a Shoulder Belt (Req 0)" ;
    ns2:hasQuality <http://example.org/req/385#BoltDiameter_Req0> ;
    ns2:satisfiesRequirement <http://example.org/req/385#Req_0> .

<http://example.org/req/385#PS_Req1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/385#ASBeltMountingProcess_Req1> ;
    ns2:satisfiesRequirement <http://example.org/req/385#Req_0> .

<http://example.org/req/385#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "Any bolt used to attach a Shoulder Belt, directly to the chassis or to an intermediate bracket, is a Critical Fasteners, see T.8.2, with a minimum diameter that is the smaller of: - The bolt diameter specified by the manufacturer - 10 mm or $3 / 8^{\\prime \\prime}$ ## T.2.7 Anti-Submarine Belt Mounting T.2.7.1 The Anti-Submarine Belt of a 5 point harness must be mounted with the mounting point in line with or slightly forward of the driver's Chest to Groin Line with an Anti-Submarine Belt Side View Angle no more than $20^{\\circ}$" ;
    ns2:requirementSatisfiedBy <http://example.org/req/385#DS_Req0>,
        <http://example.org/req/385#PS_Req1> .

