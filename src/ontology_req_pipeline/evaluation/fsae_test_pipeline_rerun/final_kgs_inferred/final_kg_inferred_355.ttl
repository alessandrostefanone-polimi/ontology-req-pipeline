<http://example.org/req/355#ConductionIsolationMaterial_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "heat resistant conduction isolation material",
        "heat resistant conduction isolation material"@en ;
    ns2:componentPartOfAtSomeTime <http://example.org/req/355#Design_0> .

<http://example.org/req/355#ContactPanel_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
