        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:minInclusive 8e-03 ;
    ns1:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/355#ConductionIsolationMaterialThickness_0> .

