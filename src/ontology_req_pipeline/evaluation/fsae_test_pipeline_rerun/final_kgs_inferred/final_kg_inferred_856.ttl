@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/856#> a owl:Ontology .

<http://example.org/req/856#CostSourceConstraint> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:label "Constraint: all costs in the Cost Report must come from the standardized Cost Tables",
        "Constraint: all costs in the Cost Report must come from the standardized Cost Tables"@en ;
    ns2:isAbout <http://example.org/req/856#ReportedCosts>,
        <http://example.org/req/856#StandardizedCostTables> .

<http://example.org/req/856#CostReport> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:label "Cost Report",
        "Cost Report"@en ;
    ns2:isAbout <http://example.org/req/856#ReportedCosts> .

<http://example.org/req/856#CostReportingProcess> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "Cost reporting process",
        "Cost reporting process"@en ;
    ns2:hasSpecifiedOutput <http://example.org/req/856#CostReport> .

<http://example.org/req/856#DS_RemovedItemCredit> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/856#RemovedItemCreditPolicy> ;
    ns2:satisfiesRequirement <http://example.org/req/856#Req_0> .

<http://example.org/req/856#PS_CostSource> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/856#CostReportingProcess> ;
    ns2:satisfiesRequirement <http://example.org/req/856#Req_0> .

<http://example.org/req/856#RemovedItemCreditPolicy> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Removed item credit policy",
        "Removed item credit policy"@en ;
    ns2:hasQuality <http://example.org/req/856#CreditAmountQuality> .

<http://example.org/req/856#StandardizedCostTables> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:label "Standardized Cost Tables",
        "Standardized Cost Tables"@en .

<http://example.org/req/856#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 7.5e-01 ;
    ns1:minInclusive 7.5e-01 ;
    ns1:unit <http://qudt.org/vocab/unit/NUM> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/856#CreditAmountQuality> .

<http://qudt.org/vocab/unit/NUM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/DimensionlessRatio> .

<http://example.org/req/856#CreditAmountQuality> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Credit amount fraction of table cost",
        "Credit amount fraction of table cost"@en ;
    ns2:hasValueExpressionAtAllTimes <http://example.org/req/856#VE_req0_c0> .

<http://example.org/req/856#ReportedCosts> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Costs in the Cost Report",
        "Costs in the Cost Report"@en .

<http://example.org/req/856#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "Removed items will be credited $75 \\%$ of the table cost: - ( $0.75 \\times$ Cost) ### 5.3.8 Cost Tables 5.3.8.1 All costs in the Cost Report must come from the standardized Cost Tables. 5.3.8.2" ;
    ns2:requirementSatisfiedBy <http://example.org/req/856#DS_RemovedItemCredit>,
        <http://example.org/req/856#PS_CostSource> .

