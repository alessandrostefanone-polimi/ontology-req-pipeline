@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/89#> a owl:Ontology .

<http://example.org/req/89#CriticalFastener> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasRole <http://example.org/req/89#CriticalFastenerRole> .

<http://example.org/req/89#Req0_Constraint0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:comment "Fasteners in the Suspension system are Critical Fasteners" ;
    ns2:isAbout <http://example.org/req/89#CriticalFastenerRole> .

<http://example.org/req/89#Req1_Constraint0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:comment "All spherical rod ends and spherical bearings on the suspension and steering must be one of the specified mounting configurations" ;
    ns2:isAbout <http://example.org/req/89#SphericalJointMountingProcess> .

<http://example.org/req/89#Req2_Constraint0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:comment "Mounted in double shear" ;
    ns2:isAbout <http://example.org/req/89#DoubleShearMountingConfiguration> .

<http://example.org/req/89#Req3_Constraint0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:comment "Captured by having a screw/bolt head or washer" ;
    ns2:isAbout <http://example.org/req/89#CapturingConfiguration> .

<http://example.org/req/89#Req3_Constraint1> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:comment "Outside diameter of the screw/bolt head or washer is larger than spherical bearing housing inside diameter" ;
    ns2:isAbout <http://example.org/req/89#OutsideDiameter>,
        <http://example.org/req/89#SphericalBearingHousingInsideDiameter> .

<http://example.org/req/89#Req4_Constraint0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:comment "The Steering Wheel must be mechanically connected to the front wheels" ;
    ns2:isAbout <http://example.org/req/89#MechanicalConnectionToFrontWheels> .

<http://example.org/req/89#CapturingConfiguration> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000019,
        ns1:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/89#DoubleShearMountingConfiguration> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000019,
        ns1:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/89#FrontWheels> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/89#MechanicalConnectionToFrontWheels> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000019,
        ns1:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:qualityOf <http://example.org/req/89#SteeringWheel> .

<http://example.org/req/89#OutsideDiameter> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000019,
        ns1:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:qualityOf <http://example.org/req/89#ScrewBoltHeadOrWasher> .

<http://example.org/req/89#Req_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "3.1.4 Fasteners in the Suspension system are Critical Fasteners, see T.8.2 V.3.1.5 All spherical rod ends and spherical bearings on the suspension and steering must be one of: - Mounted in double shear - Captured by having a screw/bolt head or washer with an outside diameter that is larger than spherical bearing housing inside diameter. ## V.3.2 Steering V.3.2.1 The Steering Wheel must be mechanically connected to the front wheels" ;
    ns2:requirementSatisfiedBy <http://example.org/req/89#SphericalJointMountingPlanSpec>,
        <http://example.org/req/89#SteeringConnectionPlanSpec>,
        <http://example.org/req/89#SuspensionFastenerDesignSpec> .

<http://example.org/req/89#ScrewBoltHeadOrWasher> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/89#SphericalBearingHousingInsideDiameter> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000019,
        ns1:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:qualityOf <http://example.org/req/89#SphericalBearing> .

<http://example.org/req/89#SphericalJointMountingPlanSpec> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/89#SphericalJointMountingProcess> .

<http://example.org/req/89#SphericalRodEnd> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/89#SteeringConnectionPlanSpec> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/89#SteeringConnectionProcess> .

<http://example.org/req/89#SteeringConnectionProcess> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        ns1:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns1:BFO_0000057 <http://example.org/req/89#FrontWheels>,
        <http://example.org/req/89#SteeringWheel> .

<http://example.org/req/89#SuspensionFastener> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:BFO_0000176 <http://example.org/req/89#SuspensionSystem> .

<http://example.org/req/89#SuspensionFastenerDesignSpec> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/89#SuspensionFastener> ;
    ns2:satisfiesRequirement <http://example.org/req/89#Req_0> .

<http://example.org/req/89#SuspensionSystem> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/89#CriticalFastenerRole> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000017,
        ns1:BFO_0000020,
        ns1:BFO_0000023,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/89#SphericalBearing> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/89#SphericalJointMountingProcess> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        ns1:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns1:BFO_0000057 <http://example.org/req/89#SphericalBearing>,
        <http://example.org/req/89#SphericalRodEnd> .

<http://example.org/req/89#SteeringWheel> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

