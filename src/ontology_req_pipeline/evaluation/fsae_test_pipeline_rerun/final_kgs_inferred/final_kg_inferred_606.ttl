@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix ns3: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/606#> a owl:Ontology .

<http://example.org/req/606#CockpitMainSwitch_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000030,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns3:hasQuality <http://example.org/req/606#Diameter_Quality_0> .

<http://example.org/req/606#DesignSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns3:DesignSpecification,
        ns3:DirectiveInformationContentEntity,
        ns3:InformationContentEntity ;
    ns3:prescribes <http://example.org/req/606#CockpitMainSwitch_0> ;
    ns3:satisfiesRequirement <http://example.org/req/606#Req_0> .

<http://example.org/req/606#ObjSpec_1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns3:InformationContentEntity,
        ns3:ObjectiveSpecification ;
    ns3:isAchievedByAtSomeTime <http://example.org/req/606#Process_Req1> .

<http://example.org/req/606#PlanSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns3:ActionSpecification,
        ns3:DirectiveInformationContentEntity,
        ns3:InformationContentEntity,
        ns3:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/606#ObjSpec_0> ;
    ns3:prescribes <http://example.org/req/606#Process_Req0> .

<http://example.org/req/606#VE_req0_c0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns3:InformationContentEntity,
        ns3:ValueExpression ;
    ns1:minInclusive 2.4e-02 ;
    ns1:unit <http://qudt.org/vocab/unit/M> ;
    ns3:isValueExpressionOfAtSomeTime <http://example.org/req/606#Diameter_Quality_0> .

<http://qudt.org/vocab/unit/M> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://example.org/req/606#ObjSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns3:DirectiveInformationContentEntity,
        ns3:InformationContentEntity,
        ns3:ObjectiveSpecification ;
    ns3:isAchievedByAtSomeTime <http://example.org/req/606#Process_Req0> ;
    ns3:prescribes <http://example.org/req/606#Diameter_Quality_0> .

<http://example.org/req/606#PlanSpec_1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns3:ActionSpecification,
        ns3:DirectiveInformationContentEntity,
        ns3:InformationContentEntity,
        ns3:PlanSpecification ;
    ns3:prescribes <http://example.org/req/606#Process_Req1> ;
    ns3:satisfiesRequirement <http://example.org/req/606#Req_0> .

<http://example.org/req/606#Process_Req0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns3:PlannedProcess ;
    ns3:prescribedBy <http://example.org/req/606#PlanSpec_0> .

<http://example.org/req/606#Process_Req1> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns3:PlannedProcess ;
    ns3:prescribedBy <http://example.org/req/606#PlanSpec_1> .

<http://example.org/req/606#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns3:InformationContentEntity,
        ns3:RequirementSpecification ;
    rdfs:comment "Have a diameter of 24 mm minimum IC.9.4.2 Location - The Cockpit Main Switch must be: a" ;
    ns3:isAbout <http://example.org/req/606#ObjSpec_0>,
        <http://example.org/req/606#ObjSpec_1> ;
    ns3:requirementSatisfiedBy <http://example.org/req/606#DesignSpec_0>,
        <http://example.org/req/606#PlanSpec_1> .

<http://example.org/req/606#Diameter_Quality_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns3:hasValueExpressionAtSomeTime <http://example.org/req/606#VE_req0_c0> .

