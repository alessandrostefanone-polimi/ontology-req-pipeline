@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix ns3: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/646#> a owl:Ontology .

<http://example.org/req/646#Accumulator_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Accumulator",
        "Accumulator"@en .

<http://example.org/req/646#DS_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Design spec for capacitor holding AIRs closed",
        "Design spec for capacitor holding AIRs closed"@en ;
    ns1:prescribes <http://example.org/req/646#AIRs_0>,
        <http://example.org/req/646#Capacitor_0> ;
    ns1:satisfiesRequirement <http://example.org/req/646#Req_0> .

<http://example.org/req/646#PS_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan for capacitor holding AIRs closed after shutdown circuit opens",
        "Plan for capacitor holding AIRs closed after shutdown circuit opens"@en ;
    ns2:BFO_0000110 <http://example.org/req/646#ObjSpec_0> ;
    ns1:prescribes <http://example.org/req/646#CapHoldProcess_0> .

<http://example.org/req/646#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "A capacitor may be used to hold the AIRs closed for up to 250 ms after the Shutdown Circuit Opens EV.7.2.2 ## EV.5.5 High Voltage Disconnect - HVD A High Voltage Disconnect (HVD) must be included to quickly disconnect one or both poles of the Accumulator EV.11.3.2 EV.5.5.1 The High Voltage Disconnect (HVD) must be: a" ;
    ns1:isAbout <http://example.org/req/646#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/646#DS_0>,
        <http://example.org/req/646#PS_1>,
        <http://example.org/req/646#PS_2> .

<http://example.org/req/646#ShutdownCircuitOpen_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Shutdown Circuit Opens process",
        "Shutdown Circuit Opens process"@en .

<http://example.org/req/646#VE_req0_c1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "hold time ≤ 0.25 s",
        "hold time ≤ 0.25 s"@en ;
    ns3:maxInclusive 2.5e-01 ;
    ns3:unit <http://qudt.org/vocab/unit/SEC> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/646#HoldTime_0> .

<http://qudt.org/vocab/unit/SEC> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/Time> .

<http://example.org/req/646#AIRs_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "AIRs",
        "AIRs"@en .

<http://example.org/req/646#Capacitor_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "capacitor used to hold AIRs closed",
        "capacitor used to hold AIRs closed"@en .

<http://example.org/req/646#HVDBeProcess_2> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "process expressing that HVD must be of a certain type",
        "process expressing that HVD must be of a certain type"@en ;
    ns2:BFO_0000057 <http://example.org/req/646#HVD_0> ;
    ns1:prescribedBy <http://example.org/req/646#PS_2> .

<http://example.org/req/646#HVDDisconnectProcess_1> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "HVD disconnection of one or both accumulator poles",
        "HVD disconnection of one or both accumulator poles"@en ;
    ns2:BFO_0000057 <http://example.org/req/646#Accumulator_0>,
        <http://example.org/req/646#HVD_0> ;
    ns1:prescribedBy <http://example.org/req/646#PS_1> .

<http://example.org/req/646#HVD_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "High Voltage Disconnect (HVD)",
        "High Voltage Disconnect (HVD)"@en .

<http://example.org/req/646#HoldTime_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "hold time of AIRs closed by capacitor",
        "hold time of AIRs closed by capacitor"@en ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/646#VE_req0_c1> ;
    ns1:processCharacteristicOf <http://example.org/req/646#CapHoldProcess_0> .

<http://example.org/req/646#PS_1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan for including HVD to disconnect accumulator poles",
        "Plan for including HVD to disconnect accumulator poles"@en ;
    ns2:BFO_0000110 <http://example.org/req/646#ObjSpec_0> ;
    ns1:prescribes <http://example.org/req/646#HVDDisconnectProcess_1> .

<http://example.org/req/646#PS_2> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan related to HVD being of a certain type",
        "Plan related to HVD being of a certain type"@en ;
    ns2:BFO_0000110 <http://example.org/req/646#ObjSpec_0> ;
    ns1:prescribes <http://example.org/req/646#HVDBeProcess_2> .

<http://example.org/req/646#CapHoldProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "process of capacitor holding AIRs closed",
        "process of capacitor holding AIRs closed"@en ;
    ns2:BFO_0000057 <http://example.org/req/646#AIRs_0>,
        <http://example.org/req/646#Capacitor_0> ;
    ns1:hasProcessCharacteristic <http://example.org/req/646#HoldTime_0> ;
    ns1:occursDuring <http://example.org/req/646#ShutdownCircuitOpen_0> ;
    ns1:prescribedBy <http://example.org/req/646#PS_0> .

<http://example.org/req/646#ObjSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objectives for capacitor use and HVD behavior",
        "Objectives for capacitor use and HVD behavior"@en ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/646#CapHoldProcess_0>,
        <http://example.org/req/646#HVDBeProcess_2>,
        <http://example.org/req/646#HVDDisconnectProcess_1> .

