@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/462#> a owl:Ontology .

<http://example.org/req/462#DesignSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/462#ForwardFacingEdge_Horiz>,
        <http://example.org/req/462#ForwardFacingEdge_Vert> ;
    ns1:satisfiesRequirement <http://example.org/req/462#Req_0> .

<http://example.org/req/462#ForwardFacingEdge_Horiz> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "forward facing horizontal edge that could contact a pedestrian (wings, end plates, undertrays)",
        "forward facing horizontal edge that could contact a pedestrian (wings, end plates, undertrays)"@en ;
    ns1:hasQuality <http://example.org/req/462#EdgeRadiusQuality_Horiz> .

<http://example.org/req/462#ForwardFacingEdge_Vert> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "forward facing vertical edge that could contact a pedestrian (wings, end plates, undertrays)",
        "forward facing vertical edge that could contact a pedestrian (wings, end plates, undertrays)"@en ;
    ns1:hasQuality <http://example.org/req/462#EdgeRadiusQuality_Vert> .

<http://example.org/req/462#ObjSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:prescribes <http://example.org/req/462#EdgeRadiusQuality_Horiz>,
        <http://example.org/req/462#EdgeRadiusQuality_Vert> .

<http://example.org/req/462#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Refer to IN.8.2 T.7.1.4 All forward facing edges that could contact a pedestrian (wings, end plates, and undertrays) must have a minimum radius of 5 mm for all horizontal edges and 3 mm for vertical edges" ;
    ns1:isAbout <http://example.org/req/462#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/462#DesignSpec_0> .

<http://example.org/req/462#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 5e-03 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/462#EdgeRadiusQuality_Horiz> .

<http://example.org/req/462#VE_req0_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 3e-03 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/462#EdgeRadiusQuality_Vert> .

<http://qudt.org/vocab/unit/M> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Radius> .

<http://example.org/req/462#EdgeRadiusQuality_Horiz> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "radius of forward facing horizontal edge",
        "radius of forward facing horizontal edge"@en ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/462#VE_req0_c1> .

<http://example.org/req/462#EdgeRadiusQuality_Vert> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "radius of forward facing vertical edge",
        "radius of forward facing vertical edge"@en ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/462#VE_req0_c2> .

