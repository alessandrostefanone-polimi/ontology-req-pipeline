@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/194#> a owl:Ontology .

<http://example.org/req/194#DS_Lug_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/194#Lug_0> ;
    ns1:satisfiesRequirement <http://example.org/req/194#Req_0> .

<http://example.org/req/194#Lug_0_Material> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "material of lug (req 0)",
        "material of lug (req 0)"@en ;
    ns1:qualityOf <http://example.org/req/194#Lug_0> .

<http://example.org/req/194#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "[img-9.jpeg](img-9.jpeg) F.5.12.3 For Double Lug Joints, each lug must: a. Be minimum 4.5 mm ( 0.177 in) thickness steel b" ;
    ns1:requirementSatisfiedBy <http://example.org/req/194#Lug_0> .

<http://example.org/req/194#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "minimum thickness 4.5 mm (0.0045 m) for lug (req 0, constraint 0)",
        "minimum thickness 4.5 mm (0.0045 m) for lug (req 0, constraint 0)"@en ;
    ns2:minInclusive 4.5e-03 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/194#Lug_0_Thickness> .

<http://qudt.org/vocab/unit/M> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Thickness> .

<http://example.org/req/194#Lug_0_Thickness> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "thickness of lug (req 0)",
        "thickness of lug (req 0)"@en ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/194#VE_req0_c0> ;
    ns1:qualityOf <http://example.org/req/194#Lug_0> .

<http://example.org/req/194#Lug_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "lug (subject of requirement 0)",
        "lug (subject of requirement 0)"@en ;
    ns1:hasQuality <http://example.org/req/194#Lug_0_Material>,
        <http://example.org/req/194#Lug_0_Thickness> .

