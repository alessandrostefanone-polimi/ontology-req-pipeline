@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/476#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:DS_Req0_0 a iof:PlanSpecification ;
    rdfs:comment "Design specification satisfying: T.9.2.1 All Low Voltage Batteries and onboard power supplies must be securely mounted inside the Chassis below the height of the Shoulder Belt Mount T.2.6"@en ;
    iof:prescribes :Mounting_Process_Req0 ;
    iof:satisfiesRequirement :Req_0 .

:DS_Req0_1 a iof:PlanSpecification ;
    rdfs:comment "Plan / design specification satisfying: T.9.2.2 All Low Voltage batteries must have Overcurrent Protection that trips at or below the maximum specified discharge current of the cells"@en ;
    iof:prescribes :Cell_Discharge_Current_Characteristic,
        :LV_Battery_Collection,
        :Overcurrent_Protection_Req1 ;
    iof:satisfiesRequirement :Req_0 .

:DS_Req0_2 a iof:DesignSpecification ;
    rdfs:comment "Design specification satisfying: T.9.2.3 The hot (ungrounded) terminal must be insulated"@en ;
    iof:prescribes :Hot_Ungrounded_Terminal,
        :Insulation_Quality_Req2 ;
    iof:satisfiesRequirement :Req_0 .

:Chassis a bfo:BFO_0000040 ;
    rdfs:label "Chassis"@en .

:Insulation_Objective_Req2 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: hot (ungrounded) terminal is insulated"@en ;
    iof:prescribes :Insulation_Quality_Req2 .

:Mounting_Objective_Req0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: LV batteries and onboard power supplies securely mounted inside chassis below shoulder belt mount"@en ;
    iof:prescribes :Mounting_Process_Req0 .

:Onboard_Power_Supply_Collection a bfo:BFO_0000040 ;
    rdfs:label "Onboard power supplies"@en .

:Overcurrent_Protection_Objective_Req1 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: LV batteries have overcurrent protection that trips at or below max specified discharge current"@en ;
    iof:prescribes :Cell_Discharge_Current_Characteristic,
        :Overcurrent_Protection_Req1 .

:Shoulder_Belt_Mount a bfo:BFO_0000040 ;
    rdfs:label "Shoulder Belt Mount (T.2.6 reference)"@en .

:Cell_Discharge_Current_Characteristic a iof:ProcessCharacteristic ;
    rdfs:label "Maximum specified discharge current of the cells (reference for trip threshold)"@en .

:Hot_Ungrounded_Terminal a bfo:BFO_0000040 ;
    rdfs:label "Hot (ungrounded) terminal"@en .

:Insulation_Quality_Req2 a bfo:BFO_0000019 ;
    rdfs:label "Insulation of hot (ungrounded) terminal"@en ;
    iof:qualityOf :Hot_Ungrounded_Terminal .

:Mounting_Process_Req0 a bfo:BFO_0000015 ;
    rdfs:label "Secure mounting of LV batteries and power supplies inside chassis below shoulder belt mount"@en ;
    bfo:BFO_0000057 :Chassis,
        :LV_Battery_Collection,
        :Onboard_Power_Supply_Collection,
        :Shoulder_Belt_Mount .

:Overcurrent_Protection_Req1 a bfo:BFO_0000040 ;
    rdfs:label "Overcurrent Protection for Low Voltage batteries"@en ;
    bfo:BFO_0000056 :LV_Battery_Collection .

:LV_Battery_Collection a bfo:BFO_0000040 ;
    rdfs:label "All Low Voltage Batteries"@en .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any voltage more than 60 V DC or 25 V AC RMS T.9.1.2 Low Voltage - LV Any voltage less than and including 60 V DC or 25 V AC RMS T.9.1.3 Normally Open A type of electrical relay or contactor that allows current flow only in the energized state ## T.9.2 Low Voltage Batteries T.9.2.1 All Low Voltage Batteries and onboard power supplies must be securely mounted inside the Chassis below the height of the Shoulder Belt Mount T.2.6 T.9.2.2 All Low Voltage batteries must have Overcurrent Protection that trips at or below the maximum specified discharge current of the cells T.9.2.3 The hot (ungrounded) terminal must be insulated"@en ;
    iof:isAbout :Insulation_Objective_Req2,
        :Mounting_Objective_Req0,
        :Overcurrent_Protection_Objective_Req1 .

