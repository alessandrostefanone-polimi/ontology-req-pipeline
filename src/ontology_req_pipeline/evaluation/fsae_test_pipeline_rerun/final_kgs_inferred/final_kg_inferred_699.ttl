@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/699#> a owl:Ontology .

<http://example.org/req/699#DS_OvercurrentProtectionDistance> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/699#OvercurrentProtectionDevice> ;
    ns1:satisfiesRequirement <http://example.org/req/699#Req_0> .

<http://example.org/req/699#OvercurrentProtectionDevice> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "additional Overcurrent Protection",
        "additional Overcurrent Protection"@en ;
    ns1:hasQuality <http://example.org/req/699#DistanceFromSourceEnd> .

<http://example.org/req/699#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "This additional Overcurrent Protection must be: a. 150 mm or less from the source end of the reduced conductor b" ;
    ns1:requirementSatisfiedBy <http://example.org/req/699#DS_OvercurrentProtectionDistance> .

<http://example.org/req/699#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 1.5e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/MIL_LENGTH> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/699#DistanceFromSourceEnd> .

<http://qudt.org/vocab/unit/MIL_LENGTH> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Distance> .

<http://example.org/req/699#DistanceFromSourceEnd> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "distance from the source end of the reduced conductor",
        "distance from the source end of the reduced conductor"@en ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/699#VE_req0_c0> .

