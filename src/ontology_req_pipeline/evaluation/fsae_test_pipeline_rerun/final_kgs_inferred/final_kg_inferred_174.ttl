@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/174#> a owl:Ontology .

<http://example.org/req/174#LocationToAccess_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000029>,
        <http://purl.obolibrary.org/obo/BFO_0000141>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Location to access during Technical Inspection",
        "Location to access during Technical Inspection"@en .

<http://example.org/req/174#TechnicalInspection_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Technical Inspection",
        "Technical Inspection"@en .

<http://example.org/req/174#FrontHoopHoleDesignSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/174#FrontHoop_0>,
        <http://example.org/req/174#Hole_0> ;
    ns1:satisfiesRequirement <http://example.org/req/174#Req_0> .

<http://example.org/req/174#ObjSpec_FrontHoopHole_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:prescribes <http://example.org/req/174#Hole_0> .

<http://example.org/req/174#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "5.7.7 A Front Hoop that is not steel must have a 4 mm hole drilled in a location to access during Technical Inspection" ;
    ns1:isAbout <http://example.org/req/174#ObjSpec_FrontHoopHole_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/174#FrontHoopHoleDesignSpec_0> .

<http://example.org/req/174#VE_req0_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 4e-03 ;
    ns2:minInclusive 4e-03 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/174#Hole_0> .

<http://qudt.org/vocab/unit/M> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://example.org/req/174#FrontHoop_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Front Hoop (non-steel)",
        "Front Hoop (non-steel)"@en .

<http://example.org/req/174#Hole_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Access hole in Front Hoop",
        "Access hole in Front Hoop"@en ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/174#VE_req0_c2> ;
    ns1:qualityOf <http://example.org/req/174#FrontHoop_0> .

