@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/225#> a owl:Ontology .

<http://example.org/req/225#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "An inspection hole approximately 4 mm in diameter must be drilled through a low stress location of every monocoque section regulated by the Structural Equivalency Spreadsheet This inspection hole is not required in the Vertical Side Impact Structure F.7.5.3.b" ;
    ns2:isAbout <http://example.org/req/225#ObjSpec_0> ;
    ns2:requirementSatisfiedBy <http://example.org/req/225#PlanSpec_0> .

<http://example.org/req/225#Req_1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    ns2:isAbout <http://example.org/req/225#ObjSpec_1> ;
    ns2:requirementSatisfiedBy <http://example.org/req/225#DesignSpec_VSIS> .

<http://example.org/req/225#StructuralEquivalencySpreadsheet> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:label "Structural Equivalency Spreadsheet" .

<http://example.org/req/225#DesignSpec_VSIS> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/225#VerticalSideImpactStructure> .

<http://example.org/req/225#DrillingProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns3:BFO_0000057 <http://example.org/req/225#MonocoqueSection_0> ;
    ns2:hasSpecifiedOutput <http://example.org/req/225#InspectionHole_0> .

<http://example.org/req/225#InspectionHole_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasQuality <http://example.org/req/225#Diameter_InspectionHole_0> .

<http://example.org/req/225#MonocoqueSection_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/225#ObjSpec_1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification .

<http://example.org/req/225#PlanSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns3:BFO_0000110 <http://example.org/req/225#ObjSpec_0> ;
    ns2:prescribes <http://example.org/req/225#DrillingProcess_0> .

<http://example.org/req/225#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 4e-03 ;
    ns1:minInclusive 4e-03 ;
    ns1:unit <http://qudt.org/vocab/unit/M> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/225#Diameter_InspectionHole_0> .

<http://example.org/req/225#VerticalSideImpactStructure> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Vertical Side Impact Structure" .

<http://qudt.org/vocab/unit/M> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://example.org/req/225#Diameter_InspectionHole_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/225#VE_req0_c1> .

<http://example.org/req/225#ObjSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification .

