<http://example.org/req/264#> a owl:Ontology .

<http://example.org/req/264#BaselineBulkheadStiffness> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000016>,
        <http://purl.obolibrary.org/obo/BFO_0000017>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:dispositionOf <http://example.org/req/264#BaselineFrontBulkhead> .

<http://example.org/req/264#BaselineBulkheadStrength> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000016>,
        <http://purl.obolibrary.org/obo/BFO_0000017>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:dispositionOf <http://example.org/req/264#BaselineFrontBulkhead> .

<http://example.org/req/264#Req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:comment "Strength of the Composite Anti Intrusion Plate must be verified by one of the two methods" ;
    ns1:isSubjectOf <http://example.org/req/264#Req_0> ;
    ns1:prescribes <http://example.org/req/264#AIPStrengthVerificationProcess> .

<http://example.org/req/264#Req1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:comment "The test fixture must have equivalent strength and stiffness to a baseline front bulkhead" ;
    ns1:isSubjectOf <http://example.org/req/264#Req_0> ;
    ns1:prescribes <http://example.org/req/264#TestFixtureStiffness>,
        <http://example.org/req/264#TestFixtureStrength> .

<http://example.org/req/264#Req2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:comment "The test fixture must be the same as the first 50 mm of the Chassis" ;
    ns1:isSubjectOf <http://example.org/req/264#Req_0> ;
    ns1:prescribes <http://example.org/req/264#ChassisFirst50mm>,
        <http://example.org/req/264#TestFixture> .

<http://example.org/req/264#Req3> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:comment "Test data is valid for only one Competition Year" ;
    ns1:isSubjectOf <http://example.org/req/264#Req_0> ;
    ns1:prescribes <http://example.org/req/264#TestDataValidityDuration> .

<http://example.org/req/264#TestData> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity .

<http://example.org/req/264#VE_req2_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 5e-02 ;
    ns2:minInclusive 5e-02 ;
    ns2:unit <http://qudt.org/vocab/unit/M> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/264#ChassisFirst50mm> .

<http://example.org/req/264#VE_req3_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 3.15576e+07 ;
    ns2:minInclusive 3.15576e+07 ;
    ns2:unit <http://qudt.org/vocab/unit/SEC> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/264#TestDataValidityDuration> .

<http://example.org/req/264#Chassis> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/264#DS_CompositeAIPStrength> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/264#BaselineFrontBulkhead>,
        <http://example.org/req/264#ChassisFirst50mm>,
        <http://example.org/req/264#CompositeAntiIntrusionPlate>,
        <http://example.org/req/264#TestFixture> .

<http://example.org/req/264#LaminateMaterialTestProcess> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:prescribedBy <http://example.org/req/264#PS_AIPStrengthVerification> .

<http://example.org/req/264#PhysicalAIPTestProcess> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:hasInput <http://example.org/req/264#CompositeAntiIntrusionPlate>,
        <http://example.org/req/264#TestFixture> ;
    ns1:prescribedBy <http://example.org/req/264#PS_AIPStrengthVerification> .

<http://example.org/req/264#TestFixtureStiffness> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000016>,
        <http://purl.obolibrary.org/obo/BFO_0000017>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:dispositionOf <http://example.org/req/264#TestFixture> .

<http://example.org/req/264#TestFixtureStrength> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000016>,
        <http://purl.obolibrary.org/obo/BFO_0000017>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:dispositionOf <http://example.org/req/264#TestFixture> .

<http://qudt.org/vocab/unit/M> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://qudt.org/vocab/unit/SEC> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Time> .

<http://example.org/req/264#CompositeAntiIntrusionPlate> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/264#TestDataValidityDuration> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    ns1:processCharacteristicOf <http://example.org/req/264#AIPStrengthVerificationProcess> .

<http://example.org/req/264#AIPStrengthVerificationProcess> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:prescribedBy <http://example.org/req/264#PS_AIPStrengthVerification> .

<http://example.org/req/264#BaselineFrontBulkhead> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/264#ChassisFirst50mm> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:componentPartOfAtSomeTime <http://example.org/req/264#Chassis> .

<http://example.org/req/264#PS_AIPStrengthVerification> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/264#AIPStrengthVerificationProcess>,
        <http://example.org/req/264#LaminateMaterialTestProcess>,
        <http://example.org/req/264#PhysicalAIPTestProcess> .

<http://example.org/req/264#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Strength of the Composite Anti Intrusion Plate must be verified by one of the two methods: a. Physical testing of the AIP attached to a structurally representative section of the intended chassis - The test fixture must have equivalent strength and stiffness to a baseline front bulkhead or must be the same as the first 50 mm of the Chassis - Test data is valid for only one Competition Year b. Laminate material testing under F.4.3.2 and F.4.3.5 and calculations of 3 point bending and perimeter shear" ;
    ns1:requirementSatisfiedBy <http://example.org/req/264#DS_CompositeAIPStrength>,
        <http://example.org/req/264#PS_AIPStrengthVerification> .

<http://example.org/req/264#TestFixture> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing .

