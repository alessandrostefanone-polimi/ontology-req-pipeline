@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/284#> a owl:Ontology .

<http://example.org/req/284#AntiIntrusionPlate> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Anti Intrusion Plate",
        "Anti Intrusion Plate"@en .

<http://example.org/req/284#AttachmentPoints_FW_BW> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "attachment points for the front wing and bodywork mounts",
        "attachment points for the front wing and bodywork mounts"@en ;
    ns1:hasQuality <http://example.org/req/284#PosRel_AttachmentPoints_AIP> .

<http://example.org/req/284#Clearance_Pedal_AIP> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "clearance between pedal assembly and rear face of Anti Intrusion Plate",
        "clearance between pedal assembly and rear face of Anti Intrusion Plate"@en ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/284#VE_req2_c0> .

<http://example.org/req/284#DS_AttachmentPoints> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/284#AttachmentPoints_FW_BW> ;
    ns1:satisfiesRequirement <http://example.org/req/284#Req_0> .

<http://example.org/req/284#DS_Tabs> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/284#Tabs_Wing_Bodywork_Attachment> ;
    ns1:satisfiesRequirement <http://example.org/req/284#Req_0> .

<http://example.org/req/284#ExtForward_Tabs_AIP> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "extension distance forward of the Anti Intrusion Plate for tabs",
        "extension distance forward of the Anti Intrusion Plate for tabs"@en ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/284#VE_req1_c0> .

<http://example.org/req/284#ObjSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification .

<http://example.org/req/284#PS_PedalClearance> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/284#PedalAssemblyFullTravelProcess> ;
    ns1:satisfiesRequirement <http://example.org/req/284#Req_0> .

<http://example.org/req/284#PedalAssemblyFullTravelProcess> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "pedal assembly at full travel and adjustment process",
        "pedal assembly at full travel and adjustment process"@en ;
    ns1:hasProcessCharacteristic <http://example.org/req/284#Clearance_Pedal_AIP> .

<http://example.org/req/284#PosRel_AttachmentPoints_AIP> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "position of attachment points relative to Anti Intrusion Plate",
        "position of attachment points relative to Anti Intrusion Plate"@en .

<http://example.org/req/284#Tabs_Wing_Bodywork_Attachment> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "tabs for wing and bodywork attachment",
        "tabs for wing and bodywork attachment"@en ;
    ns1:hasQuality <http://example.org/req/284#ExtForward_Tabs_AIP> .

<http://example.org/req/284#VE_req1_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 2.5e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/MM> .

<http://example.org/req/284#VE_req2_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 2.5e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/MM> .

<http://qudt.org/vocab/unit/MM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/284#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The attachment points for the front wing and bodywork mounts should be aft of the Anti Intrusion Plate c. Tabs for wing and bodywork attachment must not extend more than 25 mm forward of the Anti Intrusion Plate F.8.6.3 Pedal assembly at full travel and adjustment must have a minimum 25 mm clearance to the: a. Rear face of the Anti Intrusion Plate b" ;
    ns1:isAbout <http://example.org/req/284#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/284#DS_AttachmentPoints>,
        <http://example.org/req/284#DS_Tabs>,
        <http://example.org/req/284#PS_PedalClearance> .

