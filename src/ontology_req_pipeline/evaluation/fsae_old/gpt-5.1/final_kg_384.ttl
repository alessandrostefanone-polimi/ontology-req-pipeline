@prefix : <http://example.org/req/384#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AttachmentMethod_BoltThroughWeldedTubeInsert a iof:ProcessCharacteristic ;
    rdfs:label "Bolt through a welded tube insert" .

:AttachmentMethod_BoltToTabOrBracket a iof:ProcessCharacteristic ;
    rdfs:label "Bolt to a tab or bracket" .

:AttachmentMethod_ClipToTabOrBracket a iof:ProcessCharacteristic ;
    rdfs:label "Clip to a tab or bracket" .

:AttachmentMethod_TestedMonocoqueAttachment a iof:ProcessCharacteristic ;
    rdfs:label "Tested monocoque attachment" .

:AttachmentMethod_WrapAroundMountingBar a iof:ProcessCharacteristic ;
    rdfs:label "Wrap around the Shoulder Harness Mounting bar" .

:AttachmentMethod_WrapAroundTestedHardwareMonocoque a iof:ProcessCharacteristic ;
    rdfs:label "Wrap around physically tested hardware attached to a monocoque" .

:DesignSpec_ShoulderBeltMountSpacing a iof:DesignSpecification ;
    iof:prescribes :ShoulderBeltMountSpacing ;
    iof:satisfiesRequirement :Req_0 .

:PlanSpec_ShoulderBeltAttachmentMethod a iof:PlanSpecification ;
    iof:prescribes :ShoulderBeltAttachmentProcess ;
    iof:satisfiesRequirement :Req_0 .

:ShoulderBeltAttachmentMethodChoice a iof:ProcessCharacteristic ;
    rdfs:label "Shoulder Belt Attachment Method Choice" ;
    iof:hasOccurentPart :AttachmentMethod_BoltThroughWeldedTubeInsert,
        :AttachmentMethod_BoltToTabOrBracket,
        :AttachmentMethod_ClipToTabOrBracket,
        :AttachmentMethod_TestedMonocoqueAttachment,
        :AttachmentMethod_WrapAroundMountingBar,
        :AttachmentMethod_WrapAroundTestedHardwareMonocoque .

:ShoulderBeltAttachmentProcess a iof:PlannedProcess ;
    rdfs:label "Shoulder Belt Attachment Process" ;
    iof:hasParticipantAtSomeTime :ShoulderBelts ;
    iof:hasProcessCharacteristic :ShoulderBeltAttachmentMethodChoice .

:ShoulderBeltMountStructure a bfo:BFO_0000040 ;
    rdfs:label "Shoulder Belt Mount Structure" .

:ShoulderBelts a bfo:BFO_0000040 ;
    rdfs:label "Shoulder Belts" .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.35e+02 ;
    qudt:minInclusive 1.75e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :ShoulderBeltMountSpacing .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The Shoulder Belt Mount Spacing must be between 175 mm and 235 mm , center to center T.2.6.3 The Shoulder Belts must attach by one of the four: a. Wrap around the Shoulder Harness Mounting bar b. Bolt through a welded tube insert or tested monocoque attachment F.7.9 c. Bolt or clip to a tab or bracket (T.2.4.3 ) on the Shoulder Harness Mounting bar d. Wrap around physically tested hardware attached to a monocoque T.2.6.4" ;
    iof:requirementSatisfiedBy :DesignSpec_ShoulderBeltMountSpacing,
        :PlanSpec_ShoulderBeltAttachmentMethod .

:ShoulderBeltMountSpacing a bfo:BFO_0000019 ;
    rdfs:label "Shoulder Belt Mount Spacing" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :ShoulderBeltMountStructure .

