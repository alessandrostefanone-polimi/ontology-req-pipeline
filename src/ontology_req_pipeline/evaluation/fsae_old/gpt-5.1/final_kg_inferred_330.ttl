    ns3:BFO_0000110 <http://example.org/req/330#ObjSpec_Req2> ;
    rdfs:comment "Req2: When the rear impact structure is 100 mm or less from an Accumulator Container, the structure must be equivalent to Side Impact Structure (F.6.4, F.7.5)." ;
