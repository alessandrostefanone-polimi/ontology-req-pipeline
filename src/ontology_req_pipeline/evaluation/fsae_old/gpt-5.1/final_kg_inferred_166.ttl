@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/166#> a owl:Ontology .

<http://example.org/req/166#CircleDesign_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/166#Circle_0> ;
    ns1:satisfiesRequirement <http://example.org/req/166#Req_0> .

<http://example.org/req/166#LineDesign_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/166#Line_0> ;
    ns1:satisfiesRequirement <http://example.org/req/166#Req_0> .

<http://example.org/req/166#ObjSpec_CircleSize_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:prescribes <http://example.org/req/166#Circle_0> .

<http://example.org/req/166#Plan_ConnectCenters_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns3:BFO_0000110 <http://example.org/req/166#ObjSpec_LineConnection_0> ;
    ns1:prescribes <http://example.org/req/166#ConnectCentersProcess_0> .

<http://example.org/req/166#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 4.9e+02 ;
    ns2:minInclusive 4.9e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/166#LineLength_0> .

<http://example.org/req/166#VE_req0_c4> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 2e+02 ;
    ns2:minInclusive 2e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/166#CircleDiameter_0> .

<http://example.org/req/166#CircleDiameter_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/166#VE_req0_c4> .

<http://example.org/req/166#ConnectCentersProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns3:BFO_0000057 <http://example.org/req/166#Circle_0>,
        <http://example.org/req/166#Line_0> ;
    ns1:prescribedBy <http://example.org/req/166#Plan_ConnectCenters_0> .

<http://example.org/req/166#LineLength_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/166#VE_req0_c1> .

<http://example.org/req/166#Line_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasQuality <http://example.org/req/166#LineLength_0> .

<http://example.org/req/166#ObjSpec_LineConnection_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:prescribes <http://example.org/req/166#ConnectCentersProcess_0> .

<http://example.org/req/166#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "A straight line measuring 490 mm will connect the centers of the two 200 mm circles" ;
    ns1:isAbout <http://example.org/req/166#ObjSpec_CircleSize_0>,
        <http://example.org/req/166#ObjSpec_LineConnection_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/166#CircleDesign_0>,
        <http://example.org/req/166#LineDesign_0> .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/166#Circle_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasQuality <http://example.org/req/166#CircleDiameter_0> .

