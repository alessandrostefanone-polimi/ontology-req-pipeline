        ns2:PlanSpecification ;
    rdfs:label "Plan specification for presence of text 'Always Energized'" ;
    ns2:prescribes <http://example.org/req/622#TextAlwaysEnergized> .

<http://example.org/req/622#PS_TextHighVoltage> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    rdfs:label "Plan specification for presence of text 'High Voltage' under voltage condition" ;
    ns2:prescribes <http://example.org/req/622#TextHighVoltage> .

<http://example.org/req/622#TriangleGraphic> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Triangle with black lightning bolt on yellow background" ;
    ns2:isComponentPartOfAtSomeTime <http://example.org/req/622#WarningSymbol> .

<http://example.org/req/622#VE_req0_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "Minimum triangle side length for warning symbol" ;
    ns1:minInclusive 1e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/622#TriangleSideLength> .

<http://example.org/req/622#VoltageConditionProcess> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Voltage meets T.9.1.1 process" .

<http://qudt.org/vocab/unit/MilliM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/622#GLV_System> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
