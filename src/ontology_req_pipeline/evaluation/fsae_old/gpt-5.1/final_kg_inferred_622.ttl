<http://example.org/req/622#TextHighVoltage> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Text 'High Voltage'" ;
    ns2:satisfiesRequirement <http://example.org/req/622#Req_0> .

<http://example.org/req/622#TriangleSideLength> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Triangle side length" ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/622#VE_req0_c2> ;
    ns2:qualityOf <http://example.org/req/622#TriangleGraphic> .

<http://example.org/req/622#WarningSymbol> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Warning symbol for high voltage" ;
    ns2:hasQuality <http://example.org/req/622#TriangleSideLength> ;
    ns2:isSubjectOf <http://example.org/req/622#ISO_7010_W012_Spec> ;
    ns2:satisfiesRequirement <http://example.org/req/622#Req_0> .

<http://example.org/req/622#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "Symbol specified in ISO 7010-W012 (triangle with black lightning bolt on yellow background) with triangle side length of 100 mm minimum c. Text \"Always Energized\" d. Text \"High Voltage\" if the voltage meets T.9.1.1 ## EV.4.4 Grounded Low Voltage System EV.4.4.1 The GLV System must be" ;
    ns2:requirementSatisfiedBy <http://example.org/req/622#DS_GLVSystem>,
        <http://example.org/req/622#DS_WarningSymbol>,
        <http://example.org/req/622#PS_TextAlwaysEnergized>,
        <http://example.org/req/622#PS_TextHighVoltage> .

