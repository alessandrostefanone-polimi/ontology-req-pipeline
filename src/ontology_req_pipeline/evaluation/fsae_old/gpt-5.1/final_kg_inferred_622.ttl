    ns2:prescribes <http://example.org/req/622#WarningSymbol> .

<http://example.org/req/622#ISO_7010_W012_Spec> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity ;
    rdfs:label "ISO 7010-W012 symbol specification" ;
    ns2:isAbout <http://example.org/req/622#WarningSymbol> .

<http://example.org/req/622#PS_TextAlwaysEnergized> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
