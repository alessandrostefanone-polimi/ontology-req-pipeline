@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/550#> a owl:Ontology .

<http://example.org/req/550#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "The power to the electronic throttle must be immediately shut down, if throttle position differs by more than $10 \\%$ from the expected target TPS position for more than one second" ;
    ns2:isAbout <http://example.org/req/550#ObjSpec_0> ;
    ns2:requirementSatisfiedBy <http://example.org/req/550#PlanSpec_0> .

<http://example.org/req/550#ThrottlePowerOffState_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/550#ThrottlePower_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/550#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:minExclusive 1e+00 ;
    ns1:unit <http://qudt.org/vocab/unit/SEC> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/550#CondDuration_0> .

<http://example.org/req/550#VE_req0_c2> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:minExclusive 1e+01 ;
    ns1:unit <http://qudt.org/vocab/unit/PERCENT> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/550#ThrottlePosDeviation_0> .

<http://qudt.org/vocab/unit/PERCENT> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/DutyCycle> .

<http://qudt.org/vocab/unit/SEC> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Time> .

<http://example.org/req/550#CondDuration_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/550#VE_req0_c1> ;
    ns2:processCharacteristicOf <http://example.org/req/550#ShutdownProcess_0> .

<http://example.org/req/550#ObjSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:isAchievedByAtSomeTime <http://example.org/req/550#ShutdownProcess_0> ;
    ns2:prescribes <http://example.org/req/550#ShutdownProcess_0> .

<http://example.org/req/550#PlanSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns3:BFO_0000110 <http://example.org/req/550#ObjSpec_0> ;
    ns2:prescribes <http://example.org/req/550#ShutdownProcess_0> .

<http://example.org/req/550#ThrottlePosDeviation_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/550#VE_req0_c2> ;
    ns2:processCharacteristicOf <http://example.org/req/550#ShutdownProcess_0> .

<http://example.org/req/550#ShutdownProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns2:hasInput <http://example.org/req/550#ThrottlePower_0> ;
    ns2:hasOutput <http://example.org/req/550#ThrottlePowerOffState_0> ;
    ns2:hasProcessCharacteristic <http://example.org/req/550#CondDuration_0>,
        <http://example.org/req/550#ThrottlePosDeviation_0> ;
    ns2:prescribedBy <http://example.org/req/550#PlanSpec_0> .

