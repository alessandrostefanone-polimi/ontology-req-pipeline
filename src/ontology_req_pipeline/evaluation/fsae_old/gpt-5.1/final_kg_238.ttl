@prefix : <http://example.org/req/238#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:PS_MainHoopAttachment a iof:PlanSpecification ;
    iof:prescribes :MainHoopAttachmentProcess .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "7.6 Main Hoop Attachment F.7.6.1 The Main Hoop must be mechanically attached to the monocoque a. Main Hoop mounting plates must be 2.0 mm minimum thickness steel b" ;
    iof:requirementSatisfiedBy :DS_MainHoop,
        :DS_MainHoopMountingPlate .

:DS_MainHoop a iof:DesignSpecification ;
    iof:prescribes :MainHoop .

:DS_MainHoopMountingPlate a iof:DesignSpecification ;
    iof:prescribes :MainHoopMountingPlate .

:MainHoopAttachmentProcess a iof:PlannedProcess ;
    bfo:BFO_0000057 :MainHoop,
        :Monocoque .

:MainHoopMountingPlate a bfo:BFO_0000040 ;
    iof:hasQuality :MainHoopMountingPlate_Material,
        :MainHoopMountingPlate_Thickness .

:MainHoopMountingPlate_Material a bfo:BFO_0000019 .

:Monocoque a bfo:BFO_0000040 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e+00 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :MainHoopMountingPlate_Thickness .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

:MainHoop a bfo:BFO_0000040 .

:MainHoopMountingPlate_Thickness a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

