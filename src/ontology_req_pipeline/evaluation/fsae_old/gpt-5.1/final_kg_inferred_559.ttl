<http://example.org/req/559#Throttle_Monitoring_Condition> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "Condition: throttle opening above threshold" ;
    ns1:processCharacteristicOf <http://example.org/req/559#BSPD_Monitoring_Process> .

<http://example.org/req/559#VE_req1_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Duration > 1.0 (req 1, c0)" ;
    ns2:minExclusive 1e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/M-PER-SEC> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/559#HardBraking_Monitoring_Condition> .

<http://example.org/req/559#VE_req3_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Throttle opening > 10.0 percent (req 3, c0)" ;
    ns2:minExclusive 1e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/PERCENT> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/559#ThrottleOpeningQuality> .

<http://example.org/req/559#VE_req4_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Brake signal loss duration > 100.0 s (req 4, c1)" ;
    ns2:minExclusive 1e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/SEC> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/559#BrakeSignalLoss_Monitoring_Condition> .

<http://example.org/req/559#VE_req5_c1> a ns3:BFO_0000001,
