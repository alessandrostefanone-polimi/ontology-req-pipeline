<http://qudt.org/vocab/unit/M-PER-SEC> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/VehicleVelocity> .

<http://qudt.org/vocab/unit/PERCENT> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/DutyCycle> .

<http://qudt.org/vocab/unit/SEC> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Time> .

<http://example.org/req/559#BSPD_Reset_Process> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Reset BSPD by cycling Primary Master Switch OFF and ON" ;
    ns3:BFO_0000057 <http://example.org/req/559#BSPD>,
        <http://example.org/req/559#PrimaryMasterSwitch> ;
    ns1:prescribedBy <http://example.org/req/559#BSPD_Reset_Plan> .

<http://example.org/req/559#BSPD_Shutdown_Action> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "BSPD opens Shutdown Circuit" ;
    ns3:BFO_0000057 <http://example.org/req/559#BSPD>,
        <http://example.org/req/559#ShutdownCircuit> ;
    ns1:occursDuring <http://example.org/req/559#AboveConditions> ;
    ns1:prescribedBy <http://example.org/req/559#BSPD_Shutdown_Plan> .

<http://example.org/req/559#Obj_Monitoring> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: BSPD monitors and reacts to fault conditions" ;
    ns1:prescribes <http://example.org/req/559#BSPD_Monitoring_Process>,
        <http://example.org/req/559#BSPD_Reset_Process>,
        <http://example.org/req/559#BSPD_Shutdown_Action> .

