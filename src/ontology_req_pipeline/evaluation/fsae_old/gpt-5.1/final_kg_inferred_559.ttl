    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/559#ThrottleSignalLoss_Monitoring_Condition> .

<http://example.org/req/559#AboveConditions> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:Process ;
    rdfs:label "Any of the above BSPD fault conditions" ;
    ns3:BFO_0000117 <http://example.org/req/559#HardBrakingDemand>,
        <http://example.org/req/559#LossOfBrakeSignal>,
        <http://example.org/req/559#LossOfThrottleSignal>,
        <http://example.org/req/559#PowerRemovalFromBSPD> .

<http://example.org/req/559#BSPD_Monitoring_Design> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "BSPD monitoring and reaction design" ;
    ns1:prescribes <http://example.org/req/559#BSPD>,
        <http://example.org/req/559#BSPD_Monitoring_Process>,
        <http://example.org/req/559#BSPD_Reset_Process>,
        <http://example.org/req/559#BSPD_Shutdown_Action> ;
    ns1:satisfiesRequirement <http://example.org/req/559#Req_0> .

<http://example.org/req/559#BSPD_Monitoring_Plan> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan: BSPD monitoring of conditions" ;
    ns3:BFO_0000110 <http://example.org/req/559#Obj_Monitoring> ;
    ns1:prescribes <http://example.org/req/559#BSPD_Monitoring_Process> .

<http://example.org/req/559#BSPD_Reset_Plan> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan: BSPD reset by cycling Primary Master Switch" ;
