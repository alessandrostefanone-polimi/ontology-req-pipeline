@prefix : <http://example.org/req/921#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:ConePlacementPlanSpec_1 a iof:PlanSpecification ;
    iof:prescribes :ConePlacementProcess_1 ;
    iof:satisfiesRequirement :Req_0 .

:CourseWidthDesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :CourseWidth_0 ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 4.9e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :CourseWidth_0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 6e+00 ;
    qudt:minInclusive 6e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :ConePlacementInterval_1 .

qudtqk:Breadth a qudt:QuantityKind .

:ConePlacementInterval_1 a iof:ProcessCharacteristic ;
    rdfs:label "cone placement interval"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 ;
    iof:processCharacteristicOf :ConePlacementProcess_1 .

:ConePlacementProcess_1 a iof:PlannedProcess ;
    rdfs:label "cone placement along course edges"@en ;
    iof:hasProcessCharacteristic :ConePlacementInterval_1 .

:CourseWidth_0 a bfo:BFO_0000019 ;
    rdfs:label "course width"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Course width will be minimum 4.9 m wide as measured between the inner edges of the bases of the course edge cones D.9.1.3 Cones are placed along the course edges at intervals, approximately 6 m" ;
    iof:requirementSatisfiedBy :ConePlacementPlanSpec_1,
        :CourseWidthDesignSpec_0 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Breadth .

