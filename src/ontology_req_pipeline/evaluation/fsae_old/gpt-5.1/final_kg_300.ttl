@prefix : <http://example.org/req/300#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :FuelSystemPortion_0,
        :FuelTankPart_0,
        :PrimaryStructure_0 ;
    iof:satisfiesRequirement :Req_0 .

:FuelSystem_0 a bfo:BFO_0000040 ;
    rdfs:label "Fuel System" .

:FuelTank_0 a bfo:BFO_0000040 ;
    rdfs:label "Fuel Tank" .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :PrimaryStructure_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any portion of the Fuel System that is less than 350 mm above the ground, and all parts of the Fuel Tank, must be inside the Primary Structure (F.1.10)" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxExclusive 3.5e+02 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :HeightAboveGround_0 .

qudtqk:Height a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:FuelSystemPortion_0 a bfo:BFO_0000040 ;
    rdfs:label "Portion of the Fuel System" ;
    iof:componentPartOfAtSomeTime :FuelSystem_0 ;
    iof:hasQuality :HeightAboveGround_0 ;
    iof:hasRole :InsidePrimaryStructureRole_0 .

:FuelTankPart_0 a bfo:BFO_0000040 ;
    rdfs:label "Part of the Fuel Tank" ;
    iof:componentPartOfAtSomeTime :FuelTank_0 ;
    iof:hasRole :InsidePrimaryStructureRole_0 .

:HeightAboveGround_0 a bfo:BFO_0000019 ;
    rdfs:label "height above the ground of Fuel System portion" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:InsidePrimaryStructureRole_0 a bfo:BFO_0000023 ;
    rdfs:label "inside Primary Structure role" ;
    iof:roleOf :FuelSystemPortion_0,
        :FuelTankPart_0 .

:PrimaryStructure_0 a bfo:BFO_0000040 ;
    rdfs:label "Primary Structure" .

