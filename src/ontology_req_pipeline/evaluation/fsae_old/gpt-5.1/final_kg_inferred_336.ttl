@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/336#> a owl:Ontology .

<http://example.org/req/336#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The template will be held horizontally, parallel to the ground, and inserted vertically from a height above any Primary Structure or bodywork that is between the Front Hoop and the Main Hoop until it meets both of: ( refer to F.6.4 and F.7.5.1) a. Has passed 25 mm below the lowest point of the top of the Side Impact Structure b" ;
    ns1:requirementSatisfiedBy <http://example.org/req/336#Plan_0> .

<http://example.org/req/336#Plan_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/336#InsertionProcess_0> .

<http://example.org/req/336#VE_req0_c5> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 2.5e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/336#VerticalPosition_0> .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Height> .

<http://example.org/req/336#InsertionProcess_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns1:hasProcessCharacteristic <http://example.org/req/336#VerticalPosition_0> .

<http://example.org/req/336#VerticalPosition_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/336#VE_req0_c5> ;
    ns1:processCharacteristicOf <http://example.org/req/336#InsertionProcess_0> .

