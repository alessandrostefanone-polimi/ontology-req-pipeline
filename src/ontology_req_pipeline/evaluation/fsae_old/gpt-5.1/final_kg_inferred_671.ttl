@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/671#> a owl:Ontology .

<http://example.org/req/671#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "6.1.2 Contact with any Tractive System connections with a 100 mm long, 6 mm diameter insulated test probe must not be possible when the Tractive System enclosures are in place" ;
    ns1:requirementSatisfiedBy <http://example.org/req/671#PlanSpec_0> .

<http://example.org/req/671#EnclosuresInPlace_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialState ;
    rdfs:label "Tractive System enclosures in place",
        "Tractive System enclosures in place"@en .

<http://example.org/req/671#PC_ContactPossible> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "Possibility of contact with Tractive System connections",
        "Possibility of contact with Tractive System connections"@en .

<http://example.org/req/671#PlanSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/671#PlannedProcess_0> .

<http://example.org/req/671#PlannedProcess_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Prevention of contact with Tractive System connections using test probe",
        "Prevention of contact with Tractive System connections using test probe"@en ;
    ns1:hasInput <http://example.org/req/671#TestProbe_0> ;
    ns1:hasProcessCharacteristic <http://example.org/req/671#PC_ContactPossible> ;
    ns1:occursDuring <http://example.org/req/671#EnclosuresInPlace_0> .

<http://example.org/req/671#ProbeLength_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Test probe length",
        "Test probe length"@en ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/671#VE_req0_c1> .

<http://example.org/req/671#TestProbe_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Insulated test probe (100 mm long, 6 mm diameter)",
        "Insulated test probe (100 mm long, 6 mm diameter)"@en ;
    ns1:hasQuality <http://example.org/req/671#ProbeLength_0> .

<http://example.org/req/671#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Required test probe length = 100 mm",
        "Required test probe length = 100 mm"@en ;
    ns2:maxInclusive 1e+02 ;
    ns2:minInclusive 1e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/MigrationLength> .

