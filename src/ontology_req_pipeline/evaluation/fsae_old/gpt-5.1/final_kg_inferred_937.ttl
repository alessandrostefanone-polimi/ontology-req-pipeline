@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/937#> a owl:Ontology .

<http://example.org/req/937#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Length of each run should be approximately 0.80 km D.11.1.2" ;
    ns1:requirementSatisfiedBy <http://example.org/req/937#RunLengthDesignSpec_0> .

<http://example.org/req/937#RunLengthDesignSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/937#Run_0> ;
    ns1:satisfiesRequirement <http://example.org/req/937#Req_0> .

<http://example.org/req/937#Run_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "run (process) constrained by requirement 0",
        "run (process) constrained by requirement 0"@en ;
    ns1:hasProcessCharacteristic <http://example.org/req/937#RunLength_0> .

<http://example.org/req/937#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 8e-01 ;
    ns2:minInclusive 8e-01 ;
    ns2:unit <http://qudt.org/vocab/unit/KiloM> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/937#RunLength_0> .

<http://qudt.org/vocab/unit/KiloM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/PathLength> .

<http://example.org/req/937#RunLength_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "length of each run",
        "length of each run"@en ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/937#VE_req0_c0> .

