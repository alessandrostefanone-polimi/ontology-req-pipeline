@prefix : <http://example.org/req/671#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "6.1.2 Contact with any Tractive System connections with a 100 mm long, 6 mm diameter insulated test probe must not be possible when the Tractive System enclosures are in place" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:EnclosuresInPlace_0 a iof:MaterialState ;
    rdfs:label "Tractive System enclosures in place"@en .

:PC_ContactPossible a iof:ProcessCharacteristic ;
    rdfs:label "Possibility of contact with Tractive System connections"@en .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :PlannedProcess_0 .

:PlannedProcess_0 a iof:PlannedProcess ;
    rdfs:label "Prevention of contact with Tractive System connections using test probe"@en ;
    iof:hasInput :TestProbe_0 ;
    iof:hasProcessCharacteristic :PC_ContactPossible ;
    iof:occursDuring :EnclosuresInPlace_0 .

:ProbeLength_0 a bfo:BFO_0000019 ;
    rdfs:label "Test probe length"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:TestProbe_0 a bfo:BFO_0000040 ;
    rdfs:label "Insulated test probe (100 mm long, 6 mm diameter)"@en ;
    iof:hasQuality :ProbeLength_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Required test probe length = 100 mm"@en ;
    qudt:maxInclusive 1e+02 ;
    qudt:minInclusive 1e+02 ;
    qudt:unit qudtu:MilliM .

qudtqk:MigrationLength a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:MigrationLength .

