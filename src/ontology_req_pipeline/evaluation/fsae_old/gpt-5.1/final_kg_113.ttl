@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/113#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Young's Modulus (E) $=200 \\mathrm{GPa}(29,000 \\mathrm{ksi})$ Yield Strength (Sy) $=305 \\mathrm{MPa}(44.2 \\mathrm{ksi})$ Ultimate Strength (Su) $=365 \\mathrm{MPa}(52.9 \\mathrm{ksi})$ b. Welded Properties for discontinuous material such as joint calculations: Yield Strength (Sy) $=180 \\mathrm{MPa}(26 \\mathrm{ksi})$ Ultimate Strength (Su) $=300 \\mathrm{MPa}(43.5 \\mathrm{ksi})$ F.3.4.3 Where Welded tubing reinforcements are required (such as inserts for bolt holes or material to support suspension cutouts), Equivalence of the Welded tube and reinforcement must be shown to the original Non Welded tube in the SES # F.3.5 Alternative Tubing Materials F.3.5.1 Alternative Materials may be used for applications shown as permitted in F.3.2.1 F.3.5.2 If any Alternative Materials are used, the SES must contain: a. Documentation of material type, (purchase receipt, shipping document or letter of donation) and the material properties" ;
    iof:isAbout :Req0_Objective,
        :Req1_Objective,
        :Req2_Objective ;
    iof:requirementSatisfiedBy :Spec_0 .

:AltMatDocumentation a iof:InformationContentEntity ;
    rdfs:label "Documentation of material type (receipt, shipping document, letter of donation)"@en ;
    iof:isSubjectOf :SES_Document .

:AltMatProperties a iof:InformationContentEntity ;
    rdfs:label "Material properties of alternative materials"@en ;
    iof:isSubjectOf :SES_Document .

:Clause_F_3_2_1 a iof:InformationContentEntity ;
    rdfs:label "Clause F.3.2.1"@en .

:Equivalence_ICE a iof:InformationContentEntity ;
    rdfs:label "Equivalence of the Welded tube and reinforcement"@en ;
    iof:isAbout :OriginalNonWeldedTube,
        :Reinforcement,
        :WeldedTube ;
    iof:isSubjectOf :SES_Document .

:OriginalNonWeldedTube a bfo:BFO_0000040 ;
    rdfs:label "Original non-welded tube"@en .

:Process_DocumentAlternativeMaterials a iof:PlannedProcess ;
    rdfs:label "Document alternative materials in SES"@en ;
    bfo:BFO_0000063 :UseAlternativeMaterials_Event ;
    iof:achievesAtSomeTime :Req2_Objective ;
    iof:hasInput :AlternativeMaterial ;
    iof:hasSpecifiedOutput :AltMatDocumentation,
        :AltMatProperties ;
    iof:prescribedBy :Spec_0 .

:Process_UseAlternativeMaterials a iof:PlannedProcess ;
    rdfs:label "Use of alternative tubing materials"@en ;
    iof:achievesAtSomeTime :Req1_Objective ;
    iof:hasInput :AlternativeMaterial ;
    iof:hasProcessCharacteristic :UseAltMat_Applicability ;
    iof:prescribedBy :Spec_0 .

:Reinforcement a bfo:BFO_0000040 ;
    rdfs:label "Reinforcement for welded tube"@en .

:UseAltMat_Applicability a iof:ProcessCharacteristic ;
    rdfs:label "Applicability limited to applications permitted in F.3.2.1"@en ;
    iof:isSubjectOf :Clause_F_3_2_1 .

:UseAlternativeMaterials_Event a bfo:BFO_0000015 ;
    rdfs:label "Event: alternative materials are used"@en ;
    iof:hasParticipantAtSomeTime :AlternativeMaterial .

:WeldedTube a bfo:BFO_0000040 ;
    rdfs:label "Welded tube"@en .

:Process_ShowEquivalence a iof:PlannedProcess ;
    rdfs:label "Process to show equivalence of welded tube and reinforcement"@en ;
    iof:achievesAtSomeTime :Req0_Objective ;
    iof:prescribedBy :Spec_0 .

:Req0_Objective a iof:ObjectiveSpecification ;
    rdfs:label "Objective: show equivalence of welded tube + reinforcement to original non-welded tube"@en ;
    iof:prescribes :Equivalence_ICE .

:Req1_Objective a iof:ObjectiveSpecification ;
    rdfs:label "Objective: allow use of alternative materials where permitted"@en .

:Req2_Objective a iof:ObjectiveSpecification ;
    rdfs:label "Objective: SES contains documentation and material properties for any alternative materials used"@en .

:AlternativeMaterial a bfo:BFO_0000040 ;
    rdfs:label "Alternative tubing material"@en .

:SES_Document a iof:InformationContentEntity ;
    rdfs:label "SES document"@en ;
    iof:prescribes :Process_ShowEquivalence .

:Spec_0 a iof:PlanSpecification ;
    rdfs:label "Specification satisfying SES tubing material requirements"@en ;
    iof:prescribes :Process_DocumentAlternativeMaterials,
        :Process_ShowEquivalence,
        :Process_UseAlternativeMaterials .

