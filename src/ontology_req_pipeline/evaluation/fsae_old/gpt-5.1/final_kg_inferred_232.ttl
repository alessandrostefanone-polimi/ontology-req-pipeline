@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/232#> a owl:Ontology .

<http://example.org/req/232#AdhesiveAttachment_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "attaching the Front Hoop to the monocoque" ;
    ns2:BFO_0000057 <http://example.org/req/232#Adhesive_0>,
        <http://example.org/req/232#FrontHoop_0>,
        <http://example.org/req/232#Monocoque_0> .

<http://example.org/req/232#Adhesive_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Adhesive" .

<http://example.org/req/232#DS_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/232#AdhesiveAttachment_0>,
        <http://example.org/req/232#FrontHoop_0>,
        <http://example.org/req/232#Monocoque_0> ;
    ns1:satisfiesRequirement <http://example.org/req/232#Req_0> .

<http://example.org/req/232#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "A small gap in the laminate (approximately 25 mm ) exists for inspection of the Front Hoop F.5.7.6 F.7.4.4 Adhesive must not be the sole method of attaching the Front Hoop to the monocoque" ;
    ns1:requirementSatisfiedBy <http://example.org/req/232#DS_0> .

<http://example.org/req/232#FrontHoop_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Front Hoop" .

<http://example.org/req/232#Monocoque_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "monocoque" .

