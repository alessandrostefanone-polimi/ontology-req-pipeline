@prefix : <http://example.org/req/306#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:CompositeFloor a bfo:BFO_0000040 ;
    iof:satisfiesRequirement :Req_0 .

:CompositeVertWall a bfo:BFO_0000040 ;
    iof:satisfiesRequirement :Req_0 .

:FastenerStrength a bfo:BFO_0000019 ;
    iof:qualityOf :FastenerJoint .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.25e+00 ;
    qudt:quantityKind qudtqk:Thickness ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Thickness_SteelFloor .

:VE_req1_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3.2e+00 ;
    qudt:quantityKind qudtqk:Thickness ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Thickness_AluminumFloor .

:VE_req3_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 9e-01 ;
    qudt:quantityKind qudtqk:Thickness ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Thickness_SteelVertWall .

:VE_req4_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.3e+00 ;
    qudt:quantityKind qudtqk:Thickness ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Thickness_AluminumVertWall .

:VE_req6_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1e+00 ;
    qudt:quantityKind qudtqk:Dimensionless ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :WeldSpaceRatio .

:VE_req7_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 2.5e+01 ;
    qudt:quantityKind qudtqk:Length ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :WeldLength .

:WeldedJointStrength a bfo:BFO_0000019 ;
    iof:qualityOf :WeldedJoint .

:AluminumFloor a bfo:BFO_0000040 ;
    iof:satisfiesRequirement :Req_0 .

:AluminumVertWall a bfo:BFO_0000040 ;
    iof:satisfiesRequirement :Req_0 .

:DS_FloorBottom a iof:DesignSpecification ;
    iof:prescribes :FloorOrBottom ;
    iof:satisfiesRequirement :Req_0 .

:DS_VertWalls a iof:DesignSpecification ;
    iof:prescribes :VerticalWallsCoversLids ;
    iof:satisfiesRequirement :Req_0 .

:FloorOrBottom a bfo:BFO_0000040 ;
    iof:satisfiesRequirement :Req_0 .

:SteelFloor a bfo:BFO_0000040 ;
    iof:satisfiesRequirement :Req_0 .

:SteelVertWall a bfo:BFO_0000040 ;
    iof:satisfiesRequirement :Req_0 .

:Thickness_AluminumFloor a bfo:BFO_0000019 ;
    iof:qualityOf :AluminumFloor .

:Thickness_AluminumVertWall a bfo:BFO_0000019 ;
    iof:qualityOf :AluminumVertWall .

:Thickness_SteelFloor a bfo:BFO_0000019 ;
    iof:qualityOf :SteelFloor .

:Thickness_SteelVertWall a bfo:BFO_0000019 ;
    iof:qualityOf :SteelVertWall .

:VerticalWallsCoversLids a bfo:BFO_0000040 ;
    iof:satisfiesRequirement :Req_0 .

:WeldLength a bfo:BFO_0000019 ;
    iof:qualityOf :WeldedJoint .

:WeldSpaceRatio a bfo:BFO_0000019 ;
    iof:qualityOf :WeldedJoint .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

:FastenerJoint a iof:PlannedProcess ;
    iof:prescribedBy :PS_FastenerJoint .

:PS_FastenerJoint a iof:PlanSpecification ;
    iof:prescribes :FastenerJoint ;
    iof:satisfiesRequirement :Req_0 .

:PS_WeldedJoint a iof:PlanSpecification ;
    iof:prescribes :WeldedJoint ;
    iof:satisfiesRequirement :Req_0 .

:WeldedJoint a iof:PlannedProcess ;
    iof:prescribedBy :PS_WeldedJoint .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

qudtqk:Thickness a qudt:QuantityKind .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "External Structure F.10.2.1 The Floor or Bottom must be made from one of the three: a. Steel 1.25 mm minimum thickness b. Aluminum 3.2 mm minimum thickness c. Equivalent Alternate / Composite materials ( F.4.1, F.4.3) F.10.2.2 Vertical Walls, Covers and Lids must be made from one of the three: a. Steel 0.9 mm minimum thickness b. Aluminum 2.3 mm minimum thickness c. Equivalent Alternate / Composite materials ( F.4.1, F.4.3) F.10.2.3 The accepted methods of joining walls to walls and walls to floor are: a. Welding - Welds may be continuous or interrupted. - If interrupted, the weld/space ratio must be 1:1 or higher - All weld lengths must be more than 25 mm b. Fasteners Combined strength of the fasteners must be Equivalent to the strength of the welded joint ( F.10.2.3.a above)" ;
    iof:requirementSatisfiedBy :DS_FloorBottom,
        :DS_VertWalls,
        :PS_FastenerJoint,
        :PS_WeldedJoint .

