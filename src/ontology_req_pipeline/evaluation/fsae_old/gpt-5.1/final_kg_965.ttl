@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/965#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Event_VehicleStallOrConeIngest_0 a iof:Event ;
    rdfs:label "vehicle stalls or ingests a cone" ;
    iof:recognizedByAtSomeTime :Agent_Official_0 .

:Rule_D_12_1_4 a iof:InformationContentEntity ;
    rdfs:label "Rule D.12.1.4" .

:Rule_D_12_4 a iof:InformationContentEntity ;
    rdfs:label "Rule D.12.4" .

:Agent_Official_0 a iof:Agent ;
    rdfs:label "unspecified official or system acting as agent" .

:BlackFlag_1 a bfo:BFO_0000040 ;
    rdfs:label "Black Flag" .

:DesignSpec_0 a iof:DesignSpecification ;
    rdfs:label "Design specification for vehicle behavior under stall or cone ingestion" ;
    iof:prescribes :Vehicle_0 ;
    iof:satisfiesRequirement :Req_0 .

:DesignatedLocation_1 a bfo:BFO_0000040 ;
    rdfs:label "designated location for showing Black Flag" .

:PlanSpec_Cont_0 a iof:PlanSpecification ;
    rdfs:label "Plan for allowing vehicle to continue after stall or cone ingestion" ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :Process_AllowContinue_0 .

:Process_AllowContinue_0 a iof:PlannedProcess ;
    rdfs:label "process of allowing vehicle to continue" ;
    bfo:BFO_0000057 :Vehicle_0 ;
    iof:prescribedBy :PlanSpec_Cont_0 .

:Process_ShowBlackFlag_1 a iof:PlannedProcess ;
    rdfs:label "showing of Black Flag" ;
    bfo:BFO_0000057 :BlackFlag_1,
        :DesignatedLocation_1 ;
    iof:prescribedBy :PlanSpec_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If a vehicle stalls, or ingests a cone, etc., it may be allowed to continue, subject to D.12.1.4 and D.12.4 ## D.12.10 Endurance Event - Black Flags D.12.10.1 A Black Flag will be shown at the designated location D.12.10.2" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DesignSpec_0,
        :PlanSpec_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    rdfs:label "Plan specification for Black Flag showing" ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :Process_ShowBlackFlag_1 .

:Vehicle_0 a bfo:BFO_0000040 ;
    rdfs:label "vehicle (unspecified)" .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objectives for vehicle continuation and Black Flag behavior" .

