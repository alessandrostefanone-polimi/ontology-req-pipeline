@prefix : <http://example.org/req/495#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Exposed around the lower $180^{\\circ}$ of its circumference over a minimum length of 280 mm g. Access from the rear of the tube must be unobstructed for 300 mm or more of its length h" ;
    iof:requirementSatisfiedBy :Plan_0 .

:AccessProcess_0 a iof:PlannedProcess ;
    rdfs:label "Access from the rear of the tube" ;
    iof:hasInput :Tube_0 ;
    iof:hasProcessCharacteristic :ObstructionState_0 .

:ObstructionState_0 a iof:ProcessCharacteristic ;
    rdfs:label "access obstruction state" .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :AccessProcess_0 .

:Tube_0 a bfo:BFO_0000040 ;
    rdfs:label "tube" ;
    iof:hasQuality :UnobstructedLength_0 .

:UnobstructedLength_0 a bfo:BFO_0000019 ;
    rdfs:label "unobstructed length of access from rear of tube" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3e+02 ;
    qudt:unit qudtu:MM .

qudtqk:Length a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

