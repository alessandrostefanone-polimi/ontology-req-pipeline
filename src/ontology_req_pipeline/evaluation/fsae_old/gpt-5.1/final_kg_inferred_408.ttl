        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "IC.9.2.2" .

<http://example.org/req/408#OFF_Position> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "OFF position" .

<http://example.org/req/408#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "3.3.3 Operation of the BOTS to the OFF position must Open the Shutdown Circuit IC.9.2.2 / EV.7.2.2 T.3.3.4 Repeated operation of the switch must not reset or restore power T.3.3.5" ;
    ns1:isAbout <http://example.org/req/408#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/408#PlanSpec_0> .

<http://example.org/req/408#T_3_3_4> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "T.3.3.4" .

<http://example.org/req/408#T_3_3_5> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "T.3.3.5" .

<http://example.org/req/408#BOTS> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "BOTS" .

<http://example.org/req/408#ShutdownCircuit> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Shutdown Circuit" .

<http://example.org/req/408#ShutdownCircuit_Open_Process> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "Opening of the Shutdown Circuit" ;
    ns1:processCharacteristicOf <http://example.org/req/408#BOTS_Operation_Off> .

<http://example.org/req/408#ShutdownCircuit_Open_State> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Shutdown Circuit open state" ;
    ns1:qualityOf <http://example.org/req/408#ShutdownCircuit> .

<http://example.org/req/408#No_Reset_Event> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "No reset on repeated operation" ;
    ns1:processCharacteristicOf <http://example.org/req/408#BOTS_Operation_Off> .

<http://example.org/req/408#No_RestorePower_Event> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "No restore power on repeated operation" ;
    ns1:processCharacteristicOf <http://example.org/req/408#BOTS_Operation_Off> .

<http://example.org/req/408#ObjSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:prescribes <http://example.org/req/408#No_Reset_Event>,
        <http://example.org/req/408#No_RestorePower_Event>,
