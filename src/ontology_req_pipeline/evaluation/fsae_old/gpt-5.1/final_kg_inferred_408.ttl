        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/408#ObjSpec_0> ;
    ns1:prescribes <http://example.org/req/408#BOTS_Operation_Off> .

<http://example.org/req/408#BOTS_Operation_Off> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Operation of the BOTS to the OFF position" ;
    ns2:BFO_0000057 <http://example.org/req/408#BOTS> ;
    ns1:hasProcessCharacteristic <http://example.org/req/408#No_Reset_Event>,
        <http://example.org/req/408#No_RestorePower_Event> ;
    ns1:hasSpecifiedOutput <http://example.org/req/408#ShutdownCircuit_Open_State> ;
    ns1:prescribedBy <http://example.org/req/408#PlanSpec_0> .

