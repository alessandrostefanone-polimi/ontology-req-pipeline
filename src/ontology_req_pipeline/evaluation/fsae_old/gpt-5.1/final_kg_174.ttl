@prefix : <http://example.org/req/174#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AccessLocation_0 a bfo:BFO_0000029 ;
    rdfs:label "Location accessible during Technical Inspection"@en .

:TechInspection_0 a iof:PlannedProcess ;
    rdfs:label "Technical Inspection"@en .

:FrontHoop_0 a bfo:BFO_0000040 ;
    rdfs:label "Front Hoop (non-steel)"@en ;
    iof:hasComponentPartAtSomeTime :Hole_0 .

:FrontHoop_0_DesignSpec a iof:DesignSpecification ;
    iof:prescribes :FrontHoop_0 ;
    iof:satisfiesRequirement :Req_0 .

:Hole_0 a bfo:BFO_0000040 ;
    rdfs:label "4 mm access hole in Front Hoop"@en ;
    iof:hasQuality :Hole_0_Diameter .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "5.7.7 A Front Hoop that is not steel must have a 4 mm hole drilled in a location to access during Technical Inspection" ;
    iof:requirementSatisfiedBy :FrontHoop_0_DesignSpec .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 4e+00 ;
    qudt:minInclusive 4e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Hole_0_Diameter .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:Hole_0_Diameter a bfo:BFO_0000019 ;
    rdfs:label "Diameter of access hole"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c2 .

