@prefix : <http://example.org/req/550#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The power to the electronic throttle must be immediately shut down, if throttle position differs by more than $10 \\%$ from the expected target TPS position for more than one second" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:ThrottlePowerOffState_0 a bfo:BFO_0000002 .

:ThrottlePower_0 a bfo:BFO_0000040 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 1e+00 ;
    qudt:unit qudtu:SEC ;
    iof:isValueExpressionOfAtSomeTime :CondDuration_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 1e+01 ;
    qudt:unit qudtu:PERCENT ;
    iof:isValueExpressionOfAtSomeTime :ThrottlePosDeviation_0 .

qudtqk:DutyCycle a qudt:QuantityKind .

qudtqk:Time a qudt:QuantityKind .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DutyCycle .

qudtu:SEC a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Time .

:CondDuration_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:processCharacteristicOf :ShutdownProcess_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :ShutdownProcess_0 ;
    iof:prescribes :ShutdownProcess_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :ShutdownProcess_0 .

:ThrottlePosDeviation_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 ;
    iof:processCharacteristicOf :ShutdownProcess_0 .

:ShutdownProcess_0 a iof:PlannedProcess ;
    iof:hasInput :ThrottlePower_0 ;
    iof:hasOutput :ThrottlePowerOffState_0 ;
    iof:hasProcessCharacteristic :CondDuration_0,
        :ThrottlePosDeviation_0 ;
    iof:prescribedBy :PlanSpec_0 .

