@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/199#> a owl:Ontology .

<http://example.org/req/199#DS_BraceFastener> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Design specification for critical fasteners on braces",
        "Design specification for critical fasteners on braces"@en ;
    ns1:prescribes <http://example.org/req/199#CriticalFastener> ;
    ns1:satisfiesRequirement <http://example.org/req/199#Req_0> .

<http://example.org/req/199#DS_MountingPlate> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Design specification for mounting plates",
        "Design specification for mounting plates"@en ;
    ns1:prescribes <http://example.org/req/199#MountingPlate> ;
    ns1:satisfiesRequirement <http://example.org/req/199#Req_0> .

<http://example.org/req/199#Frame> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "frame",
        "frame"@en .

<http://example.org/req/199#MountingPlateWeldingProcess> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "mounting plate welding process",
        "mounting plate welding process"@en ;
    ns1:hasInput <http://example.org/req/199#MountingPlate>,
        <http://example.org/req/199#RollHoopBracing> ;
    ns1:hasSpecifiedOutput <http://example.org/req/199#MountingPlate> ;
    ns1:prescribedBy <http://example.org/req/199#PlanSpec_1> .

<http://example.org/req/199#PlanSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan for brace attachment using critical fasteners",
        "Plan for brace attachment using critical fasteners"@en ;
    ns3:BFO_0000110 <http://example.org/req/199#ObjSpec_0> ;
    ns1:prescribes <http://example.org/req/199#BraceAttachmentProcess> .

<http://example.org/req/199#PlanSpec_1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan for mounting plate welding to roll hoop bracing",
        "Plan for mounting plate welding to roll hoop bracing"@en ;
    ns3:BFO_0000110 <http://example.org/req/199#ObjSpec_1> ;
    ns1:prescribes <http://example.org/req/199#MountingPlateWeldingProcess> .

<http://example.org/req/199#RollHoopBracing> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "roll hoop bracing",
        "roll hoop bracing"@en .

<http://example.org/req/199#VE_req0_c2> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "minimum fastener diameter 8 mm",
        "minimum fastener diameter 8 mm"@en ;
    ns2:minInclusive 8e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/199#FastenerDiameterQuality> .

<http://example.org/req/199#VE_req0_c3> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "minimum fastener diameter 5/16 inch",
        "minimum fastener diameter 5/16 inch"@en ;
    ns2:minInclusive 3.125e-01 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/199#FastenerDiameterQuality> .

<http://example.org/req/199#VE_req1_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "minimum mounting plate thickness 2.0 mm (0.080 in)",
        "minimum mounting plate thickness 2.0 mm (0.080 in)"@en ;
    ns2:minInclusive 2e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/IN> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/199#MountingPlateThicknessQuality> .

<http://qudt.org/vocab/unit/IN> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://example.org/req/199#Brace> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "brace",
        "brace"@en .

<http://example.org/req/199#BraceAttachmentProcess> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "brace attachment process",
        "brace attachment process"@en ;
    ns1:hasInput <http://example.org/req/199#Brace>,
        <http://example.org/req/199#CriticalFastener>,
        <http://example.org/req/199#Frame> ;
    ns1:hasSpecifiedOutput <http://example.org/req/199#Brace> ;
    ns1:prescribedBy <http://example.org/req/199#PlanSpec_0> .

<http://example.org/req/199#CriticalFastener> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    rdfs:label "critical fastener",
        "critical fastener"@en ;
    ns1:hasQuality <http://example.org/req/199#FastenerDiameterQuality> .

<http://example.org/req/199#ObjSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective for brace attachment using critical fasteners",
        "Objective for brace attachment using critical fasteners"@en ;
    ns1:prescribes <http://example.org/req/199#BraceAttachmentProcess>,
        <http://example.org/req/199#FastenerDiameterQuality> .

<http://example.org/req/199#ObjSpec_1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective for mounting plate minimum thickness",
        "Objective for mounting plate minimum thickness"@en ;
    ns1:prescribes <http://example.org/req/199#MountingPlate>,
        <http://example.org/req/199#MountingPlateThicknessQuality> .

<http://example.org/req/199#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Other Bracing Requirements F.5.13.1 Where the braces are not welded to steel Frame Members, the braces must be securely attached to the Frame using 8 mm or 5/16\" minimum diameter Critical Fasteners, see T.8.2 F.5.13.2 Mounting plates welded to Roll Hoop Bracing must be 2.0 mm ( 0.080 in) minimum thickness steel" ;
    ns1:isAbout <http://example.org/req/199#ObjSpec_0>,
        <http://example.org/req/199#ObjSpec_1> ;
    ns1:requirementSatisfiedBy <http://example.org/req/199#DS_BraceFastener>,
        <http://example.org/req/199#DS_MountingPlate> .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Thickness> .

<http://example.org/req/199#MountingPlateThicknessQuality> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "mounting plate thickness quality",
        "mounting plate thickness quality"@en ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/199#VE_req1_c0> .

<http://example.org/req/199#FastenerDiameterQuality> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "fastener diameter quality",
        "fastener diameter quality"@en ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/199#VE_req0_c2>,
        <http://example.org/req/199#VE_req0_c3> .

<http://example.org/req/199#MountingPlate> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    rdfs:label "mounting plate",
        "mounting plate"@en ;
    ns1:hasQuality <http://example.org/req/199#MountingPlateThicknessQuality> .

