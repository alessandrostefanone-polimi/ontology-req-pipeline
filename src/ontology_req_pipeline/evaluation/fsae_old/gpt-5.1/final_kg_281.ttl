@prefix : <http://example.org/req/281#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :StandardHoneycomb_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Standard Honeycomb must be mounted 200mm width x 100mm height c" ;
    iof:requirementSatisfiedBy :DS_0 .

:StandardHoneycomb_0 a bfo:BFO_0000040 ;
    rdfs:label "Standard Honeycomb"@en ;
    iof:hasQuality :Height_0,
        :Width_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e+02 ;
    qudt:minInclusive 2e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Width_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1e+02 ;
    qudt:minInclusive 1e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Height_0 .

qudtqk:Breadth a qudt:QuantityKind .

:Height_0 a bfo:BFO_0000019 ;
    rdfs:label "height of Standard Honeycomb (mounting)"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:Width_0 a bfo:BFO_0000019 ;
    rdfs:label "width of Standard Honeycomb (mounting)"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Breadth .

