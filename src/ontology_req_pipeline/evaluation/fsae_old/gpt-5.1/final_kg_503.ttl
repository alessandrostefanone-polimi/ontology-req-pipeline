@prefix : <http://example.org/req/503#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:CameraBody_0 a bfo:BFO_0000040 ;
    iof:hasQuality :Weight_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :CameraBody_0,
        :SecuringConfiguration_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "2.5.4 The body of a camera or recording unit that weighs more than 0.25 kg must be secured at a minimum of two points on different sides of the camera body" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:SecuringConfiguration_0 a bfo:BFO_0000040 ;
    iof:hasQuality :NumberOfSecuringPoints_0,
        :SecuringPointLocation_0 .

:SecuringPointLocation_0 a bfo:BFO_0000019 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 2.5e-01 ;
    qudt:unit qudtu:KiloGM ;
    iof:isValueExpressionOfAtSomeTime :Weight_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :NumberOfSecuringPoints_0 .

qudtqk:Mass a qudt:QuantityKind .

qudtqk:PathLength a qudt:QuantityKind .

qudtu:KiloGM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Mass .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:PathLength .

:NumberOfSecuringPoints_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:Weight_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

