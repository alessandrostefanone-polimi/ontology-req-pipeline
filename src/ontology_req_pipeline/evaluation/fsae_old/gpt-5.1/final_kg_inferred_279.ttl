@prefix : <http://example.org/req/279#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:F_8_5_7_ImpactAttenuatorOrientation a iof:InformationContentEntity ;
    rdfs:label "F.8.5.7 Impact Attenuator Orientation" ;
    iof:isAbout :ImpactAttenuator .

:LowerSideImpactStructure a bfo:BFO_0000040 ;
    rdfs:label "Lower Side Impact Structure" .

:DS_ImpactAttenuatorAreaMounting a iof:DesignSpecification ;
    rdfs:label "Design specification for mounting area of Custom Impact Attenuator" ;
    iof:prescribes :ImpactAttenuator ;
    iof:satisfiesRequirement :Req_0 .

:HeightAboveLowestPoint a bfo:BFO_0000019 ;
    rdfs:label "Height of intersecting plane above lowest point on top of Lower Side Impact Structure" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c3 ;
    iof:qualityOf :PlaneParallelToGround .

:ImpactAttenuatorAreaLength a bfo:BFO_0000019 ;
    rdfs:label "Length of mounting area of Custom Impact Attenuator" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :ImpactAttenuatorArea .

:ImpactAttenuatorAreaWidth a bfo:BFO_0000019 ;
    rdfs:label "Width of mounting area of Custom Impact Attenuator" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :ImpactAttenuatorArea .

:PlaneParallelToGround a bfo:BFO_0000029 ;
    rdfs:label "Plane parallel to the ground intersecting mounting area" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A Custom Impact Attenuator must mount with an area of 200 mm or more long and 200 mm or more wide that intersects a plane parallel to the ground that is no more than 220 mm above the lowest point on the top of the Lower Side Impact Structure F.8.5.7 Impact Attenuator Orientation a" ;
    iof:requirementSatisfiedBy :DS_ImpactAttenuatorAreaMounting .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Required minimum length of mounting area (>= 200 mm)" ;
    qudt:minInclusive 2e+02 ;
    qudt:quantityKind qudtqk:Length ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :ImpactAttenuatorAreaLength .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Required minimum width of mounting area (>= 200 mm)" ;
    qudt:minInclusive 2e+02 ;
    qudt:quantityKind qudtqk:Breadth ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :ImpactAttenuatorAreaWidth .

:VE_req0_c3 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Required maximum height of intersecting plane above lowest point (<= 220 mm)" ;
    qudt:maxInclusive 2.2e+02 ;
    qudt:quantityKind qudtqk:Length ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :HeightAboveLowestPoint .

qudtqk:Breadth a qudt:QuantityKind .

:ImpactAttenuator a bfo:BFO_0000040 ;
    rdfs:label "Custom Impact Attenuator" ;
    iof:hasQuality :ImpactAttenuatorArea .

:ImpactAttenuatorArea a bfo:BFO_0000019 ;
    rdfs:label "Mounting area of Custom Impact Attenuator" ;
    iof:qualityOf :ImpactAttenuator .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Breadth,
        qudtqk:Length .

