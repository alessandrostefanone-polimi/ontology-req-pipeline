    ns2:maxInclusive 5e+01 ;
    ns2:minInclusive 5e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/PERCENT> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/160#ReductionFactor> .

<http://qudt.org/vocab/unit/PERCENT> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/ServiceFactor> .

