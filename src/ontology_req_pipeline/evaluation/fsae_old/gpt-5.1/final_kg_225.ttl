@prefix : <http://example.org/req/225#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:LowStressLocation_Monocoque a bfo:BFO_0000029 ;
    rdfs:label "low stress location of monocoque section"@en .

:StructuralEquivalencySpreadsheet a iof:InformationContentEntity ;
    rdfs:label "Structural Equivalency Spreadsheet"@en .

:VerticalSideImpactStructure a bfo:BFO_0000040 ;
    rdfs:label "Vertical Side Impact Structure"@en .

:DrillingProcess_0 a iof:PlannedProcess ;
    rdfs:label "drilling of inspection hole through low-stress monocoque location"@en ;
    iof:hasInput :MonocoqueSection ;
    iof:hasSpecifiedOutput :InspectionHole_0 ;
    iof:prescribedBy :PlanSpec_0 .

:MonocoqueSection a bfo:BFO_0000040 ;
    rdfs:label "monocoque section"@en .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :DrillingProcess_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "An inspection hole approximately 4 mm in diameter must be drilled through a low stress location of every monocoque section regulated by the Structural Equivalency Spreadsheet This inspection hole is not required in the Vertical Side Impact Structure F.7.5.3.b" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 4e+00 ;
    qudt:minInclusive 4e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Diameter_InspectionHole_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :InspectionHole_0 ;
    iof:satisfiesRequirement :Req_0 .

:Diameter_InspectionHole_0 a bfo:BFO_0000019 ;
    rdfs:label "diameter of inspection hole"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:InspectionHole_0 a bfo:BFO_0000040 ;
    rdfs:label "inspection hole in monocoque section"@en ;
    iof:hasQuality :Diameter_InspectionHole_0 ;
    iof:prescribedBy :DesignSpec_0 .

