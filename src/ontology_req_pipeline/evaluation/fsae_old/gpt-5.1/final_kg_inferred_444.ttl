<http://example.org/req/444#> a owl:Ontology .

<http://example.org/req/444#MotorScatterShield_MaterialChoice> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Motor Scatter Shield material (6061-T6 or steel)" ;
    ns1:qualityOf <http://example.org/req/444#MotorScatterShield> .

<http://example.org/req/444#VE_req1_c0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Required thickness of Motor Scatter Shield (1.0 mm)" ;
    ns3:maxInclusive 1e+00 ;
    ns3:minInclusive 1e+00 ;
    ns3:unit <http://qudt.org/vocab/unit/MM> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/444#Thickness_MotorScatterShield> .

<http://example.org/req/444#CoolantUseProcess_ElectricMotors> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Coolant use process for electric motors / accumulators / HV electronics" ;
