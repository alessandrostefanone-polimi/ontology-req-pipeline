@prefix : <http://example.org/req/418#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The circuit must have a pull-up or pull-down resistor to bring an open circuit input to $0 \\%$ Pedal Travel - An OEM pedal sensor with opposite slopes" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :PlannedProcess_0 .

:PlannedProcess_0 a iof:PlannedProcess ;
    rdfs:label "Circuit behavior with pull-up or pull-down resistor and pedal sensor" ;
    iof:hasSpecifiedOutput :PedalTravel_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "required resulting pedal travel = 0 % (duty cycle)" ;
    qudt:maxInclusive 0e+00 ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:PERCENT ;
    iof:isValueExpressionOfAtSomeTime :PedalTravel_0 .

qudtqk:DutyCycle a qudt:QuantityKind .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DutyCycle .

:PedalTravel_0 a bfo:BFO_0000019 ;
    rdfs:label "resulting pedal travel for open circuit input" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

