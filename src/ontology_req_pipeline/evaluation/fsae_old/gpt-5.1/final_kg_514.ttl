@prefix : <http://example.org/req/514#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:F_6_4 a iof:InformationContentEntity ;
    rdfs:label "F.6.4 structural standard" .

:F_7_5 a iof:InformationContentEntity ;
    rdfs:label "F.7.5 structural standard" .

:LowIntakePortion a bfo:BFO_0000040 ;
    rdfs:label "Portion of air intake system less than 350 mm above ground" ;
    iof:componentPartOfAtSomeTime :AirIntakeSystem ;
    iof:hasQuality :HeightAboveGround_Req514_1 .

:ProtectiveStructure a bfo:BFO_0000040 ;
    rdfs:label "Protective structure built per F.6.4 / F.7.5" ;
    iof:componentPartOfAtSomeTime :ShieldedLowIntakePortion .

:Req514_1 a iof:RequirementSpecification ;
    rdfs:comment "IC.2.2.2 Any portion of the air intake system that is less than 350 mm above the ground must be shielded from side or rear impacts by structure built per F.6.4 / F.7.5 as applicable." ;
    iof:isAbout :Obj_Req514_1 ;
    iof:requirementSatisfiedBy :PS_Req514_Shielding .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "2 AIR INTAKE SYSTEM ## IC.2.1 General ## IC.2.2 Intake System Location IC.2.2.1 The Intake System must meet IC.1.2 IC.2.2.2 Any portion of the air intake system that is less than 350 mm above the ground must be shielded from side or rear impacts by structure built per F.6.4 / F.7.5 as applicable. ## IC.2.3 Intake System Mounting IC.2.3.1" ;
    iof:requirementSatisfiedBy :DS_Req514_Design,
        :PS_Req514_Shielding .

:IC_1_2_Requirement a iof:InformationContentEntity ;
    rdfs:label "IC.1.2 requirement reference" .

:IntakeSystem a bfo:BFO_0000040 ;
    rdfs:label "Intake System" .

:Obj_Req514_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for Intake System compliance with IC.1.2" ;
    iof:prescribes :IC_1_2_Requirement .

:Obj_Req514_1 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for shielding low air intake portions" ;
    iof:prescribes :ShieldingProcessCharacteristic .

:Req514_0 a iof:RequirementSpecification ;
    rdfs:comment "IC.2.2.1 The Intake System must meet IC.1.2" ;
    iof:isAbout :Obj_Req514_0 ;
    iof:requirementSatisfiedBy :DS_Req514_Design .

:ShieldingProcess a iof:PlannedProcess ;
    rdfs:label "Shielding of low air intake portions from side or rear impacts" ;
    iof:hasProcessCharacteristic :ShieldingProcessCharacteristic ;
    iof:hasSpecifiedOutput :ShieldedLowIntakePortion .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Height above ground < 350 mm" ;
    qudt:maxExclusive 3.5e+02 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :HeightAboveGround_Req514_1 .

qudtqk:Height a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:AirIntakeSystem a bfo:BFO_0000040 ;
    rdfs:label "air intake system" .

:DS_Req514_Design a iof:DesignSpecification ;
    rdfs:label "Design specification for Intake System" ;
    iof:prescribes :IntakeSystem ;
    iof:satisfiesRequirement :Req514_0 .

:HeightAboveGround_Req514_1 a bfo:BFO_0000019 ;
    rdfs:label "height above the ground of low intake portion" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:PS_Req514_Shielding a iof:PlanSpecification ;
    rdfs:label "Plan specification for shielding air intake portions" ;
    iof:prescribes :ShieldingProcess .

:ShieldedLowIntakePortion a bfo:BFO_0000040 ;
    rdfs:label "Low intake portion shielded from side or rear impacts" ;
    iof:componentPartOfAtSomeTime :AirIntakeSystem .

:ShieldingProcessCharacteristic a iof:ProcessCharacteristic ;
    rdfs:label "Shielding from side or rear impacts by compliant structure" .

