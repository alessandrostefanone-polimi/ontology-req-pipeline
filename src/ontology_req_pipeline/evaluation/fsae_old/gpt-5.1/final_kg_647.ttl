@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/647#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:EV_6_1_2 a iof:InformationContentEntity ;
    rdfs:label "EV.6.1.2 isolation requirement reference" ;
    iof:isSubjectOf :IsolationState_2 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Clearly marked with \"HVD\" EV.5.5.2 An Interlock EV.7.8 must Open the Shutdown Circuit EV.7.2.2 when the HVD is removed EV.5.5.3 A dummy connector or similar may be used to restore isolation to meet EV.6.1.2 # EV.5.6 Precharge and Discharge Circuits EV.5.6.1 The Accumulator must contain a Precharge Circuit" ;
    iof:requirementSatisfiedBy :DS_0,
        :DS_3,
        :PS_1,
        :PS_2 .

:Accumulator_3 a bfo:BFO_0000040 ;
    rdfs:label "Accumulator" ;
    iof:hasComponentPartAtSomeTime :PrechargeCircuit_3 .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "HVD marking design specification" ;
    iof:prescribes :HVD_0 .

:DS_3 a iof:DesignSpecification ;
    rdfs:label "Accumulator precharge-circuit design specification" ;
    iof:prescribes :Accumulator_3 .

:DummyConnector_2 a bfo:BFO_0000040 ;
    rdfs:label "Dummy connector or similar" .

:HVD_0 a bfo:BFO_0000040 ;
    rdfs:label "High Voltage Disconnect (HVD)" ;
    iof:hasQuality :HVD_Marking_0 .

:HVD_1 a bfo:BFO_0000040 ;
    rdfs:label "HVD (for removal event)" .

:HVD_Marking_0 a bfo:BFO_0000019 ;
    rdfs:label "HVD marking quality" .

:HVD_Removal_1 a bfo:BFO_0000015 ;
    rdfs:label "HVD removal process" ;
    bfo:BFO_0000057 :HVD_1 .

:Interlock_1 a bfo:BFO_0000040 ;
    rdfs:label "Interlock EV.7.8" .

:OpenShutdown_1 a iof:PlannedProcess ;
    rdfs:label "Opening of shutdown circuit by interlock" ;
    iof:hasInput :Interlock_1,
        :ShutdownCircuit_1 ;
    iof:hasOutput :ShutdownCircuit_1 ;
    iof:occursDuring :HVD_Removal_1 .

:PS_1 a iof:PlanSpecification ;
    rdfs:label "Interlock shutdown-opening plan specification" ;
    iof:prescribes :OpenShutdown_1 .

:PS_2 a iof:PlanSpecification ;
    rdfs:label "Dummy connector isolation-restoration plan specification" ;
    iof:prescribes :RestoreIsolation_2 .

:PrechargeCircuit_3 a bfo:BFO_0000040 ;
    rdfs:label "Precharge Circuit" .

:RestoreIsolation_2 a iof:PlannedProcess ;
    rdfs:label "Restoration of isolation using dummy connector" ;
    iof:hasInput :DummyConnector_2 ;
    iof:hasOutput :IsolationState_2 .

:IsolationState_2 a bfo:BFO_0000015 ;
    rdfs:label "Isolation state satisfying EV.6.1.2" .

:ShutdownCircuit_1 a bfo:BFO_0000040 ;
    rdfs:label "Shutdown Circuit EV.7.2.2" .

