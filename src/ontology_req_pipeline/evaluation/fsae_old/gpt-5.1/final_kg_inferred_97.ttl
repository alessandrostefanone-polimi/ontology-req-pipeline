@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/97#> a owl:Ontology .

<http://example.org/req/97#Req0_Constraint0> a ns2:BFO_0000001,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Req 0, constraint 0 – behavior in any angular position" ;
    ns1:isSubjectOf <http://example.org/req/97#PS_SteeringWheelAngularBehavior> .

<http://example.org/req/97#Req0_Constraint1> a ns2:BFO_0000001,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Req 0, constraint 1 – compliance with T.1.4.4" ;
    ns1:isSubjectOf <http://example.org/req/97#T_1_4_4> .

<http://example.org/req/97#Req1_Constraint0> a ns2:BFO_0000001,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Req 1, constraint 0 – steering wheel attached to column" ;
    ns1:isSubjectOf <http://example.org/req/97#DS_SteeringWheelAttachment> .

<http://example.org/req/97#Req1_Constraint1> a ns2:BFO_0000001,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Req 1, constraint 1 – quick disconnect between steering wheel and column" ;
    ns1:isSubjectOf <http://example.org/req/97#DS_SteeringWheelAttachment> .

<http://example.org/req/97#V_3_3_2> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "Standard / clause V.3.3.2" .

<http://example.org/req/97#AngularPositionCharacteristic_1> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "Angular position of steering wheel during operation" .

<http://example.org/req/97#SteeringWheelAngularProcess_1> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Process of operating steering wheel over angular positions" ;
    ns2:BFO_0000057 <http://example.org/req/97#SteeringWheel_1> ;
    ns1:hasProcessCharacteristic <http://example.org/req/97#AngularPositionCharacteristic_1> .

<http://example.org/req/97#T_1_4_4> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "Standard / clause T.1.4.4" .

<http://example.org/req/97#Column_1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Steering column" .

<http://example.org/req/97#PS_SteeringWheelAngularBehavior> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan specification for steering wheel behavior in any angular position and compliance with T.1.4.4 / V.3.3.2" ;
    ns1:prescribes <http://example.org/req/97#SteeringWheelAngularProcess_1> ;
    ns1:satisfiesRequirement <http://example.org/req/97#Req_0> .

<http://example.org/req/97#QuickDisconnect_1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Quick disconnect coupling between steering wheel and column" ;
    ns1:componentPartOfAtSomeTime <http://example.org/req/97#Column_1>,
        <http://example.org/req/97#SteeringWheel_1> .

<http://example.org/req/97#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "In any angular position, the Steering Wheel must meet T.1.4.4 V.3.3.2 The Steering Wheel must be attached to the column with a quick disconnect" ;
    ns1:requirementSatisfiedBy <http://example.org/req/97#DS_SteeringWheelAttachment>,
        <http://example.org/req/97#PS_SteeringWheelAngularBehavior> .

<http://example.org/req/97#DS_SteeringWheelAttachment> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Design specification for steering wheel attachment to column with quick disconnect" ;
    ns1:prescribes <http://example.org/req/97#Column_1>,
        <http://example.org/req/97#QuickDisconnect_1>,
        <http://example.org/req/97#SteeringWheel_1> ;
    ns1:satisfiesRequirement <http://example.org/req/97#Req_0> .

<http://example.org/req/97#SteeringWheel_1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Steering wheel" ;
    ns1:hasComponentPartAtSomeTime <http://example.org/req/97#QuickDisconnect_1> .

