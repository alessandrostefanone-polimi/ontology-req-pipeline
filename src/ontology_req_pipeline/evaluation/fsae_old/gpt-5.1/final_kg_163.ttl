@prefix : <http://example.org/req/163#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A two dimensional template used to represent the 95th percentile male is made to the following dimensions (see figure below): - A circle of diameter 200 mm will represent the hips and buttocks" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Circle_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e+02 ;
    qudt:minInclusive 2e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Circle_0_Diameter .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:Circle_0 a bfo:BFO_0000030 ;
    rdfs:label "Circle representing hips and buttocks" ;
    iof:hasQuality :Circle_0_Diameter .

:Circle_0_Diameter a bfo:BFO_0000019 ;
    rdfs:label "Diameter of circle representing hips and buttocks" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :Circle_0 .

