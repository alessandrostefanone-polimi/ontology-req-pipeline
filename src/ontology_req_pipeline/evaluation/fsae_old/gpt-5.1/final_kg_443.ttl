@prefix : <http://example.org/req/443#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:MotorCasePerforated_1 a iof:Event ;
    rdfs:label "Motor case is perforated" ;
    iof:recognizedByAtSomeTime :Agent_ReqAuthor .

:MotorCasingRotates_1 a iof:Event ;
    rdfs:label "Motor casing rotates around stator" ;
    iof:recognizedByAtSomeTime :Agent_ReqAuthor .

:DS_Thickness_0 a iof:DesignSpecification ;
    rdfs:label "Design specification for minimum steel thickness" ;
    iof:isAbout :ObjSpec_Thickness_0 ;
    iof:prescribes :SteelSection_0 ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_ScatterShield_1 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: include scatter shield around motor under specified conditions" ;
    iof:prescribes :Motor_1,
        :ScatterShield_1 .

:ObjSpec_Thickness_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective: steel thickness 2.0 mm" ;
    iof:prescribes :Thickness_Quality_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Required steel thickness value expression (2.0 mm)" ;
    qudt:maxInclusive 2e+00 ;
    qudt:minInclusive 2e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Thickness_Quality_0 .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

:Agent_ReqAuthor a iof:Agent ;
    rdfs:label "Implicit requirement author/analyst agent" .

:Motor_1 a iof:MaterialArtifact ;
    rdfs:label "Motor" .

:PS_ScatterShield_1 a iof:PlanSpecification ;
    rdfs:label "Plan specification for scatter shield inclusion around motor" ;
    iof:isAbout :ObjSpec_ScatterShield_1 ;
    iof:prescribes :ScatterShieldInclusionProcess_1 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Minimum thickness for steel: 2.0 mm T.5.3.2 A Scatter Shield must be included around the Motor(s) when one or both: - The motor casing rotates around the stator - The motor case is perforated T.5.3.3" ;
    iof:requirementSatisfiedBy :DS_Thickness_0,
        :PS_ScatterShield_1 .

:ScatterShieldInclusionProcess_1 a iof:PlannedProcess ;
    rdfs:label "Process of including scatter shield around motor" ;
    iof:hasInput :Motor_1 ;
    iof:hasSpecifiedOutput :ScatterShield_1 ;
    iof:prescribedBy :PS_ScatterShield_1 .

:ScatterShield_1 a iof:MaterialArtifact ;
    rdfs:label "Scatter Shield" ;
    iof:isSpecifiedOutputOf :ScatterShieldInclusionProcess_1 .

:SteelSection_0 a bfo:BFO_0000040 ;
    rdfs:label "Steel section with specified minimum thickness" ;
    iof:hasQuality :Thickness_Quality_0 .

:Thickness_Quality_0 a bfo:BFO_0000019 ;
    rdfs:label "Thickness of steel section" ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 ;
    iof:qualityOf :SteelSection_0 .

