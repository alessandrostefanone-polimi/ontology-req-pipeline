@prefix : <http://example.org/req/452#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any catch can on the cooling system must vent through a hose with a minimum internal diameter of 3 mm down to the bottom levels of the Chassis. ## T. 6 PRESSURIZED SYSTEMS ##" ;
    iof:requirementSatisfiedBy :VentPlan_0 .

:CatchCan_0 a bfo:BFO_0000040 .

:Chassis_0 a bfo:BFO_0000040 .

:Hose_0 a bfo:BFO_0000040 ;
    iof:hasQuality :HoseInternalDiameter_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :HoseInternalDiameter_0 .

:VentPlan_0 a iof:PlanSpecification ;
    iof:prescribes :VentProcess_0 .

:VentProcess_0 a iof:PlannedProcess ;
    iof:hasInput :CatchCan_0 ;
    iof:hasParticipantAtSomeTime :Chassis_0,
        :Hose_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:HoseInternalDiameter_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 .

