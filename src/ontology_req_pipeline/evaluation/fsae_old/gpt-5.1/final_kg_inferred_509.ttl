@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/509#> a owl:Ontology .

<http://example.org/req/509#CompetitorRole> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000017,
        ns2:BFO_0000020,
        ns2:BFO_0000023,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "competitor role" ;
    ns1:roleOf <http://example.org/req/509#Competitor> .

<http://example.org/req/509#DriverSuit_Approved> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "approved driver suit" ;
    ns1:isSubjectOf <http://example.org/req/509#DesignSpec_Suit> .

<http://example.org/req/509#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Each suit must meet one or more of the following standards and be labeled as such: - $\\quad$ SFI 3.2A/5 (or higher ex: /10, /15, /20) - $\\quad$ SFI 3.4/5 (or higher ex: /10, /15, /20) - FIA Standard 1986 - FIA Standard 8856-2000 - FIA Standard 8856-2018 VE.3.3.2 Underclothing All competitors should wear fire retardant underwear (long pants and long sleeve shirt) under their approved Driver Suit" ;
    ns1:isAbout <http://example.org/req/509#ObjSpec_SuitStandards>,
        <http://example.org/req/509#ObjSpec_Underclothing> ;
    ns1:requirementSatisfiedBy <http://example.org/req/509#DesignSpec_Suit>,
        <http://example.org/req/509#PlanSpec_Underclothing> .

<http://example.org/req/509#Std_FIA_1986> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "FIA Standard 1986" ;
    ns1:isSubjectOf <http://example.org/req/509#ObjSpec_SuitStandards> .

<http://example.org/req/509#Std_FIA_8856_2000> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "FIA Standard 8856-2000" ;
    ns1:isSubjectOf <http://example.org/req/509#ObjSpec_SuitStandards> .

<http://example.org/req/509#Std_FIA_8856_2018> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "FIA Standard 8856-2018" ;
    ns1:isSubjectOf <http://example.org/req/509#ObjSpec_SuitStandards> .

<http://example.org/req/509#Std_SFI_3_2A_5> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "SFI 3.2A/5 (or higher ex: /10, /15, /20)" ;
    ns1:isSubjectOf <http://example.org/req/509#ObjSpec_SuitStandards> .

<http://example.org/req/509#Std_SFI_3_4_5> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "SFI 3.4/5 (or higher ex: /10, /15, /20)" ;
    ns1:isSubjectOf <http://example.org/req/509#ObjSpec_SuitStandards> .

<http://example.org/req/509#Suit> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "driver suit" ;
    ns1:isSubjectOf <http://example.org/req/509#DesignSpec_Suit> .

<http://example.org/req/509#Suit_Labeling> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "Suit labeling indicating applicable standard(s)" ;
    ns1:isSubjectOf <http://example.org/req/509#ObjSpec_SuitStandards> .

<http://example.org/req/509#Underwear_LayeringCondition> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "underwear worn under approved driver suit" ;
    ns1:processCharacteristicOf <http://example.org/req/509#Process_WearUnderwear> .

<http://example.org/req/509#Competitor> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000030,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:Person ;
    rdfs:label "competitor" ;
    ns1:hasRole <http://example.org/req/509#CompetitorRole> .

<http://example.org/req/509#ObjSpec_Underclothing> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: competitors wear fire retardant underwear under driver suit" ;
    ns1:prescribes <http://example.org/req/509#Underwear_Item>,
        <http://example.org/req/509#Underwear_LayeringCondition>,
        <http://example.org/req/509#Underwear_MaterialProperty> .

<http://example.org/req/509#PlanSpec_Underclothing> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan specification for competitor underclothing" ;
    ns2:BFO_0000110 <http://example.org/req/509#ObjSpec_Underclothing> ;
    ns1:prescribes <http://example.org/req/509#Process_WearUnderwear> .

<http://example.org/req/509#Process_WearUnderwear> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Process of competitors wearing fire retardant underwear under driver suit" ;
    ns1:hasInput <http://example.org/req/509#Competitor>,
        <http://example.org/req/509#DriverSuit_Approved>,
        <http://example.org/req/509#Underwear_Item> ;
    ns1:prescribedBy <http://example.org/req/509#PlanSpec_Underclothing> .

<http://example.org/req/509#Underwear_MaterialProperty> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "fire retardant material property" ;
    ns1:qualityOf <http://example.org/req/509#Underwear_Item> .

<http://example.org/req/509#DesignSpec_Suit> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Design specification for driver suits" ;
    ns1:prescribes <http://example.org/req/509#Suit> ;
    ns1:satisfiesRequirement <http://example.org/req/509#Req_0> .

<http://example.org/req/509#Underwear_Item> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "fire retardant underwear (long pants and long sleeve shirt)" ;
    ns1:hasQuality <http://example.org/req/509#Underwear_MaterialProperty> .

<http://example.org/req/509#ObjSpec_SuitStandards> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    rdfs:label "Objective: driver suit standards and labeling" ;
    ns1:prescribes <http://example.org/req/509#Std_FIA_1986>,
        <http://example.org/req/509#Std_FIA_8856_2000>,
        <http://example.org/req/509#Std_FIA_8856_2018>,
        <http://example.org/req/509#Std_SFI_3_2A_5>,
        <http://example.org/req/509#Std_SFI_3_4_5>,
        <http://example.org/req/509#Suit_Labeling> .

