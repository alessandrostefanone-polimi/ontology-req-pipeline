@prefix : <http://example.org/req/658#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:EV_5_8_3 a iof:InformationContentEntity ;
    rdfs:label "EV.5.8.3" ;
    iof:isAbout :Req_0 .

:TSMP_Usage_During_Charging a iof:PlannedProcess ;
    rdfs:label "Use of TSMPs during accumulator charging" ;
    bfo:BFO_0000057 :TSMP_Connector ;
    iof:prescribedBy :TSMP_DesignSpec ;
    iof:temporallyOverlaps :Accumulator_Charging_Process .

:Accumulator_Charging_Process a bfo:BFO_0000015 ;
    rdfs:label "charging of any Accumulator(s)" .

:TSMP_ConnectorTypeRole a bfo:BFO_0000023 ;
    rdfs:label "TSMP connector type role: shrouded banana jacks" .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression for TSMP connector size (4 mm)" ;
    qudt:maxInclusive 4e+00 ;
    qudt:minInclusive 4e+00 ;
    qudt:quantityKind qudtqk:Length ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtAllTimes :TSMP_Connector_Size .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Available during charging of any Accumulator(s) EV.5.8.3 The TSMPs must be: a. 4 mm shrouded banana jacks rated to an appropriate voltage level b. Color" ;
    iof:requirementSatisfiedBy :TSMP_DesignSpec .

:TSMP_Connector a iof:MaterialArtifact ;
    rdfs:label "TSMP connector (shrouded banana jack)" ;
    iof:hasQuality :TSMP_Connector_Size ;
    iof:hasRole :TSMP_ConnectorTypeRole .

:TSMP_Connector_Size a bfo:BFO_0000019 ;
    rdfs:label "TSMP connector size quality" ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 .

:TSMP_DesignSpec a iof:DesignSpecification ;
    rdfs:label "TSMP design specification satisfying EV.5.8.3" ;
    iof:prescribes :TSMP_Connector ;
    iof:satisfiesRequirement :Req_0 .

qudtqk:Length a qudt:QuantityKind .

