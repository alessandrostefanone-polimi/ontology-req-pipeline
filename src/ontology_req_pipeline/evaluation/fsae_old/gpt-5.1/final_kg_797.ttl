@prefix : <http://example.org/req/797#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "All vehicles with a maximum nominal operation voltage below 500 V will be measured with the next available voltage level" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:MeasurementResult_0 a iof:MeasurementInformationContentEntity ;
    bfo:BFO_0000110 :VE_req0_c0 ;
    iof:describes :NominalOperationVoltage_0 ;
    iof:isAbout :VehicleClass_0 ;
    iof:isOutputOf :MeasuringProcess_0 .

:MeasurementVoltageLevel_0 a bfo:BFO_0000019 ;
    iof:qualityOf :NextAvailableVoltageLevel_0 .

:NextAvailableVoltageLevel_0 a bfo:BFO_0000040 ;
    iof:hasQuality :MeasurementVoltageLevel_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :MeasuringProcess_0 .

qudtqk:Voltage a qudt:QuantityKind .

qudtu:V a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Voltage .

:MeasuringProcess_0 a iof:MeasurementProcess ;
    bfo:BFO_0000057 :VehicleClass_0 ;
    iof:hasInput :VehicleClass_0 ;
    iof:hasSpecifiedOutput :MeasurementResult_0 ;
    iof:measuresAtSomeTime :NominalOperationVoltage_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxExclusive 5e+02 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtSomeTime :NominalOperationVoltage_0 .

:NominalOperationVoltage_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :VehicleClass_0 .

:VehicleClass_0 a bfo:BFO_0000040 .

