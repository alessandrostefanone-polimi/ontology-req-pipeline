@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/488#> a owl:Ontology .

<http://example.org/req/488#Vehicle_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:comment "The vehicle that bears the name marking on both sides." .

<http://example.org/req/488#NameCharSet_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:comment "Character set of the vehicle name; required to be Roman characters." ;
    ns1:qualityOf <http://example.org/req/488#VehicleNameMarking_0> .

<http://example.org/req/488#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 5e+01 ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/Height> ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    rdfs:comment "Minimum required height of the vehicle name marking: 50 mm." ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/488#NameHeight_0> .

<http://example.org/req/488#VehicleSideLocation_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000029,
        ns3:BFO_0000141,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:comment "Both sides of the vehicle where the name marking is located." .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Height> .

<http://example.org/req/488#NameDesignSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:comment "Design specification for the vehicle name marking satisfying Req_0." ;
    ns1:prescribes <http://example.org/req/488#VehicleNameMarking_0> ;
    ns1:satisfiesRequirement <http://example.org/req/488#Req_0> .

<http://example.org/req/488#NameHeight_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:comment "Height of the vehicle name marking; required to be at least 50 mm." ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/488#VE_req0_c1> ;
    ns1:qualityOf <http://example.org/req/488#VehicleNameMarking_0> .

<http://example.org/req/488#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The name must be in Roman characters minimum 50 mm high on both sides of the vehicle" ;
    ns1:requirementSatisfiedBy <http://example.org/req/488#NameDesignSpec_0> .

<http://example.org/req/488#VehicleNameMarking_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns3:BFO_0000082 <http://example.org/req/488#VehicleSideLocation_0> ;
    rdfs:comment "Name marking on the vehicle that must be in Roman characters, at least 50 mm high, on both sides of the vehicle." ;
    ns1:hasQuality <http://example.org/req/488#NameCharSet_0>,
        <http://example.org/req/488#NameHeight_0> ;
    ns1:prescribedBy <http://example.org/req/488#NameDesignSpec_0> ;
    ns1:satisfiesRequirement <http://example.org/req/488#Req_0> .

