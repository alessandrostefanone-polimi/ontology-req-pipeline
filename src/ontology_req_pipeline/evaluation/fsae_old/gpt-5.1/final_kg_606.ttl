@prefix : <http://example.org/req/606#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:CockpitMainSwitchProcess_0 a iof:PlannedProcess .

:CockpitMainSwitch_0 a iof:MaterialArtifact ;
    iof:hasQuality :Diameter_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :CockpitMainSwitch_0 ;
    iof:satisfiesRequirement :Req_0 .

:PlanSpec_1 a iof:PlanSpecification ;
    iof:prescribes :CockpitMainSwitchProcess_0 ;
    iof:satisfiesRequirement :Req_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.4e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Diameter_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:Diameter_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Have a diameter of 24 mm minimum IC.9.4.2 Location - The Cockpit Main Switch must be: a" ;
    iof:requirementSatisfiedBy :DesignSpec_0,
        :PlanSpec_1 .

