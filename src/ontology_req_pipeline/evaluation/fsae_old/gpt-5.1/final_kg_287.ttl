@prefix : <http://example.org/req/287#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :ImpactScenario_0,
        :Vehicle_0 ;
    iof:satisfiesRequirement :Req_0 .

:ImpactScenario_0 a bfo:BFO_0000002 ;
    rdfs:label "Impact scenario (design condition)"@en ;
    iof:hasQuality :EnergyAbsorbed_0,
        :ImpactVelocity_0 .

:SES_0 a iof:EngineeredSystem ;
    rdfs:label "SES (Standard Impact Attenuator System)"@en .

:SES_Use_Process_0 a iof:PlannedProcess ;
    rdfs:label "Using the Standard Impact Attenuator"@en ;
    iof:hasParticipantAtSomeTime :SES_0,
        :StandardImpactAttenuator_0 ;
    iof:prescribedBy :PlanSpec_0 .

:StandardImpactAttenuator_0 a iof:MaterialArtifact ;
    rdfs:label "Standard Impact Attenuator"@en .

:TestDataSubmissionProcess_0 a iof:PlannedProcess ;
    rdfs:label "Test data submission"@en ;
    iof:prescribedBy :PlanSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Energy absorbed > 7350 J"@en ;
    qudt:minExclusive 7.35e+03 ;
    qudt:unit qudtu:J ;
    iof:isValueExpressionOfAtSomeTime :EnergyAbsorbed_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Total mass of Vehicle = 300 kg"@en ;
    qudt:maxInclusive 3e+02 ;
    qudt:minInclusive 3e+02 ;
    qudt:unit qudtu:KiloGM ;
    iof:isValueExpressionOfAtSomeTime :VehicleMass_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Impact velocity = 7.0 m/s"@en ;
    qudt:maxInclusive 7e+00 ;
    qudt:minInclusive 7e+00 ;
    qudt:unit qudtu:KiloGM-PER-SEC ;
    iof:isValueExpressionOfAtSomeTime :ImpactVelocity_0 .

:Vehicle_0 a bfo:BFO_0000040 ;
    rdfs:label "Vehicle (impact test configuration)"@en ;
    iof:hasQuality :VehicleMass_0 .

qudtqk:FinalOrCurrentVehicleMass a qudt:QuantityKind .

qudtqk:KineticEnergy a qudt:QuantityKind .

qudtqk:MassFlowRate a qudt:QuantityKind .

qudtu:J a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:KineticEnergy .

qudtu:KiloGM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:FinalOrCurrentVehicleMass .

qudtu:KiloGM-PER-SEC a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:MassFlowRate .

:EnergyAbsorbed_0 a bfo:BFO_0000019 ;
    rdfs:label "Energy absorbed"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:ImpactVelocity_0 a bfo:BFO_0000019 ;
    rdfs:label "Impact velocity"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Energy absorbed must be more than 7350 J When: - Total mass of Vehicle is 300 kg - Impact velocity is $7.0 \\mathrm{~m} / \\mathrm{s}$ F.8.8.3 When using the Standard Impact Attenuator, the SES must meet the following: a. Test data will not be submitted b" ;
    iof:requirementSatisfiedBy :DesignSpec_0,
        :PlanSpec_0 .

:VehicleMass_0 a bfo:BFO_0000019 ;
    rdfs:label "Total mass of Vehicle"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :SES_Use_Process_0,
        :TestDataSubmissionProcess_0 ;
    iof:satisfiesRequirement :Req_0 .

