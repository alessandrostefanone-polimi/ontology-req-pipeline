@prefix : <http://example.org/req/570#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:FuelFillerCap_0 a iof:MaterialArtifact ;
    rdfs:label "Fuel Filler cap"@en .

:FuelFillerNeck_0 a iof:MaterialArtifact ;
    rdfs:label "Fuel Filler Neck"@en .

:FuelTank_0 a iof:MaterialArtifact ;
    rdfs:label "Fuel Tank"@en .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :FuelFillerNeckPortion_0 ;
    iof:satisfiesRequirement :Req_0 .

:FuelFillerNeckPortion_0 a bfo:BFO_0000040 ;
    rdfs:label "Portion of the Fuel Filler Neck nearest to the Fuel Filler cap"@en ;
    iof:hasQuality :VerticalHeightAboveFuelTank_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The portion of the Fuel Filler Neck nearest to the Fuel Filler cap must be: a. Minimum 125 mm vertical height above the top level of the Fuel Tank b" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.25e+02 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :VerticalHeightAboveFuelTank_0 .

qudtqk:Height a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:VerticalHeightAboveFuelTank_0 a bfo:BFO_0000019 ;
    rdfs:label "vertical height above the top level of the Fuel Tank"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

