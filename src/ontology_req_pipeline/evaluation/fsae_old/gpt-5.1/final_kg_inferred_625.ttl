@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/625#> a owl:Ontology .

<http://example.org/req/625#T_4_3> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "T.4.3",
        "T.4.3"@en ;
    ns1:isSubjectOf <http://example.org/req/625#DS_Req0> .

<http://example.org/req/625#VE_req1_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "APPS pedal travel > 25% (duty cycle)",
        "APPS pedal travel > 25% (duty cycle)"@en ;
    ns2:minExclusive 2.5e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/PERCENT> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/625#PC_APPSPedalTravel_Req1> .

<http://example.org/req/625#BSE_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Brake System Encoder - BSE",
        "Brake System Encoder - BSE"@en .

<http://example.org/req/625#MonitoringProcess_Req1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Monitoring of brake and APPS conditions",
        "Monitoring of brake and APPS conditions"@en ;
    ns1:hasProcessCharacteristic <http://example.org/req/625#PC_APPSPedalTravel_Req1>,
        <http://example.org/req/625#PC_MechanicalBrakesState_Req1> ;
    ns1:prescribedBy <http://example.org/req/625#PS_Req1> .

<http://example.org/req/625#MotorPowerSupply_Req2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Power to the Motor(s)",
        "Power to the Motor(s)"@en .

<http://example.org/req/625#PC_MechanicalBrakesState_Req1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "mechanical brakes state during monitoring",
        "mechanical brakes state during monitoring"@en .

<http://example.org/req/625#PowerShutdownProcess_Req2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Immediate and complete shutdown of power to the motor(s)",
        "Immediate and complete shutdown of power to the motor(s)"@en ;
    ns1:hasInput <http://example.org/req/625#MotorPowerSupply_Req2> ;
    ns1:prescribedBy <http://example.org/req/625#PS_Req2> .

<http://qudt.org/vocab/unit/PERCENT> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/DutyCycle> .

<http://example.org/req/625#DS_Req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/625#BSE_1> ;
    ns1:satisfiesRequirement <http://example.org/req/625#Req_0> .

<http://example.org/req/625#PC_APPSPedalTravel_Req1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    rdfs:label "APPS pedal travel during monitoring",
        "APPS pedal travel during monitoring"@en .

<http://example.org/req/625#PS_Req1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "EV.4.7.1 monitoring plan",
        "EV.4.7.1 monitoring plan"@en ;
    ns1:prescribes <http://example.org/req/625#MonitoringProcess_Req1> ;
    ns1:satisfiesRequirement <http://example.org/req/625#Req_0> .

<http://example.org/req/625#PS_Req2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "EV.4.7.2 power shutdown plan",
        "EV.4.7.2 power shutdown plan"@en ;
    ns1:prescribes <http://example.org/req/625#PowerShutdownProcess_Req2> ;
    ns1:satisfiesRequirement <http://example.org/req/625#Req_0> .

<http://example.org/req/625#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "4.6 Brake System Encoder - BSE Refer to T.4.3 for specific requirements of the BSE ## EV.4.7 APPS / Brake Pedal Plausibility Check EV.4.7.1 Must monitor for the two conditions: - The mechanical brakes are engaged EV.4.6, T.3.2.4 - The APPS signals more than 25\\% Pedal Travel EV.4.5 EV.4.7.2 If the two conditions in EV.4.7.1 occur at the same time: a. Power to the Motor(s) must be immediately and completely shut down b" ;
    ns1:requirementSatisfiedBy <http://example.org/req/625#DS_Req0>,
        <http://example.org/req/625#PS_Req1>,
        <http://example.org/req/625#PS_Req2> .

