        owl:Thing,
        ns1:Assembly,
        ns1:MaterialArtifact ;
    rdfs:label "Roll bar padding assembly",
        "Roll bar padding assembly"@en ;
    ns1:hasQuality <http://example.org/req/397#PaddingThickness_3> .

<http://example.org/req/397#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
