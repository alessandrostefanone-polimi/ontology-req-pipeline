        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Value expression for minimum area 235 cm^2",
        "Value expression for minimum area 235 cm^2"@en ;
    ns2:minInclusive 2.35e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/CentiM2> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/397#Area_0> .

<http://example.org/req/397#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
