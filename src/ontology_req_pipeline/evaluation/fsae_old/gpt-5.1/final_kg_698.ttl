@prefix : <http://example.org/req/698#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If conductor ampacity is reduced below the ampacity of the upstream Overcurrent Protection, the reduced conductor longer than 150 mm must have additional Overcurrent Protection" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:AdditionalOCP_0 a bfo:BFO_0000040 .

:Conductor_0 a bfo:BFO_0000040 ;
    iof:hasQuality :ConductorLength_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :PlannedProcess_0 .

:PlannedProcess_0 a iof:PlannedProcess ;
    iof:hasParticipantAtSomeTime :AdditionalOCP_0,
        :Conductor_0,
        :UpstreamOCP_0 .

:UpstreamOCP_0 a bfo:BFO_0000040 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 1.5e+02 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :ConductorLength_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:ConductorLength_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

