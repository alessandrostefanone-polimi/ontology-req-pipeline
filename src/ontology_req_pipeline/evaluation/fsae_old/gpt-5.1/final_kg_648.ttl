@prefix : <http://example.org/req/648#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:PrechargeCharging_Plan_0 a iof:PlanSpecification ;
    rdfs:label "Plan to charge Intermediate Circuit using Precharge Circuit"@en ;
    iof:prescribes :PrechargeCharging_Process_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The Precharge Circuit must: a. Be able to charge the Intermediate Circuit to minimum $90 \\%$ of the Accumulator voltage before closing the second AIR b" ;
    iof:requirementSatisfiedBy :PrechargeCircuit_DesignSpec_0 .

:SecondAIR_0 a bfo:BFO_0000040 ;
    rdfs:label "second AIR"@en .

:Accumulator_0 a bfo:BFO_0000040 ;
    rdfs:label "Accumulator"@en .

:PrechargeCircuit_DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :PrechargeCircuit_0 .

:PrechargeCircuit_EquipmentRole_0 a iof:EquipmentRole ;
    iof:roleOf :PrechargeCircuit_0 .

:SecondAIR_Closing_0 a bfo:BFO_0000015 ;
    rdfs:label "closing the second AIR"@en .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Intermediate Circuit state of charge >= 90 percent of Accumulator voltage"@en ;
    qudt:minInclusive 9e+01 ;
    qudt:unit qudtu:PERCENT ;
    iof:isValueExpressionOfAtSomeTime :IntermediateCircuitVoltage_0 .

qudtqk:StateOfCharge a qudt:QuantityKind .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:StateOfCharge .

:IntermediateCircuitVoltage_0 a iof:ProcessCharacteristic ;
    rdfs:label "Intermediate Circuit voltage (state of charge relative to Accumulator)"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:processCharacteristicOf :PrechargeCharging_Process_0 .

:IntermediateCircuit_0 a bfo:BFO_0000040 ;
    rdfs:label "Intermediate Circuit"@en .

:PrechargeCharging_Process_0 a iof:PlannedProcess ;
    rdfs:label "Charging of Intermediate Circuit by Precharge Circuit"@en ;
    bfo:BFO_0000057 :IntermediateCircuit_0,
        :PrechargeCircuit_0 ;
    iof:before :SecondAIR_Closing_0 ;
    iof:hasInput :Accumulator_0 ;
    iof:hasProcessCharacteristic :IntermediateCircuitVoltage_0 ;
    iof:hasSpecifiedOutput :IntermediateCircuit_0 .

:PrechargeCircuit_0 a iof:MaterialArtifact ;
    rdfs:label "Precharge Circuit"@en ;
    iof:hasRole :PrechargeCircuit_EquipmentRole_0 .

