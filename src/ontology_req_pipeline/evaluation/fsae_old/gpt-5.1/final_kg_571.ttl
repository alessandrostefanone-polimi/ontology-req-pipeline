@prefix : <http://example.org/req/571#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :SightTube_0,
        :SightTube_0_Height ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :SightTube_0 .

:ObjSpec_1 a iof:ObjectiveSpecification ;
    iof:prescribes :SightTube_0_Height .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Angled no more than $30^{\\circ}$ from the vertical IC.5.4.3 The Fuel Filler Neck must be accompanied by a clear fuel resistant sight tube for reading the fuel level which must be: a. Visible vertical height: 125 mm minimum b" ;
    iof:isAbout :ObjSpec_0,
        :ObjSpec_1 .

:VE_req1_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.25e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :SightTube_0_Height .

qudtqk:Height a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:SightTube_0 a iof:MaterialArtifact ;
    rdfs:label "clear fuel resistant sight tube for reading the fuel level"@en ;
    iof:hasQuality :SightTube_0_Height .

:SightTube_0_Height a bfo:BFO_0000019 ;
    rdfs:label "visible vertical height of sight tube"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c2 .

