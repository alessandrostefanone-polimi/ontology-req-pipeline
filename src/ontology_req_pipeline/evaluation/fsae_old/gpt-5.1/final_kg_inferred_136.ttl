@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/136#> a owl:Ontology .

<http://example.org/req/136#Constraint_req0_c0> a ns1:BFO_0000001,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:comment "Constraint 0 (supported area): support the entire sample." ;
    ns2:isSubjectOf <http://example.org/req/136#Req_0> .

<http://example.org/req/136#Constraint_req0_c1> a ns1:BFO_0000001,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:comment "Constraint 1 (unsupported region): except for a 32 mm hole aligned coaxially with the punch." ;
    ns2:isSubjectOf <http://example.org/req/136#Req_0> .

<http://example.org/req/136#Hole_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/136#DesignSpec_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:isAbout <http://example.org/req/136#ObjSpec_0> ;
    ns2:prescribes <http://example.org/req/136#Fixture_0> .

<http://example.org/req/136#ObjSpec_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:prescribes <http://example.org/req/136#SupportProcessChar_0> .

<http://example.org/req/136#Punch_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/136#Sample_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/136#SupportProcess_0> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        ns1:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns1:BFO_0000057 <http://example.org/req/136#Fixture_0>,
        <http://example.org/req/136#Punch_0>,
        <http://example.org/req/136#Sample_0> ;
    ns2:hasProcessCharacteristic <http://example.org/req/136#SupportProcessChar_0> .

<http://example.org/req/136#Fixture_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000004,
        ns1:BFO_0000030,
        ns1:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/136#Req_0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "The fixture must support the entire sample, except for a 32 mm hole aligned coaxially with the punch" ;
    ns2:requirementSatisfiedBy <http://example.org/req/136#DesignSpec_0> .

<http://example.org/req/136#SupportProcessChar_0> a ns1:BFO_0000001,
        ns1:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:comment "Process characteristic that the fixture supports the entire sample except for a coaxial hole region aligned with the punch." ;
    ns2:processCharacteristicOf <http://example.org/req/136#SupportProcess_0> .

