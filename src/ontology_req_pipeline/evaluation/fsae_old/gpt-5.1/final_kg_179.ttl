@prefix : <http://example.org/req/179#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AttachmentLocation_0 a bfo:BFO_0000029 ;
    rdfs:label "location where the Main Hoop is attached to the bottom tubes of the Major Structure of the Chassis"@en .

:FrontViewProcess_0 a bfo:BFO_0000015 ;
    rdfs:label "front view of the vehicle"@en .

:MainHoop_0 a bfo:BFO_0000040 ;
    rdfs:label "Main Hoop"@en .

:MajorStructureChassis_0 a bfo:BFO_0000040 ;
    rdfs:label "Major Structure of the Chassis"@en .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :VerticalMembers_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "In the front view of the vehicle, the vertical members of the Main Hoop must be minimum 380 mm apart (inside dimension) at the location where the Main Hoop is attached to the bottom tubes of the Major Structure of the Chassis" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:Spacing_0 a bfo:BFO_0000019 ;
    rdfs:label "inside spacing between vertical members of the Main Hoop at attachment location in front view"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3.8e+02 ;
    qudt:unit qudtu:MilliM .

:VerticalMembers_0 a bfo:BFO_0000040 ;
    rdfs:label "vertical members of the Main Hoop"@en ;
    iof:hasQuality :Spacing_0 .

qudtqk:Breadth a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Breadth .

