@prefix : <http://example.org/req/800#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:IN_2_6 a iof:InformationContentEntity .

:Req0_Constraint0 a owl:NamedIndividual ;
    rdfs:comment "Constraint 0 (req_idx=0): measurement performance – action 'will be measured'." ;
    iof:isSubjectOf :Req_0 .

:Req0_Constraint1 a owl:NamedIndividual ;
    rdfs:comment "Constraint 1 (req_idx=0): measurement configuration – with a free field microphone." ;
    iof:isSubjectOf :Req_0 .

:Req0_Constraint2 a owl:NamedIndividual ;
    rdfs:comment "Constraint 2 (req_idx=0): obstruction state – microphone placed free from obstructions." ;
    iof:isSubjectOf :Req_0 .

:Req0_Constraint3 a owl:NamedIndividual ;
    rdfs:comment "Constraint 3 (req_idx=0): microphone position radius == 2 m around the vehicle." ;
    iof:isSubjectOf :Req_0 .

:Req0_Constraint4 a owl:NamedIndividual ;
    rdfs:comment "Constraint 4 (req_idx=0): acceptance criteria reference EV.9.5." ;
    iof:isAbout :EV_9_5_Criteria ;
    iof:isSubjectOf :Req_0 .

:Req1_Constraint0 a owl:NamedIndividual ;
    rdfs:comment "Constraint 0 (req_idx=1): subject components may be sealed (quality 'sealed')." ;
    iof:isSubjectOf :Req_0 .

:Req2 a owl:NamedIndividual ;
    rdfs:comment "Requirement fragment (req_idx=2): Additional monitoring to verify conformance to rules may be installed." ;
    iof:isSubjectOf :Req_0 .

:SealedQuality a bfo:BFO_0000019 ;
    iof:qualityOf :Charger,
        :OtherComponents,
        :TractiveSystem .

:AdditionalMonitoringSystem a bfo:BFO_0000040 .

:DesignSpec_1 a iof:DesignSpecification ;
    iof:prescribes :Charger,
        :OtherComponents,
        :TractiveSystem ;
    iof:satisfiesRequirement :Req_0 .

:EV_9_5_Criteria a iof:InformationContentEntity .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :SoundLevelMeasurementProcess .

:PlanSpec_2 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :AdditionalMonitoringInstallationProcess .

:SoundLevelMeasurementResult a iof:MeasurementInformationContentEntity ;
    iof:describes :SoundLevelProcessCharacteristic ;
    iof:isAbout :VehicleSoundEmissionProcess ;
    iof:isOutputOf :SoundLevelMeasurementProcess .

:VE_req0_c3 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e+00 ;
    qudt:minInclusive 2e+00 ;
    qudt:quantityKind qudtqk:Radius ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :MicrophonePositionRadiusQuality .

:VehicleSoundEmissionProcess a bfo:BFO_0000015 ;
    iof:hasProcessCharacteristic :SoundLevelProcessCharacteristic .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Radius .

:AdditionalMonitoringInstallationProcess a iof:PlannedProcess ;
    bfo:BFO_0000057 :AdditionalMonitoringSystem .

:Charger a bfo:BFO_0000040 .

:FreeFieldMicrophone a iof:PieceOfEquipment .

:MicrophonePositionRadiusQuality a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c3 ;
    iof:qualityOf :FreeFieldMicrophone .

:OtherComponents a bfo:BFO_0000040 .

:TractiveSystem a bfo:BFO_0000040 .

qudtqk:Radius a qudt:QuantityKind .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :AdditionalMonitoringInstallationProcess,
        :SoundLevelMeasurementProcess ;
    iof:prescribes :MicrophonePositionRadiusQuality,
        :SoundLevelProcessCharacteristic .

:SoundLevelMeasurementProcess a iof:MeasurementProcess ;
    bfo:BFO_0000057 :FreeFieldMicrophone ;
    iof:hasSpecifiedOutput :SoundLevelMeasurementResult ;
    iof:measuresAtSomeTime :SoundLevelProcessCharacteristic .

:SoundLevelProcessCharacteristic a iof:ProcessCharacteristic .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "4.6 Ready to Drive Sound The sound level will be measured with a free field microphone placed free from obstructions in a radius of 2 m around the vehicle against the criteria in EV.9.5 ## IN.4.7 Electrical Inspection Completion IN.4.7.1 All or portions of the Tractive System, Charger and other components may be sealed IN.2.6 IN.4.7.2 Additional monitoring to verify conformance to rules may be installed" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DesignSpec_1,
        :PlanSpec_0,
        :PlanSpec_2 .

