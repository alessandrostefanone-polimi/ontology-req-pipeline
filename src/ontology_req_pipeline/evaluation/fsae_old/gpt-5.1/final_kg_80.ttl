@prefix : <http://example.org/req/80#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:GroundContactEvent a iof:Event ;
    rdfs:label "Ground contact of vehicle (non-tire parts)" ;
    bfo:BFO_0000057 :Vehicle .

:Tire a iof:MaterialArtifact ;
    rdfs:label "Tire" .

:DS_GroundClearance a iof:DesignSpecification ;
    rdfs:label "Design spec: vehicle ground clearance" ;
    iof:prescribes :VehicleGroundClearanceQuality ;
    iof:satisfiesRequirement :Req_0 .

:DS_LSIS_Clearance a iof:DesignSpecification ;
    rdfs:label "Design spec: LSIS ground clearance" ;
    iof:prescribes :LSIS_ClearanceQuality ;
    iof:satisfiesRequirement :Req_0 .

:LowerSideImpactStructure a iof:MaterialArtifact ;
    rdfs:label "Lower Side Impact Structure" ;
    bfo:BFO_0000040 :Vehicle .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression: LSIS distance to ground <= 75 mm" ;
    qudt:maxInclusive 7.5e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :LSIS_ClearanceQuality .

qudtqk:Height a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:DynamicEventProcess a iof:PlannedProcess ;
    rdfs:label "Vehicle dynamic event" ;
    bfo:BFO_0000057 :Vehicle ;
    iof:prescribedBy :PS_DynamicEvents .

:ObjSpec_GroundClearance a iof:ObjectiveSpecification ;
    rdfs:label "Objective: ground clearance behavior" ;
    iof:prescribes :DynamicEventProcess,
        :LSIS_ClearanceQuality,
        :VehicleGroundClearanceQuality .

:PS_DynamicEvents a iof:PlanSpecification ;
    rdfs:label "Plan spec: vehicle dynamic events" ;
    bfo:BFO_0000110 :ObjSpec_GroundClearance ;
    iof:prescribes :DynamicEventProcess ;
    iof:satisfiesRequirement :Req_0 .

:VehicleGroundClearanceQuality a bfo:BFO_0000019 ;
    rdfs:label "Vehicle ground clearance quality" ;
    iof:qualityOf :Vehicle .

:LSIS_ClearanceQuality a bfo:BFO_0000019 ;
    rdfs:label "Distance to ground below LSIS at lowest point" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 ;
    iof:qualityOf :LowerSideImpactStructure .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Ground Clearance V.1.4.1 Ground clearance must be sufficient to prevent any portion of the vehicle except the tires from touching the ground during dynamic events V.1.4.2 The distance to the ground below the Lower Side Impact Structure ( F.6.4.5, F.7.5.1 ) at its lowest point should be 75 mm or less V.1.4.3 Intentional or excessive ground contact of any portion of the vehicle other than the tires will forfeit a run or an entire dynamic event" ;
    iof:isAbout :ObjSpec_GroundClearance ;
    iof:requirementSatisfiedBy :DS_GroundClearance,
        :DS_LSIS_Clearance,
        :PS_DynamicEvents .

:Vehicle a iof:EngineeredSystem ;
    rdfs:label "Vehicle" .

