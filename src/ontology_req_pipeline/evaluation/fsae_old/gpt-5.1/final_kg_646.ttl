@prefix : <http://example.org/req/646#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:HVD_1 a bfo:BFO_0000040 ;
    rdfs:label "High Voltage Disconnect (HVD) (req1)" .

:AIRs_0 a bfo:BFO_0000040 ;
    rdfs:label "AIRs (Accumulator Isolation Relays)" .

:Accumulator_1 a bfo:BFO_0000040 ;
    rdfs:label "Accumulator (req1)" .

:Accumulator_1_Disconnected a bfo:BFO_0000040 ;
    rdfs:label "Accumulator with one or both poles disconnected (req1)" .

:Agent_Implicit a iof:Agent ;
    rdfs:label "Unspecified agent recognizing events" .

:Capacitor_0 a bfo:BFO_0000040 ;
    rdfs:label "capacitor (requirement 0 subject)" .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "Design spec for capacitor and AIRs behavior" ;
    iof:prescribes :AIRs_0,
        :Capacitor_0 ;
    iof:satisfiesRequirement :Req_0 .

:DS_2 a iof:DesignSpecification ;
    rdfs:label "Design spec for High Voltage Disconnect (HVD) (req2)" ;
    iof:prescribes :HVD_2 ;
    iof:satisfiesRequirement :Req_0 .

:Event_ShutdownCircuitOpens a iof:Event ;
    rdfs:label "Shutdown Circuit Opens event" ;
    iof:recognizedByAtSomeTime :Agent_Implicit .

:HVD_2 a bfo:BFO_0000040 ;
    rdfs:label "High Voltage Disconnect (HVD) (req2)" .

:PS_0 a iof:PlanSpecification ;
    rdfs:label "Plan spec for capacitor holding AIRs closed" ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :Proc_HoldAIRsClosed .

:Proc_HVD_Disconnect a iof:PlannedProcess ;
    rdfs:label "Process: HVD quickly disconnects accumulator poles" ;
    iof:hasInput :Accumulator_1 ;
    iof:hasSpecifiedOutput :Accumulator_1_Disconnected ;
    iof:prescribedBy :PS_1 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression for duration <= 250 ms (req0, constraint0)" ;
    qudt:maxInclusive 2.5e+02 ;
    qudt:unit qudtu:MilliSEC ;
    iof:isValueExpressionOfAtSomeTime :PC_Duration_0 .

qudtqk:Time a qudt:QuantityKind .

qudtu:MilliSEC a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Time .

:PC_Duration_0 a iof:ProcessCharacteristic ;
    rdfs:label "Duration of holding AIRs closed (req0)" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:processCharacteristicOf :Proc_HoldAIRsClosed .

:PS_1 a iof:PlanSpecification ;
    rdfs:label "Plan spec for HVD disconnecting accumulator poles" ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :Proc_HVD_Disconnect .

:Proc_HoldAIRsClosed a iof:PlannedProcess ;
    rdfs:label "Process: capacitor holds AIRs closed" ;
    iof:hasProcessCharacteristic :PC_Duration_0 ;
    iof:occursDuring :Event_ShutdownCircuitOpens ;
    iof:prescribedBy :PS_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A capacitor may be used to hold the AIRs closed for up to 250 ms after the Shutdown Circuit Opens EV.7.2.2 ## EV.5.5 High Voltage Disconnect - HVD A High Voltage Disconnect (HVD) must be included to quickly disconnect one or both poles of the Accumulator EV.11.3.2 EV.5.5.1 The High Voltage Disconnect (HVD) must be: a" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0,
        :DS_2,
        :PS_1 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for requirement 646" .

