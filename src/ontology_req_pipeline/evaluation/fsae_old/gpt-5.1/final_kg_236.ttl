@prefix : <http://example.org/req/236#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :LaminateSection_0,
        :MonocoqueLaminate_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The perimeter shear strength of the monocoque laminate must be 7.5 kN or more for a section with a diameter of 25 mm" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 7.5e+00 ;
    qudt:unit qudtu:M-PER-SEC ;
    iof:isValueExpressionOfAtSomeTime :PerimeterShearStrength_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.5e+01 ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :SectionDiameter_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Velocity a qudt:QuantityKind .

qudtu:M-PER-SEC a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Velocity .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:LaminateSection_0 a bfo:BFO_0000040 ;
    rdfs:label "laminate section"@en ;
    iof:hasQuality :SectionDiameter_0 .

:MonocoqueLaminate_0 a bfo:BFO_0000040 ;
    rdfs:label "monocoque laminate"@en ;
    iof:hasQuality :PerimeterShearStrength_0 .

:PerimeterShearStrength_0 a bfo:BFO_0000019 ;
    rdfs:label "perimeter shear strength"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :MonocoqueLaminate_0 .

:SectionDiameter_0 a bfo:BFO_0000019 ;
    rdfs:label "section diameter"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:qualityOf :LaminateSection_0 .

