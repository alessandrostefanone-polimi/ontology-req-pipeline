@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/394#> a owl:Ontology .

<http://example.org/req/394#WithstandForceProcess> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns3:BFO_0000057 <http://example.org/req/394#HeadRestraintAssembly> ;
    ns1:hasProcessCharacteristic <http://example.org/req/394#WithstandForceCapability> ;
    ns1:prescribedBy <http://example.org/req/394#DS_HeadRestraintStrength> .

<http://example.org/req/394#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Head Restraint Protection (if used) F.5.10 T.2.8.4 The Head Restraint, attachment and mounting must be strong enough to withstand a minimum force of: a. 900 N applied in a rearward direction b. 300 N applied in a lateral or vertical direction T.2.8.5 For all drivers, the Head Restraint must be located and adjusted where: a" ;
    ns1:requirementSatisfiedBy <http://example.org/req/394#DS_HeadRestraintStrength> .

<http://example.org/req/394#VE_req0_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 9e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/N> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/394#WithstandForceCapability> .

<http://example.org/req/394#VE_req1_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 3e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/N> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/394#WithstandForceCapability> .

<http://example.org/req/394#DS_HeadRestraintStrength> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/394#HeadRestraintAssembly> .

<http://example.org/req/394#HeadRestraintAssembly> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:satisfiesRequirement <http://example.org/req/394#Req_0> .

<http://qudt.org/vocab/unit/N> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Force> .

<http://example.org/req/394#WithstandForceCapability> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/394#VE_req0_c0>,
        <http://example.org/req/394#VE_req1_c1> .

