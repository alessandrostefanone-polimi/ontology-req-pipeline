@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/648#> a owl:Ontology .

<http://example.org/req/648#PrechargeCharging_Plan_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    rdfs:label "Plan to charge Intermediate Circuit using Precharge Circuit",
        "Plan to charge Intermediate Circuit using Precharge Circuit"@en ;
    ns2:prescribes <http://example.org/req/648#PrechargeCharging_Process_0> .

<http://example.org/req/648#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "The Precharge Circuit must: a. Be able to charge the Intermediate Circuit to minimum $90 \\%$ of the Accumulator voltage before closing the second AIR b" ;
    ns2:requirementSatisfiedBy <http://example.org/req/648#PrechargeCircuit_DesignSpec_0> .

<http://example.org/req/648#SecondAIR_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "second AIR",
        "second AIR"@en .

<http://example.org/req/648#Accumulator_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Accumulator",
        "Accumulator"@en .

<http://example.org/req/648#PrechargeCircuit_DesignSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/648#PrechargeCircuit_0> .

<http://example.org/req/648#PrechargeCircuit_EquipmentRole_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000017,
        ns3:BFO_0000020,
        ns3:BFO_0000023,
        owl:NamedIndividual,
        owl:Thing,
        ns2:EquipmentRole ;
    ns2:roleOf <http://example.org/req/648#PrechargeCircuit_0> .

<http://example.org/req/648#SecondAIR_Closing_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "closing the second AIR",
        "closing the second AIR"@en .

<http://example.org/req/648#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "Intermediate Circuit state of charge >= 90 percent of Accumulator voltage",
        "Intermediate Circuit state of charge >= 90 percent of Accumulator voltage"@en ;
    ns1:minInclusive 9e+01 ;
    ns1:unit <http://qudt.org/vocab/unit/PERCENT> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/648#IntermediateCircuitVoltage_0> .

<http://qudt.org/vocab/unit/PERCENT> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/StateOfCharge> .

<http://example.org/req/648#IntermediateCircuitVoltage_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "Intermediate Circuit voltage (state of charge relative to Accumulator)",
        "Intermediate Circuit voltage (state of charge relative to Accumulator)"@en ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/648#VE_req0_c1> ;
    ns2:processCharacteristicOf <http://example.org/req/648#PrechargeCharging_Process_0> .

<http://example.org/req/648#IntermediateCircuit_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Intermediate Circuit",
        "Intermediate Circuit"@en .

<http://example.org/req/648#PrechargeCharging_Process_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "Charging of Intermediate Circuit by Precharge Circuit",
        "Charging of Intermediate Circuit by Precharge Circuit"@en ;
    ns3:BFO_0000057 <http://example.org/req/648#IntermediateCircuit_0>,
        <http://example.org/req/648#PrechargeCircuit_0> ;
    ns2:before <http://example.org/req/648#SecondAIR_Closing_0> ;
    ns2:hasInput <http://example.org/req/648#Accumulator_0> ;
    ns2:hasProcessCharacteristic <http://example.org/req/648#IntermediateCircuitVoltage_0> ;
    ns2:hasSpecifiedOutput <http://example.org/req/648#IntermediateCircuit_0> .

<http://example.org/req/648#PrechargeCircuit_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact,
        ns2:PieceOfEquipment ;
    rdfs:label "Precharge Circuit",
        "Precharge Circuit"@en ;
    ns2:hasRole <http://example.org/req/648#PrechargeCircuit_EquipmentRole_0> .

