@prefix : <http://example.org/req/456#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Insulation - The gas cylinder/tank must be insulated from any heat sources T.6.1.6 Cylinder Material - gas cylinders/tanks in a position 150 mm or less from an exhaust system must meet one of the two: - Made from metal" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:CylTank_0_Insulation a bfo:BFO_0000019 ;
    rdfs:label "insulation from heat sources"@en .

:ExhaustSystem_0 a bfo:BFO_0000040 ;
    rdfs:label "exhaust system"@en .

:HeatSource_Generic a bfo:BFO_0000040 ;
    rdfs:label "heat source (generic)"@en .

:Metal_Material a bfo:BFO_0000040 ;
    rdfs:label "metal material"@en .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.5e+02 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :PC_Distance_Cyl_Exhaust .

qudtqk:Length a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:CylTank_0_Material a bfo:BFO_0000023 ;
    rdfs:label "material role of gas cylinder/tank"@en .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :Proc_Insulation,
        :Proc_MaterialSelection,
        :Proc_Positioning ;
    iof:prescribes :CylTank_0,
        :CylTank_0_Material .

:PC_Distance_Cyl_Exhaust a iof:ProcessCharacteristic ;
    rdfs:label "distance between gas cylinders/tanks and exhaust system"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:Proc_Insulation a iof:PlannedProcess ;
    rdfs:label "insulating gas cylinder/tank from heat sources"@en ;
    iof:hasParticipantAtSomeTime :CylTank_0,
        :HeatSource_Generic ;
    iof:prescribedBy :PlanSpec_0 .

:Proc_MaterialSelection a iof:PlannedProcess ;
    rdfs:label "selection of metal material for gas cylinder/tank"@en ;
    iof:hasParticipantAtSomeTime :CylTank_0,
        :Metal_Material ;
    iof:prescribedBy :PlanSpec_0 .

:Proc_Positioning a iof:PlannedProcess ;
    rdfs:label "positioning gas cylinders/tanks relative to exhaust system"@en ;
    iof:hasParticipantAtSomeTime :CylTank_0,
        :ExhaustSystem_0 ;
    iof:hasProcessCharacteristic :PC_Distance_Cyl_Exhaust ;
    iof:prescribedBy :PlanSpec_0 .

:CylTank_0 a bfo:BFO_0000040 ;
    rdfs:label "gas cylinder/tank"@en ;
    iof:hasQuality :CylTank_0_Insulation ;
    iof:hasRole :CylTank_0_Material .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:hasContinuantPartAtAllTimes :ObjSpec_0 ;
    iof:prescribes :Proc_Insulation,
        :Proc_MaterialSelection,
        :Proc_Positioning .

