@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/276#> a owl:Ontology .

<http://example.org/req/276#DS_IAFasteners> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    rdfs:label "Design spec for IA bolted fasteners",
        "Design spec for IA bolted fasteners"@en ;
    ns2:prescribes <http://example.org/req/276#CriticalFastener>,
        <http://example.org/req/276#ImpactAttenuatorAssembly> ;
    ns2:satisfiesRequirement <http://example.org/req/276#Req_0> .

<http://example.org/req/276#DS_Welds> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    rdfs:label "Design spec for weld lengths",
        "Design spec for weld lengths"@en ;
    ns2:prescribes <http://example.org/req/276#WeldAssembly> ;
    ns2:satisfiesRequirement <http://example.org/req/276#Req_0> .

<http://example.org/req/276#ObjSpec_IAFasteners> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    rdfs:label "Objective: IA bolted fasteners",
        "Objective: IA bolted fasteners"@en ;
    ns2:prescribes <http://example.org/req/276#FastenerCount_Quality>,
        <http://example.org/req/276#FastenerDiameter_Quality> .

<http://example.org/req/276#ObjSpec_Welds> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    rdfs:label "Objective: weld lengths",
        "Objective: weld lengths"@en ;
    ns2:prescribes <http://example.org/req/276#WeldLength_Quality> .

<http://example.org/req/276#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "weld length > 25 mm",
        "weld length > 25 mm"@en ;
    ns1:minExclusive 2.5e+01 ;
    ns1:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/276#WeldLength_Quality> .

<http://example.org/req/276#VE_req1_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "number of Critical Fasteners ≥ 8 (dimensionless)",
        "number of Critical Fasteners ≥ 8 (dimensionless)"@en ;
    ns1:minInclusive 8e+00 ;
    ns1:unit <http://qudt.org/vocab/unit/MM> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/276#FastenerCount_Quality> .

<http://example.org/req/276#VE_req1_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "fastener diameter ≥ 8 mm",
        "fastener diameter ≥ 8 mm"@en ;
    ns1:minInclusive 8e+00 ;
    ns1:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/276#FastenerDiameter_Quality> .

<http://qudt.org/vocab/unit/MM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/PathLength> .

<http://example.org/req/276#ImpactAttenuatorAssembly> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:Assembly,
        ns2:MaterialArtifact ;
    rdfs:label "Impact Attenuator assembly",
        "Impact Attenuator assembly"@en ;
    ns2:hasComponentPartAtSomeTime <http://example.org/req/276#CriticalFastener> ;
    ns2:hasQuality <http://example.org/req/276#FastenerCount_Quality> .

<http://example.org/req/276#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "All weld lengths must be more than 25 mm F.8.5.5 If the Impact Attenuator is attached by bolting: a. Must have no less than eight 8 mm or $5 / 16^{\\prime \\prime}$ minimum diameter Critical Fasteners, T.8.2 b" ;
    ns2:isAbout <http://example.org/req/276#ObjSpec_IAFasteners>,
        <http://example.org/req/276#ObjSpec_Welds> ;
    ns2:requirementSatisfiedBy <http://example.org/req/276#DS_IAFasteners>,
        <http://example.org/req/276#DS_Welds> .

<http://example.org/req/276#WeldAssembly> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:Assembly,
        ns2:MaterialArtifact ;
    rdfs:label "Welded structure (all welds)",
        "Welded structure (all welds)"@en ;
    ns2:hasQuality <http://example.org/req/276#WeldLength_Quality> .

<http://qudt.org/vocab/unit/MilliM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/276#CriticalFastener> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialComponent ;
    rdfs:label "Critical Fastener",
        "Critical Fastener"@en ;
    ns2:hasQuality <http://example.org/req/276#FastenerDiameter_Quality> .

<http://example.org/req/276#FastenerCount_Quality> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "number of Critical Fasteners",
        "number of Critical Fasteners"@en ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/276#VE_req1_c1> ;
    ns2:qualityOf <http://example.org/req/276#ImpactAttenuatorAssembly> .

<http://example.org/req/276#FastenerDiameter_Quality> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "fastener diameter",
        "fastener diameter"@en ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/276#VE_req1_c2> ;
    ns2:qualityOf <http://example.org/req/276#CriticalFastener> .

<http://example.org/req/276#WeldLength_Quality> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "weld length quality",
        "weld length quality"@en ;
    ns2:hasValueExpressionAtAllTimes <http://example.org/req/276#VE_req0_c0> ;
    ns2:qualityOf <http://example.org/req/276#WeldAssembly> .

