<http://example.org/req/658#> a owl:Ontology .

<http://example.org/req/658#EV_5_8_3> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "EV.5.8.3" ;
    ns1:isAbout <http://example.org/req/658#Req_0> .

<http://example.org/req/658#TSMP_Usage_During_Charging> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Use of TSMPs during accumulator charging" ;
    ns3:BFO_0000057 <http://example.org/req/658#TSMP_Connector> ;
    ns1:prescribedBy <http://example.org/req/658#TSMP_DesignSpec> ;
    ns1:temporallyOverlaps <http://example.org/req/658#Accumulator_Charging_Process> .

<http://example.org/req/658#Accumulator_Charging_Process> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "charging of any Accumulator(s)" .

<http://example.org/req/658#TSMP_ConnectorTypeRole> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000017,
        ns3:BFO_0000020,
        ns3:BFO_0000023,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "TSMP connector type role: shrouded banana jacks" .

<http://example.org/req/658#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Value expression for TSMP connector size (4 mm)" ;
    ns2:maxInclusive 4e+00 ;
    ns2:minInclusive 4e+00 ;
    ns2:quantityKind <http://qudt.org/vocab/quantitykind/Length> ;
    ns2:unit <http://qudt.org/vocab/unit/MM> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/658#TSMP_Connector_Size> .

<http://qudt.org/vocab/unit/MM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/658#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Available during charging of any Accumulator(s) EV.5.8.3 The TSMPs must be: a. 4 mm shrouded banana jacks rated to an appropriate voltage level b. Color" ;
    ns1:requirementSatisfiedBy <http://example.org/req/658#TSMP_DesignSpec> .

<http://example.org/req/658#TSMP_Connector> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact ;
    rdfs:label "TSMP connector (shrouded banana jack)" ;
    ns1:hasQuality <http://example.org/req/658#TSMP_Connector_Size> ;
    ns1:hasRole <http://example.org/req/658#TSMP_ConnectorTypeRole> .

<http://example.org/req/658#TSMP_Connector_Size> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "TSMP connector size quality" ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/658#VE_req0_c1> .

<http://example.org/req/658#TSMP_DesignSpec> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "TSMP design specification satisfying EV.5.8.3" ;
    ns1:prescribes <http://example.org/req/658#TSMP_Connector> ;
    ns1:satisfiesRequirement <http://example.org/req/658#Req_0> .

