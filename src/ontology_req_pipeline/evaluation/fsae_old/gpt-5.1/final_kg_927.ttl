@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/927#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "10.1.3 Course Operation a. Vehicles will enter and exit through gates on a 3.0 m wide path that is tangential to the circles where they meet" ;
    iof:requirementSatisfiedBy :Plan_0 .

:Path_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :Process_0 .

:Process_0 a iof:PlannedProcess ;
    iof:hasProcessCharacteristic :Path_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3e+00 ;
    qudt:minInclusive 3e+00 ;
    qudt:unit qudtu:M .

qudtqk:Breadth a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Breadth .

