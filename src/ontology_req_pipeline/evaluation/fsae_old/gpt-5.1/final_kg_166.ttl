@prefix : <http://example.org/req/166#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:CircleDesign_0 a iof:DesignSpecification ;
    iof:prescribes :Circle_0 ;
    iof:satisfiesRequirement :Req_0 .

:LineDesign_0 a iof:DesignSpecification ;
    iof:prescribes :Line_0 ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_CircleSize_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Circle_0 .

:Plan_ConnectCenters_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_LineConnection_0 ;
    iof:prescribes :ConnectCentersProcess_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 4.9e+02 ;
    qudt:minInclusive 4.9e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :LineLength_0 .

:VE_req0_c4 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e+02 ;
    qudt:minInclusive 2e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :CircleDiameter_0 .

qudtqk:Length a qudt:QuantityKind .

:CircleDiameter_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c4 .

:ConnectCentersProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :Circle_0,
        :Line_0 ;
    iof:prescribedBy :Plan_ConnectCenters_0 .

:LineLength_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:Line_0 a bfo:BFO_0000040 ;
    iof:hasQuality :LineLength_0 .

:ObjSpec_LineConnection_0 a iof:ObjectiveSpecification ;
    iof:prescribes :ConnectCentersProcess_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A straight line measuring 490 mm will connect the centers of the two 200 mm circles" ;
    iof:isAbout :ObjSpec_CircleSize_0,
        :ObjSpec_LineConnection_0 ;
    iof:requirementSatisfiedBy :CircleDesign_0,
        :LineDesign_0 .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Circle_0 a bfo:BFO_0000040 ;
    iof:hasQuality :CircleDiameter_0 .

