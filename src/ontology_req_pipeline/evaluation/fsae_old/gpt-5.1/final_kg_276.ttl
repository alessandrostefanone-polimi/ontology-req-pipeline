@prefix : <http://example.org/req/276#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_IAFasteners a iof:DesignSpecification ;
    rdfs:label "Design spec for IA bolted fasteners"@en ;
    iof:prescribes :CriticalFastener,
        :ImpactAttenuatorAssembly ;
    iof:satisfiesRequirement :Req_0 .

:DS_Welds a iof:DesignSpecification ;
    rdfs:label "Design spec for weld lengths"@en ;
    iof:prescribes :WeldAssembly ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_IAFasteners a iof:ObjectiveSpecification ;
    rdfs:label "Objective: IA bolted fasteners"@en ;
    iof:prescribes :FastenerCount_Quality,
        :FastenerDiameter_Quality .

:ObjSpec_Welds a iof:ObjectiveSpecification ;
    rdfs:label "Objective: weld lengths"@en ;
    iof:prescribes :WeldLength_Quality .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "weld length > 25 mm"@en ;
    qudt:minExclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :WeldLength_Quality .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "number of Critical Fasteners ≥ 8 (dimensionless)"@en ;
    qudt:minInclusive 8e+00 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :FastenerCount_Quality .

:VE_req1_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "fastener diameter ≥ 8 mm"@en ;
    qudt:minInclusive 8e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :FastenerDiameter_Quality .

qudtqk:Length a qudt:QuantityKind .

qudtqk:PathLength a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:PathLength .

:ImpactAttenuatorAssembly a iof:Assembly ;
    rdfs:label "Impact Attenuator assembly"@en ;
    iof:hasComponentPartAtSomeTime :CriticalFastener ;
    iof:hasQuality :FastenerCount_Quality .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "All weld lengths must be more than 25 mm F.8.5.5 If the Impact Attenuator is attached by bolting: a. Must have no less than eight 8 mm or $5 / 16^{\\prime \\prime}$ minimum diameter Critical Fasteners, T.8.2 b" ;
    iof:isAbout :ObjSpec_IAFasteners,
        :ObjSpec_Welds ;
    iof:requirementSatisfiedBy :DS_IAFasteners,
        :DS_Welds .

:WeldAssembly a iof:Assembly ;
    rdfs:label "Welded structure (all welds)"@en ;
    iof:hasQuality :WeldLength_Quality .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:CriticalFastener a iof:MaterialComponent ;
    rdfs:label "Critical Fastener"@en ;
    iof:hasQuality :FastenerDiameter_Quality .

:FastenerCount_Quality a bfo:BFO_0000019 ;
    rdfs:label "number of Critical Fasteners"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 ;
    iof:qualityOf :ImpactAttenuatorAssembly .

:FastenerDiameter_Quality a bfo:BFO_0000019 ;
    rdfs:label "fastener diameter"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c2 ;
    iof:qualityOf :CriticalFastener .

:WeldLength_Quality a bfo:BFO_0000019 ;
    rdfs:label "weld length quality"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 ;
    iof:qualityOf :WeldAssembly .

