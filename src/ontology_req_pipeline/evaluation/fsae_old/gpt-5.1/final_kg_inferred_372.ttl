@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix ns3: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/372#> a owl:Ontology .

<http://example.org/req/372#BracketFastenedToChassis_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:BFO_0000057 <http://example.org/req/372#Bracket_0>,
        <http://example.org/req/372#Chassis_0> .

<http://example.org/req/372#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Attachment of tabs or brackets must meet the following: a. Where brackets are fastened to the chassis, no less than two 6 mm or $1 / 4^{\\prime \\prime}$ minimum diameter Critical Fasteners, see T.8.2 or stronger must be used to attach the bracket to the chassis" ;
    ns1:isAbout <http://example.org/req/372#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/372#PlanSpec_0> .

<http://example.org/req/372#VE_req0_c1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns3:minInclusive 2e+00 ;
    ns3:unit <http://qudt.org/vocab/unit/COUNT> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/372#FastenerSet_0> .

<http://example.org/req/372#VE_req0_c2> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns3:minInclusive 6e+00 ;
    ns3:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/372#Fastener_0> .

<http://qudt.org/vocab/unit/COUNT> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/Dimensionless> .

<http://qudt.org/vocab/unit/MilliM> ns3:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://example.org/req/372#BracketAttachment_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:isOutputOf <http://example.org/req/372#FastenerAttachmentProcess_0> .

<http://example.org/req/372#Fastener_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/372#ObjSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/372#FastenerAttachmentProcess_0> ;
    ns1:prescribes <http://example.org/req/372#BracketAttachment_0> .

<http://example.org/req/372#PlanSpec_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns2:BFO_0000110 <http://example.org/req/372#ObjSpec_0> ;
    ns1:prescribes <http://example.org/req/372#FastenerAttachmentProcess_0> .

<http://example.org/req/372#Bracket_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/372#Chassis_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/372#FastenerAttachmentProcess_0> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns2:BFO_0000057 <http://example.org/req/372#Bracket_0>,
        <http://example.org/req/372#Chassis_0>,
        <http://example.org/req/372#FastenerSet_0> ;
    ns1:hasInput <http://example.org/req/372#Bracket_0>,
        <http://example.org/req/372#Chassis_0>,
        <http://example.org/req/372#FastenerSet_0> ;
    ns1:hasSpecifiedOutput <http://example.org/req/372#BracketAttachment_0> ;
    ns1:prescribedBy <http://example.org/req/372#PlanSpec_0> .

<http://example.org/req/372#FastenerSet_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasComponentPartAtSomeTime <http://example.org/req/372#Fastener_0> .

