@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/179#> a owl:Ontology .

<http://example.org/req/179#AttachmentLocation_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000029>,
        <http://purl.obolibrary.org/obo/BFO_0000141>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "location where the Main Hoop is attached to the bottom tubes of the Major Structure of the Chassis",
        "location where the Main Hoop is attached to the bottom tubes of the Major Structure of the Chassis"@en .

<http://example.org/req/179#FrontViewProcess_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "front view of the vehicle",
        "front view of the vehicle"@en .

<http://example.org/req/179#MainHoop_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Main Hoop",
        "Main Hoop"@en .

<http://example.org/req/179#MajorStructureChassis_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Major Structure of the Chassis",
        "Major Structure of the Chassis"@en .

<http://example.org/req/179#DesignSpec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/179#VerticalMembers_0> ;
    ns1:satisfiesRequirement <http://example.org/req/179#Req_0> .

<http://example.org/req/179#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "In the front view of the vehicle, the vertical members of the Main Hoop must be minimum 380 mm apart (inside dimension) at the location where the Main Hoop is attached to the bottom tubes of the Major Structure of the Chassis" ;
    ns1:requirementSatisfiedBy <http://example.org/req/179#DesignSpec_0> .

<http://example.org/req/179#Spacing_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "inside spacing between vertical members of the Main Hoop at attachment location in front view",
        "inside spacing between vertical members of the Main Hoop at attachment location in front view"@en ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/179#VE_req0_c0> .

<http://example.org/req/179#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 3.8e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> .

<http://example.org/req/179#VerticalMembers_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "vertical members of the Main Hoop",
        "vertical members of the Main Hoop"@en ;
    ns1:hasQuality <http://example.org/req/179#Spacing_0> .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Breadth> .

