@prefix : <http://example.org/req/920#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "9 ACCELERATION EVENT The Acceleration event evaluates the vehicle acceleration in a straight line on flat pavement. ## D.9.1 Acceleration Layout D.9.1.1 Course length will be 75 m from starting line to finish line D.9.1.2" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:Course_0 a bfo:BFO_0000040 ;
    rdfs:label "Acceleration event course" ;
    iof:hasQuality :CourseLength_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Course_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 7.5e+01 ;
    qudt:minInclusive 7.5e+01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :CourseLength_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:CourseLength_0 a bfo:BFO_0000019 ;
    rdfs:label "course length" ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

