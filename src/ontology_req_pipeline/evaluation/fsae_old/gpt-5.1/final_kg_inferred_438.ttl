<http://example.org/req/438#> a owl:Ontology .

<http://example.org/req/438#VE_req1_c0> a ns1:BFO_0000001,
        ns1:BFO_0000002,
        ns1:BFO_0000031,
        ns3:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "Minimum diameter 6 mm",
        "Minimum diameter 6 mm"@en ;
    ns3:minInclusive 6e+00 ;
    ns3:unit <http://qudt.org/vocab/unit/MM> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/438#FastenerDiameter_1> .

<http://example.org/req/438#VE_req1_c1> a ns1:BFO_0000001,
        ns1:BFO_0000002,
