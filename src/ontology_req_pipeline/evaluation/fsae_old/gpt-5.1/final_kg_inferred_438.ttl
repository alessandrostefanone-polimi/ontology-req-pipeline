        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "Minimum diameter 0.25 mm (normalized from 1/4\")",
        "Minimum diameter 0.25 mm (normalized from 1/4\")"@en ;
    ns3:minInclusive 2.5e-01 ;
    ns3:unit <http://qudt.org/vocab/unit/MM> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/438#FastenerDiameter_1> .

