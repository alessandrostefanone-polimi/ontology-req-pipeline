@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/234#> a owl:Ontology .

<http://example.org/req/234#DS_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/234#SideImpactZonePortion_0> ;
    ns1:satisfiesRequirement <http://example.org/req/234#Req_0> .

<http://example.org/req/234#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The portion of the Side Impact Zone that is vertically between the upper surface of the floor and 320 mm above the lowest point of the upper surface of the floor (see figure above) must have: a. Equivalence to minimum two (2) Steel Tubes (F.3.2.1.e) per F.4.4 b" ;
    ns1:requirementSatisfiedBy <http://example.org/req/234#DS_0> .

<http://example.org/req/234#SideImpactZonePortion_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Portion of Side Impact Zone between floor surface and 320 mm above",
        "Portion of Side Impact Zone between floor surface and 320 mm above"@en ;
    ns1:hasComponentPartAtSomeTime <http://example.org/req/234#SteelTube_0> .

<http://example.org/req/234#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    rdfs:label "Minimum number of Steel Tubes for Side Impact Zone portion",
        "Minimum number of Steel Tubes for Side Impact Zone portion"@en ;
    ns2:minInclusive 2e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/COUNT> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/234#SteelTube_0> .

<http://qudt.org/vocab/unit/COUNT> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/CharacteristicNumber> .

<http://example.org/req/234#SteelTube_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Steel Tube (equivalent reference)",
        "Steel Tube (equivalent reference)"@en ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/234#VE_req0_c1> .

