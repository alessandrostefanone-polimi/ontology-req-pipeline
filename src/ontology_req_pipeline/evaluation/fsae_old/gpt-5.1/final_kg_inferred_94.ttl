@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/94#> a owl:Ontology .

<http://example.org/req/94#Req0_Constraint0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    ns1:isAbout <http://example.org/req/94#CriticalFastenerClassification_0>,
        <http://example.org/req/94#Fastener_0> .

<http://example.org/req/94#Req1_Constraint0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    ns1:isAbout <http://example.org/req/94#SphericalBearing_0>,
        <http://example.org/req/94#SphericalRodEnd_0>,
        <http://example.org/req/94#V_3_1_5_Ref> .

<http://example.org/req/94#Req2_Constraint0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    ns1:isAbout <http://example.org/req/94#RearWheelSteeringSystem_0> .

<http://example.org/req/94#T_8_2_Ref> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity .

<http://example.org/req/94#CriticalFastenerClassification_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:qualityOf <http://example.org/req/94#Fastener_0> .

<http://example.org/req/94#DS_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/94#RearWheelSteeringSystem_0>,
        <http://example.org/req/94#SphericalBearing_0>,
        <http://example.org/req/94#SphericalRodEnd_0>,
        <http://example.org/req/94#SteeringSystem_0> ;
    ns1:satisfiesRequirement <http://example.org/req/94#Req_0> .

<http://example.org/req/94#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "3.2.8 Fasteners in the steering system are Critical Fasteners, see T.8.2 V.3.2.9 Spherical rod ends and spherical bearings in the steering must meet V.3.1.5 above V.3.2.10 Rear wheel steering may be used" ;
    ns1:requirementSatisfiedBy <http://example.org/req/94#DS_0> .

<http://example.org/req/94#V_3_1_5_Ref> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity .

<http://example.org/req/94#Fastener_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:BFO_0000176 <http://example.org/req/94#SteeringSystem_0> .

<http://example.org/req/94#RearWheelSteeringSystem_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/94#SphericalBearing_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:BFO_0000176 <http://example.org/req/94#SteeringSystem_0> .

<http://example.org/req/94#SphericalRodEnd_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:BFO_0000176 <http://example.org/req/94#SteeringSystem_0> .

<http://example.org/req/94#SteeringSystem_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

