@prefix : <http://example.org/req/491#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:InspectionSticker_0 a bfo:BFO_0000040 ;
    rdfs:comment "Inspection Sticker(s) IN.13.2." .

:AreaVisibility_0 a bfo:BFO_0000019 ;
    rdfs:comment "Clear and unobstructed area for the inspection sticker." .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :StickerSpace_0,
        :Vehicle_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "1.4 Inspection Sticker The vehicle must have space for the Inspection Sticker(s) IN.13.2 that is: - A clear and unobstructed area, minimum 25 cm wide $\\times 20 \\mathrm{~cm}$ high - Located on the upper front surface of the nose along the vehicle centerline ## VE.1.5 Transponder / RFID Tag VE.1.5.1" ;
    iof:requirementSatisfiedBy :DS_0 .

:StickerLocation_0 a bfo:BFO_0000029 ;
    rdfs:comment "Upper front surface of the nose along the vehicle centerline." .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:CentiM ;
    iof:isValueExpressionOfAtSomeTime :StickerSpace_0 .

:VE_req0_c3 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e+01 ;
    qudt:minInclusive 2e+01 ;
    qudt:unit qudtu:CentiM ;
    iof:isValueExpressionOfAtSomeTime :StickerSpace_0 .

:Vehicle_0 a bfo:BFO_0000040 ;
    iof:hasComponentPartAtSomeTime :StickerSpace_0 .

qudtqk:MigrationLength a qudt:QuantityKind .

qudtqk:PathLength a qudt:QuantityKind .

qudtu:CentiM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:MigrationLength,
        qudtqk:PathLength .

:StickerSpace_0 a bfo:BFO_0000040 ;
    bfo:BFO_0000082 :StickerLocation_0 ;
    rdfs:comment "Space for the Inspection Sticker(s) IN.13.2; clear and unobstructed area located on the upper front surface of the nose along the vehicle centerline." ;
    iof:hasQuality :AreaVisibility_0 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2,
        :VE_req0_c3 .

