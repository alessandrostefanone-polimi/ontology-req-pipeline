@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/731#> a owl:Ontology .

<http://example.org/req/731#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The temperature of a minimum of $20 \\%$ of the cells must be monitored by the AMS b" ;
    ns1:isAbout <http://example.org/req/731#ObjSpec_0> ;
    ns1:requirementSatisfiedBy <http://example.org/req/731#PlanSpec_0> .

<http://example.org/req/731#AMSb_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/731#VE_req0_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 2e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/PERCENT> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/731#CellsCoverage_0> .

<http://qudt.org/vocab/unit/PERCENT> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/StateOfCharge> .

<http://example.org/req/731#MonitoringProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    ns3:BFO_0000057 <http://example.org/req/731#AMSb_0> ;
    ns1:hasProcessCharacteristic <http://example.org/req/731#CellsCoverage_0> ;
    ns1:prescribedBy <http://example.org/req/731#PlanSpec_0> .

<http://example.org/req/731#ObjSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:ObjectiveSpecification ;
    ns1:isAchievedByAtSomeTime <http://example.org/req/731#MonitoringProcess_0> ;
    ns1:prescribes <http://example.org/req/731#CellsCoverage_0> .

<http://example.org/req/731#PlanSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns3:BFO_0000110 <http://example.org/req/731#ObjSpec_0> ;
    ns1:prescribes <http://example.org/req/731#MonitoringProcess_0> .

<http://example.org/req/731#CellsCoverage_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ProcessCharacteristic ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/731#VE_req0_c0> .

