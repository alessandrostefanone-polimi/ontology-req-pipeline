@prefix : <http://example.org/req/122#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_BareEdges a iof:DesignSpecification ;
    iof:prescribes :TestPanel ;
    iof:satisfiesRequirement :Req_0 .

:DS_SurfaceAreaEquality a iof:DesignSpecification ;
    iof:prescribes :TestPanel ;
    iof:satisfiesRequirement :Req_0 .

:DS_TestPanel a iof:DesignSpecification ;
    iof:prescribes :TestPanel ;
    iof:satisfiesRequirement :Req_0 .

:Feature_BareEdges a bfo:BFO_0000019 ;
    iof:qualityOf :TestPanel .

:Feature_NoSkinOnEdges a bfo:BFO_0000019 ;
    iof:qualityOf :TestPanel .

:ObjSpec_BareEdges a iof:ObjectiveSpecification ;
    iof:prescribes :Feature_BareEdges,
        :Feature_NoSkinOnEdges .

:ObjSpec_SurfaceAreaEquality a iof:ObjectiveSpecification ;
    iof:prescribes :Qual_SurfaceAreaEquality .

:PS_TestPanelDimensions a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_TestPanelDimensions ;
    iof:prescribes :Proc_TestPanelMeasurement .

:Qual_SurfaceAreaEquality a bfo:BFO_0000019 ;
    iof:qualityOf :TestPanel .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.38e+02 ;
    qudt:minInclusive 1.38e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :DimOption_138x500 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.75e+02 ;
    qudt:minInclusive 2.75e+02 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :DimOption_275x500 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 4e+02 ;
    qudt:minInclusive 4e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :SpanDistance_400mm .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:DimOption_138x500 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:processCharacteristicOf :Proc_TestPanelMeasurement .

:DimOption_275x500 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 ;
    iof:processCharacteristicOf :Proc_TestPanelMeasurement .

:ObjSpec_SpanSupport a iof:ObjectiveSpecification ;
    iof:prescribes :SpanDistance_400mm .

:ObjSpec_TestPanelDimensions a iof:ObjectiveSpecification ;
    iof:prescribes :DimOption_138x500,
        :DimOption_275x500 .

:PS_SpanSupport a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_SpanSupport ;
    iof:prescribes :Proc_SpanSupport .

:Proc_SpanSupport a iof:PlannedProcess ;
    bfo:BFO_0000057 :TestPanel ;
    iof:prescribedBy :PS_SpanSupport .

:SpanDistance_400mm a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 ;
    iof:processCharacteristicOf :Proc_SpanSupport .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length,
        qudtqk:Thickness .

:Proc_TestPanelMeasurement a iof:PlannedProcess ;
    bfo:BFO_0000057 :TestPanel ;
    iof:prescribedBy :PS_TestPanelDimensions .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Refer to F.4.3.4 a. Test panels must: - Measure one of the two options: $138 \\mathrm{~mm} \\times 500 \\mathrm{~mm}$ OR $275 \\mathrm{~mm} \\times 500 \\mathrm{~mm}$ - Be supported by a span distance of 400 mm - Have equal surface area for the top and bottom skin - Have bare edges, without skin material b" ;
    iof:isAbout :ObjSpec_BareEdges,
        :ObjSpec_SpanSupport,
        :ObjSpec_SurfaceAreaEquality,
        :ObjSpec_TestPanelDimensions ;
    iof:requirementSatisfiedBy :DS_BareEdges,
        :DS_SurfaceAreaEquality,
        :DS_TestPanel,
        :PS_SpanSupport .

:TestPanel a iof:MaterialArtifact .

