@prefix : <http://example.org/req/471#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :OutsideRearAerodynamicZone_0 ;
    iof:satisfiesRequirement :Req_0 .

:OutsideRearAerodynamicZone_0 a bfo:BFO_0000040 ;
    rdfs:label "Outside of the Rear Aerodynamic Zone"@en ;
    iof:hasQuality :OutsideRearAerodynamicZone_0_Height .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Outside of the Rear Aerodynamic Zone must be no higher than 500 mm above the ground" ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "height <= 500 mm"@en ;
    qudt:maxInclusive 5e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :OutsideRearAerodynamicZone_0_Height .

qudtqk:Height a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:OutsideRearAerodynamicZone_0_Height a bfo:BFO_0000019 ;
    rdfs:label "height of Outside of the Rear Aerodynamic Zone"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

