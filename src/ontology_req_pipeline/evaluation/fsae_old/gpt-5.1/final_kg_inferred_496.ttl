@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/496#> a owl:Ontology .

<http://example.org/req/496#WheelAssembly_1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "wheels of vehicle",
        "wheels of vehicle"@en .

<http://example.org/req/496#DS_TubeHeightClearance> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/496#Clearance_0>,
        <http://example.org/req/496#Tube_0> ;
    ns2:satisfiesRequirement <http://example.org/req/496#Req_0> .

<http://example.org/req/496#Tube_1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "tube on vehicle (for raised condition)",
        "tube on vehicle (for raised condition)"@en .

<http://example.org/req/496#VE_req0_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "minimum clearance from bottom of tube to ground >= 75 mm",
        "minimum clearance from bottom of tube to ground >= 75 mm"@en ;
    ns1:minInclusive 7.5e+01 ;
    ns1:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/496#Clearance_0> .

<http://example.org/req/496#VE_req1_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    rdfs:label "bottom of tube height above ground = 200 mm",
        "bottom of tube height above ground = 200 mm"@en ;
    ns1:maxInclusive 2e+02 ;
    ns1:minInclusive 2e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/MM> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/496#BottomOfTubeHeight_1> .

<http://example.org/req/496#Vehicle_1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "vehicle",
        "vehicle"@en .

<http://example.org/req/496#WheelGroundContactState_1> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "wheel-ground contact state during full rebound when vehicle raised",
        "wheel-ground contact state during full rebound when vehicle raised"@en ;
    ns2:processCharacteristicOf <http://example.org/req/496#VehicleRaiseProcess_1> .

<http://qudt.org/vocab/unit/MM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Height> .

<http://qudt.org/vocab/unit/MilliM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Height> .

<http://example.org/req/496#BottomOfTubeHeight_1> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    rdfs:label "height of bottom of tube above ground during raised condition",
        "height of bottom of tube above ground during raised condition"@en ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/496#VE_req1_c0> ;
    ns2:processCharacteristicOf <http://example.org/req/496#VehicleRaiseProcess_1> .

<http://example.org/req/496#Clearance_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "clearance from bottom of tube to ground",
        "clearance from bottom of tube to ground"@en ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/496#VE_req0_c0> ;
    ns2:qualityOf <http://example.org/req/496#Tube_0> .

<http://example.org/req/496#PS_VehicleRaisedNoWheelContact> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/496#VehicleRaiseProcess_1>,
        <http://example.org/req/496#WheelGroundContactState_1> ;
    ns2:satisfiesRequirement <http://example.org/req/496#Req_0> .

<http://example.org/req/496#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "The height of the tube must allow 75 mm minimum clearance from the bottom of the tube to the ground i. When the vehicle is raised to where the bottom of the tube is 200 mm above ground, the wheels do not touch the ground when they are in full rebound # VE.2.2 Push Bar Each vehicle must have a removable device which attaches to the rear of the vehicle that: a. Allows two people, standing erect behind the vehicle, to push the vehicle around the competition site b" ;
    ns2:requirementSatisfiedBy <http://example.org/req/496#DS_TubeHeightClearance>,
        <http://example.org/req/496#PS_VehicleRaisedNoWheelContact> .

<http://example.org/req/496#Tube_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "tube (vehicle tube whose height is constrained)",
        "tube (vehicle tube whose height is constrained)"@en .

<http://example.org/req/496#VehicleRaiseProcess_1> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    rdfs:label "vehicle raised until bottom of tube is 200 mm above ground",
        "vehicle raised until bottom of tube is 200 mm above ground"@en ;
    ns3:BFO_0000057 <http://example.org/req/496#Tube_1>,
        <http://example.org/req/496#Vehicle_1> ;
    ns2:hasProcessCharacteristic <http://example.org/req/496#BottomOfTubeHeight_1> ;
    ns2:prescribedBy <http://example.org/req/496#PS_VehicleRaisedNoWheelContact> .

