@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/122#> a owl:Ontology .

<http://example.org/req/122#DS_BareEdges> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/122#TestPanel> ;
    ns2:satisfiesRequirement <http://example.org/req/122#Req_0> .

<http://example.org/req/122#DS_SurfaceAreaEquality> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/122#TestPanel> ;
    ns2:satisfiesRequirement <http://example.org/req/122#Req_0> .

<http://example.org/req/122#DS_TestPanel> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/122#TestPanel> ;
    ns2:satisfiesRequirement <http://example.org/req/122#Req_0> .

<http://example.org/req/122#Feature_BareEdges> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:qualityOf <http://example.org/req/122#TestPanel> .

<http://example.org/req/122#Feature_NoSkinOnEdges> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:qualityOf <http://example.org/req/122#TestPanel> .

<http://example.org/req/122#ObjSpec_BareEdges> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:prescribes <http://example.org/req/122#Feature_BareEdges>,
        <http://example.org/req/122#Feature_NoSkinOnEdges> .

<http://example.org/req/122#ObjSpec_SurfaceAreaEquality> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:prescribes <http://example.org/req/122#Qual_SurfaceAreaEquality> .

<http://example.org/req/122#PS_TestPanelDimensions> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns3:BFO_0000110 <http://example.org/req/122#ObjSpec_TestPanelDimensions> ;
    ns2:prescribes <http://example.org/req/122#Proc_TestPanelMeasurement> .

<http://example.org/req/122#Qual_SurfaceAreaEquality> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:qualityOf <http://example.org/req/122#TestPanel> .

<http://example.org/req/122#VE_req0_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 1.38e+02 ;
    ns1:minInclusive 1.38e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/122#DimOption_138x500> .

<http://example.org/req/122#VE_req0_c1> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 2.75e+02 ;
    ns1:minInclusive 2.75e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/MM> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/122#DimOption_275x500> .

<http://example.org/req/122#VE_req1_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 4e+02 ;
    ns1:minInclusive 4e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/122#SpanDistance_400mm> .

<http://qudt.org/vocab/unit/MM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/122#DimOption_138x500> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/122#VE_req0_c0> ;
    ns2:processCharacteristicOf <http://example.org/req/122#Proc_TestPanelMeasurement> .

<http://example.org/req/122#DimOption_275x500> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/122#VE_req0_c1> ;
    ns2:processCharacteristicOf <http://example.org/req/122#Proc_TestPanelMeasurement> .

<http://example.org/req/122#ObjSpec_SpanSupport> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:prescribes <http://example.org/req/122#SpanDistance_400mm> .

<http://example.org/req/122#ObjSpec_TestPanelDimensions> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:ObjectiveSpecification ;
    ns2:prescribes <http://example.org/req/122#DimOption_138x500>,
        <http://example.org/req/122#DimOption_275x500> .

<http://example.org/req/122#PS_SpanSupport> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns3:BFO_0000110 <http://example.org/req/122#ObjSpec_SpanSupport> ;
    ns2:prescribes <http://example.org/req/122#Proc_SpanSupport> .

<http://example.org/req/122#Proc_SpanSupport> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns3:BFO_0000057 <http://example.org/req/122#TestPanel> ;
    ns2:prescribedBy <http://example.org/req/122#PS_SpanSupport> .

<http://example.org/req/122#SpanDistance_400mm> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/122#VE_req1_c0> ;
    ns2:processCharacteristicOf <http://example.org/req/122#Proc_SpanSupport> .

<http://qudt.org/vocab/unit/MilliM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length>,
        <http://qudt.org/vocab/quantitykind/Thickness> .

<http://example.org/req/122#Proc_TestPanelMeasurement> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns3:BFO_0000057 <http://example.org/req/122#TestPanel> ;
    ns2:prescribedBy <http://example.org/req/122#PS_TestPanelDimensions> .

<http://example.org/req/122#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "Refer to F.4.3.4 a. Test panels must: - Measure one of the two options: $138 \\mathrm{~mm} \\times 500 \\mathrm{~mm}$ OR $275 \\mathrm{~mm} \\times 500 \\mathrm{~mm}$ - Be supported by a span distance of 400 mm - Have equal surface area for the top and bottom skin - Have bare edges, without skin material b" ;
    ns2:isAbout <http://example.org/req/122#ObjSpec_BareEdges>,
        <http://example.org/req/122#ObjSpec_SpanSupport>,
        <http://example.org/req/122#ObjSpec_SurfaceAreaEquality>,
        <http://example.org/req/122#ObjSpec_TestPanelDimensions> ;
    ns2:requirementSatisfiedBy <http://example.org/req/122#DS_BareEdges>,
        <http://example.org/req/122#DS_SurfaceAreaEquality>,
        <http://example.org/req/122#DS_TestPanel>,
        <http://example.org/req/122#PS_SpanSupport> .

<http://example.org/req/122#TestPanel> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact .

