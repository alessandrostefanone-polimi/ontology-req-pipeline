<http://example.org/req/168#Proc_SeatAdjust> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:PlannedProcess ;
    ns2:hasProcessCharacteristic <http://example.org/req/168#SeatPosition> ;
    ns2:prescribedBy <http://example.org/req/168#Plan_0> .

<http://example.org/req/168#BottomCircle> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/168#Plan_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/168#Proc_BottomCirclePlacement>,
        <http://example.org/req/168#Proc_MiddleCirclePlacement>,
        <http://example.org/req/168#Proc_PedalAdjust>,
        <http://example.org/req/168#Proc_SeatAdjust> .

