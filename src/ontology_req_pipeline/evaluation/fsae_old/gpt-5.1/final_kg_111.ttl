@prefix : <http://example.org/req/111#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:NonStructuralTubing_0 a bfo:BFO_0000040 ;
    rdfs:label "Non Structural Tubing"@en .

:SizeInfo_0 a iof:InformationContentEntity ;
    rdfs:label "Size specification"@en ;
    iof:isAbout :Tube_0 .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "number of minimum requirements = 4"@en ;
    qudt:maxInclusive 4e+00 ;
    qudt:minInclusive 4e+00 ;
    qudt:unit qudtu:COUNT ;
    iof:isValueExpressionOfAtSomeTime :MinRequirements_0 .

:ComplianceAssessment_0 a iof:PlannedProcess ;
    rdfs:label "assessing compliance to any rule"@en .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Tube_0 .

:MinRequirements_0 a iof:InformationContentEntity ;
    rdfs:label "minimum requirements for tube"@en ;
    iof:isAbout :Tube_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :ComplianceAssessment_0,
        :SizeSpecificationProcess_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Definition Any tubing which does NOT meet F.3.2.1.o Structural Tubing F.3.3.2 Applicability Non Structural Tubing is ignored when assessing compliance to any rule ## F.3.4 Steel Tubing and Material F.3.4.1 Minimum Requirements for Steel Tubing A tube must meet all four minimum requirements for each Size specified: Tube Minimum Area Moment of Inertia Minimum Cross Sectional Area Minimum Outside Diameter or Square Width Minimum Wall Thickness Example Sizes of Round Tube :--: :--: :--: :--: :--: :--: :--: a. Size A $11320 \\mathrm{~mm}^{4}$ $173 \\mathrm{~mm}^{2}$ 25.0 mm 2.0 mm $\\begin{aligned} & 1.0^{\\prime \\prime} \\times 0.095^{\\prime \\prime} \\\\ & 25 \\times 2.5 \\mathrm{~mm} \\end{aligned}$ b" ;
    iof:requirementSatisfiedBy :DesignSpec_0,
        :PlanSpec_0 .

:SizeSpecificationProcess_0 a iof:PlannedProcess ;
    rdfs:label "each Size specified"@en .

:TubeRole_MinReq_0 a bfo:BFO_0000023 ;
    rdfs:label "tube role with minimum requirements"@en .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtu:COUNT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

:Tube_0 a bfo:BFO_0000040 ;
    rdfs:label "tube"@en ;
    iof:hasRole :TubeRole_MinReq_0 ;
    iof:satisfiesRequirement :Req_0 .

