@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/190#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:ComponentEnvelopeSpec_F_1_15 a iof:InformationContentEntity ;
    rdfs:label "Component Envelope F.1.15" .

:MainHoop a bfo:BFO_0000040 ;
    rdfs:label "Main Hoop" .

:MainHoopBrace a bfo:BFO_0000040 ;
    rdfs:label "Main Hoop Brace" .

:RolloverProcess_F_5_11_2 a bfo:BFO_0000015 ;
    rdfs:label "Rollover process F.5.11.2" .

:ShoulderHarnessMounting a bfo:BFO_0000040 ;
    rdfs:label "Shoulder Harness Mounting" .

:ExtItem_DesignSpec_0 a iof:DesignSpecification ;
    rdfs:label "Design specification for external items attachment conditions" ;
    iof:prescribes :ExternalItem_0 .

:ExternalItem_0 a bfo:BFO_0000040 ;
    rdfs:label "External Item" ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any item which meets all three of: - Located outside the Component Envelope F.1.15 - Located above 350 mm from the ground - Could load the Main Hoop, Main Hoop Brace, or Shoulder Harness Mounting during a rollover F.5.11.2 External Items must meet one of the two conditions: a. Be attached at a Hoop to Brace node or a fully Triangulated structural node without the ability to create a moment at the node b" ;
    iof:requirementSatisfiedBy :ExtItem_DesignSpec_0 .

