@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/852#> a owl:Ontology .

<http://example.org/req/852#PenaltyImpositionApplicability_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DescriptiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Applicability of penalty imposition as given in DR Document Requirements" ;
    ns1:describes <http://example.org/req/852#DR_DocumentRequirements_Section> ;
    ns1:isAbout <http://example.org/req/852#PenaltyImpositionProcess_0> .

<http://example.org/req/852#Req_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:label "Requirement 1: Supplement to Cost Report may be submitted" ;
    ns1:requirementSatisfiedBy <http://example.org/req/852#PS_Req0_Processes> .

<http://example.org/req/852#CostReport_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "Cost Report (Req 1 reference)" .

<http://example.org/req/852#DR_DocumentRequirements_Section> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "section DR Document Requirements" .

<http://example.org/req/852#DS_Req0_Design> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    rdfs:label "Design spec for Cost Report artifacts and penalties" ;
    ns1:prescribes <http://example.org/req/852#CostReport_0>,
        <http://example.org/req/852#LateSubmissionPenalty_0> .

<http://example.org/req/852#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Late Submission Penalties for Late Submission of Cost Report will be imposed as given in section DR Document Requirements. ### 5.3.7 Cost Addendum 5.3.7.1 A supplement to the Cost Report that reflects any changes or corrections made after the submission of the Cost Report may be submitted" ;
    ns1:requirementSatisfiedBy <http://example.org/req/852#DS_Req0_Design>,
        <http://example.org/req/852#PS_Req0_Processes> .

<http://example.org/req/852#SubmissionOfCostReport_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Submission of the Cost Report (Req 1)" .

<http://example.org/req/852#SupplementSubmissionProcess_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Submission of supplement to the Cost Report" ;
    ns1:after <http://example.org/req/852#SubmissionOfCostReport_1> ;
    ns1:hasInput <http://example.org/req/852#SupplementToCostReport_1> ;
    ns1:hasSpecifiedOutput <http://example.org/req/852#SupplementToCostReport_1> ;
    ns1:prescribedBy <http://example.org/req/852#PS_Req0_Processes> .

<http://example.org/req/852#CostReport_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Cost Report (information artifact treated as material bearer)" .

<http://example.org/req/852#LateSubmissionPenalty_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Late Submission Penalties for Late Submission of Cost Report" ;
    ns1:satisfiesRequirement <http://example.org/req/852#Req_0> .

<http://example.org/req/852#PenaltyImpositionProcess_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "Imposition of late submission penalties for Cost Report" ;
    ns1:hasInput <http://example.org/req/852#CostReport_0> ;
    ns1:hasSpecifiedOutput <http://example.org/req/852#LateSubmissionPenalty_0> ;
    ns1:prescribedBy <http://example.org/req/852#PS_Req0_Processes> .

<http://example.org/req/852#SupplementToCostReport_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity ;
    rdfs:label "Supplement to the Cost Report reflecting post-submission changes" ;
    ns1:isAbout <http://example.org/req/852#CostReport_1> .

<http://example.org/req/852#PS_Req0_Processes> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    rdfs:label "Plan spec for penalty imposition and cost report supplements" ;
    ns1:prescribes <http://example.org/req/852#PenaltyImpositionProcess_0>,
        <http://example.org/req/852#SupplementSubmissionProcess_1> .

