@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <http://purl.obolibrary.org/obo/> .
@prefix ns3: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/205#> a owl:Ontology .

<http://example.org/req/205#AttachmentToFrontBulkhead> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "attachment of upper support member to Front Bulkhead" ;
    ns2:BFO_0000057 <http://example.org/req/205#FrontBulkhead>,
        <http://example.org/req/205#UpperSupportMember> ;
    ns3:prescribedBy <http://example.org/req/205#DS_UpperSupportAttachment> .

<http://example.org/req/205#AttachmentToFrontHoop> a ns2:BFO_0000001,
        ns2:BFO_0000003,
        ns2:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "attachment of upper support member to Front Hoop" ;
    ns2:BFO_0000057 <http://example.org/req/205#FrontHoop>,
        <http://example.org/req/205#UpperSupportMember>,
        <http://example.org/req/205#Zone_AttachmentToFrontHoop> ;
    ns3:prescribedBy <http://example.org/req/205#DS_UpperSupportAttachment> .

<http://example.org/req/205#UpperSideImpactMember> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Upper Side Impact member" .

<http://example.org/req/205#VE_req0_c1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns3:InformationContentEntity,
        ns3:ValueExpression ;
    rdfs:label "distance <= 50 mm from top surface of Front Bulkhead" ;
    ns1:maxInclusive 5e+01 ;
    ns1:unit <http://qudt.org/vocab/unit/MM> ;
    ns3:isValueExpressionOfAtSomeTime <http://example.org/req/205#Distance_UpperSupport_to_FrontBulkheadTopSurface> .

<http://example.org/req/205#VE_req1_c1> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns3:InformationContentEntity,
        ns3:ValueExpression ;
    rdfs:label "extension 100 mm above Upper Side Impact member" ;
    ns1:maxInclusive 1e+02 ;
    ns1:minInclusive 1e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/MM> ;
    ns3:isValueExpressionOfAtSomeTime <http://example.org/req/205#ExtensionAbove_UpperSideImpactMember> .

<http://example.org/req/205#VE_req1_c2> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns3:InformationContentEntity,
        ns3:ValueExpression ;
    rdfs:label "extension 50 mm below Upper Side Impact member" ;
    ns1:maxInclusive 5e+01 ;
    ns1:minInclusive 5e+01 ;
    ns1:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns3:isValueExpressionOfAtSomeTime <http://example.org/req/205#ExtensionBelow_UpperSideImpactMember> .

<http://example.org/req/205#Distance_UpperSupport_to_FrontBulkheadTopSurface> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "distance from upper support member to top surface of Front Bulkhead" ;
    ns3:qualityOf <http://example.org/req/205#UpperSupportMember> .

<http://example.org/req/205#ExtensionAbove_UpperSideImpactMember> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "extension above Upper Side Impact member" ;
    ns3:qualityOf <http://example.org/req/205#Zone_AttachmentToFrontHoop> .

<http://example.org/req/205#ExtensionBelow_UpperSideImpactMember> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000019,
        ns2:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "extension below Upper Side Impact member" ;
    ns3:qualityOf <http://example.org/req/205#Zone_AttachmentToFrontHoop> .

<http://example.org/req/205#FrontBulkhead> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Front Bulkhead" .

<http://example.org/req/205#FrontHoop> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "Front Hoop" .

<http://example.org/req/205#Req_0> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns3:InformationContentEntity,
        ns3:RequirementSpecification ;
    rdfs:comment "The upper support member must be attached 50 mm or less from the top surface of the Front Bulkhead, and attach to the Front Hoop inside a zone extending 100 mm above and 50 mm below the Upper Side Impact member" ;
    ns3:requirementSatisfiedBy <http://example.org/req/205#DS_UpperSupportAttachment> .

<http://qudt.org/vocab/unit/MilliM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://qudt.org/vocab/unit/MM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/205#DS_UpperSupportAttachment> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns3:DesignSpecification,
        ns3:DirectiveInformationContentEntity,
        ns3:InformationContentEntity ;
    ns3:prescribes <http://example.org/req/205#UpperSupportMember> .

<http://example.org/req/205#Zone_AttachmentToFrontHoop> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "zone for attachment to Front Hoop relative to Upper Side Impact member" .

<http://example.org/req/205#UpperSupportMember> a ns2:BFO_0000001,
        ns2:BFO_0000002,
        ns2:BFO_0000004,
        ns2:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "upper support member" ;
    ns3:satisfiesRequirement <http://example.org/req/205#Req_0> .

