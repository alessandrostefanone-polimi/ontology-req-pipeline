@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/164#> a owl:Ontology .

<http://example.org/req/164#RepresentationPlan_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/164#RepresentationProcess_0> .

<http://example.org/req/164#RepresentationProcess_0> a ns3:BFO_0000001,
        ns3:BFO_0000003,
        ns3:BFO_0000015,
        owl:NamedIndividual,
        owl:Thing,
        ns1:PlannedProcess ;
    rdfs:label "representation of shoulder/cervical region by circle" ;
    ns3:BFO_0000057 <http://example.org/req/164#Circle_0>,
        <http://example.org/req/164#ShoulderCervicalRegion_0> ;
    ns1:prescribedBy <http://example.org/req/164#RepresentationPlan_0> .

<http://example.org/req/164#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "A circle of diameter 200 mm will represent the shoulder/cervical region" ;
    ns1:requirementSatisfiedBy <http://example.org/req/164#DesignSpec_0> .

<http://example.org/req/164#ShoulderCervicalRegion_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000029,
        ns3:BFO_0000141,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "shoulder/cervical region" .

<http://example.org/req/164#VE_req0_c0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 2e+02 ;
    ns2:minInclusive 2e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/164#Circle_0_Diameter> .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Diameter> .

<http://example.org/req/164#Circle_0_Diameter> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "diameter of circle representing shoulder/cervical region" ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/164#VE_req0_c0> ;
    ns1:qualityOf <http://example.org/req/164#Circle_0> .

<http://example.org/req/164#DesignSpec_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/164#Circle_0> ;
    ns1:satisfiesRequirement <http://example.org/req/164#Req_0> .

<http://example.org/req/164#Circle_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000030,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:label "circle representing shoulder/cervical region" ;
    ns1:hasQuality <http://example.org/req/164#Circle_0_Diameter> ;
    ns1:prescribedBy <http://example.org/req/164#DesignSpec_0> .

