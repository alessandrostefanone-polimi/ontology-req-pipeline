@prefix : <http://example.org/req/798#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "All teams with a system voltage of 500 V or more will be measured with 500 V" ;
    iof:requirementSatisfiedBy :Plan_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 5e+02 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtSomeTime :SystemVoltage_0 .

:VE_req0_c3 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 5e+02 ;
    qudt:minInclusive 5e+02 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtSomeTime :MeasVoltage_0 .

:MeasICE_0 a iof:MeasurementInformationContentEntity ;
    iof:describes :MeasVoltage_0 ;
    iof:isOutputOf :MeasProc_0 .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :MeasProc_0 .

:SystemVoltage_0 a bfo:BFO_0000019 ;
    iof:qualityOf :TeamSystem_0 .

:TeamSystem_0 a bfo:BFO_0000040 .

qudtqk:Voltage a qudt:QuantityKind .

:MeasProc_0 a iof:MeasurementProcess ;
    iof:hasSpecifiedOutput :MeasICE_0 .

:MeasVoltage_0 a bfo:BFO_0000019 .

qudtu:V a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Voltage .

