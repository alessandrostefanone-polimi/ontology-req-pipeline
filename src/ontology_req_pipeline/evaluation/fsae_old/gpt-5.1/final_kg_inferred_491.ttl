@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix ns3: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/491#> a owl:Ontology .

<http://example.org/req/491#InspectionSticker_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:comment "Inspection Sticker(s) IN.13.2." .

<http://example.org/req/491#AreaVisibility_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000019,
        ns3:BFO_0000020,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:comment "Clear and unobstructed area for the inspection sticker." .

<http://example.org/req/491#DS_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/491#StickerSpace_0>,
        <http://example.org/req/491#Vehicle_0> ;
    ns1:satisfiesRequirement <http://example.org/req/491#Req_0> .

<http://example.org/req/491#Req_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "1.4 Inspection Sticker The vehicle must have space for the Inspection Sticker(s) IN.13.2 that is: - A clear and unobstructed area, minimum 25 cm wide $\\times 20 \\mathrm{~cm}$ high - Located on the upper front surface of the nose along the vehicle centerline ## VE.1.5 Transponder / RFID Tag VE.1.5.1" ;
    ns1:requirementSatisfiedBy <http://example.org/req/491#DS_0> .

<http://example.org/req/491#StickerLocation_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000029,
        ns3:BFO_0000141,
        owl:NamedIndividual,
        owl:Thing ;
    rdfs:comment "Upper front surface of the nose along the vehicle centerline." .

<http://example.org/req/491#VE_req0_c2> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:minInclusive 2.5e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/CentiM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/491#StickerSpace_0> .

<http://example.org/req/491#VE_req0_c3> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000031,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxInclusive 2e+01 ;
    ns2:minInclusive 2e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/CentiM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/491#StickerSpace_0> .

<http://example.org/req/491#Vehicle_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasComponentPartAtSomeTime <http://example.org/req/491#StickerSpace_0> .

<http://qudt.org/vocab/unit/CentiM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/MigrationLength>,
        <http://qudt.org/vocab/quantitykind/PathLength> .

<http://example.org/req/491#StickerSpace_0> a ns3:BFO_0000001,
        ns3:BFO_0000002,
        ns3:BFO_0000004,
        ns3:BFO_0000040,
        owl:NamedIndividual,
        owl:Thing ;
    ns3:BFO_0000082 <http://example.org/req/491#StickerLocation_0> ;
    rdfs:comment "Space for the Inspection Sticker(s) IN.13.2; clear and unobstructed area located on the upper front surface of the nose along the vehicle centerline." ;
    ns1:hasQuality <http://example.org/req/491#AreaVisibility_0> ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/491#VE_req0_c2>,
        <http://example.org/req/491#VE_req0_c3> .

