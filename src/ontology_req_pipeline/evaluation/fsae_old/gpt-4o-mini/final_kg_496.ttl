@prefix : <http://example.org/req/496#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The height of the tube must allow 75 mm minimum clearance from the bottom of the tube to the ground i. When the vehicle is raised to where the bottom of the tube is 200 mm above ground, the wheels do not touch the ground when they are in full rebound # VE.2.2 Push Bar Each vehicle must have a removable device which attaches to the rear of the vehicle that: a. Allows two people, standing erect behind the vehicle, to push the vehicle around the competition site b" ;
    iof:requirementSatisfiedBy :DS_req0 .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :VE_req0_c0 .

:Height_of_the_tube a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:Push_capability a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req3_c0 .

:Removable_device a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c0 .

:VE_req1_c0 a iof:ValueExpression ;
    iof:isValueExpressionOfAtSomeTime :Wheels_touching_ground .

:VE_req1_c1 a iof:ValueExpression ;
    iof:isValueExpressionOfAtSomeTime :Vehicle_position .

:VE_req2_c0 a iof:ValueExpression ;
    iof:isValueExpressionOfAtSomeTime :Removable_device .

:VE_req3_c0 a iof:ValueExpression ;
    iof:isValueExpressionOfAtSomeTime :Push_capability .

:Vehicle_position a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 .

:Wheels_touching_ground a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

qudtqk:Height a qudt:QuantityKind .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudtu:MilliM ;
    qudt:minInclusive 7.5e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Height_of_the_tube .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

