@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/491#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AreaRequirement a iof:RequirementSpecification ;
    rdfs:comment "A clear and unobstructed area, minimum 25 cm wide × 20 cm high is required." ;
    iof:prescribes :A_clear_and_unobstructed_area .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "1.4 Inspection Sticker The vehicle must have space for the Inspection Sticker(s) IN.13.2 that is: - A clear and unobstructed area, minimum 25 cm wide × 20 cm high - Located on the upper front surface of the nose along the vehicle centerline ## VE.1.5 Transponder / RFID Tag VE.1.5.1" ;
    iof:requirementSatisfiedBy :DS_1 .

:AreaRole a iof:MaterialComponentRole ;
    rdfs:label "role of the clear and unobstructed area" .

:C0 a iof:PlanSpecification ;
    iof:prescribes :A_clear_and_unobstructed_area .

:DS_1 a iof:DesignSpecification ;
    iof:prescribes :C0 .

:InspectionSticker a iof:MaterialArtifact ;
    iof:hasRole :InspectionStickerRole .

:InspectionStickerRole a iof:MaterialComponentRole ;
    rdfs:label "role of the Inspection Sticker" .

:LocationRequirement a iof:RequirementSpecification ;
    rdfs:comment "The area must be located on the upper front surface of the nose along the vehicle centerline." ;
    iof:prescribes :LocationSpecification .

:LocationSpecification a iof:DesignSpecification ;
    iof:prescribes :LocationRequirement .

:Quality_1 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtAllTimes :VE_req1_c1 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 .

qudtqk:MigrationLength a qudt:QuantityKind .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudtu:CentiM ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:CentiM ;
    iof:isValueExpressionOfAtSomeTime :A_clear_and_unobstructed_area .

qudtu:CentiM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:MigrationLength .

:A_clear_and_unobstructed_area a iof:MaterialArtifact ;
    iof:hasComponentPartAtAllTimes :InspectionSticker ;
    iof:hasQuality :Quality_1 ;
    iof:hasRole :AreaRole .

