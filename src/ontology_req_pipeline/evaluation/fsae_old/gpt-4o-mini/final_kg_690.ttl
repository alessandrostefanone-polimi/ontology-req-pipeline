@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/690#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Teams must be prepared to show spacing on team built equipment For inaccessible circuitry, spare boards or appropriate photographs must be available for inspection" ;
    iof:requirementSatisfiedBy :Spec_0 .

:Action_0 a iof:ActionSpecification ;
    iof:prescribes :OBJECT .

:Action_1 a iof:ActionSpecification ;
    iof:prescribes :OBJECT .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :Action_0,
        :Action_1 .

:OBJECT a iof:MaterialEntity ;
    iof:hasRole :spare_boards_or_appropriate_photographs .

