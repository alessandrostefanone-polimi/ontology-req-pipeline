@prefix : <http://example.org/req/470#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "In the Rear Aerodynamic Zone must be no higher than 1200 mm above the ground" ;
    iof:requirementSatisfiedBy :DS_req0 .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :VE_req0_c0 .

:HeightQuality a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:Height_0 a bfo:BFO_0000001 ;
    iof:hasQuality :HeightQuality ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

qudtqk:Height a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.2e+03 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtAllTimes :Height_0 .

