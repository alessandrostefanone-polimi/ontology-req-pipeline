@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/671#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "6.1.2 Contact with any Tractive System connections with a 100 mm long, 6 mm diameter insulated test probe must not be possible when the Tractive System enclosures are in place" ;
    iof:requirementSatisfiedBy :DS_0 .

:condition_0 a iof:ObjectiveSpecification ;
    iof:hasContinuantPartAtAllTimes :input_0 ;
    iof:prescribes :output_0 .

:constraint_0 a iof:ObjectiveSpecification ;
    iof:hasContinuantPartAtAllTimes :input_0 ;
    iof:prescribes :output_0 .

:constraint_1 a iof:RequirementSpecification ;
    iof:prescribes :output_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :P_0 .

:P_0 a iof:PlanSpecification ;
    iof:hasInput :input_0 ;
    iof:prescribes :output_0 .

:input_0 a iof:ProcessCharacteristic .

:output_0 a iof:MaterialProduct .

