@prefix : <http://example.org/req/937#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Length of each run should be approximately 0.80 km D.11.1.2" ;
    iof:requirementSatisfiedBy :DS_req0 .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :VE_req0_c0 .

:LengthOfEachRun a bfo:BFO_0000001 ;
    iof:hasQuality :LengthQuality ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

:LengthQuality a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

qudtqk:PathLength a qudt:QuantityKind .

qudtu:KiloM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:PathLength .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue 0.8 ;
    qudt:hasUnit qudt:KiloM ;
    qudt:maxInclusive 8e-01 ;
    qudt:minInclusive 8e-01 ;
    qudt:unit qudtu:KiloM ;
    iof:isValueExpressionOfAtAllTimes :LengthOfEachRun .

