        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/496#Vehicle_position> .

<http://example.org/req/496#VE_req2_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns2:isValueExpressionOfAtSomeTime <http://example.org/req/496#Removable_device> .

<http://example.org/req/496#VE_req3_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
