@prefix : <http://example.org/req/922#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The foremost part of the vehicle will be staged at 0.30 m behind the starting line b" ;
    iof:requirementSatisfiedBy :DS_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :P_0 .

:P_0 a iof:PlanSpecification ;
    iof:prescribes :VE_req0_c0 .

:staging_distance a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue "0.3"^^xsd:float ;
    qudt:maxInclusive 3e-01 ;
    qudt:minInclusive 3e-01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :staging_distance .

