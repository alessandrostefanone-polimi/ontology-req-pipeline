@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/571#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Angled no more than $30^{\\circ}$ from the vertical IC.5.4.3 The Fuel Filler Neck must be accompanied by a clear fuel resistant sight tube for reading the fuel level which must be: a. Visible vertical height: 125 mm minimum b" ;
    iof:requirementSatisfiedBy :DS_req1 .

:VisibleHeight a iof:ObjectiveSpecification ;
    iof:prescribes :VerticalHeight .

:P_req1 a iof:PlanSpecification ;
    iof:prescribes :VE_req1_c0 .

:SightTubeRole a iof:MaterialComponentRole ;
    iof:prescribedBy :DS_req1 .

qudtqk:Height a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:DS_req1 a iof:DesignSpecification ;
    iof:prescribes :P_req1 .

:TheSightTube a iof:MaterialArtifact ;
    iof:hasQuality :VerticalHeight ;
    iof:hasRole :SightTubeRole .

:VerticalHeight a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtAllTimes :VE_req1_c0 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:MeasuredValueExpression,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue 125.0 ;
    qudt:minInclusive 1.25e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :TheSightTube ;
    iof:isValueExpressionOfAtSomeTime :TheSightTube .

