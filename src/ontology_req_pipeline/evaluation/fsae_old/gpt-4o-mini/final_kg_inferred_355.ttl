@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/355#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The design must address all three types of heat transfer between the heat source (examples include but are not limited to: exhaust pipe, coolant hose/tube, Accumulator Container) and the panel that the driver could contact (seat or floor): a. Conduction Isolation by one of the following: - No direct contact between the heat source and the panel - A heat resistant, conduction isolation material with a minimum thickness of 8 mm between the heat source and the panel b. Convection Isolation by a minimum air gap of 25 mm between the heat source and the panel c. Radiation Isolation by one of the following: - A solid metal heat shield with a minimum thickness of 0.4 mm - Reflective foil or tape when combined with conduction insulation # T.1.7" ;
    iof:requirementSatisfiedBy :Spec_0 .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "Conduction Isolation by one of the following: No direct contact between the heat source and the panel." ;
    iof:requirementSatisfiedBy :ConductionIsolation .

:Req_2 a iof:RequirementSpecification ;
    rdfs:comment "Convection Isolation by a minimum air gap of 25 mm between the heat source and the panel." ;
    iof:requirementSatisfiedBy :ConvectionIsolation .

:Req_3 a iof:RequirementSpecification ;
    rdfs:comment "Radiation Isolation by one of the following: A solid metal heat shield with a minimum thickness of 0.4 mm." ;
    iof:requirementSatisfiedBy :RadiationIsolation .

:VE_req1_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 8e+00 ;
    qudt:unit qudtu:MM .

:VE_req3_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 8e+00 ;
    qudt:unit qudtu:MilliM .

:VE_req4_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM .

:VE_req6_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 4e-01 ;
    qudt:unit qudtu:MilliM .

:AirGapForConvectionIsolation a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 .

:ConductionIsolationMaterial a iof:MaterialArtifact ;
    iof:hasQuality :ThicknessForConductionIsolation .

:HeatShield a iof:MaterialArtifact ;
    iof:hasQuality :ThicknessForRadiationIsolation .

:Spec_0 a iof:DesignSpecification ;
    iof:prescribes :ConductionIsolation,
        :ConvectionIsolation,
        :RadiationIsolation .

:ThicknessForConductionIsolation a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:ThicknessForRadiationIsolation a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c3 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue 8.0 ;
    qudt:minInclusive 8e+00 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :ConductionIsolation .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue 25.0 ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :ConvectionIsolation .

:VE_req0_c3 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue 0.4 ;
    qudt:minInclusive 4e-01 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :RadiationIsolation .

qudtqk:Thickness a qudt:QuantityKind .

:ConductionIsolation a iof:PlanSpecification ;
    iof:prescribes :ConductionIsolationMaterial .

:ConvectionIsolation a iof:PlanSpecification ;
    iof:prescribes :AirGapForConvectionIsolation .

:RadiationIsolation a iof:PlanSpecification ;
    iof:prescribes :HeatShield .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

