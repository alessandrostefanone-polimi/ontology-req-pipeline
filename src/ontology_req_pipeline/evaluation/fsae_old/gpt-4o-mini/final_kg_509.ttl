@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Competitors a iof:InformationContentEntity .

:Fire_Retardant_Underwear a iof:InformationContentEntity .

:Long_Pants_and_Long_Sleeve_Shirt a iof:InformationContentEntity .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Each suit must meet one or more of the following standards and be labeled as such: - $\\quad$ SFI 3.2A/5 (or higher ex: /10, /15, /20) - $\\quad$ SFI 3.4/5 (or higher ex: /10, /15, /20) - FIA Standard 1986 - FIA Standard 8856-2000 - FIA Standard 8856-2018 VE.3.3.2 Underclothing All competitors should wear fire retardant underwear (long pants and long sleeve shirt) under their approved Driver Suit" ;
    iof:requirementSatisfiedBy :Spec_0 .

:FIA_Standard_1986 a iof:InformationContentEntity .

:FIA_Standard_8856_2000 a iof:InformationContentEntity .

:FIA_Standard_8856_2018 a iof:InformationContentEntity .

:SFI_3_2A_5 a iof:InformationContentEntity .

:SFI_3_4_5 a iof:InformationContentEntity .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :FIA_Standard_1986,
        :FIA_Standard_8856_2000,
        :FIA_Standard_8856_2018,
        :SFI_3_2A_5,
        :SFI_3_4_5 .

