@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/190#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any item which meets all three of: - Located outside the Component Envelope F.1.15 - Located above 350 mm from the ground - Could load the Main Hoop, Main Hoop Brace, or Shoulder Harness Mounting during a rollover F.5.11.2 External Items must meet one of the two conditions: a. Be attached at a Hoop to Brace node or a fully Triangulated structural node without the ability to create a moment at the node b" ;
    iof:requirementSatisfiedBy :Spec_0 .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "- Located above 350 mm from the ground" ;
    iof:requirementSatisfiedBy :Spec_1 .

:Req_2 a iof:RequirementSpecification ;
    rdfs:comment "- Could load the Main Hoop, Main Hoop Brace, or Shoulder Harness Mounting during a rollover" ;
    iof:requirementSatisfiedBy :Spec_2 .

:Req_3 a iof:RequirementSpecification ;
    rdfs:comment "External Items must meet one of the two conditions:" ;
    iof:requirementSatisfiedBy :Spec_3 .

:Req_4 a iof:RequirementSpecification ;
    rdfs:comment "a. Be attached at a Hoop to Brace node or a fully Triangulated structural node without the ability to create a moment at the node" ;
    iof:requirementSatisfiedBy :Spec_4 .

:GroundClearance a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:Height a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:Output_0 a iof:MaterialProduct ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:Output_1 a iof:MaterialProduct ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:Output_2 a iof:MaterialProduct .

:Output_3 a iof:MaterialProduct .

:Output_4 a iof:MaterialProduct .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :Output_0 .

:Spec_1 a iof:PlanSpecification ;
    iof:prescribes :Output_1 .

:Spec_2 a iof:PlanSpecification ;
    iof:prescribes :Output_2 .

:Spec_3 a iof:PlanSpecification ;
    iof:prescribes :Output_3 .

:Spec_4 a iof:PlanSpecification ;
    iof:prescribes :Output_4 .

qudtqk:Height a qudt:QuantityKind .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3.5e+02 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :GroundClearance .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3.5e+02 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :Height .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

