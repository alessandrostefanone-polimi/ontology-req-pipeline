@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/385#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:BoltDiameter_SpecifiedBy_Manufacturer a iof:InformationContentEntity ;
    iof:prescribes :BoltDiameter_SpecifiedBy_Manufacturer_Ref .

:MountingPointInLineWithDriver a iof:InformationContentEntity ;
    iof:prescribes :MountingPointInLineWithDriver_Ref .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any bolt used to attach a Shoulder Belt, directly to the chassis or to an intermediate bracket, is a Critical Fasteners, see T.8.2, with a minimum diameter that is the smaller of: - The bolt diameter specified by the manufacturer - 10 mm or $3 / 8^{\\prime \\prime}$ ## T.2.7 Anti-Submarine Belt Mounting T.2.7.1 The Anti-Submarine Belt of a 5 point harness must be mounted with the mounting point in line with or slightly forward of the driver's Chest to Groin Line with an Anti-Submarine Belt Side View Angle no more than $20^{\\circ}$" ;
    iof:requirementSatisfiedBy :Spec_1 .

:CriticalFastenerRole a iof:AgentRole ;
    rdfs:label "Critical Fasteners" .

:Diameter_10mm a iof:MaterialEntity ;
    iof:hasRole :CriticalFastenerRole .

:Spec_1 a iof:PlanSpecification ;
    iof:prescribes :VE_req1_c0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1e+01 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :Diameter_10mm .

:VE_req2_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 20.0 ;
    qudt:unit qudtu:Degrees ;
    iof:isValueExpressionOfAtSomeTime :AntiSubmarineBeltSideViewAngle .

:VE_req3_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 20.0 ;
    qudt:unit qudtu:Degrees ;
    iof:isValueExpressionOfAtSomeTime :AntiSubmarineBeltSideViewAngle .

:VE_req4_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 20.0 ;
    qudt:unit qudtu:Degrees ;
    iof:isValueExpressionOfAtSomeTime :AntiSubmarineBeltSideViewAngle .

qudtqk:Angle a qudt:QuantityKind .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:AntiSubmarineBeltSideViewAngle a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c0,
        :VE_req3_c0,
        :VE_req4_c0 .

qudtu:Degrees a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Angle .

