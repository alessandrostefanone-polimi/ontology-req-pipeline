@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/415#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Each spring must be capable of returning the pedal to $0 \\%$ Pedal Travel with the other disconnected" ;
    iof:requirementSatisfiedBy :DS_req0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 0e+00 ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:NUM .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :P_req0 .

:P_req0 a iof:PlanSpecification ;
    iof:hasInput :DisconnectionState_0 ;
    iof:prescribes :PedalTravel_0 .

:PedalTravel_0 a iof:MaterialProduct ;
    iof:hasValueExpressionAtAllTimes :VE_req0_0 .

:VE_req0_0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 0e+00 ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:PERCENT .

:VE_req0_1 a iof:ValueExpression ;
    iof:hasSimpleExpressionValue "disconnected"^^xsd:string ;
    iof:isValueExpressionOfAtSomeTime :DisconnectionState_0 .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DutyCycle .

qudtu:PERCENT a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DutyCycle .

:DisconnectionState_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_1 .

qudtqk:DutyCycle a qudt:QuantityKind .

