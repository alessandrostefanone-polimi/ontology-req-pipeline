@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/281#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Standard Honeycomb must be mounted 200mm width x 100mm height c" ;
    iof:requirementSatisfiedBy :DS_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Plan_0 .

:Height_0 a iof:MaterialComponent ;
    iof:hasRole iof:MaterialComponentRole ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :Honeycomb_0 .

:Width_0 a iof:MaterialComponent ;
    iof:hasRole iof:MaterialComponentRole ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Honeycomb_0 a iof:MaterialArtifact ;
    iof:hasComponentPartAtAllTimes :Height_0,
        :Width_0 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:maxInclusive 2e+02 ;
    qudt:minInclusive 2e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Honeycomb_0 .

