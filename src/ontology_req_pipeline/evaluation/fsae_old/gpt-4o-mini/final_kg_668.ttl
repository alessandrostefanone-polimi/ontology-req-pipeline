@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/668#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "From a point 1.6 m vertically from ground level, inside a 3 m horizontal radius from the TSAL c. In direct sunlight # EV.5.10 Connectors Tractive System connectors outside of a housing must meet one of the two: - Contain an Interlock EV.7.8 which must Open the Shutdown Circuit EV.7.2.2 - Be sealed at Tech Inspection IN.4.7.1 ## EV" ;
    iof:requirementSatisfiedBy :Spec_0 .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "an Interlock EV.7.8 must Open the Shutdown Circuit EV.7.2.2" ;
    iof:requirementSatisfiedBy :Spec_1 .

:Req_2 a iof:RequirementSpecification ;
    rdfs:comment "Be sealed at Tech Inspection IN.4.7.1" ;
    iof:requirementSatisfiedBy :Spec_2 .

:Shutdown_Circuit_EV_7_2_2 a iof:MaterialEntity ;
    rdfs:label "Shutdown Circuit EV.7.2.2" .

:Tech_Inspection_IN_4_7_1 a iof:Process ;
    rdfs:label "Tech Inspection IN.4.7.1" .

:Action_0 a iof:ActionSpecification ;
    iof:prescribes :Feature_0 .

:Action_1 a iof:ActionSpecification ;
    iof:prescribes :Feature_1 .

:Action_2 a iof:ActionSpecification ;
    iof:prescribes :Sealed .

:Feature_0 a iof:MaterialEntity ;
    iof:hasFeature :Interlock_EV_7_8 .

:Feature_1 a iof:MaterialEntity ;
    iof:hasFeature :Interlock_EV_7_8 .

:Objective_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Output_0 .

:Objective_1 a iof:ObjectiveSpecification ;
    iof:prescribes :Output_1 .

:Output_2 a iof:MaterialProduct ;
    iof:hasOutput :Output_2 .

:Sealed a iof:MaterialEntity ;
    rdfs:label "sealed" ;
    iof:hasFeature :Sealed_Feature .

:Sealed_Feature a iof:MaterialEntity ;
    rdfs:label "sealed" .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :Action_0,
        :Objective_0 .

:Spec_1 a iof:PlanSpecification ;
    iof:prescribes :Action_1,
        :Objective_1 .

:Spec_2 a iof:PlanSpecification ;
    iof:prescribes :Action_2 .

:Interlock_EV_7_8 a iof:MaterialEntity ;
    rdfs:label "Interlock EV.7.8" .

:Output_0 a iof:MaterialProduct ;
    iof:hasOutput :Output_0 .

:Output_1 a iof:MaterialProduct ;
    iof:hasOutput :Output_1 .

