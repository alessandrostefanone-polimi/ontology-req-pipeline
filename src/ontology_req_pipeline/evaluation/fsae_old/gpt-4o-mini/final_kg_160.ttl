@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/160#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Chassis a iof:MaterialArtifact ;
    iof:hasComponentPartAtAllTimes :Front_Hoop,
        :Main_Hoop .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Document the adhesive choice, age and expiration date, substrate preparation, and the equivalency of the bonded joint in the SES F.5.5.3 The SES will reduce any referenced or tested adhesive values by $50 \\%$ ## F.5.6 Roll Hoops F.5.6.1 The Chassis must include both a Main Hoop and a Front Hoop. F.5.6.2" ;
    iof:requirementSatisfiedBy :Spec_1 .

:Front_Hoop a iof:MaterialComponent ;
    iof:hasRole :Front_Hoop_Role .

:Front_Hoop_Role a iof:MaterialComponentRole ;
    rdfs:label "Front Hoop" .

:Main_Hoop a iof:MaterialComponent ;
    iof:hasRole :Main_Hoop_Role .

:Main_Hoop_Role a iof:MaterialComponentRole ;
    rdfs:label "Main Hoop" .

:Process_1 a iof:ManufacturingProcess ;
    iof:hasInput :adhesive_values ;
    iof:hasSpecifiedOutput :adhesive_values .

:Spec_1 a iof:PlanSpecification ;
    iof:prescribes :Process_1 .

qudtqk:ServiceFactor a qudt:QuantityKind .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:ServiceFactor .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 5e-01 ;
    qudt:unit qudtu:NUM ;
    iof:isValueExpressionOfAtSomeTime :adhesive_values .

:adhesive_values a iof:ValueExpression ;
    iof:hasValueExpressionAtAllTimes :VE_req1_c0 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

