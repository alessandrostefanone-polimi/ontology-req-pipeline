@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/164#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A circle of diameter 200 mm will represent the shoulder/cervical region" ;
    iof:requirementSatisfiedBy :DS_req0 .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :Circle_0 .

:DiameterRole a iof:MaterialComponentRole ;
    rdfs:label "diameter role" .

:VE_req0_c0 a qudt:QuantityValue,
        iof:MeasuredValueExpression,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:maxInclusive 2e+02 ;
    qudt:minInclusive 2e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Circle_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:Circle_0 a iof:MaterialArtifact,
        iof:MaterialComponent ;
    iof:hasQuality :VE_req0_c0 ;
    iof:hasRole :DiameterRole .

