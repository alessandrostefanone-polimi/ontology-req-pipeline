@prefix : <http://example.org/req/488#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The name must be in Roman characters minimum 50 mm high on both sides of the vehicle" ;
    iof:requirementSatisfiedBy :DS_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Plan_0 .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :VE_req0_c1 .

:name_height a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:name_role a iof:AgentRole ;
    iof:roleOf :the_name .

:the_name a iof:MaterialArtifact ;
    iof:hasRole :name_role .

qudtqk:Height a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 5e+01 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtAllTimes :name_height .

