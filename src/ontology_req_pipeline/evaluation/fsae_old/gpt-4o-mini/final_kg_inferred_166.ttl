@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/166#> a owl:Ontology .

<http://example.org/req/166#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "A straight line measuring 490 mm will connect the centers of the two 200 mm circles" ;
    ns2:requirementSatisfiedBy <http://example.org/req/166#DS_req0> .

<http://example.org/req/166#DS_req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DesignSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/166#P_req0> .

<http://example.org/req/166#P_req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/166#circle_diameter>,
        <http://example.org/req/166#line_length> .

<http://example.org/req/166#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 4.9e+02 ;
    ns1:minInclusive 4.9e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/MilliM> .

<http://example.org/req/166#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxInclusive 2e+02 ;
    ns1:minInclusive 2e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/MilliM> .

<http://example.org/req/166#circle_diameter> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/166#VE_req0_c1> .

<http://example.org/req/166#line_length> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/166#VE_req0_c0> .

<http://qudt.org/vocab/unit/MilliM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

