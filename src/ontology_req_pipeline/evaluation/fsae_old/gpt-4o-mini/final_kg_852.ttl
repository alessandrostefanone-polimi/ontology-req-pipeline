@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/852#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Late Submission Penalties for Late Submission of Cost Report will be imposed as given in section DR Document Requirements. ### 5.3.7 Cost Addendum 5.3.7.1 A supplement to the Cost Report that reflects any changes or corrections made after the submission of the Cost Report may be submitted" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:SubmissionModality a iof:ProcessCharacteristic ;
    rdfs:label "may be submitted" .

:SubmissionProcess a iof:PlannedProcess ;
    iof:hasSpecifiedOutput :CostReportSupplement .

:SubmissionTiming a iof:ProcessCharacteristic ;
    rdfs:label "after the submission of the Cost Report" .

:SupplementToCostReport a iof:MaterialArtifact ;
    iof:hasRole :CostReportSupplementRole .

:CostReportRole a iof:SupplierRole ;
    rdfs:label "Cost Report Role" .

:CostReportSupplement a iof:MaterialArtifact ;
    iof:hasRole :CostReportRole .

:CostReportSupplementRole a iof:SupplierRole ;
    rdfs:label "Cost Report Supplement Role" .

:DesignSpec_0 a iof:PlanSpecification ;
    iof:prescribes :PenaltyImpositionProcess .

:LateSubmissionPenalties a iof:MaterialArtifact ;
    iof:hasRole :LateSubmissionPenaltyRole .

:LateSubmissionPenaltyRole a iof:SupplierRole ;
    rdfs:label "Late Submission Penalty Role" .

:PenaltyImpositionProcess a iof:PlannedProcess ;
    iof:hasSpecifiedOutput :LateSubmissionPenalties .

