@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/698#> a owl:Ontology .

<http://example.org/req/698#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "If conductor ampacity is reduced below the ampacity of the upstream Overcurrent Protection, the reduced conductor longer than 150 mm must have additional Overcurrent Protection" ;
    ns2:requirementSatisfiedBy <http://example.org/req/698#DS_req0> .

<http://example.org/req/698#DS_req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/698#OP_req0>,
        <http://example.org/req/698#VE_req0_c0> .

<http://example.org/req/698#OP_req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/698#Overcurrent_Protection> .

<http://example.org/req/698#Overcurrent_Protection> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialEntity ;
    rdfs:label "additional Overcurrent Protection" .

<http://example.org/req/698#length_quality> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/698#VE_req0_c0> .

<http://example.org/req/698#reduced_conductor> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact ;
    ns2:hasQuality <http://example.org/req/698#length_quality> .

<http://qudt.org/vocab/unit/MilliM> ns1:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

<http://example.org/req/698#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:hasUnit ns1:MilliM ;
    ns1:minExclusive 1.5e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/698#reduced_conductor> .

