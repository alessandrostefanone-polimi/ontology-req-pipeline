@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/333#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If used, the mounts or plate must be 25 mm or more larger at both the top and bottom of the upper and lower tubes F.11.2.3 All Non Crushable Items should have a minimum 25 mm clearance to the surface of the Accumulator Container" ;
    iof:requirementSatisfiedBy :DS_req0 .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "All Non Crushable Items should have a minimum 25 mm clearance to the surface of the Accumulator Container." ;
    iof:requirementSatisfiedBy :DS_req1 .

:All_Non_Crushable_Items a iof:MaterialArtifact .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :VE_req0_c0 .

:DS_req1 a iof:DesignSpecification ;
    iof:prescribes :VE_req1_c0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :the_mounts_or_plate .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :All_Non_Crushable_Items .

:the_mounts_or_plate a iof:MaterialArtifact .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

