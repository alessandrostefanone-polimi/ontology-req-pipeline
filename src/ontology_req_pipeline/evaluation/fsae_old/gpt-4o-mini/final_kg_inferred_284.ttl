        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/284#AntiIntrusionPlate_0> .

<http://example.org/req/284#DesignSpec_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
