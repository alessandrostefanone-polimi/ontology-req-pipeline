<http://example.org/req/284#> a owl:Ontology .

<http://example.org/req/284#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "The attachment points for the front wing and bodywork mounts should be aft of the Anti Intrusion Plate." ;
    ns2:requirementSatisfiedBy <http://example.org/req/284#DesignSpec_0> .

<http://example.org/req/284#Req_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "Tabs for wing and bodywork attachment must not extend more than 25 mm forward of the Anti Intrusion Plate." ;
    ns2:requirementSatisfiedBy <http://example.org/req/284#DesignSpec_1> .

<http://example.org/req/284#Req_2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "Pedal assembly at full travel and adjustment must have a minimum 25 mm clearance to the rear face of the Anti Intrusion Plate." ;
    ns2:requirementSatisfiedBy <http://example.org/req/284#DesignSpec_2> .

<http://example.org/req/284#AntiIntrusionPlate_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
