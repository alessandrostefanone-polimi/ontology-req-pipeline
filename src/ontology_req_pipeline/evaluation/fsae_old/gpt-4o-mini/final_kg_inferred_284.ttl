        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialEntity ;
    rdfs:label "Anti Intrusion Plate" .

<http://example.org/req/284#AntiIntrusionPlate_2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        owl:NamedIndividual,
        owl:Thing,
