@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/req/647#> a owl:Ontology .

<http://example.org/req/647#Accumulator> a owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialEntity .

<http://example.org/req/647#Dummy_Connector> a owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialEntity .

<http://example.org/req/647#HVD> a owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialEntity .

<http://example.org/req/647#Precharge_Circuit> a owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialEntity .

<http://example.org/req/647#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Clearly marked with \"HVD\" EV.5.5.2 An Interlock EV.7.8 must Open the Shutdown Circuit EV.7.2.2 when the HVD is removed EV.5.5.3 A dummy connector or similar may be used to restore isolation to meet EV.6.1.2 # EV.5.6 Precharge and Discharge Circuits EV.5.6.1 The Accumulator must contain a Precharge Circuit" ;
    ns1:requirementSatisfiedBy <http://example.org/req/647#Interlock_EV7_8> .

<http://example.org/req/647#Interlock_EV7_8> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/647#Open_Shutdown_Circuit_EV7_2_2> .

<http://example.org/req/647#Open_Shutdown_Circuit_EV7_2_2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/647#Shutdown_Circuit_EV7_2_2> .

<http://example.org/req/647#Shutdown_Circuit_EV7_2_2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialEntity .

