@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/284#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The attachment points for the front wing and bodywork mounts should be aft of the Anti Intrusion Plate." ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "Tabs for wing and bodywork attachment must not extend more than 25 mm forward of the Anti Intrusion Plate." ;
    iof:requirementSatisfiedBy :DesignSpec_1 .

:Req_2 a iof:RequirementSpecification ;
    rdfs:comment "Pedal assembly at full travel and adjustment must have a minimum 25 mm clearance to the rear face of the Anti Intrusion Plate." ;
    iof:requirementSatisfiedBy :DesignSpec_2 .

:AntiIntrusionPlate_0 a iof:MaterialEntity ;
    rdfs:label "Anti Intrusion Plate" .

:AntiIntrusionPlate_1 a iof:MaterialEntity ;
    rdfs:label "Anti Intrusion Plate" .

:AntiIntrusionPlate_2 a iof:MaterialEntity ;
    rdfs:label "Anti Intrusion Plate" .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :AntiIntrusionPlate_0 .

:DesignSpec_1 a iof:DesignSpecification ;
    iof:prescribes :AntiIntrusionPlate_1 .

:DesignSpec_2 a iof:DesignSpecification ;
    iof:prescribes :AntiIntrusionPlate_2 .

:PedalAssembly_0 a iof:MaterialEntity ;
    rdfs:label "Pedal assembly" ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c0 .

:Tabs_0 a iof:MaterialEntity ;
    rdfs:label "Tabs for wing and bodywork attachment" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:maxInclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Tabs_0 .

:VE_req2_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :PedalAssembly_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

