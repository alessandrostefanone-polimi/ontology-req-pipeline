@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/89#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.1.4 Fasteners in the Suspension system are Critical Fasteners, see T.8.2 V.3.1.5 All spherical rod ends and spherical bearings on the suspension and steering must be one of: - Mounted in double shear - Captured by having a screw/bolt head or washer with an outside diameter that is larger than spherical bearing housing inside diameter. ## V.3.2 Steering V.3.2.1 The Steering Wheel must be mechanically connected to the front wheels" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:Req_1 a iof:RequirementSpecification ;
    iof:requirementSatisfiedBy :DesignSpec_1 .

:Req_2 a iof:RequirementSpecification ;
    iof:requirementSatisfiedBy :DesignSpec_2 .

:SteeringWheel a iof:MaterialEntity ;
    iof:hasRole :steeringWheelRole .

:frontWheels a iof:MaterialEntity ;
    iof:hasRole :frontWheelsRole .

:screwBoltHeadOrWasher a iof:MaterialEntity ;
    iof:hasRole :screwBoltHeadOrWasherRole .

:sphericalRodEndsAndSphericalBearings a iof:MaterialEntity ;
    iof:hasRole :sphericalRodEndsAndSphericalBearingsRole .

:ActionSpec_0 a iof:ActionSpecification .

:ActionSpec_1 a iof:ActionSpecification .

:ActionSpec_2 a iof:ActionSpecification .

:ActionSpec_3 a iof:ActionSpecification .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :ActionSpec_0,
        :ActionSpec_1 .

:DesignSpec_1 a iof:DesignSpecification ;
    iof:prescribes :ActionSpec_2 .

:DesignSpec_2 a iof:DesignSpecification ;
    iof:prescribes :ActionSpec_3 .

:frontWheelsRole a iof:AgentRole ;
    rdfs:label "front wheels role" .

:screwBoltHeadOrWasherRole a iof:AgentRole ;
    rdfs:label "screw/bolt head or washer role" .

:sphericalRodEndsAndSphericalBearingsRole a iof:AgentRole ;
    rdfs:label "spherical rod ends and spherical bearings role" .

:steeringWheelRole a iof:AgentRole ;
    rdfs:label "steering wheel role" .

