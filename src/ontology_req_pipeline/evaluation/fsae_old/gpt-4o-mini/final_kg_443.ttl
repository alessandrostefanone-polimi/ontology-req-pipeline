@prefix : <http://example.org/req/443#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Motor_Case_Perforation a iof:Process ;
    iof:hasOutput :Motor_Case .

:Motor_Casing_Rotation a iof:Process ;
    iof:hasOutput :Motor_Casing .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Minimum thickness for steel: 2.0 mm T.5.3.2 A Scatter Shield must be included around the Motor(s) when one or both: - The motor casing rotates around the stator - The motor case is perforated T.5.3.3" ;
    iof:requirementSatisfiedBy :DS_req0 .

:Scatter_Shield a iof:MaterialEntity ;
    iof:hasRole :Scatter_Shield_Role .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :VE_req0_c0 .

:Motor_Case a iof:MaterialEntity ;
    iof:hasRole :Motor_Case_Role .

:Motor_Case_Role a iof:AgentRole ;
    rdfs:label "Motor Case Role" .

:Motor_Casing a iof:MaterialEntity ;
    iof:hasRole :Motor_Casing_Role .

:Motor_Casing_Role a iof:AgentRole ;
    rdfs:label "Motor Casing Role" .

:Scatter_Shield_Role a iof:AgentRole ;
    rdfs:label "Scatter Shield Role" .

:Thickness_Quality a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:Thickness_Steel a bfo:BFO_0000001 ;
    iof:hasQuality :Thickness_Quality .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Thickness_Steel .

