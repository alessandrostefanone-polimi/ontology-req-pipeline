@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/136#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:MaterialLocationChangeProcess_1 a iof:MaterialLocationChangeProcess ;
    iof:hasInput :MaterialEntity_1 ;
    iof:hasSpecifiedOutput :MaterialEntity_2 ;
    iof:prescribedBy :DS_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The fixture must support the entire sample, except for a 32 mm hole aligned coaxially with the punch" ;
    iof:requirementSatisfiedBy :DS_0 .

:Feature_1 a iof:Quality ;
    iof:hasQuality "the entire sample" .

:Feature_2 a iof:Quality ;
    iof:hasQuality "32 mm hole aligned coaxially with the punch" .

:MaterialComponentRole_1 a iof:MaterialComponentRole ;
    iof:prescribedBy :DS_0 .

:MaterialComponentRole_2 a iof:MaterialComponentRole ;
    iof:prescribedBy :DS_0 .

:P_0 a iof:PlanSpecification ;
    iof:prescribes :MaterialEntity_1,
        :MaterialEntity_2 .

:MaterialEntity_1 a iof:MaterialComponent,
        iof:MaterialEntity ;
    iof:hasFeature :Feature_1 ;
    iof:hasRole :MaterialComponentRole_1 .

:MaterialEntity_2 a iof:MaterialComponent,
        iof:MaterialEntity ;
    iof:hasFeature :Feature_2 ;
    iof:hasRole :MaterialComponentRole_2 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :P_0 .

