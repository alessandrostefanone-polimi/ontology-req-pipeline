@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/452#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any catch can on the cooling system must vent through a hose with a minimum internal diameter of 3 mm down to the bottom levels of the Chassis. ## T. 6 PRESSURIZED SYSTEMS ##" ;
    iof:requirementSatisfiedBy :DS_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Plan_0 .

:HoseRole_0 a iof:MaterialComponentRole ;
    rdfs:label "hose role" .

:Hose_0 a iof:MaterialComponent ;
    iof:hasRole :HoseRole_0 .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :VE_req0_c0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:minInclusive 3e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :Hose_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

