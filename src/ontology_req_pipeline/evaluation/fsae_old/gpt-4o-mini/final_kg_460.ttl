@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/460#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The shields must be steel or aluminum with a minimum thickness of 1 mm" ;
    iof:requirementSatisfiedBy :Spec_0 .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "The shields must be steel or aluminum with a minimum thickness of 1 mm" ;
    iof:requirementSatisfiedBy :Spec_1 .

:Req_2 a iof:RequirementSpecification ;
    rdfs:comment "The shields must be steel or aluminum with a minimum thickness of 1 mm" ;
    iof:requirementSatisfiedBy :Spec_2 .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :Output_0 .

:Spec_1 a iof:PlanSpecification ;
    iof:prescribes :Output_1 .

:Spec_2 a iof:PlanSpecification ;
    iof:prescribes :Output_2 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:minInclusive 1e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Output_0 .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:minInclusive 1e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Output_1 .

:VE_req2_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:minInclusive 1e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Output_2 .

qudtqk:Thickness a qudt:QuantityKind .

:Output_0 a iof:MaterialProduct ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:Output_1 a iof:MaterialProduct ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 .

:Output_2 a iof:MaterialProduct ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c1 .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

