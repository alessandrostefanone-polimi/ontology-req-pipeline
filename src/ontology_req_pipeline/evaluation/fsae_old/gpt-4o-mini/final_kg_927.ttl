@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/927#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "10.1.3 Course Operation a. Vehicles will enter and exit through gates on a 3.0 m wide path that is tangential to the circles where they meet" ;
    iof:requirementSatisfiedBy :DS_req0 .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "10.1.3 Course Operation a. Vehicles will enter and exit through gates on a 3.0 m wide path that is tangential to the circles where they meet" ;
    iof:requirementSatisfiedBy :DS_req1 .

:Action_spec0 a iof:ActionSpecification ;
    iof:prescribes :gates .

:Action_spec1 a iof:ActionSpecification ;
    iof:prescribes :gates .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :Plan_req0 .

:DS_req1 a iof:DesignSpecification ;
    iof:prescribes :Plan_req1 .

:Objective_spec0 a iof:ObjectiveSpecification ;
    iof:prescribes :path_width_3m .

:Objective_spec1 a iof:ObjectiveSpecification ;
    iof:prescribes :width_of_path_3m .

:Plan_req0 a iof:PlanSpecification ;
    iof:prescribes :Action_spec0,
        :Objective_spec0 .

:Plan_req1 a iof:PlanSpecification ;
    iof:prescribes :Action_spec1,
        :Objective_spec1 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3e+00 ;
    qudt:minInclusive 3e+00 ;
    qudt:unit qudtu:M .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3e+00 ;
    qudt:minInclusive 3e+00 ;
    qudt:unit qudtu:M .

:path_width_3m a iof:MaterialArtifact ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 .

:width_of_path_3m a iof:MaterialArtifact ;
    iof:hasValueExpressionAtAllTimes :VE_req1_c0 .

qudtqk:Breadth a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Breadth .

