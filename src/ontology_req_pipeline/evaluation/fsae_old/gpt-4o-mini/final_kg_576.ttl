@prefix : <http://example.org/req/576#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The gas can is minimum 25 cm wide × 25 cm deep × 35 cm high, with a 25 cm spout at the top IC.5.4.8 The filler neck must have a fuel cap that can withstand severe vibrations or high pressures such as could occur during a vehicle rollover event # IC.5.5 Fuel Tank Filling IC.5.5.1 Fueling / Refueling policies and procedures are at the discretion of the fuel crew and officials" ;
    iof:requirementSatisfiedBy :DS_req0 .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :P_req0 .

:P_req0 a iof:PlanSpecification ;
    iof:prescribes :VE_req0_c0 .

:Quality_dimensions a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

qudtqk:MigrationLength a qudt:QuantityKind .

qudtu:CentiM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:MigrationLength .

:The_gas_can a iof:MaterialArtifact ;
    iof:hasQuality :Quality_dimensions .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:CentiM ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:CentiM ;
    iof:isValueExpressionOfAtAllTimes :The_gas_can ;
    iof:isValueExpressionOfAtSomeTime :The_gas_can .

