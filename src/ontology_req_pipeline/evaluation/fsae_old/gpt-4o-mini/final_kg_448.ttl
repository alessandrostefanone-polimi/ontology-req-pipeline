@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/448#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "5.5.3 Flammable liquid and vapors or other leaks must not collect or contact the driver T.5.5.4 Two holes of minimum diameter 25 mm each must be provided in the structure or belly pan at the locations: a" ;
    iof:requirementSatisfiedBy :DS_1 .

:DS_1 a iof:DesignSpecification ;
    iof:prescribes :Holes_1 .

:HoleRole_1 a iof:MaterialComponentRole ;
    rdfs:label "hole role" .

:HoleRole_2 a iof:MaterialComponentRole ;
    rdfs:label "hole role" .

:Holes_1 a iof:MaterialArtifact ;
    iof:hasComponentPartAtAllTimes :Hole_1,
        :Hole_2 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:Hole_1 a iof:MaterialComponent ;
    iof:hasRole :HoleRole_1 ;
    iof:hasValueExpressionAtAllTimes :VE_req1_c0 .

:Hole_2 a iof:MaterialComponent ;
    iof:hasRole :HoleRole_2 ;
    iof:hasValueExpressionAtAllTimes :VE_req1_c0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue 25.0 ;
    qudt:minInclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Hole_1,
        :Hole_2 .

