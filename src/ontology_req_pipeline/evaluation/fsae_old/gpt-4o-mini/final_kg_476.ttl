@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/476#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Any voltage more than 60 V DC or 25 V AC RMS T.9.1.2 Low Voltage - LV Any voltage less than and including 60 V DC or 25 V AC RMS T.9.1.3 Normally Open A type of electrical relay or contactor that allows current flow only in the energized state ## T.9.2 Low Voltage Batteries T.9.2.1 All Low Voltage Batteries and onboard power supplies must be securely mounted inside the Chassis below the height of the Shoulder Belt Mount T.2.6 T.9.2.2 All Low Voltage batteries must have Overcurrent Protection that trips at or below the maximum specified discharge current of the cells T.9.2.3 The hot (ungrounded) terminal must be insulated" ;
    iof:requirementSatisfiedBy :Spec_0 .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "Any voltage less than and including 60 V DC or 25 V AC RMS." ;
    iof:requirementSatisfiedBy :Spec_1 .

:Req_2 a iof:RequirementSpecification ;
    rdfs:comment "All Low Voltage Batteries and onboard power supplies must be securely mounted inside the Chassis below the height of the Shoulder Belt Mount." ;
    iof:requirementSatisfiedBy :Spec_2 .

:Req_3 a iof:RequirementSpecification ;
    rdfs:comment "All Low Voltage batteries must have Overcurrent Protection that trips at or below the maximum specified discharge current of the cells." ;
    iof:requirementSatisfiedBy :Spec_3 .

:Req_4 a iof:RequirementSpecification ;
    rdfs:comment "The hot (ungrounded) terminal must be insulated." ;
    iof:requirementSatisfiedBy :Spec_4 .

:Output_2 a iof:MaterialProduct .

:Output_3 a iof:MaterialProduct .

:Output_4 a iof:MaterialProduct .

:Process_0 a iof:ManufacturingProcess ;
    iof:hasSpecifiedOutput :Output_0 .

:Process_1 a iof:ManufacturingProcess ;
    iof:hasSpecifiedOutput :Output_1 .

:Process_2 a iof:ManufacturingProcess ;
    iof:hasSpecifiedOutput :Output_2 .

:Process_3 a iof:ManufacturingProcess ;
    iof:hasSpecifiedOutput :Output_3 .

:Process_4 a iof:ManufacturingProcess ;
    iof:hasSpecifiedOutput :Output_4 .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :Process_0 .

:Spec_1 a iof:PlanSpecification ;
    iof:prescribes :Process_1 .

:Spec_2 a iof:PlanSpecification ;
    iof:prescribes :Process_2 .

:Spec_3 a iof:PlanSpecification ;
    iof:prescribes :Process_3 .

:Spec_4 a iof:PlanSpecification ;
    iof:prescribes :Process_4 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 6e+01 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtSomeTime :Output_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 2.5e+01 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtSomeTime :Output_0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 6e+01 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtSomeTime :Output_1 .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.5e+01 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtSomeTime :Output_1 .

qudtqk:Voltage a qudt:QuantityKind .

:Output_0 a iof:MaterialProduct ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0,
        :VE_req0_c1 .

:Output_1 a iof:MaterialProduct ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0,
        :VE_req1_c1 .

qudtu:V a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Voltage .

