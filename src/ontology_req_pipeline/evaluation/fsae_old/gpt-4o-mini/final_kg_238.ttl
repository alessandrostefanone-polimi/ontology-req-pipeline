@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/238#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "7.6 Main Hoop Attachment F.7.6.1 The Main Hoop must be mechanically attached to the monocoque a. Main Hoop mounting plates must be 2.0 mm minimum thickness steel b" ;
    iof:requirementSatisfiedBy :DS_1 .

:DS_1 a iof:PlanSpecification ;
    iof:prescribes :MP_1 .

:MPM_1 a iof:MaterialProduct ;
    iof:hasRole :MPM_Role_1 .

:MPM_Role_0 a iof:MaterialProductRole ;
    rdfs:label "Main Hoop mounting plates" .

:MPM_Role_1 a iof:MaterialProductRole ;
    rdfs:label "2.0 mm minimum thickness steel" .

:MP_1 a iof:ManufacturingProcess ;
    iof:hasInput :MPM_0 ;
    iof:hasSpecifiedOutput :MPM_1 .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:hasValueExpressionAtAllTimes :VE_req1_c1 ;
    iof:isValueExpressionOfAtAllTimes :MPM_0 ;
    iof:isValueExpressionOfAtSomeTime :MPM_0 .

:MPM_0 a iof:MaterialProduct ;
    iof:hasRole :MPM_Role_0 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 .

