@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/279#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A Custom Impact Attenuator must mount with an area of 200 mm or more long and 200 mm or more wide that intersects a plane parallel to the ground that is no more than 220 mm above the lowest point on the top of the Lower Side Impact Structure F.8.5.7 Impact Attenuator Orientation a" ;
    iof:requirementSatisfiedBy :Spec_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Area_0 ;
    iof:isValueExpressionOfAtSomeTime :Area_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Area_0 ;
    iof:isValueExpressionOfAtSomeTime :Area_0 .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.2e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Plane_0 ;
    iof:isValueExpressionOfAtSomeTime :Plane_0 .

:Action_0 a iof:ActionSpecification ;
    iof:prescribes :Area_0 .

:Height_0 a iof:ValueExpression ;
    iof:isValueExpressionOfAtAllTimes :Plane_0 ;
    iof:isValueExpressionOfAtSomeTime :Plane_0 .

:Length_0 a iof:ValueExpression ;
    iof:isValueExpressionOfAtAllTimes :Area_0 ;
    iof:isValueExpressionOfAtSomeTime :Area_0 .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :Action_0,
        :Area_0 .

:Width_0 a iof:ValueExpression ;
    iof:isValueExpressionOfAtAllTimes :Area_0 ;
    iof:isValueExpressionOfAtSomeTime :Area_0 .

qudtqk:Breadth a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Breadth,
        qudtqk:Length .

:Plane_0 a iof:MaterialArtifact ;
    iof:hasComponentPartAtAllTimes :Height_0 .

:Area_0 a iof:MaterialArtifact ;
    iof:hasComponentPartAtAllTimes :Length_0,
        :Width_0 .

