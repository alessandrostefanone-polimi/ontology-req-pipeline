: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "This additional Overcurrent Protection must be: a. 150 mm or less from the source end of the reduced conductor" ;
    iof:requirementSatisfiedBy :DS_req0 .

:distance_from_source_end a iof:ProcessCharacteristic .

:DS_req0 a iof:DesignSpecification .

