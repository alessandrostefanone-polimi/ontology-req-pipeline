@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/730#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The temperature sensor used must be in direct contact with one of: - The negative terminal itself - The negative terminal busbar less than 10 mm away from the cell terminal EV.7.5.5 For lithium based cells, a" ;
    iof:requirementSatisfiedBy :Spec_1 .

:Input_1 a iof:MaterialComponent ;
    iof:hasRole :Role_1 .

:Input_2 a iof:MaterialComponent ;
    iof:hasRole :Role_2 .

:Obj_1 a iof:ObjectiveSpecification ;
    iof:hasContinuantPartAtAllTimes :Obj_2 .

:Output_1 a iof:MaterialProduct ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:Output_2 a iof:MaterialProduct ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c0 .

:Quality_1 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:Quality_2 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c0 .

:Role_1 a iof:MaterialComponentRole ;
    iof:roleOf :Obj_2 .

:Role_2 a iof:MaterialComponentRole ;
    iof:roleOf :Obj_3 .

:Spec_1 a iof:PlanSpecification ;
    iof:prescribes :Obj_1,
        :Obj_2 .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

:VE_req1_c0 a qudt:QuantityValue,
        iof:MeasuredValueExpression,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue 10.0 ;
    qudt:maxExclusive 1e+01 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtAllTimes :Obj_2 ;
    iof:isValueExpressionOfAtSomeTime :Obj_2 .

:VE_req2_c0 a iof:MeasuredValueExpression ;
    qudt:hasSimpleExpressionValue 10.0 ;
    iof:isValueExpressionOfAtAllTimes :Obj_3 ;
    iof:isValueExpressionOfAtSomeTime :Obj_3 .

:Obj_3 a iof:MaterialProduct ;
    iof:hasInput :Input_2 ;
    iof:hasOutput :Output_2 ;
    iof:hasQuality :Quality_2 ;
    iof:hasValueExpressionAtAllTimes :VE_req2_c0 .

:Obj_2 a iof:MaterialProduct,
        iof:ObjectiveSpecification ;
    iof:hasContinuantPartAtAllTimes :Obj_3 ;
    iof:hasInput :Input_1 ;
    iof:hasOutput :Output_1 ;
    iof:hasQuality :Quality_1 ;
    iof:hasValueExpressionAtAllTimes :VE_req1_c0 .

