@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/394#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Driver a iof:Agent ;
    rdfs:label "Driver" .

:Head_Restraint a iof:MaterialArtifact ;
    iof:hasRole :Head_Restraint_Role .

:Head_Restraint_Condition a iof:PlanSpecification ;
    iof:prescribes :Head_Restraint_Location_Adjustment .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Head Restraint Protection (if used) F.5.10 T.2.8.4 The Head Restraint, attachment and mounting must be strong enough to withstand a minimum force of: a. 900 N applied in a rearward direction b. 300 N applied in a lateral or vertical direction T.2.8.5 For all drivers, the Head Restraint must be located and adjusted where: a" ;
    iof:requirementSatisfiedBy :DS_req0 .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :Plan_req0 .

:Force_300_N a qudt:Force ;
    qudt:hasUnit qudt:N ;
    qudt:hasValue 300.0 .

:Force_900_N a qudt:Force ;
    qudt:hasUnit qudt:N ;
    qudt:hasValue 900.0 .

:Head_Restraint_Location_Adjustment a iof:ActionSpecification ;
    rdfs:comment "The Head Restraint must be located and adjusted where: a" .

:Head_Restraint_Role a iof:AgentRole ;
    rdfs:label "Head Restraint Role" .

:Plan_req0 a iof:PlanSpecification ;
    iof:prescribes :VE_req0_c0,
        :VE_req1_c0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 9e+02 ;
    qudt:unit qudtu:N ;
    iof:isValueExpressionOfAtAllTimes :Force_900_N .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3e+02 ;
    qudt:unit qudtu:N ;
    iof:isValueExpressionOfAtAllTimes :Force_300_N .

qudtqk:Force a qudt:QuantityKind .

qudtu:N a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Force .

