@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/318#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Attachment_1 a iof:MaterialComponent ;
    iof:hasRole :CornerAttachmentRole_0 .

:Attachment_2 a iof:MaterialComponent ;
    iof:hasRole :LoadBasedAnalysisRole_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Teams must justify the Accumulator Container attachment using one of the two methods: - Corner Attachments and Analysis per F.10.5.6 and F.10.5.8 - Load Based Analysis per F.10.5.7 and F.10.5.8 F.10.5.6 Accumulator Attachment - Corner Attachments a. Eight or more attachments are required for any configuration" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:ActionSpec_0 a iof:ActionSpecification ;
    iof:prescribes :Process_0 .

:AttachmentRole_0 a iof:MaterialComponentRole ;
    rdfs:label "attachment role" .

:Attachment_0 a iof:MaterialComponent ;
    iof:hasRole :AttachmentRole_0 .

:CornerAttachmentRole_0 a iof:MaterialComponentRole ;
    rdfs:label "Corner Attachments" .

:LoadBasedAnalysisRole_0 a iof:MaterialComponentRole ;
    rdfs:label "Load Based Analysis" .

:MaterialEntity_0 a iof:MaterialArtifact ;
    iof:hasComponentPartAtAllTimes :Attachment_0 .

:ObjectiveSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :MaterialEntity_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :ActionSpec_0,
        :ObjectiveSpec_0 .

