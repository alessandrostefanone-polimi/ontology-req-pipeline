@prefix : <http://example.org/req/611#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.3.2 The maximum permitted voltage that may occur between any two points must not exceed 600 V DC EV.3.3.3 The powertrain must not regenerate energy when vehicle speed is between 0 and $5 \\mathrm{~km} /" ;
    iof:requirementSatisfiedBy :DS_req0 .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "3.3.2 The maximum permitted voltage that may occur between any two points must not exceed 600 V DC EV.3.3.3 The powertrain must not regenerate energy when vehicle speed is between 0 and $5 \\mathrm{~km} /" ;
    iof:requirementSatisfiedBy :PS_req1 .

:energy_regeneration a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c2 .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :VE_req0_c0 .

:PS_req1 a iof:PlanSpecification ;
    iof:prescribes :VE_req1_c0 .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 5.0 ;
    qudt:minInclusive 0.0 ;
    qudt:unit qudtu:KiloM ;
    iof:isValueExpressionOfAtSomeTime :vehicle_speed_upper_bound .

:VE_req1_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtSomeTime :energy_regeneration_status .

:max_permitted_voltage a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

:vehicle_speed_lower_bound a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:vehicle_speed_upper_bound a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 .

qudtqk:PathLength a qudt:QuantityKind .

qudtqk:Voltage a qudt:QuantityKind .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 6e+02 ;
    qudt:unit qudtu:V ;
    iof:isValueExpressionOfAtAllTimes :max_permitted_voltage .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 5e+00 ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:KiloM ;
    iof:isValueExpressionOfAtSomeTime :vehicle_speed_lower_bound .

qudtu:KiloM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:PathLength .

qudtu:V a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Voltage .

