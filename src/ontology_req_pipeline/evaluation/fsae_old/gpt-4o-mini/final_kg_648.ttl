@prefix : <http://example.org/req/648#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The Precharge Circuit must: a. Be able to charge the Intermediate Circuit to minimum $90 \\%$ of the Accumulator voltage before closing the second AIR b" ;
    iof:requirementSatisfiedBy :DS_0 .

:AccumulatorVoltage a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Plan_0 .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :VE_req0_c1 .

qudtqk:StateOfCharge a qudt:QuantityKind .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:StateOfCharge .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudtu:NUM ;
    qudt:minInclusive 9e-01 ;
    qudt:unit qudtu:NUM ;
    iof:isValueExpressionOfAtAllTimes :AccumulatorVoltage .

