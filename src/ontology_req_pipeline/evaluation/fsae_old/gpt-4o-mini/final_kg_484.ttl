@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/484#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Must trigger due to a longitudinal impact load which decelerates the vehicle at between 8 g and 11 g depending on the duration of the deceleration (refer to spec sheet of the Sensata device)" ;
    iof:requirementSatisfiedBy :Spec_0 .

:Action_0 a iof:ActionSpecification ;
    iof:prescribes :Condition_0 .

:Condition_0 a iof:ObjectiveSpecification ;
    iof:hasProcessCharacteristic :Deceleration_0 .

:Output_0 a iof:InformationContentEntity ;
    iof:describes :Deceleration_0 .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :Action_0,
        :Output_0 .

qudtqk:AccelerationOfGravity a qudt:QuantityKind .

qudtu:M-PER-SEC2 a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:AccelerationOfGravity .

:VE_req0_c1 a qudt:QuantityValue,
        iof:MeasuredValueExpression,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue "78.4532"^^xsd:float ;
    qudt:maxInclusive 1.078731e+02 ;
    qudt:minInclusive 7.84532e+01 ;
    qudt:unit qudtu:M-PER-SEC2 ;
    iof:isValueExpressionOfAtAllTimes :Deceleration_0 .

:VE_req0_c2 a iof:MeasuredValueExpression ;
    qudt:hasSimpleExpressionValue "107.87315"^^xsd:float ;
    iof:isValueExpressionOfAtAllTimes :Deceleration_0 .

:Deceleration_0 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1,
        :VE_req0_c2 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1,
        :VE_req0_c2 .

