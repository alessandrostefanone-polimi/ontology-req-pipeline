@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/167#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A straight line measuring 280 mm will connect the centers of the upper 200 mm circle and the 300 mm head circle" ;
    iof:requirementSatisfiedBy :DS_req0 .

:Action_req0 a iof:ActionSpecification ;
    iof:prescribes :Connection_req0 .

:ConnectionRole a iof:MaterialComponentRole ;
    rdfs:label "connection role" .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :Plan_req0 .

:Objective_req0 a iof:ObjectiveSpecification ;
    iof:hasOutput :Connection_req0 .

:Plan_req0 a iof:PlanSpecification ;
    iof:prescribes :Action_req0,
        :Objective_req0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:MeasuredValueExpression,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:maxInclusive 2.8e+02 ;
    qudt:minInclusive 2.8e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Connection_req0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Connection_req0 a iof:MaterialComponent,
        iof:MaterialEntity ;
    rdfs:label "the centers of the upper 200 mm circle and the 300 mm head circle" ;
    iof:hasRole :ConnectionRole ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

