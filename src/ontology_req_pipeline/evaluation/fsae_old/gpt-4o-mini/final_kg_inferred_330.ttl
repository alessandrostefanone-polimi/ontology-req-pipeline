@prefix ns1: <http://qudt.org/schema/qudt/> .
@prefix ns2: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/330#> a owl:Ontology .

<http://example.org/req/330#AccumulatorContainer> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact ;
    ns2:hasRole <http://example.org/req/330#AccumulatorContainerRole> ;
    ns2:has_feature <http://example.org/req/330#EquivalentStructure> .

<http://example.org/req/330#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:RequirementSpecification ;
    rdfs:comment "Tractive System components other than Accumulator Containers in a position below 350 mm from the ground must be protected from side impact by structure that meets F.5.16 Component Protection F.11.2.2 Rear Impact Protection a. All Accumulator Containers must be protected from rear impact: - When the rear impact structure is 100 mm or less from an Accumulator Container, the structure must be Equivalent to Side Impact Structure (F.6.4, F.7.5) - When the rear impact structure is more than 100 mm from an Accumulator Container, the structure must meet F.5.16 Component Protection - The Accumulator Container must not be part of the Equivalent structure. b" ;
    ns2:requirementSatisfiedBy <http://example.org/req/330#Specification_0> .

<http://example.org/req/330#AccumulatorContainerRole> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000017>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        <http://purl.obolibrary.org/obo/BFO_0000023>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/330#EquivalentStructure> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact ;
    ns2:hasRole <http://example.org/req/330#EquivalentStructureRole> .

<http://example.org/req/330#EquivalentStructureRole> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000017>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        <http://purl.obolibrary.org/obo/BFO_0000023>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/330#ProtectionPlan_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ActionSpecification,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity ;
    ns2:prescribes <http://example.org/req/330#ProtectionFromSideImpact> .

<http://example.org/req/330#RearImpactDistance> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/330#VE_req2_c0> .

<http://example.org/req/330#RearImpactStructureDistance> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:ProcessCharacteristic ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/330#VE_req3_c0> .

<http://example.org/req/330#Specification_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:DirectiveInformationContentEntity,
        ns2:InformationContentEntity,
        ns2:PlanSpecification ;
    ns2:prescribes <http://example.org/req/330#ProtectionPlan_0> .

<http://example.org/req/330#TractiveSystemComponents> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns2:MaterialArtifact ;
    ns2:hasRole <http://example.org/req/330#TractiveSystemRole> ;
    ns2:has_feature <http://example.org/req/330#ProtectionFromSideImpact> .

<http://example.org/req/330#TractiveSystemRole> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000017>,
