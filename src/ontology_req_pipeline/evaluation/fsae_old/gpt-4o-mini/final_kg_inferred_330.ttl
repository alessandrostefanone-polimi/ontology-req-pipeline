    ns1:minExclusive 1e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/MM> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/330#RearImpactStructureDistance> .

<http://example.org/req/330#ProtectionFromSideImpact> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
