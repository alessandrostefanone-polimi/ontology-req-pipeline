<http://example.org/req/330#VE_req0_c1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
        ns2:ValueExpression ;
    ns1:maxExclusive 3.5e+02 ;
    ns1:unit <http://qudt.org/vocab/unit/MM> ;
    ns2:isValueExpressionOfAtAllTimes <http://example.org/req/330#TractiveSystemComponents> .

<http://example.org/req/330#VE_req2_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns1:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns2:InformationContentEntity,
