@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/647#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Accumulator a iof:MaterialEntity .

:Dummy_Connector a iof:MaterialEntity .

:HVD a iof:MaterialEntity .

:Precharge_Circuit a iof:MaterialEntity .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Clearly marked with \"HVD\" EV.5.5.2 An Interlock EV.7.8 must Open the Shutdown Circuit EV.7.2.2 when the HVD is removed EV.5.5.3 A dummy connector or similar may be used to restore isolation to meet EV.6.1.2 # EV.5.6 Precharge and Discharge Circuits EV.5.6.1 The Accumulator must contain a Precharge Circuit" ;
    iof:requirementSatisfiedBy :Interlock_EV7_8 .

:Interlock_EV7_8 a iof:PlanSpecification ;
    iof:prescribes :Open_Shutdown_Circuit_EV7_2_2 .

:Open_Shutdown_Circuit_EV7_2_2 a iof:ActionSpecification ;
    iof:prescribes :Shutdown_Circuit_EV7_2_2 .

:Shutdown_Circuit_EV7_2_2 a iof:MaterialEntity .

