@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/855#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.7.6 Changes to the Cost Report in the Cost Addendum will incur additional cost: a. Added items will be cost at $125 \\%$ of the table cost: + (1.25 x Cost) b" ;
    iof:requirementSatisfiedBy :DS_0 .

:AddedItems a iof:InformationContentEntity ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:AddedItemsCost a iof:InformationContentEntity ;
    iof:describes :AddedItems .

:ChangesToCostReport a iof:InformationContentEntity ;
    iof:describes :CostReport .

:CostReport a iof:InformationContentEntity ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :P_0 .

:P_0 a iof:PlanSpecification ;
    iof:prescribes :VE_req1_c0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.25e+00 ;
    qudt:unit qudtu:UNITLESS ;
    iof:isValueExpressionOfAtAllTimes :ChangesToCostReport .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtqk:ServiceFactor a qudt:QuantityKind .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:ServiceFactor .

qudtu:UNITLESS a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.25e-02 ;
    qudt:minInclusive 1.25e-02 ;
    qudt:unit qudtu:NUM ;
    iof:isValueExpressionOfAtSomeTime :AddedItemsCost .

