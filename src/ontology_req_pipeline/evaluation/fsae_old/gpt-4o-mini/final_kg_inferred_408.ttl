@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/408#> a owl:Ontology .

<http://example.org/req/408#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "3.3.3 Operation of the BOTS to the OFF position must Open the Shutdown Circuit IC.9.2.2 / EV.7.2.2 T.3.3.4 Repeated operation of the switch must not reset or restore power T.3.3.5" ;
    ns1:requirementSatisfiedBy <http://example.org/req/408#Spec_0> .

<http://example.org/req/408#Switch> a owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialEntity ;
    rdfs:label "the switch" .

<http://example.org/req/408#Action_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/408#Open_Shutdown_Circuit>,
        <http://example.org/req/408#Shutdown_Circuit_IC_9_2_2> .

<http://example.org/req/408#Action_1> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:ActionSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/408#Switch_Operation> .

<http://example.org/req/408#Open_Shutdown_Circuit> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:Process ;
    ns1:hasOutput <http://example.org/req/408#Shutdown_Circuit_IC_9_2_2> .

<http://example.org/req/408#Power_Reset> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:BooleanValueExpression,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns1:hasSimpleExpressionValue false .

<http://example.org/req/408#Spec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/408#Action_0>,
        <http://example.org/req/408#Action_1> .

<http://example.org/req/408#Switch_Operation> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000003>,
        <http://purl.obolibrary.org/obo/BFO_0000015>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:Process ;
    ns1:hasOutput <http://example.org/req/408#Power_Reset> .

<http://example.org/req/408#Shutdown_Circuit_IC_9_2_2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialEntity ;
    rdfs:label "the Shutdown Circuit IC.9.2.2" .

