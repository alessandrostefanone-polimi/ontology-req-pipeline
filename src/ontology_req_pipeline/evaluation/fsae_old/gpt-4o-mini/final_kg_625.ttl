@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/625#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:PedalTravelCondition a iof:ValueExpression ;
    iof:isValueExpressionOfAtSomeTime :APPSCondition .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "4.6 Brake System Encoder - BSE Refer to T.4.3 for specific requirements of the BSE ## EV.4.7 APPS / Brake Pedal Plausibility Check EV.4.7.1 Must monitor for the two conditions: - The mechanical brakes are engaged EV.4.6, T.3.2.4 - The APPS signals more than 25% Pedal Travel EV.4.5 EV.4.7.2 If the two conditions in EV.4.7.1 occur at the same time: a. Power to the Motor(s) must be immediately and completely shut down b" ;
    iof:requirementSatisfiedBy :Spec_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 2.5e-01 ;
    qudt:unit qudtu:NUM ;
    iof:hasValueExpressionAtSomeTime :APPSCondition .

:VE_req2_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 2.5e-01 ;
    qudt:unit qudtu:NUM ;
    iof:hasValueExpressionAtSomeTime :APPSCondition .

:Action_0 a iof:ActionSpecification ;
    iof:prescribes :Condition_0 .

:Condition_0 a iof:ActionSpecification ;
    iof:prescribes :MechanicalBrakesCondition .

:MechanicalBrakesCondition a iof:RequirementSpecification ;
    iof:satisfiesRequirement :MechanicalBrakesEngaged .

:MechanicalBrakesEngaged a iof:ValueExpression ;
    iof:hasSimpleExpressionValue true .

:Objective_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Output_0 .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :Action_0,
        :Objective_0,
        :Output_0 .

qudtqk:DutyCycle a qudt:QuantityKind .

:Output_0 a iof:ValueExpression ;
    iof:hasSimpleExpressionValue "Power to the Motor(s) must be immediately and completely shut down"^^xsd:string .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DutyCycle .

