@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/728#> a owl:Ontology .

<http://example.org/req/728#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "The voltage rating of the Overcurrent Protection must be equal to or higher than the maximum segment voltage EV.7.4.5 Overcurrent Protection is not required on a voltage sense wire if all three of the following conditions are met: - AMS is a distributed AMS system (one cell measurement per board) - $\\quad$ Sense wire length is less than 25 mm - AMS board has Overcurrent Protection # EV.7.5 Accumulator Temperature EV.7.5.1" ;
    ns1:requirementSatisfiedBy <http://example.org/req/728#Spec_0> .

<http://example.org/req/728#AMS> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000027>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:Agent,
        ns1:GroupOfAgents,
        ns1:Organization,
        ns1:OrganizedGroupOfAgents ;
    ns1:hasRole <http://example.org/req/728#AMSRole> .

<http://example.org/req/728#AMSRole> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000017>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        <http://purl.obolibrary.org/obo/BFO_0000023>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:AgentRole ;
    rdfs:label "distributed AMS system (one cell measurement per board)" .

<http://example.org/req/728#MaxSegmentVoltage> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/728#MaxSegmentVoltageEntity> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/728#VE_req1_c2> .

<http://example.org/req/728#OvercurrentProtection> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/728#MaxSegmentVoltage>,
        <http://example.org/req/728#OvercurrentProtectionRequirement>,
        <http://example.org/req/728#VoltageSenseWire> .

<http://example.org/req/728#OvercurrentProtectionRequirement> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    ns1:requirementSatisfiedBy <http://example.org/req/728#OvercurrentProtectionEntity> .

<http://example.org/req/728#SenseWireLengthEntity> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/728#VE_req1_c2> .

<http://example.org/req/728#Spec_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/728#OvercurrentProtection> .

<http://example.org/req/728#VE_req3_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxExclusive 2.5e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/MM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/728#AMS>,
        <http://example.org/req/728#VoltageSenseWireEntity> .

<http://example.org/req/728#VE_req4_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxExclusive 2.5e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/MM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/728#OvercurrentProtectionEntity> .

<http://example.org/req/728#VoltageSenseWire> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        owl:NamedIndividual,
        owl:Thing .

<http://example.org/req/728#VoltageSenseWireEntity> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/728#VE_req3_c0> .

<http://example.org/req/728#OvercurrentProtectionEntity> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/728#VE_req4_c0> .

<http://example.org/req/728#VE_req1_c2> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:maxExclusive 2.5e+01 ;
    ns2:unit <http://qudt.org/vocab/unit/MM> ;
    ns1:isValueExpressionOfAtSomeTime <http://example.org/req/728#MaxSegmentVoltageEntity>,
        <http://example.org/req/728#SenseWireLengthEntity> .

<http://qudt.org/vocab/unit/MM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Length> .

