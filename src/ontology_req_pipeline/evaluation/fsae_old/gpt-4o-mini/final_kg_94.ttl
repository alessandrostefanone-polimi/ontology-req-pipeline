@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/94#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Rear_Wheel_Steering_Requirement a iof:RequirementSpecification ;
    rdfs:comment "Rear wheel steering may be used." ;
    iof:requirementSatisfiedBy :Rear_Wheel_Steering_Design_Specification .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.2.8 Fasteners in the steering system are Critical Fasteners, see T.8.2 V.3.2.9 Spherical rod ends and spherical bearings in the steering must meet V.3.1.5 above V.3.2.10 Rear wheel steering may be used" ;
    iof:requirementSatisfiedBy :Critical_Fasteners_Design_Specification .

:Spherical_Rod_Ends_and_Bearings_Requirement a iof:RequirementSpecification ;
    rdfs:comment "Spherical rod ends and spherical bearings in the steering must meet V.3.1.5 above." ;
    iof:requirementSatisfiedBy :Spherical_Rod_Ends_and_Bearings_Design_Specification .

:Critical_Fasteners a iof:MaterialEntity .

:Critical_Fasteners_Design_Specification a iof:DesignSpecification ;
    iof:prescribes :Critical_Fasteners .

:Rear_Wheel_Steering a iof:MaterialEntity .

:Rear_Wheel_Steering_Design_Specification a iof:PlanSpecification ;
    iof:prescribes :Rear_Wheel_Steering .

:Spherical_Rod_Ends_and_Bearings_Design_Specification a iof:DesignSpecification ;
    iof:prescribes :V_3_1_5 .

:V_3_1_5 a iof:InformationContentEntity .

