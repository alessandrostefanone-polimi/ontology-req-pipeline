@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/163#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A two dimensional template used to represent the 95th percentile male is made to the following dimensions (see figure below): - A circle of diameter 200 mm will represent the hips and buttocks" ;
    iof:requirementSatisfiedBy :Spec_1 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e+02 ;
    qudt:minInclusive 2e+02 ;
    qudt:unit qudtu:MilliM .

:Circle_0_Diameter a qudt:QuantityValue ;
    qudt:maxInclusive 2e+02 ;
    qudt:minInclusive 2e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:hasValueExpressionAtAllTimes :Circle_0_Diameter_Value ;
    iof:isValueExpressionOfAtAllTimes :Circle_0 .

:Circle_0_Diameter_Value a qudt:QuantityValue ;
    qudt:maxInclusive 2e+02 ;
    qudt:minInclusive 2e+02 ;
    qudt:unit qudtu:MilliM .

:Circle_Role a iof:MaterialComponentRole ;
    rdfs:label "Circle representing hips and buttocks" .

:Spec_1 a iof:PlanSpecification ;
    iof:prescribes :Circle_0 .

qudtqk:Diameter a qudt:QuantityKind .

:Circle_0 a iof:DesignSpecification,
        iof:MaterialArtifact,
        iof:MaterialComponent ;
    iof:hasRole :Circle_Role ;
    iof:prescribes :Circle_0_Diameter .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

