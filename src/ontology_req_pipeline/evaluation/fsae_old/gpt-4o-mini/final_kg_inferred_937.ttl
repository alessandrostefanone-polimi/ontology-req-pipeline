@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/937#> a owl:Ontology .

<http://example.org/req/937#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Length of each run should be approximately 0.80 km D.11.1.2" ;
    ns1:requirementSatisfiedBy <http://example.org/req/937#DS_req0> .

<http://example.org/req/937#DS_req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/937#VE_req0_c0> .

<http://example.org/req/937#LengthOfEachRun> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasQuality <http://example.org/req/937#LengthQuality> ;
    ns1:hasValueExpressionAtAllTimes <http://example.org/req/937#VE_req0_c0> .

<http://example.org/req/937#LengthQuality> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000019>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        owl:NamedIndividual,
        owl:Thing ;
    ns1:hasValueExpressionAtSomeTime <http://example.org/req/937#VE_req0_c0> .

<http://qudt.org/vocab/unit/KiloM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/PathLength> .

<http://example.org/req/937#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:hasSimpleExpressionValue 0.8,
        8e-01 ;
    ns2:hasUnit ns2:KiloM ;
    ns2:maxInclusive 8e-01 ;
    ns2:minInclusive 8e-01 ;
    ns2:unit <http://qudt.org/vocab/unit/KiloM> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/937#LengthOfEachRun> .

