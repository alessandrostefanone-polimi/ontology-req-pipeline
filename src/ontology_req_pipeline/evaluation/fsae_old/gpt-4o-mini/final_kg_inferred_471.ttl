@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/471#> a owl:Ontology .

<http://example.org/req/471#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Outside of the Rear Aerodynamic Zone must be no higher than 500 mm above the ground" ;
    ns1:requirementSatisfiedBy <http://example.org/req/471#DS_0> .

<http://example.org/req/471#DS_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/471#Plan_0> .

<http://example.org/req/471#Height_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        owl:NamedIndividual,
        owl:Thing ;
    ns2:hasValueExpressionAtSomeTime <http://example.org/req/471#VE_req0_c0> .

<http://example.org/req/471#Plan_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/471#VE_req0_c0> .

<http://qudt.org/vocab/unit/MM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Height> .

<http://example.org/req/471#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:hasUnit ns2:MM ;
    ns2:maxInclusive 5e+02 ;
    ns2:unit <http://qudt.org/vocab/unit/MM> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/471#Height_0> .

