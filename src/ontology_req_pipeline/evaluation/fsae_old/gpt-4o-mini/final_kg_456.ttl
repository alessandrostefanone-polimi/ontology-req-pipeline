@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/456#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Material_2 a iof:ActionSpecification ;
    iof:prescribes :Material_2_1 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Insulation - The gas cylinder/tank must be insulated from any heat sources T.6.1.6 Cylinder Material - gas cylinders/tanks in a position 150 mm or less from an exhaust system must meet one of the two: - Made from metal" ;
    iof:requirementSatisfiedBy :Spec_0 .

:cylinders_tanks a iof:MaterialEntity ;
    rdfs:label "cylinders/tanks" .

:heat_sources a iof:MaterialEntity ;
    rdfs:label "heat sources" .

:metal a iof:MaterialEntity ;
    rdfs:label "metal" .

:position a iof:MaterialEntity ;
    rdfs:label "Gas cylinders/tanks in a position 150 mm or less from an exhaust system" .

:Insulation_0 a iof:ActionSpecification ;
    iof:prescribes :Insulation_0_1 .

:Insulation_0_1 a iof:ObjectiveSpecification .

:Material_1 a iof:ActionSpecification ;
    iof:prescribes :Material_1_1 .

:Material_1_1 a iof:ObjectiveSpecification .

:Material_2_1 a iof:ObjectiveSpecification .

:Spec_0 a iof:DesignSpecification ;
    iof:prescribes :Insulation_0,
        :Material_1 .

