@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/965#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "If a vehicle stalls, or ingests a cone, etc., it may be allowed to continue, subject to D.12.1.4 and D.12.4." ;
    iof:requirementSatisfiedBy :Req_0_Specification .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "A Black Flag will be shown at the designated location." ;
    iof:requirementSatisfiedBy :Req_1_Specification .

:Req_0_Action a iof:ActionSpecification ;
    iof:prescribes :Req_0_Condition .

:Req_0_Condition a iof:ObjectiveSpecification .

:Req_0_Specification a iof:PlanSpecification ;
    iof:prescribes :Req_0_Action .

:Req_1_Action a iof:ActionSpecification ;
    iof:prescribes :Req_1_Condition .

:Req_1_Condition a iof:ObjectiveSpecification .

:Req_1_Specification a iof:PlanSpecification ;
    iof:prescribes :Req_1_Action .

