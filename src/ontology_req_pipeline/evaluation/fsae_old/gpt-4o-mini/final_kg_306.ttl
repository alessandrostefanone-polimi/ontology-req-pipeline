@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/306#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Fasteners a iof:MaterialArtifact ;
    iof:hasValueExpressionAtSomeTime :VE_req9_c0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "External Structure F.10.2.1 The Floor or Bottom must be made from one of the three: a. Steel 1.25 mm minimum thickness b. Aluminum 3.2 mm minimum thickness c. Equivalent Alternate / Composite materials ( F.4.1, F.4.3) F.10.2.2 Vertical Walls, Covers and Lids must be made from one of the three: a. Steel 0.9 mm minimum thickness b. Aluminum 2.3 mm minimum thickness c. Equivalent Alternate / Composite materials ( F.4.1, F.4.3) F.10.2.3 The accepted methods of joining walls to walls and walls to floor are: a. Welding - Welds may be continuous or interrupted. - If interrupted, the weld/space ratio must be 1:1 or higher - All weld lengths must be more than 25 mm b. Fasteners Combined strength of the fasteners must be Equivalent to the strength of the welded joint ( F.10.2.3.a above)" ;
    iof:requirementSatisfiedBy :Spec_0 .

:VE_req4_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.3e+00 ;
    qudt:unit qudtu:MilliM .

:VE_req7_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1e+00 ;
    qudt:unit qudtu:UNITLESS .

:VE_req8_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM .

:Aluminum_3_2_mm a iof:MaterialArtifact ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :WeldingMethod_0,
        :WeldingMethod_1,
        :WeldingMethod_2 .

:Steel_1_25_mm a iof:MaterialArtifact ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1.25e+00 ;
    qudt:unit qudtu:MilliM .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 3.2e+00 ;
    qudt:unit qudtu:MilliM .

:VE_req6_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1e+00 ;
    qudt:unit qudtu:UNITLESS .

:VE_req6_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 2.5e+01 ;
    qudt:unit qudtu:MilliM .

:WeldingMethod_0 a iof:DesignSpecification ;
    iof:hasValueExpressionAtSomeTime :VE_req6_c0 ;
    iof:prescribes :Aluminum_3_2_mm,
        :CompositeMaterials,
        :Steel_1_25_mm .

:WeldingMethod_1 a iof:DesignSpecification ;
    iof:hasValueExpressionAtSomeTime :VE_req6_c1 .

:WeldingMethod_2 a iof:DesignSpecification ;
    iof:hasValueExpressionAtSomeTime :VE_req6_c2 .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:UNITLESS a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Thickness .

