@prefix : <http://example.org/req/622#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Symbol specified in ISO 7010-W012 (triangle with black lightning bolt on yellow background) with triangle side length of 100 mm minimum c. Text \"Always Energized\" d. Text \"High Voltage\" if the voltage meets T.9.1.1 ## EV.4.4 Grounded Low Voltage System EV.4.4.1 The GLV System must be" ;
    iof:requirementSatisfiedBy :DS_req0 .

:voltage_condition a iof:ProcessCharacteristic ;
    rdfs:label "voltage condition" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:has_feature :GLV_System .

:voltage_meets_T9_1_1 a iof:Process ;
    rdfs:label "voltage meets T.9.1.1" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:has_feature :GLV_System .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :VE_req0_c0 .

:Text_Always_Energized a iof:MaterialEntity ;
    rdfs:label "Text \"Always Energized\"" .

:Text_High_Voltage a iof:MaterialEntity ;
    rdfs:label "Text \"High Voltage\"" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:has_feature :GLV_System .

:triangle_side_length a bfo:BFO_0000001 ;
    rdfs:label "triangle side length" .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:GLV_System a iof:MaterialEntity ;
    rdfs:label "The GLV System" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:has_feature :Text_Always_Energized,
        :Text_High_Voltage .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue "100.0"^^xsd:float ;
    qudt:minInclusive 1e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :triangle_side_length .

