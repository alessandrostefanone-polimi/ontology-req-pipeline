@prefix : <http://example.org/req/798#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "All teams with a system voltage of 500 V or more will be measured with 500 V" ;
    iof:requirementSatisfiedBy :DS_req0 .

:measurement_500V a bfo:BFO_0000001,
        bfo:BFO_0000029 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:system_voltage_500V a bfo:BFO_0000001,
        bfo:BFO_0000029 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :P_req0 .

:P_req0 a iof:PlanSpecification ;
    iof:hasInput :VE_req0_c0 ;
    iof:prescribes :VE_req0_c1 .

qudtqk:Voltage a qudt:QuantityKind .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudtu:V ;
    qudt:minInclusive 5e+02 ;
    qudt:unit qudtu:V .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudtu:V ;
    qudt:maxInclusive 5e+02 ;
    qudt:minInclusive 5e+02 ;
    qudt:unit qudtu:V .

qudtu:V a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Voltage .

