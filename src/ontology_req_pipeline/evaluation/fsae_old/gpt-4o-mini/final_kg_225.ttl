@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/225#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "An inspection hole approximately 4 mm in diameter must be drilled through a low stress location of every monocoque section regulated by the Structural Equivalency Spreadsheet This inspection hole is not required in the Vertical Side Impact Structure F.7.5.3.b" ;
    iof:requirementSatisfiedBy :DS_req0 .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "This inspection hole is not required in the Vertical Side Impact Structure F.7.5.3.b." ;
    iof:requirementSatisfiedBy :DS_req1 .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :P_req0 .

:DS_req1 a iof:DesignSpecification ;
    iof:prescribes :P_req1 .

:P_req0 a iof:PlanSpecification ;
    iof:prescribes :inspection_hole,
        :objective_specification .

:P_req1 a iof:PlanSpecification ;
    iof:prescribes :inspection_hole_not_required,
        :objective_specification_not_required .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudtu:MilliM ;
    qudt:maxInclusive 4e+00 ;
    qudt:minInclusive 4e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :inspection_hole .

:inspection_hole_not_required a iof:MaterialArtifact ;
    iof:hasQuality :quality_inspection_hole_not_required .

:low_stress_location a iof:MaterialEntity ;
    iof:hasRole :low_stress_location_role .

:low_stress_location_role a iof:Role ;
    rdfs:label "low stress location" .

:objective_specification a iof:ObjectSpecification ;
    iof:hasFeature :low_stress_location .

:quality_inspection_hole a iof:Quality ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:quality_inspection_hole_not_required a iof:Quality ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

qudtqk:Diameter a qudt:QuantityKind .

:inspection_hole a iof:MaterialArtifact ;
    iof:hasQuality :quality_inspection_hole .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

