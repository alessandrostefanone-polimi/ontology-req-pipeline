@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/514#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "2 AIR INTAKE SYSTEM ## IC.2.1 General ## IC.2.2 Intake System Location IC.2.2.1 The Intake System must meet IC.1.2 IC.2.2.2 Any portion of the air intake system that is less than 350 mm above the ground must be shielded from side or rear impacts by structure built per F.6.4 / F.7.5 as applicable. ## IC.2.3 Intake System Mounting IC.2.3.1" ;
    iof:requirementSatisfiedBy :DS_1 .

:DS_1 a iof:DesignSpecification ;
    iof:prescribes :P_1 .

:P_1 a iof:PlanSpecification ;
    iof:hasInput :M_2 ;
    iof:prescribes :M_1 .

:Q_1 a iof:Quality ;
    rdfs:label "height above ground" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:Q_2 a iof:Quality ;
    rdfs:label "shielding" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 .

:R_1 a iof:MaterialProductRole ;
    rdfs:label "material product role" .

:R_2 a iof:RawMaterialRole ;
    rdfs:label "raw material role" .

:R_3 a iof:MaintainableMaterialItemRole ;
    rdfs:label "maintainable material item role" .

:VE_req1_c0 a qudt:QuantityValue,
        iof:MeasuredValueExpression,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue "350.0"^^xsd:float ;
    qudt:maxExclusive 3.5e+02 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtSomeTime :Any_portion_of_the_air_intake_system .

:VE_req1_c1 a iof:MeasuredValueExpression ;
    qudt:hasSimpleExpressionValue "shielding"^^xsd:string ;
    iof:isValueExpressionOfAtSomeTime :Any_portion_of_the_air_intake_system .

qudtqk:Height a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Height .

:Any_portion_of_the_air_intake_system a iof:MaterialArtifact ;
    iof:hasInput :M_2 ;
    iof:hasQuality :Q_1,
        :Q_2 ;
    iof:hasRole :R_3 ;
    iof:hasSpecifiedOutput :M_1 .

:M_1 a iof:MaterialArtifact ;
    iof:hasRole :R_1 .

:M_2 a iof:MaterialArtifact ;
    iof:hasRole :R_2 .

