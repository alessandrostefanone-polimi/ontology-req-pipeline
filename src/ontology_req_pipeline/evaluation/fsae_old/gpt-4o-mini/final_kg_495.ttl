@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/495#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Exposed around the lower $180^{\\circ}$ of its circumference over a minimum length of 280 mm g. Access from the rear of the tube must be unobstructed for 300 mm or more of its length h" ;
    iof:requirementSatisfiedBy :DS_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Plan_0 .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :VE_req0_c0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:minInclusive 3e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtSomeTime :tube .

:tube a iof:MaterialArtifact .

qudtqk:Length a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

