@prefix ns1: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix ns2: <http://qudt.org/schema/qudt/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/req/462#> a owl:Ontology .

<http://example.org/req/462#Req_0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:RequirementSpecification ;
    rdfs:comment "Refer to IN.8.2 T.7.1.4 All forward facing edges that could contact a pedestrian (wings, end plates, and undertrays) must have a minimum radius of 5 mm for all horizontal edges and 3 mm for vertical edges" ;
    ns1:requirementSatisfiedBy <http://example.org/req/462#DS_req0> .

<http://example.org/req/462#DS_req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DesignSpecification,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity ;
    ns1:prescribes <http://example.org/req/462#Plan_req0> .

<http://example.org/req/462#Plan_req0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:DirectiveInformationContentEntity,
        ns1:InformationContentEntity,
        ns1:PlanSpecification ;
    ns1:prescribes <http://example.org/req/462#VE_req0_c0>,
        <http://example.org/req/462#VE_req1_c0> .

<http://example.org/req/462#VE_req0_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:hasUnit ns2:MilliM ;
    ns2:minInclusive 5e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/462#horizontal_edges> .

<http://example.org/req/462#VE_req1_c0> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000031>,
        ns2:QuantityValue,
        owl:NamedIndividual,
        owl:Thing,
        ns1:InformationContentEntity,
        ns1:ValueExpression ;
    ns2:hasUnit ns2:MilliM ;
    ns2:minInclusive 3e+00 ;
    ns2:unit <http://qudt.org/vocab/unit/MilliM> ;
    ns1:isValueExpressionOfAtAllTimes <http://example.org/req/462#vertical_edges> .

<http://example.org/req/462#horizontal_edges> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact,
        ns1:MaterialComponent ;
    ns1:hasRole <http://example.org/req/462#minimum_radius_horizontal> .

<http://example.org/req/462#minimum_radius_horizontal> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000017>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        <http://purl.obolibrary.org/obo/BFO_0000023>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialComponentRole ;
    rdfs:label "minimum radius for horizontal edges" .

<http://example.org/req/462#minimum_radius_vertical> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000017>,
        <http://purl.obolibrary.org/obo/BFO_0000020>,
        <http://purl.obolibrary.org/obo/BFO_0000023>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialComponentRole ;
    rdfs:label "minimum radius for vertical edges" .

<http://example.org/req/462#vertical_edges> a <http://purl.obolibrary.org/obo/BFO_0000001>,
        <http://purl.obolibrary.org/obo/BFO_0000002>,
        <http://purl.obolibrary.org/obo/BFO_0000004>,
        <http://purl.obolibrary.org/obo/BFO_0000030>,
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        owl:NamedIndividual,
        owl:Thing,
        ns1:MaterialArtifact,
        ns1:MaterialComponent ;
    ns1:hasRole <http://example.org/req/462#minimum_radius_vertical> .

<http://qudt.org/vocab/unit/MilliM> ns2:hasQuantityKind <http://qudt.org/vocab/quantitykind/Radius> .

