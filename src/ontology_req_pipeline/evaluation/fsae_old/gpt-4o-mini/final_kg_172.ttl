@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/172#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "See figure following F.5.9.6 below F.5.7.5 The Front Hoop must be no more than 250 mm forward of the steering wheel" ;
    iof:requirementSatisfiedBy :DS_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Plan_0 .

:FrontHoopRole a iof:MaterialComponentRole ;
    iof:roleOf :The_Front_Hoop .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :VE_req0_c0 .

qudtqk:Length a qudt:QuantityKind .

:Distance_Quality a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:The_Front_Hoop a iof:MaterialArtifact ;
    iof:hasDisposition :Distance_Quality ;
    iof:hasQuality :Distance_Quality ;
    iof:hasRole :FrontHoopRole .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudtu:MilliM ;
    qudt:maxInclusive 2.5e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:hasValueExpressionAtAllTimes :The_Front_Hoop .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

