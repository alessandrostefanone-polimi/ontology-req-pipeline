@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/408#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.3.3 Operation of the BOTS to the OFF position must Open the Shutdown Circuit IC.9.2.2 / EV.7.2.2 T.3.3.4 Repeated operation of the switch must not reset or restore power T.3.3.5" ;
    iof:requirementSatisfiedBy :Spec_0 .

:Switch a iof:MaterialEntity ;
    rdfs:label "the switch" .

:Action_0 a iof:ActionSpecification ;
    iof:prescribes :Open_Shutdown_Circuit,
        :Shutdown_Circuit_IC_9_2_2 .

:Action_1 a iof:ActionSpecification ;
    iof:prescribes :Switch_Operation .

:Open_Shutdown_Circuit a iof:Process ;
    iof:hasOutput :Shutdown_Circuit_IC_9_2_2 .

:Power_Reset a iof:BooleanValueExpression ;
    iof:hasSimpleExpressionValue false .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :Action_0,
        :Action_1 .

:Switch_Operation a iof:Process ;
    iof:hasOutput :Power_Reset .

:Shutdown_Circuit_IC_9_2_2 a iof:MaterialEntity ;
    rdfs:label "the Shutdown Circuit IC.9.2.2" .

