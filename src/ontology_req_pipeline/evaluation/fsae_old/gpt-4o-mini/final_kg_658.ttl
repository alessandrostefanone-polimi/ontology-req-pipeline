@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/658#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Available during charging of any Accumulator(s) EV.5.8.3 The TSMPs must be: a. 4 mm shrouded banana jacks rated to an appropriate voltage level b. Color" ;
    iof:requirementSatisfiedBy :DS_req0 .

:Req_1 a iof:RequirementSpecification ;
    rdfs:comment "Color." ;
    iof:requirementSatisfiedBy :DS_req1 .

:VE_req0_c1 a iof:MeasuredValueExpression .

:voltage_level a iof:ProcessCharacteristic .

:C0 a iof:MaterialArtifact ;
    iof:hasComponentPartAtAllTimes :jack_4mm .

:Color a iof:DescriptiveInformationContentEntity,
        iof:MaterialArtifact ;
    iof:hasComponentPartAtAllTimes :color_role ;
    iof:prescribes :ColorSpecification .

:ColorSpecification a iof:DesignSpecification .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :C0 .

:DS_req1 a iof:DesignSpecification ;
    iof:prescribes :Color .

:color_role a iof:MaterialComponentRole ;
    rdfs:label "Color" .

:jack_4mm a iof:MaterialComponent ;
    iof:hasRole :jack_role .

:jack_role a iof:MaterialComponentRole ;
    rdfs:label "4 mm shrouded banana jacks" .

