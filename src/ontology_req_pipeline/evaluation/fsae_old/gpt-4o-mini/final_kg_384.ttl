@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/384#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The Shoulder Belt Mount Spacing must be between 175 mm and 235 mm, center to center T.2.6.3 The Shoulder Belts must attach by one of the four: a. Wrap around the Shoulder Harness Mounting bar b. Bolt through a welded tube insert or tested monocoque attachment F.7.9 c. Bolt or clip to a tab or bracket (T.2.4.3 ) on the Shoulder Harness Mounting bar d. Wrap around physically tested hardware attached to a monocoque T.2.6.4" ;
    iof:requirementSatisfiedBy :Spec_0 .

:VE_req2_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.35e+02 ;
    qudt:minInclusive 1.75e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Material_0 .

:VE_req3_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.35e+02 ;
    qudt:minInclusive 1.75e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Material_0 .

:VE_req4_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.35e+02 ;
    qudt:minInclusive 1.75e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Material_0 .

:Output_0 a iof:MaterialProduct ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:Process_0 a iof:ManufacturingProcess ;
    iof:hasInput :Material_0 ;
    iof:hasSpecifiedOutput :Output_0 .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :Process_0 .

qudtqk:Length a qudt:QuantityKind .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.35e+02 ;
    qudt:minInclusive 1.75e+02 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Material_0 .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Material_0 a iof:MaterialProduct ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

