@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix : <http://example.org/req/174#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Front_Hoop a iof:MaterialArtifact ;
    iof:hasRole :NonSteelRole .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "5.7.7 A Front Hoop that is not steel must have a 4 mm hole drilled in a location to access during Technical Inspection" ;
    iof:requirementSatisfiedBy :DS_0 .

:Action_0 a iof:ActionSpecification ;
    rdfs:label "have a 4 mm hole drilled" .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Plan_0 .

:NonSteelRole a iof:AgentRole ;
    rdfs:label "not steel" .

:Objective_0 a iof:ObjectiveSpecification ;
    rdfs:label "access during Technical Inspection" .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :Action_0,
        :Hole_0,
        :Objective_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasUnit qudt:MilliM ;
    qudt:maxInclusive 4e+00 ;
    qudt:minInclusive 4e+00 ;
    qudt:unit qudtu:MilliM ;
    iof:isValueExpressionOfAtAllTimes :Hole_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:MilliM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:Hole_0 a iof:MaterialArtifact ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 .

