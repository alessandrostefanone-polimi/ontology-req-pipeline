@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/731#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The temperature of a minimum of $20 \\%$ of the cells must be monitored by the AMS" ;
    iof:requirementSatisfiedBy :Spec_0 .

:Cells a iof:MaterialEntity ;
    rdfs:label "cells" .

:MonitoringProcess a iof:PlannedProcess ;
    iof:hasInput :Cells ;
    iof:hasSpecifiedOutput :TemperatureMonitoring .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :MonitoringProcess .

:TemperatureMonitoring a iof:InformationContentEntity ;
    rdfs:label "temperature monitoring" .

