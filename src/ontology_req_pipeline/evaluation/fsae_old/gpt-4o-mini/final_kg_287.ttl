@prefix : <http://example.org/req/287#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Energy absorbed must be more than 7350 J When: - Total mass of Vehicle is 300 kg - Impact velocity is $7.0 \\mathrm{~m} / \\mathrm{s}$ F.8.8.3 When using the Standard Impact Attenuator, the SES must meet the following: a. Test data will not be submitted b" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :VE_req0_c0,
        :VE_req1_c0,
        :VE_req2_c0,
        :VE_req3_c0 .

qudtqk:Energy a qudt:QuantityKind .

:EnergyAbsorbed_0 a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

:EnergyAbsorbed_3 a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req3_c0 .

:ImpactVelocity_2 a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c0 .

:TotalMassOfVehicle_1 a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 7.35e+03 ;
    qudt:unit qudtu:J ;
    iof:hasValueExpressionAtAllTimes :EnergyAbsorbed_0 ;
    iof:isValueExpressionOfAtSomeTime :EnergyAbsorbed_0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 3e+02 ;
    qudt:unit qudtu:J ;
    iof:hasValueExpressionAtAllTimes :TotalMassOfVehicle_1 ;
    iof:isValueExpressionOfAtSomeTime :TotalMassOfVehicle_1 .

:VE_req2_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 7e+00 ;
    qudt:unit qudtu:J ;
    iof:hasValueExpressionAtAllTimes :ImpactVelocity_2 ;
    iof:isValueExpressionOfAtSomeTime :ImpactVelocity_2 .

:VE_req3_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minExclusive 7.35e+03 ;
    qudt:unit qudtu:J ;
    iof:hasValueExpressionAtAllTimes :EnergyAbsorbed_3 ;
    iof:isValueExpressionOfAtSomeTime :EnergyAbsorbed_3 .

qudtu:J a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Energy .

