@prefix : <http://example.org/req/572#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A permanent, non movable fuel level line must be located between 12 mm and 25 mm below the top of the visible portion of the sight tube" ;
    iof:requirementSatisfiedBy :DS_req0 .

:DS_req0 a iof:DesignSpecification ;
    iof:prescribes :VE_req0_c0 .

:fuel_level_line_position a bfo:BFO_0000001 ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:MM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:hasSimpleExpressionValue "12.0"^^xsd:float,
        "25.0"^^xsd:float ;
    qudt:maxInclusive 2.5e+01 ;
    qudt:minInclusive 1.2e+01 ;
    qudt:unit qudtu:MM ;
    iof:isValueExpressionOfAtAllTimes :fuel_level_line_position .

