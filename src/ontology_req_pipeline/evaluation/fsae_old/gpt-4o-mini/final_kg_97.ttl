@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/97#> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:ComplianceRequirement a iof:ObjectiveSpecification ;
    iof:prescribes :T1_4_4_V3_3_2 .

:QuickDisconnect a iof:MaterialArtifact ;
    iof:hasRole :QuickDisconnectRole .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "In any angular position, the Steering Wheel must meet T.1.4.4 V.3.3.2 The Steering Wheel must be attached to the column with a quick disconnect" ;
    iof:requirementSatisfiedBy :Spec_0 .

:ColumnWithQuickDisconnect a iof:MaterialArtifact ;
    iof:hasRole :QuickDisconnectRole .

:Spec_0 a iof:PlanSpecification ;
    iof:prescribes :SteeringWheelAttachmentProcess .

:SteeringWheel a iof:MaterialArtifact ;
    iof:hasRole :SteeringWheelRole .

:SteeringWheelAttachmentProcess a iof:ManufacturingProcess ;
    iof:hasInput :SteeringWheel ;
    iof:hasSpecifiedOutput :ColumnWithQuickDisconnect .

:SteeringWheelRole a iof:MaterialComponentRole ;
    rdfs:label "Steering Wheel Role" .

:T1_4_4_V3_3_2 a iof:MaterialEntity ;
    rdfs:label "T.1.4.4 V.3.3.2" .

:QuickDisconnectRole a iof:MaterialComponentRole ;
    rdfs:label "Quick Disconnect Role" .

