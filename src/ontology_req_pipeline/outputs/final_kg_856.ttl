@prefix : <http://example.org/req/856#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:CostSourceConstraint a iof:InformationContentEntity ;
    rdfs:label "Constraint: all costs in the Cost Report must come from the standardized Cost Tables"@en ;
    iof:isAbout :ReportedCosts,
        :StandardizedCostTables .

:CostReport a iof:InformationContentEntity ;
    rdfs:label "Cost Report"@en ;
    iof:isAbout :ReportedCosts .

:CostReportingProcess a iof:PlannedProcess ;
    rdfs:label "Cost reporting process"@en ;
    iof:hasSpecifiedOutput :CostReport .

:DS_RemovedItemCredit a iof:DesignSpecification ;
    iof:prescribes :RemovedItemCreditPolicy ;
    iof:satisfiesRequirement :Req_0 .

:PS_CostSource a iof:PlanSpecification ;
    iof:prescribes :CostReportingProcess ;
    iof:satisfiesRequirement :Req_0 .

:RemovedItemCreditPolicy a bfo:BFO_0000002 ;
    rdfs:label "Removed item credit policy"@en ;
    iof:hasQuality :CreditAmountQuality .

:StandardizedCostTables a iof:InformationContentEntity ;
    rdfs:label "Standardized Cost Tables"@en .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 7.5e-01 ;
    qudt:minInclusive 7.5e-01 ;
    qudt:unit qudtu:NUM ;
    iof:isValueExpressionOfAtAllTimes :CreditAmountQuality .

qudtqk:DimensionlessRatio a qudt:QuantityKind .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DimensionlessRatio .

:CreditAmountQuality a bfo:BFO_0000019 ;
    rdfs:label "Credit amount fraction of table cost"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

:ReportedCosts a bfo:BFO_0000040 ;
    rdfs:label "Costs in the Cost Report"@en .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Removed items will be credited $75 \\%$ of the table cost: - ( $0.75 \\times$ Cost) ### 5.3.8 Cost Tables 5.3.8.1 All costs in the Cost Report must come from the standardized Cost Tables. 5.3.8.2" ;
    iof:requirementSatisfiedBy :DS_RemovedItemCredit,
        :PS_CostSource .

