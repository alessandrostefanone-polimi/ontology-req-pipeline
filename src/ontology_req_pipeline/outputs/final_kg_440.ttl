@prefix : <http://example.org/req/440#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Object_12mm_0 a bfo:BFO_0000040 ;
    iof:hasQuality :Object_12mm_Diameter_0 .

:Req1_PassageConstraint_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :GuardUsageProcess_0 ;
    iof:prescribes :BlockedPassageEvent_0 .

:BlockedPassageEvent_0 a iof:Event ;
    iof:recognizedByAtSomeTime :SafetyEngineer_0 .

:GuardDesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Guard_0 ;
    iof:satisfiesRequirement :Req_0 .

:GuardUsagePlan_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :Req0_UsageConstraint_0 ;
    iof:prescribes :GuardUsageProcess_0 .

:Guard_0 a bfo:BFO_0000040 ;
    iof:hasComponentPartAtSomeTime :GuardMaterial_0 .

:Req0_UsageConstraint_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :GuardUsageProcess_0 ;
    iof:prescribes :GuardMaterialRole_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Mesh or perforated material may be used but must prevent the passage of a 12 mm diameter object through the guard" ;
    iof:requirementSatisfiedBy :GuardDesignSpec_0 .

:SafetyEngineer_0 a iof:Person .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.2e-02 ;
    qudt:minInclusive 1.2e-02 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Object_12mm_Diameter_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:GuardMaterialRole_0 a bfo:BFO_0000023 ;
    iof:roleOf :GuardMaterial_0 .

:Object_12mm_Diameter_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 .

:GuardMaterial_0 a iof:MaterialArtifact ;
    iof:hasRole :GuardMaterialRole_0 .

:GuardUsageProcess_0 a iof:PlannedProcess ;
    bfo:BFO_0000057 :GuardMaterial_0 ;
    iof:prescribedBy :GuardUsagePlan_0 .

