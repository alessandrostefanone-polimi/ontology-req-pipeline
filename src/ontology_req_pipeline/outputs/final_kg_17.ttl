@prefix : <http://example.org/req/17#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :Precision_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The robot shall have a precision of at least 10 millimeters in the positioning of its tool." ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :Spec_0 .

:Spec_0 a iof:DesignSpecification ;
    iof:prescribes :Precision_0,
        :Robot_0,
        :ToolPositioning_0 ;
    iof:satisfiesRequirement :Req_0 .

:ToolPositioning_0 a bfo:BFO_0000019 ;
    iof:qualityOf :Tool_0 .

:Tool_0 a bfo:BFO_0000040 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1e-02 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Precision_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Robot_0 a iof:EngineeredSystem ;
    iof:hasQuality :Precision_0 .

:Precision_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 ;
    iof:qualityOf :Robot_0 .

