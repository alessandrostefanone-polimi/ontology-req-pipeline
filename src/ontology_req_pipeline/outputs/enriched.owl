                                                                                                               ] ;
                                                                                           rdfs:subClassOf <https://spec.industrialontologies.org/ontology/core/Core/ValueExpression> ;
                                                                                           owl:disjointWith <https://spec.industrialontologies.org/ontology/core/Core/TemporalInstantValueExpression> .


###  https://spec.industrialontologies.org/ontology/core/Core/TemporalInstantValueExpression
<https://spec.industrialontologies.org/ontology/core/Core/TemporalInstantValueExpression> rdf:type owl:Class ;
                                                                                          owl:equivalentClass [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/core/Core/ValueExpression>
                                                                                                                                     [ rdf:type owl:Restriction ;
