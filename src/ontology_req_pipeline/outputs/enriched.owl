                                                                                                                                        owl:onProperty <https://spec.industrialontologies.org/ontology/core/Core/isValueExpressionOfAtAllTimes> ;
                                                                                                                                        owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                                                      ]
                                                                                                                                    ) ;
