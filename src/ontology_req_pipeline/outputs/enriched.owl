[ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/core/Core/InformationContentEntity>
                       [ rdf:type owl:Restriction ;
                         owl:onProperty <https://spec.industrialontologies.org/ontology/core/Core/isAchievedByAtSomeTime> ;
