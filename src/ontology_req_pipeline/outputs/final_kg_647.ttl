@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix : <http://example.org/req/647#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Clearly marked with \"HVD\" EV.5.5.2 An Interlock EV.7.8 must Open the Shutdown Circuit EV.7.2.2 when the HVD is removed EV.5.5.3 A dummy connector or similar may be used to restore isolation to meet EV.6.1.2 # EV.5.6 Precharge and Discharge Circuits EV.5.6.1 The Accumulator must contain a Precharge Circuit" ;
    iof:requirementSatisfiedBy :DS_0,
        :DS_3,
        :PS_1,
        :PS_2 .

:Accumulator_3 a bfo:BFO_0000040 ;
    rdfs:label "Accumulator" ;
    iof:hasComponentPartAtAllTimes :PrechargeCircuit_3 .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "Design spec for HVD marking" ;
    iof:prescribes :HVD_0 .

:DS_3 a iof:DesignSpecification ;
    rdfs:label "Design spec for accumulator precharge circuit" ;
    iof:prescribes :Accumulator_3 .

:DummyConnector_2 a bfo:BFO_0000040 ;
    rdfs:label "Dummy connector or similar" .

:EV_6_1_2_Objective a iof:ObjectiveSpecification ;
    rdfs:label "Objective EV.6.1.2 (isolation requirement)" .

:HVDRemoval_1 a bfo:BFO_0000015 ;
    rdfs:label "HVD removal process" ;
    bfo:BFO_0000057 :HVD_1 .

:HVD_0 a bfo:BFO_0000040 ;
    rdfs:label "HVD (high-voltage disconnect)" ;
    iof:hasQuality :HVD_0_Marking .

:HVD_0_Label a iof:InformationContentEntity ;
    rdfs:label "\"HVD\" marking text" ;
    iof:hasSimpleExpressionValue "\"HVD\""^^xsd:string .

:HVD_0_Marking a bfo:BFO_0000019 ;
    rdfs:label "HVD marking quality" ;
    iof:denotedBy :HVD_0_Label .

:HVD_1 a bfo:BFO_0000040 ;
    rdfs:label "HVD (for interlock requirement)" .

:InterlockOpenProcess_1 a bfo:BFO_0000015 ;
    rdfs:label "Process: interlock opens shutdown circuit" ;
    bfo:BFO_0000057 :Interlock_1,
        :ShutdownCircuit_1 ;
    iof:occursDuring :HVDRemoval_1 .

:Interlock_1 a bfo:BFO_0000040 ;
    rdfs:label "Interlock EV.7.8" .

:PS_1 a iof:PlanSpecification ;
    rdfs:label "Plan spec for interlock opening shutdown circuit on HVD removal" ;
    iof:prescribes :InterlockOpenProcess_1 .

:PS_2 a iof:PlanSpecification ;
    rdfs:label "Plan spec for using dummy connector to restore isolation" ;
    iof:hasContinuantPartAtAllTimes :EV_6_1_2_Objective ;
    iof:prescribes :RestoreIsolationProcess_2 .

:PrechargeCircuit_3 a bfo:BFO_0000040 ;
    rdfs:label "Precharge Circuit" .

:RestoreIsolationProcess_2 a bfo:BFO_0000015 ;
    rdfs:label "Process: restore isolation using dummy connector" ;
    bfo:BFO_0000057 :DummyConnector_2 .

:ShutdownCircuit_1 a bfo:BFO_0000040 ;
    rdfs:label "Shutdown Circuit EV.7.2.2" .

