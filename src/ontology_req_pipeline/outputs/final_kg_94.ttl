@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/94#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:T_8_2 a iof:InformationContentEntity ;
    rdfs:label "Reference T.8.2" .

:V_3_2_9 a iof:InformationContentEntity ;
    rdfs:label "Reference V.3.2.9" .

:CriticalFastenerRole a bfo:BFO_0000023 ;
    rdfs:label "Critical fastener role" .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "Design specification for fasteners in the steering system" ;
    iof:prescribes :FastenersInSteeringSystem ;
    iof:satisfiesRequirement :Req_0 .

:FastenersInSteeringSystem a bfo:BFO_0000040 ;
    rdfs:label "Fasteners in the steering system" ;
    iof:hasRole :CriticalFastenerRole .

:PS_1 a iof:PlanSpecification ;
    rdfs:label "Plan specification for steering spherical joints" ;
    iof:prescribes :SteeringSphericalJointProcess ;
    iof:satisfiesRequirement :Req_0 .

:PS_2 a iof:PlanSpecification ;
    rdfs:label "Plan specification allowing rear wheel steering" ;
    iof:prescribes :RearWheelSteeringUsageProcess ;
    iof:satisfiesRequirement :Req_0 .

:RearWheelSteering a bfo:BFO_0000040 ;
    rdfs:label "Rear wheel steering" .

:RearWheelSteeringUsageProcess a iof:PlannedProcess ;
    rdfs:label "Usage of rear wheel steering" ;
    bfo:BFO_0000057 :RearWheelSteering .

:SphericalRodEndsAndBearingsInSteering a bfo:BFO_0000040 ;
    rdfs:label "Spherical rod ends and spherical bearings in the steering" .

:SteeringSphericalJointProcess a iof:PlannedProcess ;
    rdfs:label "Process involving spherical rod ends and spherical bearings in the steering" ;
    bfo:BFO_0000057 :SphericalRodEndsAndBearingsInSteering ;
    iof:isSubjectOf :V_3_1_5,
        :V_3_2_10_RefGroup .

:V_3_2_10 a iof:InformationContentEntity ;
    rdfs:label "Reference V.3.2.10" .

:V_3_2_10_RefGroup a iof:InformationContentEntity ;
    rdfs:label "Reference group 'V.3.1.5 above V.3.2.10'" ;
    iof:isAbout :V_3_1_5,
        :V_3_2_10 .

:V_3_1_5 a iof:InformationContentEntity ;
    rdfs:label "Reference V.3.1.5" .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.2.8 Fasteners in the steering system are Critical Fasteners, see T.8.2 V.3.2.9 Spherical rod ends and spherical bearings in the steering must meet V.3.1.5 above V.3.2.10 Rear wheel steering may be used" ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1,
        :PS_2 .

