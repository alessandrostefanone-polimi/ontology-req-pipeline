@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/443#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Minimum thickness for steel: 2.0 mm T.5.3.2 A Scatter Shield must be included around the Motor(s) when one or both: - The motor casing rotates around the stator - The motor case is perforated T.5.3.3" ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:MotorCasePerforated_0 a bfo:BFO_0000015 ;
    rdfs:label "motor case is perforated" .

:MotorCasingRotation_0 a bfo:BFO_0000015 ;
    rdfs:label "motor casing rotates around the stator" .

:ScatterShieldInclusionProcess_0 a iof:PlannedProcess ;
    rdfs:label "Include Scatter Shield around Motor(s) when motor casing rotates around stator" ;
    bfo:BFO_0000057 :Motor_0,
        :ScatterShield_0 ;
    bfo:BFO_0000117 :MotorCasingRotation_0 ;
    iof:prescribedBy :PlanSpec_0 .

:ScatterShieldInclusionProcess_1 a iof:PlannedProcess ;
    rdfs:label "Include Scatter Shield around Motor(s) when motor case is perforated" ;
    bfo:BFO_0000057 :Motor_0,
        :ScatterShield_0 ;
    bfo:BFO_0000117 :MotorCasePerforated_0 ;
    iof:prescribedBy :PlanSpec_0 .

:Motor_0 a bfo:BFO_0000040 ;
    rdfs:label "Motor(s)" .

:ScatterShield_0 a bfo:BFO_0000040 ;
    rdfs:label "Scatter Shield" .

:PlanSpec_0 a iof:PlanSpecification ;
    iof:prescribes :ScatterShieldInclusionProcess_0,
        :ScatterShieldInclusionProcess_1 .

