@prefix : <http://example.org/req/259#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :WeldLengthQuality_0,
        :WeldSpaceRatio_0 ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:prescribes :WeldLengthQuality_0,
        :WeldSpaceRatio_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The accepted methods of attachment are: a. Welding - All weld lengths must be 25 mm or longer - If interrupted, the weld/space ratio must be 1:1 or higher b" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.5e-02 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :WeldLengthQuality_0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 1e+00 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :WeldSpaceRatio_0 .

qudtqk:Length a qudt:QuantityKind .

qudtqk:Thickness a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length,
        qudtqk:Thickness .

:WeldLengthQuality_0 a bfo:BFO_0000019 ;
    rdfs:label "weld length"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

:WeldSpaceRatio_0 a bfo:BFO_0000019 ;
    rdfs:label "weld/space ratio"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req1_c0 .

