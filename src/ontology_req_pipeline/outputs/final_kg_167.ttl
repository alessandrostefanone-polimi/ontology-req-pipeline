@prefix : <http://example.org/req/167#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :HeadCircle_0,
        :Line_0,
        :UpperCircle_0 ;
    iof:satisfiesRequirement :Req_0 .

:HeadCircle_0 a bfo:BFO_0000030 ;
    rdfs:label "head circle"@en ;
    iof:hasQuality :HeadCircleDiameter_0 .

:Line_0 a bfo:BFO_0000030 ;
    rdfs:label "straight line connecting circle centers"@en ;
    iof:hasQuality :LineLength_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "A straight line measuring 280 mm will connect the centers of the upper 200 mm circle and the 300 mm head circle" ;
    iof:requirementSatisfiedBy :DS_0 .

:UpperCircle_0 a bfo:BFO_0000030 ;
    rdfs:label "upper circle"@en ;
    iof:hasQuality :UpperCircleDiameter_0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.8e-01 ;
    qudt:minInclusive 2.8e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :LineLength_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2e-01 ;
    qudt:minInclusive 2e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :UpperCircleDiameter_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 3e-01 ;
    qudt:minInclusive 3e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :HeadCircleDiameter_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Length a qudt:QuantityKind .

:HeadCircleDiameter_0 a bfo:BFO_0000019 ;
    rdfs:label "diameter of head circle"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c2 .

:LineLength_0 a bfo:BFO_0000019 ;
    rdfs:label "length of straight line"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 .

:UpperCircleDiameter_0 a bfo:BFO_0000019 ;
    rdfs:label "diameter of upper circle"@en ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c1 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter,
        qudtqk:Length .

