@prefix : <http://example.org/req/284#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The attachment points for the front wing and bodywork mounts should be aft of the Anti Intrusion Plate c. Tabs for wing and bodywork attachment must not extend more than 25 mm forward of the Anti Intrusion Plate F.8.6.3 Pedal assembly at full travel and adjustment must have a minimum 25 mm clearance to the: a. Rear face of the Anti Intrusion Plate b" ;
    iof:requirementSatisfiedBy :DS_AttachmentPoints,
        :DS_Tabs,
        :PS_PedalAssemblyClearance .

:AP_PositionRelToPlate a bfo:BFO_0000019 ;
    rdfs:label "Position of attachment points relative to Anti Intrusion Plate" ;
    iof:isAbout :AntiIntrusionPlate,
        :AttachmentPoints ;
    iof:isSubjectOf :DS_AttachmentPoints .

:PedalAssemblyFullTravelProcess a iof:PlannedProcess ;
    rdfs:label "Pedal assembly at full travel and adjustment" ;
    iof:hasParticipantAtSomeTime :AntiIntrusionPlate,
        :PedalAssembly ;
    iof:hasProcessCharacteristic :Pedal_ClearanceToPlate ;
    iof:prescribedBy :PS_PedalAssemblyClearance .

:Tabs_ExtensionRelToPlate a bfo:BFO_0000019 ;
    rdfs:label "Forward extension of tabs relative to Anti Intrusion Plate" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 ;
    iof:isAbout :AntiIntrusionPlate,
        :Tabs ;
    iof:isSubjectOf :DS_Tabs .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 2.5e-02 ;
    qudt:quantityKind qudtqk:Length ;
    qudt:unit qudtu:M .

:VE_req2_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.5e-02 ;
    qudt:quantityKind qudtqk:Length ;
    qudt:unit qudtu:M .

:AttachmentPoints a bfo:BFO_0000040 ;
    rdfs:label "Attachment points for the front wing and bodywork mounts" .

:DS_AttachmentPoints a iof:DesignSpecification ;
    rdfs:label "Design spec for front wing/bodywork attachment points" ;
    iof:isAbout :AP_PositionRelToPlate ;
    iof:prescribes :AttachmentPoints .

:DS_Tabs a iof:DesignSpecification ;
    rdfs:label "Design spec for wing/bodywork tabs" ;
    iof:isAbout :Tabs_ExtensionRelToPlate ;
    iof:prescribes :Tabs .

:PedalAssembly a bfo:BFO_0000040 ;
    rdfs:label "Pedal assembly" .

:Pedal_ClearanceToPlate a iof:ProcessCharacteristic ;
    rdfs:label "Clearance between pedal assembly and rear face of Anti Intrusion Plate at full travel" ;
    iof:hasValueExpressionAtSomeTime :VE_req2_c0 ;
    iof:isAbout :AntiIntrusionPlate,
        :PedalAssembly ;
    iof:isSubjectOf :PS_PedalAssemblyClearance .

:Tabs a bfo:BFO_0000040 ;
    rdfs:label "Tabs for wing and bodywork attachment" .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:PS_PedalAssemblyClearance a iof:PlanSpecification ;
    rdfs:label "Plan spec for pedal assembly clearance at full travel" ;
    iof:isAbout :Pedal_ClearanceToPlate ;
    iof:prescribes :PedalAssemblyFullTravelProcess .

qudtqk:Length a qudt:QuantityKind .

:AntiIntrusionPlate a bfo:BFO_0000040 ;
    rdfs:label "Anti Intrusion Plate" .

