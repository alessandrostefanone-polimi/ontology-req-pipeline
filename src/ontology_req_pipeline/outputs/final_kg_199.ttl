@prefix : <http://example.org/req/199#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Braces_0 a bfo:BFO_0000040 .

:DS_Req0 a iof:DesignSpecification ;
    iof:prescribes :Braces_0,
        :CriticalFastener_0 ;
    iof:satisfiesRequirement :Req_0 .

:DS_Req1 a iof:DesignSpecification ;
    iof:prescribes :MountingPlate_1 ;
    iof:satisfiesRequirement :Req_0 .

:Diameter_CF_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 ;
    iof:qualityOf :CriticalFastener_0 .

:Thickness_MP_1 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 ;
    iof:qualityOf :MountingPlate_1 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 8e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Diameter_CF_0 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e-03 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Thickness_MP_1 .

qudtqk:Diameter a qudt:QuantityKind .

qudtqk:Thickness a qudt:QuantityKind .

:CriticalFastener_0 a bfo:BFO_0000040 .

:MountingPlate_1 a bfo:BFO_0000040 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Other Bracing Requirements F.5.13.1 Where the braces are not welded to steel Frame Members, the braces must be securely attached to the Frame using 8 mm or 5/16\" minimum diameter Critical Fasteners, see T.8.2 F.5.13.2 Mounting plates welded to Roll Hoop Bracing must be 2.0 mm ( 0.080 in) minimum thickness steel" ;
    iof:requirementSatisfiedBy :DS_Req0,
        :DS_Req1 .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter,
        qudtqk:Thickness .

