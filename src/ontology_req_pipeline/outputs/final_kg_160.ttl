@prefix : <http://example.org/req/160#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req0 a iof:RequirementSpecification ;
    iof:isAbout :ObjSpec_Req0 ;
    iof:requirementSatisfiedBy :SES_Design .

:Req1 a iof:RequirementSpecification ;
    iof:isAbout :ObjSpec_Req1 ;
    iof:requirementSatisfiedBy :PlanSpec_Req1 .

:AdhesiveValue_Req1 a bfo:BFO_0000019 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Chassis_1,
        :SES_Design ;
    iof:satisfiesRequirement :Req_0 .

:DesignSpec_Req2 a iof:DesignSpecification ;
    iof:prescribes :Chassis_1,
        :FrontHoop_1,
        :MainHoop_1 ;
    iof:satisfiesRequirement :Req2 .

:ObjSpec_Req0 a iof:ObjectiveSpecification ;
    iof:prescribes :SES_Design .

:ObjSpec_Req1 a iof:ObjectiveSpecification ;
    iof:prescribes :ReductionProcess_Req1 .

:ObjSpec_Req2 a iof:ObjectiveSpecification ;
    iof:prescribes :Chassis_1,
        :FrontHoop_1,
        :MainHoop_1 .

:PlanSpec_Req1 a iof:PlanSpecification ;
    iof:prescribes :ReductionProcess_Req1 .

:ReducedAdhesiveValue_Req1 a bfo:BFO_0000019 .

:ReductionFactor_Req1 a iof:ProcessCharacteristic ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c0 .

:Req2 a iof:RequirementSpecification ;
    iof:isAbout :ObjSpec_Req2 ;
    iof:requirementSatisfiedBy :DesignSpec_Req2 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Document the adhesive choice, age and expiration date, substrate preparation, and the equivalency of the bonded joint in the SES F.5.5.3 The SES will reduce any referenced or tested adhesive values by $50 \\%$ ## F.5.6 Roll Hoops F.5.6.1 The Chassis must include both a Main Hoop and a Front Hoop. F.5.6.2" ;
    iof:requirementSatisfiedBy :DesignSpec_0 .

:SES_1 a bfo:BFO_0000040 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 5e-01 ;
    qudt:minInclusive 5e-01 ;
    qudt:unit qudtu:NUM .

qudtqk:DimensionlessRatio a qudt:QuantityKind .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DimensionlessRatio .

:ReductionProcess_Req1 a iof:PlannedProcess ;
    iof:hasInput :AdhesiveValue_Req1 ;
    iof:hasProcessCharacteristic :ReductionFactor_Req1 ;
    iof:hasSpecifiedOutput :ReducedAdhesiveValue_Req1 .

:FrontHoop_1 a iof:MaterialArtifact ;
    iof:componentPartOfAtSomeTime :Chassis_1 .

:MainHoop_1 a iof:MaterialArtifact ;
    iof:componentPartOfAtSomeTime :Chassis_1 .

:SES_Design a iof:DesignSpecification ;
    iof:prescribes :SES_1 .

:Chassis_1 a iof:MaterialArtifact ;
    iof:hasComponentPartAtSomeTime :FrontHoop_1,
        :MainHoop_1 .

