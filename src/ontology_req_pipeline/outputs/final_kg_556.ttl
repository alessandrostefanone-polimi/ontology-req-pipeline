@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/556#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Obj_0 a iof:ObjectiveSpecification ;
    rdfs:label "objective: circuit monitors electronic throttle control" ;
    iof:isAchievedByAtSomeTime :MonitoringProcess_0 ;
    iof:prescribes :MonitoringProcessChar_0 .

:CircuitRole_0 a bfo:BFO_0000023 ;
    rdfs:label "standalone nonprogrammable circuit role" ;
    iof:roleOf :Circuit_0 .

:ETC_0 a iof:MaterialArtifact ;
    rdfs:label "electronic throttle control" .

:MonitoringProcessChar_0 a iof:ProcessCharacteristic ;
    rdfs:label "monitoring relation between circuit and electronic throttle control" ;
    iof:processCharacteristicOf :MonitoringProcess_0 .

:Plan_0 a iof:PlanSpecification ;
    iof:prescribes :MonitoringProcess_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Brake System Plausibility Device - BSPD IC.4.8.1 A standalone nonprogrammable circuit must be used to monitor the electronic throttle control" ;
    iof:requirementSatisfiedBy :DS_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :Circuit_0 ;
    iof:satisfiesRequirement :Req_0 .

:Circuit_0 a iof:MaterialArtifact ;
    rdfs:label "standalone nonprogrammable circuit" ;
    iof:hasRole :CircuitRole_0 ;
    iof:prescribedBy :DS_0 .

:MonitoringProcess_0 a iof:PlannedProcess ;
    rdfs:label "monitoring of electronic throttle control by circuit" ;
    bfo:BFO_0000057 :Circuit_0,
        :ETC_0 ;
    iof:prescribedBy :Plan_0 .

