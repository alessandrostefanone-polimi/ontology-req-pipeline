@prefix : <http://example.org/req/456#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:InsulationRequirement_0 a iof:ObjectiveSpecification ;
    rdfs:label "Insulation requirement for gas cylinder/tank"@en ;
    iof:isAchievedByAtSomeTime :InsulationProcess_0 ;
    iof:prescribes :InsulationQuality_0 .

:LocationRequirement_1 a iof:ObjectiveSpecification ;
    rdfs:label "Location requirement relative to exhaust system"@en ;
    iof:isAchievedByAtSomeTime :PositioningProcess_1 ;
    iof:prescribes :LocationRelExhaust_1 .

:MaterialRequirement_2 a iof:ObjectiveSpecification ;
    rdfs:label "Cylinder material requirement (metal, near exhaust)"@en ;
    iof:isAchievedByAtSomeTime :ManufacturingProcess_2 ;
    iof:prescribes :MaterialQuality_2 .

:VE_req1_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "distance to exhaust system ≤ 0.15 m"@en ;
    qudt:maxInclusive 1.5e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :LocationRelExhaust_1 .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "Design specification for gas cylinder/tank insulation and material"@en ;
    iof:prescribes :Cylinder_0 ;
    iof:satisfiesRequirement :Req_0 .

:ExhaustSystem_1 a bfo:BFO_0000040 ;
    rdfs:label "exhaust system"@en .

:HeatSource_0 a bfo:BFO_0000040 ;
    rdfs:label "heat source (generic)"@en .

:InsulationProcess_0 a bfo:BFO_0000015 ;
    rdfs:label "insulation process for gas cylinder/tank"@en ;
    bfo:BFO_0000057 :Cylinder_0,
        :HeatSource_0 ;
    iof:hasOutput :InsulationQuality_0 .

:ManufacturingProcess_2 a iof:ManufacturingProcess ;
    rdfs:label "manufacturing of metal gas cylinder/tank"@en ;
    bfo:BFO_0000057 :Metal_2 ;
    iof:hasSpecifiedOutput :Cylinder_0 .

:MaterialValueExpr_2 a iof:ValueExpression ;
    rdfs:label "cylinder material = metal"@en ;
    iof:denotes :Metal_2 ;
    iof:isValueExpressionOfAtSomeTime :MaterialQuality_2 .

:PositioningProcess_1 a bfo:BFO_0000015 ;
    rdfs:label "positioning of gas cylinder/tank relative to exhaust system"@en ;
    bfo:BFO_0000057 :Cylinder_0,
        :ExhaustSystem_1 ;
    iof:hasProcessCharacteristic :LocationRelExhaust_1 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Insulation - The gas cylinder/tank must be insulated from any heat sources T.6.1.6 Cylinder Material - gas cylinders/tanks in a position 150 mm or less from an exhaust system must meet one of the two: - Made from metal" ;
    iof:requirementSatisfiedBy :DS_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:Metal_2 a bfo:BFO_0000040 ;
    rdfs:label "metal"@en .

:InsulationQuality_0 a bfo:BFO_0000019 ;
    rdfs:label "insulated quality of gas cylinder/tank"@en ;
    iof:qualityOf :Cylinder_0 .

:MaterialQuality_2 a bfo:BFO_0000019 ;
    rdfs:label "material of gas cylinder/tank"@en ;
    iof:describedBy :MaterialValueExpr_2 ;
    iof:qualityOf :Cylinder_0 .

:LocationRelExhaust_1 a bfo:BFO_0000019 ;
    rdfs:label "location of gas cylinder/tank relative to exhaust system"@en ;
    iof:qualityOf :Cylinder_0 .

:Cylinder_0 a bfo:BFO_0000040 ;
    rdfs:label "gas cylinder/tank"@en ;
    iof:hasQuality :InsulationQuality_0,
        :LocationRelExhaust_1,
        :MaterialQuality_2 .

