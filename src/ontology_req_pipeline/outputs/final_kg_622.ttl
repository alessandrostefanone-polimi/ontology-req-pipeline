@prefix : <http://example.org/req/622#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :WarningSymbol_0 ;
    iof:satisfiesRequirement :Req_0 .

:DS_3 a iof:DesignSpecification ;
    iof:prescribes :GLV_System_3 ;
    iof:satisfiesRequirement :Req_0 .

:EV_4_4_1_Ref_3 a iof:InformationContentEntity ;
    rdfs:label "Reference EV.4.4.1"@en .

:GLV_System_3 a bfo:BFO_0000040 ;
    rdfs:label "GLV System"@en ;
    iof:isSubjectOf :EV_4_4_1_Ref_3 .

:ISO7010_W012_Ref_0 a iof:InformationContentEntity ;
    rdfs:label "ISO 7010-W012 symbol reference"@en .

:PS_1 a iof:PlanSpecification ;
    iof:prescribes :TextElement_AlwaysEnergized_1 ;
    iof:satisfiesRequirement :Req_0 .

:PS_2 a iof:PlanSpecification ;
    iof:prescribes :TextElement_HighVoltage_2 ;
    iof:satisfiesRequirement :Req_0 .

:TextContent_AlwaysEnergized_1 a iof:InformationContentEntity ;
    rdfs:label "\"Always Energized\""@en .

:TextContent_HighVoltage_2 a iof:InformationContentEntity ;
    rdfs:label "\"High Voltage\""@en ;
    iof:isSubjectOf :VoltageMeets_T_9_1_1_Condition_2 .

:TextElement_AlwaysEnergized_1 a bfo:BFO_0000040 ;
    rdfs:label "Text element: Always Energized"@en ;
    iof:isSubjectOf :TextContent_AlwaysEnergized_1 .

:TextElement_HighVoltage_2 a bfo:BFO_0000040 ;
    rdfs:label "Text element: High Voltage"@en ;
    iof:isSubjectOf :TextContent_HighVoltage_2 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Triangle side length ≥ 0.1 m"@en ;
    qudt:minInclusive 1e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :TriangleSideLength_0 .

:VoltageMeets_T_9_1_1_Condition_2 a iof:InformationContentEntity ;
    rdfs:label "Condition: voltage meets T.9.1.1"@en ;
    iof:isAbout :VoltageRequirement_T_9_1_1_Ref_2 .

:VoltageRequirement_T_9_1_1_Ref_2 a iof:InformationContentEntity ;
    rdfs:label "Reference T.9.1.1"@en .

:WarningSymbol_0 a bfo:BFO_0000040 ;
    rdfs:label "Warning symbol specified in ISO 7010-W012"@en ;
    iof:hasQuality :TriangleSideLength_0 ;
    iof:isSubjectOf :ISO7010_W012_Ref_0 .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:TriangleSideLength_0 a bfo:BFO_0000019 ;
    rdfs:label "Triangle side length of warning symbol"@en ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Symbol specified in ISO 7010-W012 (triangle with black lightning bolt on yellow background) with triangle side length of 100 mm minimum c. Text \"Always Energized\" d. Text \"High Voltage\" if the voltage meets T.9.1.1 ## EV.4.4 Grounded Low Voltage System EV.4.4.1 The GLV System must be" ;
    iof:requirementSatisfiedBy :DS_0,
        :DS_3,
        :PS_1,
        :PS_2 .

