@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/req/807#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Successfully complete the Egress Test IN.5.2 IN.5.3.2 A driver(s) must complete the Driver Cockpit Checks to pass Mechanical Inspection # IN" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :PlanSpec_0 .

:DriverCockpitChecksIdentifier a iof:Identifier ;
    rdfs:label "Driver Cockpit Checks identifier" ;
    iof:designates :DriverCockpitChecksProcess .

:Driver_0 a iof:Agent ;
    rdfs:label "Driver (agent performing cockpit checks)" .

:EgressTestIdentifier a iof:Identifier ;
    rdfs:label "Egress Test IN.5.2 IN.5.3.2 identifier" ;
    iof:designates :EgressTestProcess .

:MechanicalInspectionIdentifier a iof:Identifier ;
    rdfs:label "Mechanical Inspection # IN identifier" ;
    iof:designates :MechanicalInspectionProcess .

:MechanicalInspectionProcess a iof:PlannedProcess ;
    rdfs:label "Mechanical Inspection # IN" ;
    bfo:BFO_0000117 :DriverCockpitChecksProcess ;
    iof:isSubjectOf :MechanicalInspectionIdentifier ;
    iof:prescribedBy :PlanSpec_0 .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    rdfs:label "Objective for egress test and driver cockpit checks" ;
    iof:isAchievedByAtSomeTime :DriverCockpitChecksProcess,
        :EgressTestProcess ;
    iof:prescribes :DriverCockpitChecksProcess,
        :EgressTestProcess .

:EgressTestProcess a iof:PlannedProcess ;
    rdfs:label "Egress Test IN.5.2 IN.5.3.2" ;
    iof:isSubjectOf :EgressTestIdentifier ;
    iof:prescribedBy :PlanSpec_0 .

:PlanSpec_0 a iof:PlanSpecification ;
    rdfs:label "Plan for egress test and driver cockpit checks" ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :DriverCockpitChecksProcess,
        :EgressTestProcess,
        :MechanicalInspectionProcess .

:DriverCockpitChecksProcess a iof:PlannedProcess ;
    rdfs:label "Driver Cockpit Checks" ;
    bfo:BFO_0000057 :Driver_0 ;
    iof:achievesAtSomeTime :ObjSpec_0 ;
    iof:isSubjectOf :DriverCockpitChecksIdentifier ;
    iof:prescribedBy :PlanSpec_0 .

