@prefix : <http://example.org/req/419#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The intent is that in a short circuit the APPSs will only agree at 0\\% Pedal Travel T.4.2.4 Implausibility is defined as a deviation of more than 10\\% Pedal Travel between the sensors or other failure as defined in this Section T.4.2" ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1 .

:ShortCircuitProcess_0 a bfo:BFO_0000015 ;
    rdfs:label "short circuit process context for APPSs" .

:APPSs_0 a bfo:BFO_0000040 ;
    rdfs:label "APPSs sensor set" ;
    iof:hasQuality :PedalTravel_0 .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "APPSs pedal travel agreement design spec" ;
    iof:prescribes :APPSs_0 .

:ImplausibilityAssessmentProcess_1 a iof:PlannedProcess ;
    rdfs:label "Implausibility assessment between APPS sensors" ;
    iof:hasProcessCharacteristic :Deviation_1 .

:PS_1 a iof:PlanSpecification ;
    rdfs:label "Implausibility definition plan spec" ;
    iof:prescribes :ImplausibilityAssessmentProcess_1 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression for 0% pedal travel (APPSs, short circuit)" ;
    qudt:maxInclusive 0e+00 ;
    qudt:minInclusive 0e+00 ;
    qudt:unit qudtu:NUM ;
    iof:isValueExpressionOfAtSomeTime :PedalTravel_0 .

:VE_req1_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Value expression for deviation > 10% pedal travel" ;
    qudt:minExclusive 1e-01 ;
    qudt:unit qudtu:NUM ;
    iof:isValueExpressionOfAtSomeTime :Deviation_1 .

qudtqk:DimensionlessRatio a qudt:QuantityKind .

qudtqk:PositiveDimensionlessRatio a qudt:QuantityKind .

:Deviation_1 a iof:ProcessCharacteristic ;
    rdfs:label "Pedal travel deviation between sensors" ;
    iof:hasValueExpressionAtSomeTime :VE_req1_c1 .

:PedalTravel_0 a bfo:BFO_0000019 ;
    rdfs:label "Pedal travel (APPSs)" ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DimensionlessRatio,
        qudtqk:PositiveDimensionlessRatio .

