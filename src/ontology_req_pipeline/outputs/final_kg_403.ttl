@prefix : <http://example.org/req/403#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:VE_req5_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2e+03 ;
    qudt:quantityKind qudtqk:Force ;
    qudt:unit qudtu:N ;
    iof:isValueExpressionOfAtSomeTime :BrakePedalWithstandForce_0 .

:BrakePedalDesignAlt_0 a iof:InformationContentEntity .

:BrakePedalFabricated_0 a iof:InformationContentEntity .

:BrakePedalMachined_0 a iof:InformationContentEntity .

:BrakeSystemPortion_0 a bfo:BFO_0000040 ;
    iof:componentPartOfAtSomeTime :BrakeSystem_0 .

:Chassis_0 a bfo:BFO_0000040 .

:CriticalFastenerSpec_0 a iof:InformationContentEntity .

:Fastener_0 a bfo:BFO_0000040 ;
    iof:componentPartOfAtSomeTime :BrakeSystem_0 .

:Ref_T_8_2 a iof:InformationContentEntity .

:Req0 a iof:RequirementSpecification ;
    rdfs:comment "Req 0: In side view any portion of the Brake System that is mounted on the sprung part of the vehicle must not project below the lower surface of the chassis." ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0 .

:Req1 a iof:RequirementSpecification ;
    rdfs:comment "Req 1: Fasteners in the Brake System are Critical Fasteners, see T.8.2." ;
    iof:isAbout :ObjSpec_0 ;
    iof:isSubjectOf :CriticalFastenerSpec_0,
        :Ref_T_8_2 ;
    iof:requirementSatisfiedBy :DS_0 .

:Req2 a iof:RequirementSpecification ;
    rdfs:comment "Req 2: The Brake Pedal must be one of: - Fabricated from steel or aluminum - Machined from steel, aluminum or titanium." ;
    iof:isAbout :ObjSpec_0 ;
    iof:isSubjectOf :BrakePedalDesignAlt_0 ;
    iof:requirementSatisfiedBy :DS_0 .

:Req3 a iof:RequirementSpecification ;
    rdfs:comment "Req 3: Brake Pedal alternative – fabricated from steel or aluminum." ;
    iof:isAbout :ObjSpec_0 ;
    iof:isSubjectOf :BrakePedalFabricated_0 ;
    iof:requirementSatisfiedBy :DS_0 .

:Req4 a iof:RequirementSpecification ;
    rdfs:comment "Req 4: Brake Pedal alternative – machined from steel, aluminum or titanium." ;
    iof:isAbout :ObjSpec_0 ;
    iof:isSubjectOf :BrakePedalMachined_0 ;
    iof:requirementSatisfiedBy :DS_0 .

:Req5 a iof:RequirementSpecification ;
    rdfs:comment "Req 5: T.3.2.2 The Brake Pedal and associated components design must withstand a minimum force of 2000 N without any failure of the Brake System, pedal box, chassis mounting, or pedal adjustment." ;
    iof:isAbout :ObjSpec_0 ;
    iof:isSubjectOf :BrakePedalWithstandForce_0 ;
    iof:requirementSatisfiedBy :DS_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Full paragraph: In side view any portion of the Brake System that is mounted on the sprung part of the vehicle must not project below the lower surface of the chassis T.3.1.10 Fasteners in the Brake System are Critical Fasteners, see T.8.2 ## T.3.2 Brake Pedal, Pedal Box and Mounting T.3.2.1 The Brake Pedal must be one of: - Fabricated from steel or aluminum - Machined from steel, aluminum or titanium T.3.2.2 The Brake Pedal and associated components design must withstand a minimum force of 2000 N without any failure of the Brake System, pedal box, chassis mounting, or pedal adjustment" ;
    iof:isAbout :ObjSpec_0 ;
    iof:requirementSatisfiedBy :DS_0 .

:VehicleSprungPart_0 a bfo:BFO_0000040 .

qudtu:N a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Force .

:BrakePedalWithstandForce_0 a iof:ProcessCharacteristic ;
    iof:processCharacteristicOf :BrakePedal_0 .

:BrakePedal_0 a bfo:BFO_0000040 .

qudtqk:Force a qudt:QuantityKind .

:BrakeSystem_0 a bfo:BFO_0000040 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :BrakePedal_0,
        :BrakeSystemPortion_0,
        :BrakeSystem_0,
        :Chassis_0,
        :Fastener_0,
        :VehicleSprungPart_0 ;
    iof:satisfiesRequirement :Req0,
        :Req1,
        :Req2,
        :Req3,
        :Req4,
        :Req5,
        :Req_0 .

:ObjSpec_0 a iof:ObjectiveSpecification .

