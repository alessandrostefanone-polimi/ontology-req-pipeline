:SuitLabel_0 a iof:InformationContentEntity ;
    rdfs:label "suit standard label"@en ;
    iof:describes :Suit_0 .

:SuitDesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :Suit_0 ;
    iof:satisfiesRequirement :Req_0 .

:UnderclothingPlanSpec_1 a iof:PlanSpecification ;
    iof:prescribes :UnderclothingWearingProcess_1 ;
    iof:satisfiesRequirement :Req_0 .

:Competitor_1 a iof:Agent ;
    rdfs:label "competitor"@en .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Each suit must meet one or more of the following standards and be labeled as such: - $\\quad$ SFI 3.2A/5 (or higher ex: /10, /15, /20) - $\\quad$ SFI 3.4/5 (or higher ex: /10, /15, /20) - FIA Standard 1986 - FIA Standard 8856-2000 - FIA Standard 8856-2018 VE.3.3.2 Underclothing All competitors should wear fire retardant underwear (long pants and long sleeve shirt) under their approved Driver Suit" ;
    iof:requirementSatisfiedBy :SuitDesignSpec_0,
        :UnderclothingPlanSpec_1 .

:Suit_1 a bfo:BFO_0000040 ;
    rdfs:label "approved driver suit"@en .

:UnderclothingWearingProcess_1 a iof:PlannedProcess ;
    rdfs:label "wearing fire retardant underwear under driver suit"@en ;
    iof:hasParticipantAtSomeTime :Competitor_1,
        :Suit_1,
        :Underwear_1 .

:Underwear_1 a bfo:BFO_0000040 ;
    rdfs:label "fire retardant underwear (long pants and long sleeve shirt)"@en .

:Suit_0 a bfo:BFO_0000040 ;
    rdfs:label "driver suit"@en .

