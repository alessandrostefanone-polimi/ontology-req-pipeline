@prefix : <http://example.org/req/384#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AttachShoulderBeltsProcess_1 a iof:PlannedProcess ;
    rdfs:label "Shoulder Belts attachment process" .

:BoltOrClipToTabOrBracketProcess_4 a iof:PlannedProcess ;
    rdfs:label "Bolt or clip to tab or bracket on Shoulder Harness Mounting bar process" .

:BoltThroughInsertOrMonocoqueProcess_3 a iof:PlannedProcess ;
    rdfs:label "Bolt through welded tube insert or tested monocoque attachment process" .

:DS_0 a iof:DesignSpecification ;
    rdfs:label "Shoulder Belt Mount Spacing design specification" ;
    iof:prescribes :ShoulderBeltMountSpacing_0 ;
    iof:satisfiesRequirement :Req_0 .

:PS_1 a iof:PlanSpecification ;
    rdfs:label "Plan for Shoulder Belts attachment methods" ;
    iof:prescribes :AttachShoulderBeltsProcess_1 ;
    iof:satisfiesRequirement :Req_0 .

:PS_2 a iof:PlanSpecification ;
    rdfs:label "Plan: wrap around Shoulder Harness Mounting bar" ;
    iof:prescribes :WrapAroundMountingBarProcess_2 ;
    iof:satisfiesRequirement :Req_0 .

:PS_3 a iof:PlanSpecification ;
    rdfs:label "Plan: bolt through welded tube insert or tested monocoque attachment" ;
    iof:prescribes :BoltThroughInsertOrMonocoqueProcess_3 ;
    iof:satisfiesRequirement :Req_0 .

:PS_4 a iof:PlanSpecification ;
    rdfs:label "Plan: bolt or clip to tab or bracket on Shoulder Harness Mounting bar" ;
    iof:prescribes :BoltOrClipToTabOrBracketProcess_4 ;
    iof:satisfiesRequirement :Req_0 .

:PS_5 a iof:PlanSpecification ;
    rdfs:label "Plan: wrap around physically tested hardware attached to a monocoque" ;
    iof:prescribes :WrapAroundTestedHardwareOnMonocoqueProcess_5 ;
    iof:satisfiesRequirement :Req_0 .

:ShoulderBeltAssembly_0 a iof:MaterialArtifact ;
    rdfs:label "Shoulder Belt assembly" .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    rdfs:label "Shoulder Belt Mount Spacing between 0.175 m and 0.235 m" ;
    qudt:maxInclusive 2.35e-01 ;
    qudt:minInclusive 1.75e-01 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtAllTimes :ShoulderBeltMountSpacing_0 .

:WrapAroundMountingBarProcess_2 a iof:PlannedProcess ;
    rdfs:label "Wrap around Shoulder Harness Mounting bar process" .

:WrapAroundTestedHardwareOnMonocoqueProcess_5 a iof:PlannedProcess ;
    rdfs:label "Wrap around physically tested hardware attached to a monocoque process" .

qudtqk:Length a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Length .

:ShoulderBeltMountSpacing_0 a bfo:BFO_0000019 ;
    rdfs:label "Shoulder Belt Mount Spacing quality" ;
    iof:hasValueExpressionAtAllTimes :VE_req0_c0 ;
    iof:qualityOf :ShoulderBeltAssembly_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "The Shoulder Belt Mount Spacing must be between 175 mm and 235 mm , center to center T.2.6.3 The Shoulder Belts must attach by one of the four: a. Wrap around the Shoulder Harness Mounting bar b. Bolt through a welded tube insert or tested monocoque attachment F.7.9 c. Bolt or clip to a tab or bracket (T.2.4.3 ) on the Shoulder Harness Mounting bar d. Wrap around physically tested hardware attached to a monocoque T.2.6.4" ;
    iof:requirementSatisfiedBy :DS_0,
        :PS_1,
        :PS_2,
        :PS_3,
        :PS_4,
        :PS_5 .

