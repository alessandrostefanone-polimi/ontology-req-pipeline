@prefix : <http://example.org/req/855#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:AddedItemsCosting_0 a bfo:BFO_0000002 ;
    iof:hasQuality :CostMultiplier_0,
        :CostRate_0 .

:CostAddendum_0 a iof:InformationContentEntity .

:CostReport_0 a iof:InformationContentEntity .

:AdditionalCost_0 a bfo:BFO_0000019 .

:CostChange_0 a bfo:BFO_0000002 ;
    iof:hasQuality :AdditionalCost_0 .

:DS_0 a iof:DesignSpecification ;
    iof:prescribes :CostChange_0 ;
    iof:satisfiesRequirement :Req_0 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "3.7.6 Changes to the Cost Report in the Cost Addendum will incur additional cost: a. Added items will be cost at $125 \\%$ of the table cost: + (1.25 x Cost) b" ;
    iof:requirementSatisfiedBy :DS_0 .

:VE_req0_c1 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.25e+00 ;
    qudt:minInclusive 1.25e+00 ;
    qudt:unit qudtu:NUM ;
    iof:isValueExpressionOfAtSomeTime :CostRate_0 .

:VE_req0_c2 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:maxInclusive 1.25e+00 ;
    qudt:minInclusive 1.25e+00 ;
    qudt:unit qudtu:UNITLESS ;
    iof:isValueExpressionOfAtSomeTime :CostMultiplier_0 .

qudtqk:Dimensionless a qudt:QuantityKind .

qudtqk:DimensionlessRatio a qudt:QuantityKind .

qudtu:NUM a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:DimensionlessRatio .

qudtu:UNITLESS a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Dimensionless .

:CostMultiplier_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c2 .

:CostRate_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c1 .

