@prefix : <http://example.org/req/606#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix iof: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtqk: <http://qudt.org/vocab/quantitykind/> .
@prefix qudtu: <http://qudt.org/vocab/unit/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:CockpitMainSwitch_0 a bfo:BFO_0000030 ;
    iof:hasQuality :Diameter_Quality_0 .

:DesignSpec_0 a iof:DesignSpecification ;
    iof:prescribes :CockpitMainSwitch_0 ;
    iof:satisfiesRequirement :Req_0 .

:ObjSpec_1 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :Process_Req1 .

:PlanSpec_0 a iof:PlanSpecification ;
    bfo:BFO_0000110 :ObjSpec_0 ;
    iof:prescribes :Process_Req0 .

:VE_req0_c0 a qudt:QuantityValue,
        iof:ValueExpression ;
    qudt:minInclusive 2.4e-02 ;
    qudt:unit qudtu:M ;
    iof:isValueExpressionOfAtSomeTime :Diameter_Quality_0 .

qudtqk:Diameter a qudt:QuantityKind .

qudtu:M a qudt:Unit ;
    qudt:hasQuantityKind qudtqk:Diameter .

:ObjSpec_0 a iof:ObjectiveSpecification ;
    iof:isAchievedByAtSomeTime :Process_Req0 ;
    iof:prescribes :Diameter_Quality_0 .

:PlanSpec_1 a iof:PlanSpecification ;
    iof:prescribes :Process_Req1 ;
    iof:satisfiesRequirement :Req_0 .

:Process_Req0 a iof:PlannedProcess ;
    iof:prescribedBy :PlanSpec_0 .

:Process_Req1 a iof:PlannedProcess ;
    iof:prescribedBy :PlanSpec_1 .

:Req_0 a iof:RequirementSpecification ;
    rdfs:comment "Have a diameter of 24 mm minimum IC.9.4.2 Location - The Cockpit Main Switch must be: a" ;
    iof:isAbout :ObjSpec_0,
        :ObjSpec_1 ;
    iof:requirementSatisfiedBy :DesignSpec_0,
        :PlanSpec_1 .

:Diameter_Quality_0 a bfo:BFO_0000019 ;
    iof:hasValueExpressionAtSomeTime :VE_req0_c0 .

