# OpenAI provider
OPENAI_API_KEY=your_openai_api_key

# Ollama provider (only needed when using --provider ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Required Chroma Cloud settings used by QUDT normalization.
# normalize_qudt() now raises an error when these are unset.
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_COLLECTION=qudt_quantity_kinds_with_descriptions
